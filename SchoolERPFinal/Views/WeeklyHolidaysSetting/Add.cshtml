@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.WeeklyHolidaysSettingAddViewModel
@{
    ViewData["Title"] = "Holidays Setting";
    var p = Model.Permissions;
    var companyId = User.FindFirst("CompanyID")?.Value ?? "0";
}
<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditWeeklyHolidays == null ? "Add Holidays Setting" : "Edit Holidays Setting")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveItem()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/WeeklyHolidaysSetting/Index" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <input type="hidden" id="txtItemId" value="@(Model.EditWeeklyHolidays?.Id ?? 0)">
                    <input type="hidden" id="hdnUserID" value="@(Model.EditWeeklyHolidays?.CreatedBy ?? 0)">
                    <input type="hidden" id="hdnCompanyID" value="@companyId">

                    <div class="row">

                        <!-- Institute select -->
                        @* <div class="col-md-6 mb-4">
                            <label for="ddlInstitute" class="form-label">Institute select karein</label>
                            <select id="ddlInstitute" class="form-select select2" style="width:100%;">
                                @foreach (var inst in Model.InstituteList)
                                {
                                    <option value="@inst.Value">@inst.Text</option>
                                }
                            </select>
                        </div> *@

                        <!-- Day checkboxes (box style) -->
                        <div class="col-md-12 mb-2">
                            <label class="form-label d-block">Default weekly holiday</label>
                            <div class="row g-2" id="dayCheckboxRow">
                                <!-- 4 per row on desktop -->
                                <div class="col-6 col-md-3">
                                    <label class="day-box form-check d-flex align-items-center gap-2 border rounded p-2 mb-0">
                                        <input class="form-check-input day-chk m-0" type="checkbox" value="SUNDAY" id="chkSunday">
                                        <span class="form-check-label">Sunday</span>
                                    </label>
                                </div>
                                <div class="col-6 col-md-3">
                                    <label class="day-box form-check d-flex align-items-center gap-2 border rounded p-2 mb-0">
                                        <input class="form-check-input day-chk m-0" type="checkbox" value="MONDAY" id="chkMonday">
                                        <span class="form-check-label">Monday</span>
                                    </label>
                                </div>
                                <div class="col-6 col-md-3">
                                    <label class="day-box form-check d-flex align-items-center gap-2 border rounded p-2 mb-0">
                                        <input class="form-check-input day-chk m-0" type="checkbox" value="TUESDAY" id="chkTuesday">
                                        <span class="form-check-label">Tuesday</span>
                                    </label>
                                </div>
                                <div class="col-6 col-md-3">
                                    <label class="day-box form-check d-flex align-items-center gap-2 border rounded p-2 mb-0">
                                        <input class="form-check-input day-chk m-0" type="checkbox" value="WEDNESDAY" id="chkWednesday">
                                        <span class="form-check-label">Wednesday</span>
                                    </label>
                                </div>
                                <div class="col-6 col-md-3">
                                    <label class="day-box form-check d-flex align-items-center gap-2 border rounded p-2 mb-0">
                                        <input class="form-check-input day-chk m-0" type="checkbox" value="THURSDAY" id="chkThursday">
                                        <span class="form-check-label">Thursday</span>
                                    </label>
                                </div>
                                <div class="col-6 col-md-3">
                                    <label class="day-box form-check d-flex align-items-center gap-2 border rounded p-2 mb-0">
                                        <input class="form-check-input day-chk m-0" type="checkbox" value="FRIDAY" id="chkFriday">
                                        <span class="form-check-label">Friday</span>
                                    </label>
                                </div>
                                <div class="col-6 col-md-3">
                                    <label class="day-box form-check d-flex align-items-center gap-2 border rounded p-2 mb-0">
                                        <input class="form-check-input day-chk m-0" type="checkbox" value="SATURDAY" id="chkSaturday">
                                        <span class="form-check-label">Saturday</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- nthWeek multi-select, shown only when Saturday is checked -->
                        <div class="col-md-6 mb-3 d-none" id="divNthWeek">
                            <label for="ddlNthWeek" class="form-label">Saturday Holiday Applies To</label>
                            <select id="ddlNthWeek" class="form-select select2" multiple="multiple" style="width:100%;">
                                <option value="1">1st Saturday</option>
                                <option value="2">2nd Saturday</option>
                                <option value="3">3rd Saturday</option>
                                <option value="4">4th Saturday</option>
                            </select>                           
                        </div>

                        <!-- Effective From -->
                        <div class="col-md-6 mb-3 d-none">
                            <label for="txtEffectiveFrom" class="form-label">Effective from</label>
                            <input type="date" id="txtEffectiveFrom" class="form-control">
                        </div>

                        <!-- Impact preview -->
                        <div class="col-md-12">
                            <div class="alert alert-info py-2 px-3" id="divImpactPreview" style="display:none;"></div>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<link href="~/assets/css/select2.min.css" rel="stylesheet" />
<style>
    .day-box {
        cursor: pointer;
    }

        .day-box:has(.day-chk:checked) {
            border-color: #0d6efd !important;
            background-color: #eaf2ff;
        }
</style>
@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
        window.existingHolidays = @Html.Raw(Model.EditWeeklyHolidays != null ? JsonSerializer.Serialize(Model.EditWeeklyHolidays) : "[]");
    </script>
    <script src="~/assets/js/select2.min.js"></script>
    <script src="~/assets/js/WeeklyHolidaysSetting.js"></script>
}
