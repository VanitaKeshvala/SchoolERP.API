@model SchoolERP.Shared.Models.MediaAddViewModel
@using System.Security.Claims
@using System.Text.Json

@{
    Layout = "_Layout";
    ViewData["Title"] = "Gallery List";

    // Permission loading for the view
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Add Media</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        <button class="btn btn-success top-btn" onclick="saveHomework()">
            <i class="ti ti-device-floppy me-1"></i> Save
        </button>

        <a href="/Media/Index" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<!-- End Page Header -->
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <form id="homeworkForm" class="row"> 
                    <div class="col-md-4 mb-3">
                        <div class="mb-3">
                            <label class="form-label">Attach Document</label>
                            <input type="file" id="fileAttachment" class="form-control" multiple>
                            <div id="existingAttachmentsList" class="mt-2"></div>
                            <div id="newAttachmentsList" class="mt-2"></div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let existingAttachments = []; // populated on edit
    let selectedFiles = [];       // newly picked files (queued, removable)

    function loadHomeworkForEdit(mediaId) {
                $.get('/Media/UpsertMedia', { mediaId }, function (res) {
            $('#mediaId').val(res.mediaID);
            existingAttachments = res.mediaJson ? JSON.parse(res.mediaJson) : [];
            renderExistingAttachments();
        });
    }

    function renderExistingAttachments() {
        const $list = $('#existingAttachmentsList').empty();
        existingAttachments.forEach((att, idx) => {
            $list.append(`
                <div class="d-flex align-items-center border rounded p-1 mb-1">
                    <a href="${att.Attachment}" target="_blank" class="me-2">${att.FileName}</a>
                    <button type="button" class="btn btn-sm btn-outline-danger ms-auto remove-existing" data-idx="${idx}">&times;</button>
                </div>`);
        });
    }

    $(document).on('click', '.remove-existing', function () {
        existingAttachments.splice($(this).data('idx'), 1);
        renderExistingAttachments();
    });

    $('#fileAttachment').on('change', function (e) {
        selectedFiles = selectedFiles.concat(Array.from(e.target.files));
        syncFileInput();
        renderNewAttachments();
    });

    function renderNewAttachments() {
        const $list = $('#newAttachmentsList').empty();
        selectedFiles.forEach((file, idx) => {
            $list.append(`
                <div class="d-flex align-items-center border rounded p-1 mb-1">
                    <span class="me-2">${file.name}</span>
                    <button type="button" class="btn btn-sm btn-outline-danger ms-auto remove-new" data-idx="${idx}">&times;</button>
                </div>`);
        });
    }

    $(document).on('click', '.remove-new', function () {
        selectedFiles.splice($(this).data('idx'), 1);
        syncFileInput();
        renderNewAttachments();
    });

    // native FileList is immutable, so rebuild it via DataTransfer when items are removed
    function syncFileInput() {
        const dt = new DataTransfer();
        selectedFiles.forEach(f => dt.items.add(f));
        document.getElementById('fileAttachment').files = dt.files;
    }

    function saveHomework() {
        const formData = new FormData();
        formData.append('MediaID', $('#mediaId').val() || 0);
        formData.append('ExistingAttachmentsJson', JSON.stringify(existingAttachments));
        selectedFiles.forEach(file => formData.append('attachmentFiles', file));

        $.ajax({
                    url: '/Media/UpsertMedia',
            type: 'POST',
            data: formData,
            processData: false,
            contentType: false,
            success: function (res) {
                // reset state, close modal / refresh list
                selectedFiles = [];
                existingAttachments = [];
            }
        });
    }
</script>
}