@model SchoolERP.Shared.Models.DailyAssignmentAddViewModel
@using System.Security.Claims
@using System.Text.Json

@{
    Layout = "_Layout";
    ViewData["Title"] = "Add Daily Assignment";

    // ── Permission + role loading ──────────────────────────────────────
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;

    // A logged-in student carries a "StudentID" claim; admin/teacher accounts don't.
    // Students can only VIEW Remark / Evaluation Date. Admin can edit them.
    bool isStudent = User.FindFirst("StudentID") != null;
    bool canEditAssignment = (Model.EditDailyAssignment == null && p.CanAdd) || (Model.EditDailyAssignment != null && p.CanEdit);
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditDailyAssignment == null ? "Add Daily Assignment" : "Edit Daily Assignment")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        
            <button type="button" id="btnSaveHomework" class="btn btn-success top-btn" onclick="saveHomework()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
      

        <a href="/dailyAssignment/Index" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<!-- End Page Header -->

<div id="pageNotice"></div>

<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <form id="homeworkForm" class="row">
                    <input type="hidden" id="txtHomeworkId" value="@Model.EditDailyAssignment?.AssignmentID">
                    <input type="hidden" id="txtStudentID" value="@Model.EditDailyAssignment?.StudentID">
                    <input type="hidden" id="txtSectionID" value="@Model.EditDailyAssignment?.SectionID">
                    <input type="hidden" id="txtSubjectGroupID" value="@Model.EditDailyAssignment?.SubjectGroupID">
                    <input type="hidden" id="txtClassID" value="@Model.EditDailyAssignment?.ClassID">
                    <input type="hidden" id="txtSubjectID" value="@Model.EditDailyAssignment?.SubjectID">
                    <input type="hidden" id="hdnDescription" value="@Model.EditDailyAssignment?.Description">
                    <input type="hidden" id="hdnTitle" value="@Model.EditDailyAssignment?.Title">
                   
                    <!-- ============ Shared fields (both admin & student see these) ============ -->
                    @if(isStudent)
                    {
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Subject<span class="text-danger">*</span></label>
                            <select id="ddlSubject" class="form-select form-control">
                                <option value="">Select Subject</option>
                                @foreach (var c in Model.Subject)
                                {
                                    <option value="@c.Id" selected="@(Model.EditDailyAssignment?.SubjectID == c.Id)">@c.Name</option>
                                }
                            </select>
                            <div class="invalid-feedback" id="errDdlSubject"></div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Title</label>
                            <input type="text" id="txtTitle" value="@Model.EditDailyAssignment?.Title" class="form-control">
                        </div>

                        <div class="col-md-4 mb-3">
                            <div class="mb-3">
                                <label class="form-label">Attach Document</label>
                                <input type="file" id="fileAttachment" class="form-control" multiple>
                                
                            </div>
                            <div class="mb-3 d-none">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="chkIsActive"
                                    @(Model.EditDailyAssignment?.IsActive ?? true ? "checked" : "")
                                    @(canEditAssignment ? "" : "disabled")>
                                    <label class="form-check-label fw-semibold" for="chkIsActive">Active Status</label>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-8 mb-3">
                            <label class="form-label">Description<span class="text-danger">*</span></label>
                            <textarea id="txtDescription" class="form-control" rows="5">@Model.EditDailyAssignment?.Description</textarea>
                            <div class="invalid-feedback" id="errTxtDescription"></div>
                        </div>

                    }
                   else
                    {
                        <div class="row">
                            <div class="col-xl-4">
                                <div class="card shadow-tbl-outer position-sticky"
                                     style="top: 70px">
                                    <div class="card-body d-flex align-items-center flex-sm-nowrap flex-wrap row-gap-3">
                                        <div class="flex-fill">
                                            <div class="d-flex align-items-center mb-1">
                                                <h6 class="mb-2 fw-semibold">
                                                    <a>Summary</a>
                                                </h6>
                                            </div>
                                            <p class="mb-2 fs-13">
                                                <span class="text-dark">Submission Date </span> : @Model.EditDailyAssignment?.AssignmentDate?.ToString("dd MMM yyyy")
                                            </p>
                                            <p class="mb-2 fs-13">
                                                <span class="text-dark">Evaluation Date</span> : @Model.EditDailyAssignment?.EvaluationDate?.ToString("dd MMM yyyy")
                                            </p>                                           
                                        </div>
                                    </div>
                                    <!-- end card body -->
                                    <ul class="list-group list-group-flush">
                                        <li class="list-group-item list-group-item-action d-flex justify-content-between">
                                            <span class="text-dark">Student Name :</span> @Model.EditDailyAssignment?.StudentName
                                        </li>
                                        <li class="list-group-item list-group-item-action d-flex justify-content-between">
                                            <span class="text-dark">Evaluated By :</span> @Model.EditDailyAssignment?.EvaluatedByName
                                        </li>
                                        <li class="list-group-item list-group-item-action d-flex justify-content-between">
                                            <span class="text-dark">Class :</span>@Model.EditDailyAssignment?.ClassName
                                        </li>
                                        <li class="list-group-item list-group-item-action d-flex justify-content-between">
                                            <span class="text-dark">Section :</span> @Model.EditDailyAssignment?.SectionName
                                        </li>
                                        <li class="list-group-item list-group-item-action d-flex justify-content-between">
                                            <span class="text-dark">Subject :</span> @Model.EditDailyAssignment?.SubjectName
                                        </li>
                                        <li class="list-group-item list-group-item-action d-flex justify-content-between">
                                            <span class="text-dark">Remark :</span> @Model.EditDailyAssignment?.Remark
                                        </li>                                        
                                    </ul>
                                </div>
                                <!-- end card -->
                            </div>
                            <div class="col-md-8 mb-3">
                            <div class="col-md-12 mb-3">

                                    <span class="mb-3"><b>Title:</b>@Model.EditDailyAssignment?.Title</span><br />
                                    <span class="mb-3"><b>Description:</b>@Model.EditDailyAssignment?.Description</span><br />
                                    
                                <label class="form-label">
                                    Evaluation Date <span class="text-danger">*</span>

                                </label>
                                <input type="date" id="txtEvaluationDate"
                                       value="@(Model.EditDailyAssignment?.EvaluationDate?.ToString("yyyy-MM-dd"))"
                                       class="form-control">
                                <div class="invalid-feedback" id="errTxtEvaluationDate"></div>
                            </div>
                            <div class="col-md-12 mb-3">
                                <label class="form-label">
                                    Remark
                                </label>
                                <textarea id="txtRemark" class="form-control" rows="5">@Model.EditDailyAssignment?.Remark</textarea>
                            </div>
                            </div>
                            

                            
                        </div>
                        
                        <!-- ============ Admin-only editable ============ -->
                        
                    }
                    

                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="attachmentPreviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Document Preview</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="attachmentPreviewBody">
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .item-row.bg-light-primary {
            background-color: rgba(13, 110, 253, 0.05);
        }

        .ck-editor__editable {
            min-height: 200px;
        }
    </style>
}

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
        window.isStudent = @JsonSerializer.Serialize(isStudent);
    </script>

    <script src="~/assets/js/DailyAssignment.js"></script>
}
