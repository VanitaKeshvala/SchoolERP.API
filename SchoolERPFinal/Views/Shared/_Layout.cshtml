                 // ── Cookie helpers ───────────────────────────────────────────────
        function setCookie(name, value, days) {
            const expires = new Date();
            expires.setTime(expires.getTime() + days * 24 * 60 * 60 * 1000);
            document.cookie = `${name}=${value};expires=${expires.toUTCString()};path=/`;
        }

        function getCookie(name) {
            const match = document.cookie.match(new RegExp('(?:^|; )' + name + '=([^;]*)'));
            return match ? decodeURIComponent(match[1]) : null;
        }

        // ── Global accessor ──────────────────────────────────────────────
        // Any page: window.getSessionId()  → integer session ID
        window.getSessionId = function () {
            return parseInt(getCookie('CurrentSessionId') || ddl.value || '0', 10);
        };

        function dispatchSessionReady(sessionId) {
            document.dispatchEvent(new CustomEvent('sessionReady', { detail: { sessionId } }));
        }

        function setLoadingState(message) {
            ddl.innerHTML = '';
            const opt = document.createElement('option');
            opt.value = '';
            opt.textContent = message || 'Loading…';
            ddl.appendChild(opt);
            ddl.disabled = true;
        }

        function populateSessions(sessions) {
            ddl.innerHTML = '';
            for (const s of sessions) {
                const opt = document.createElement('option');
                opt.value = String(s.sessionId);
                opt.textContent = s.sessionTitle || `Session #${s.sessionId}`;
                ddl.appendChild(opt);
            }
            ddl.disabled = sessions.length === 0;
        }

        function selectDefaultSession(sessions, cookieSessionId) {
            // Priority: cookie → isActive → first
            const fromCookie = cookieSessionId
                ? (sessions.find(s => s && String(s.sessionId) === String(cookieSessionId)) || null)
                : null;
            const active = fromCookie || sessions.find(s => s && s.isActive === true) || sessions[0] || null;
            if (!active) { ddl.value = ''; return null; }
            ddl.value = String(active.sessionId);
            // Always keep cookie in sync
            setCookie('CurrentSessionId', active.sessionId, 365);
            return active;
        }

            async function init() {
                try {
                    setLoadingState('Loading…');
                    const [sessions, currentSessionId] = await Promise.all([
                        fetchSessions(),
                        fetchUserCurrentSession()
                    ]);
                    const cookieSessionId = getCookie('CurrentSessionId');
            // Only call server if no cookie exists yet
            const sessionss = await fetchSessions();
            populateSessions(sessionss);
            const active = selectDefaultSession(sessionss, cookieSessionId);
            dispatchSessionReady(active ? active.sessionId : 0);
                } catch (e) {
                    console.error(e);
                    setLoadingState('No sessions');
                    //titleEl.textContent = '—';
                }
            }

            ddl.addEventListener('change', async function () {
                const selectedId = parseInt(ddl.value || '0', 10);
                if (!selectedId) return;

                //btnSave.disabled = true;
                ddl.disabled = true;
                try {
                    setCookie('CurrentSessionId', selectedId, 365);
                    const resp = await fetch('/Sessions/SetCurrent', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ sessionId: selectedId })
                    });
                    const res = await resp.json();
                    if (!res || res.success !== true) {
                        throw new Error(res?.message || 'Could not set current session.');
                    }
                    window.location.reload();
                } catch (e) {
                    console.error(e);
                    //btnSave.disabled = false;
                    ddl.disabled = false;
                }
            });

            init();
        })();

        // ── Global accessor ──────────────────────────────────────────────
        // Any page/script: window.getCompanyId() → integer company ID
        // (same pattern as window.getSessionId() above). Backed by the
        // same /Company/GetUserCurrentCompany call the topbar selector
        // already makes, cached on window.__currentCompanyId so we don't
        // fetch it twice.
        window.fetchUserCurrentCompany = async function () {
            try {
                const resp = await fetch('/Company/GetUserCurrentCompany', { method: 'GET' });
                const payload = await resp.json();
                return payload.success ? (payload.data || 0) : 0;
            } catch {
                return 0;
            }
        };

        window.getCompanyId = function () {
            return parseInt(window.__currentCompanyId || '0', 10);
        };

        (function () {
            const ddl = document.getElementById('ddlCompanySelection');
            const titleEl = document.getElementById('activeCompanyTitle');
            const btnSave = document.getElementById('btnSaveCompany');

            // Even on pages without the topbar company-selection markup,
            // still resolve and cache the current company id so that
            // window.getCompanyId() works everywhere (e.g. for
            // copySessionModal.js).
            if (!ddl || !titleEl || !btnSave) {
                window.fetchUserCurrentCompany().then(id => {
                    window.__currentCompanyId = id || 0;
                });
                return;
            }

            async function fetchCompanies() {
                const resp = await fetch('/Company/GetAssignedCompanies', { method: 'GET' });
                const payload = await resp.json();
                if (!payload || payload.success !== true || !Array.isArray(payload.data)) {
                    throw new Error(payload?.message || 'Failed to load companies');
                }
                return payload.data;
            }

            function setLoadingState(message) {
                ddl.innerHTML = '';
                const opt = document.createElement('option');
                opt.value = '';
                opt.textContent = message || 'Loading…';
                ddl.appendChild(opt);
                ddl.disabled = true;
                btnSave.disabled = true;
            }

            function populateCompanies(companies) {
                ddl.innerHTML = '';
                for (const c of companies) {
                    const opt = document.createElement('option');
                    opt.value = String(c.companyId);
                    opt.textContent = c.schoolName || `Company #${c.companyId}`;
                    ddl.appendChild(opt);
                }
                ddl.disabled = companies.length === 0;
                btnSave.disabled = companies.length === 0;
            }

            function selectDefaultCompany(companies, dbCompanyId) {
                const fromDb = dbCompanyId
                    ? (companies.find(c => c && c.companyId === dbCompanyId) || null)
                    : null;

                const active = fromDb || companies.find(c => c && c.isActive === true) || companies[0] || null;
                if (!active) {
                    titleEl.textContent = '—';
                    ddl.value = '';
                    return null;
                }
                titleEl.textContent = active.schoolName || '—';
                ddl.value = String(active.companyId);
                return active;
            }

            async function init() {
                try {
                    setLoadingState('Loading…');
                    const [companies, currentCompanyId] = await Promise.all([
                        fetchCompanies(),
                        window.fetchUserCurrentCompany()
                    ]);
                    window.__currentCompanyId = currentCompanyId || 0;
                    populateCompanies(companies);
                    selectDefaultCompany(companies, currentCompanyId);
                } catch (e) {
                    console.error(e);
                    setLoadingState('No companies');
                    titleEl.textContent = '—';
                }
            }

            btnSave.addEventListener('click', async function () {
                const selectedId = parseInt(ddl.value || '0', 10);
                if (!selectedId) return;

                btnSave.disabled = true;
                ddl.disabled = true;
                try {
                    const resp = await fetch('/Company/SetCurrent', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ companyId: selectedId })
                    });
                    const res = await resp.json();
                    if (!res || res.success !== true) {
                        throw new Error(res?.message || 'Could not set current company.');
                    }
                    window.__currentCompanyId = selectedId;
                    window.location.reload();
                } catch (e) {
                    console.error(e);
                    btnSave.disabled = false;
                    ddl.disabled = false;
                }
            });

            init();
        })();

         const input = document.getElementById("txtBackDaysAllow");

        input.addEventListener("keydown", (e) => {
            if (e.key === "-" || e.key === "Minus") {
                e.preventDefault();
            }
        });
    </script>
    <script>
        /**
         * Sidebar Toggle & Persistence Logic
         * Overrides default script.js behavior to ensure ThemeCustomizer state is preserved.
         */
        $(document).ready(function () {
            if (typeof ThemeCustomizer !== 'undefined') {
                // Initialize customizer if not already assigned to window
                if (!window.themeCustomizer) {
                    window.themeCustomizer = new ThemeCustomizer();
                    window.themeCustomizer.init();
                }

                function toggleSidebarStyle() {
                    let html = document.documentElement;
                    let currentSize = html.getAttribute("data-layout");

                    // Fallback if attribute is missing
                    if (!currentSize) {
                        currentSize = window.themeCustomizer.config.sidenav.size || "default";
                    }

                    let newSize = (currentSize === "mini") ? "default" : "mini";

                    // Apply layout: This updates <html> data-layout, toggles <body> .mini-sidebar class,
                    // and persists the state to sessionStorage via ThemeCustomizer's internal methods.
                    window.themeCustomizer.changeLeftbarSize(newSize);

                    // Force UI refresh for responsive elements (tables, charts, etc.)
                    window.dispatchEvent(new Event('resize'));
                }

                // Unbind the conflicting handlers from assets/js/script.js to prevent double-toggling
                $(document).off('click', '#toggle_btn');
                $(document).off('click', '#toggle_btn2');

                // Re-bind both toggle buttons to the persistent handler
                $(document).on('click', '#toggle_btn, #toggle_btn2', function (e) {
                    e.preventDefault();
                    toggleSidebarStyle();
                    return false;
                });
            }
        });
    </script>


