    <script>
        /**
         * Global Toast Helper
         * param {string} message - The message to display
         * param {string} type - 'success', 'error', 'warning', 'info'
         */
        window.showToast = function (message, type) {
            const toastEl = document.getElementById('globalToast');
            const messageEl = document.getElementById('globalToastMessage');
            const iconEl = document.getElementById('globalToastIcon');

            if (!toastEl || !messageEl) return;

            // Handle boolean type (compatibility with older showToast(msg, isSuccess))
            let toastType = type;
            if (typeof type === 'boolean') {
                toastType = type ? 'success' : 'error';
            }

            // Reset classes
            toastEl.classList.remove('bg-success', 'bg-danger', 'bg-warning', 'bg-info');
            iconEl.className = 'ti fs-5';

            // Set type specifics
            switch (toastType?.toLowerCase()) {
                case 'success':
                    toastEl.classList.add('bg-success');
                    iconEl.classList.add('ti-circle-check');
                    break;
                case 'error':
                case 'danger':
                    toastEl.classList.add('bg-danger');
                    iconEl.classList.add('ti-alert-circle');
                    break;
                case 'warning':
                    toastEl.classList.add('bg-warning');
                    iconEl.classList.add('ti-alert-triangle');
                    break;
                case 'info':
                default:
                    toastEl.classList.add('bg-info');
                    iconEl.classList.add('ti-info-circle');
                    break;
            }

            messageEl.textContent = message;

            const toast = bootstrap.Toast.getOrCreateInstance(toastEl, { delay: 4000 });
            toast.show();
        };
    </script>

    <script>

        const calendarGrid = document.getElementById("calendarGrid");
        const monthYear = document.getElementById("monthYear");

        const today = new Date();

        const currentMonth = today.getMonth();
        const currentYear = today.getFullYear();

        const months = [
            "January", "February", "March", "April", "May", "June",
            "July", "August", "September", "October", "November", "December"
        ];

        monthYear.innerText = `${months[currentMonth]} ${currentYear}`;

        const firstDay = new Date(currentYear, currentMonth, 1).getDay();
        const totalDays = new Date(currentYear, currentMonth + 1, 0).getDate();

        // Previous month placeholders
        for (let i = 0; i < firstDay; i++) {

            const div = document.createElement("div");
            div.classList.add("day", "inactive");

            calendarGrid.appendChild(div);
        }

        // Calendar Days
        for (let day = 1; day <= totalDays; day++) {

            const dayDiv = document.createElement("div");
            dayDiv.classList.add("day");

            if (
                day === today.getDate() &&
                currentMonth === today.getMonth() &&
                currentYear === today.getFullYear()
            ) {
                dayDiv.classList.add("today");
            }

            let eventHtml = "";

            // Sample Events
            if (day === 5) {
                eventHtml = `<div class="event">Sports Day</div>`;
            }

            if (day === 12) {
                eventHtml = `<div class="holiday">Holiday</div>`;
            }

            if (day === 18) {
                eventHtml = `<div class="meeting">Meeting</div>`;
            }

            if (day === 25) {
                eventHtml = `<div class="event">Annual Event</div>`;
            }

            dayDiv.innerHTML = `
                        <div class="day-number">${day}</div>
                        ${eventHtml}
                    `;

            calendarGrid.appendChild(dayDiv);
        }

    </script>
    <script>
        /**
         * Global Table Sorting
         * Automatically adds sorting to tables with class 'table'
         */
          
        $(document).ready(function () {

                   // ================= Generic Sticky Layout (works on ANY page) =================
        function updateStickyLayout() {
            var headers = document.querySelectorAll('.page-sticky-header');
            if (headers.length === 0) return;

            // Use the tallest sticky header on the page (usually just one)
            var headerHeight = 0;
            headers.forEach(function (h) { headerHeight = Math.max(headerHeight, h.offsetHeight); });

            document.querySelectorAll('.sticky-table-scroll thead th').forEach(function (th) {
                th.style.top = 0 + 'px';
            });
        }

        window.addEventListener('load', updateStickyLayout);
        window.addEventListener('resize', updateStickyLayout);
        setTimeout(updateStickyLayout, 300); // catch late-rendering content (AJAX tables, filters, etc.)

            function scrollTabIntoView($tab) {
                var $scroller = $tab.closest('.tab-scroll');
                if ($scroller.length) {
                    var target = $tab[0].offsetLeft - ($scroller.outerWidth() / 2) + ($tab.outerWidth() / 2);
                    $scroller.stop().animate({ scrollLeft: Math.max(0, target) }, 250);
                }
            }

            $(document).on('shown.bs.tab', '.tab-scroll .nav-link', function () {
                scrollTabIntoView($(this));
            });

            $('.tab-scroll').scrollLeft(0);

            window.addEventListener('resize', updateStickyLayout);
            updateStickyLayout();
            setTimeout(updateStickyLayout, 300);

            // ================= Sidebar Active Menu + Auto-scroll =================
            function setActiveMenu() {
                var currentPath = window.location.pathname.toLowerCase().replace(/\/+$/, '');
                var links = document.querySelectorAll('.sidebar-menu a[href]');
                var bestMatch = null, bestMatchLength = 0;

                links.forEach(function (link) {
                    var linkPath = link.getAttribute('href');
                    if (!linkPath || linkPath === '#' || linkPath.startsWith('javascript:')) return;
                    linkPath = linkPath.toLowerCase().replace(/\/+$/, '');

                    if (linkPath === currentPath) {
                        bestMatch = link; bestMatchLength = linkPath.length; return;
                    }
                    if (currentPath.startsWith(linkPath + '/') && linkPath.length > bestMatchLength) {
                        bestMatch = link; bestMatchLength = linkPath.length;
                    }
                });

                if (!bestMatch) return null;

                document.querySelectorAll('.sidebar-menu li.active, .sidebar-menu a.active')
                    .forEach(function (el) { el.classList.remove('active'); });

                bestMatch.classList.add('active');
                var li = bestMatch.closest('li');
                if (li) li.classList.add('active');

                var submenuParent = bestMatch.closest('li.submenu');
                while (submenuParent) {
                    submenuParent.classList.add('active', 'subdrop');
                    var parentAnchor = submenuParent.querySelector(':scope > a');
                    if (parentAnchor) parentAnchor.classList.add('active', 'subdrop');
                    var subUl = submenuParent.querySelector(':scope > ul');
                    if (subUl) subUl.style.display = 'block';
                    submenuParent = submenuParent.parentElement ? submenuParent.parentElement.closest('li.submenu') : null;
                }

                return bestMatch;
            }

            function scrollSidebarToActive(activeLink) {
                if (!activeLink) return;
                requestAnimationFrame(function () {
                    setTimeout(function () {
                        var simplebarWrapper = document.querySelector('.sidebar [data-simplebar] .simplebar-content-wrapper');
                        if (simplebarWrapper) {
                            var linkTop = activeLink.getBoundingClientRect().top;
                            var wrapperTop = simplebarWrapper.getBoundingClientRect().top;
                            var offset = linkTop - wrapperTop - (simplebarWrapper.clientHeight / 2);
                            simplebarWrapper.scrollTop += offset;
                        } else {
                            activeLink.scrollIntoView({ block: 'center', behavior: 'auto' });
                        }
                    }, 50);
                });
            }

            var activeMenuLink = setActiveMenu();
            scrollSidebarToActive(activeMenuLink);

            // ================= Timepicker =================
            $('#txtStartTime').timepicker({
                timeFormat: 'hh:mm p',
                interval: 15,
                minTime: '12:00am',
                maxTime: '11:59pm',
                defaultTime: '12',
                startTime: '12:00am',
                dynamic: false,
                dropdown: true,
                scrollbar: true
            });
        });

