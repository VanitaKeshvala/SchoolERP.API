    <script>
        /**
         * Global Toast Helper
         * param {string} message - The message to display
         * param {string} type - 'success', 'error', 'warning', 'info'
         */
        window.showToast = function (message, type) {
            const toastEl = document.getElementById('globalToast');
            const messageEl = document.getElementById('globalToastMessage');
            const iconEl = document.getElementById('globalToastIcon');

            if (!toastEl || !messageEl) return;

            // Handle boolean type (compatibility with older showToast(msg, isSuccess))
            let toastType = type;
            if (typeof type === 'boolean') {
                toastType = type ? 'success' : 'error';
            }

            // Reset classes
            toastEl.classList.remove('bg-success', 'bg-danger', 'bg-warning', 'bg-info');
            iconEl.className = 'ti fs-5';

            // Set type specifics
            switch (toastType?.toLowerCase()) {
                case 'success':
                    toastEl.classList.add('bg-success');
                    iconEl.classList.add('ti-circle-check');
                    break;
                case 'error':
                case 'danger':
                    toastEl.classList.add('bg-danger');
                    iconEl.classList.add('ti-alert-circle');
                    break;
                case 'warning':
                    toastEl.classList.add('bg-warning');
                    iconEl.classList.add('ti-alert-triangle');
                    break;
                case 'info':
                default:
                    toastEl.classList.add('bg-info');
                    iconEl.classList.add('ti-info-circle');
                    break;
            }

            messageEl.textContent = message;

            const toast = bootstrap.Toast.getOrCreateInstance(toastEl, { delay: 4000 });
            toast.show();
        };
    </script>

    <script>

        const calendarGrid = document.getElementById("calendarGrid");
        const monthYear = document.getElementById("monthYear");

        const today = new Date();

        const currentMonth = today.getMonth();
        const currentYear = today.getFullYear();

        const months = [
            "January", "February", "March", "April", "May", "June",
            "July", "August", "September", "October", "November", "December"
        ];

        monthYear.innerText = `${months[currentMonth]} ${currentYear}`;

        const firstDay = new Date(currentYear, currentMonth, 1).getDay();
        const totalDays = new Date(currentYear, currentMonth + 1, 0).getDate();

        // Previous month placeholders
        for (let i = 0; i < firstDay; i++) {

            const div = document.createElement("div");
            div.classList.add("day", "inactive");

            calendarGrid.appendChild(div);
        }

        // Calendar Days
        for (let day = 1; day <= totalDays; day++) {

            const dayDiv = document.createElement("div");
            dayDiv.classList.add("day");

            if (
                day === today.getDate() &&
                currentMonth === today.getMonth() &&
                currentYear === today.getFullYear()
            ) {
                dayDiv.classList.add("today");
            }

            let eventHtml = "";

            // Sample Events
            if (day === 5) {
                eventHtml = `<div class="event">Sports Day</div>`;
            }

            if (day === 12) {
                eventHtml = `<div class="holiday">Holiday</div>`;
            }

            if (day === 18) {
                eventHtml = `<div class="meeting">Meeting</div>`;
            }

            if (day === 25) {
                eventHtml = `<div class="event">Annual Event</div>`;
            }

            dayDiv.innerHTML = `
                        <div class="day-number">${day}</div>
                        ${eventHtml}
                    `;

            calendarGrid.appendChild(dayDiv);
        }

    </script>
    <script>
        /**
         * Global Table Sorting
         * Automatically adds sorting to tables with class 'table'
         */
        $(document).ready(function() {
            document.querySelectorAll('table.table:not(.dataTable)').forEach(table => {
                if (table.getAttribute('data-manual-sort') === 'true') return;

                const thead = table.querySelector('thead');
                const tbody = table.querySelector('tbody');
                if (!thead || !tbody) return;

                const headers = thead.querySelectorAll('th');
                headers.forEach((header, index) => {
                    const headerText = header.innerText.trim().toLowerCase();
                    if (headerText === 'select' || headerText === 'action' || headerText === 'status' || headerText === '') {
                        return;
                    }

                    if (!header.querySelector('i.fa-sort')) {
                        const icon = document.createElement('i');
                        icon.className = 'fas fa-sort text-muted ms-1';
                        header.appendChild(icon);
                    }

                    header.style.cursor = 'pointer';
                    header.addEventListener('click', function() {
                        const rows = Array.from(tbody.querySelectorAll('tr'));
                        const validRows = rows.filter(row => !row.querySelector('td[colspan]'));

                        if (validRows.length <= 1) return;

                        const isAscending = header.dataset.order !== 'asc';

                        validRows.sort((a, b) => {
                            if (index >= a.cells.length || index >= b.cells.length) return 0;

                            let aCol = a.cells[index].innerText.trim();
                            let bCol = b.cells[index].innerText.trim();

                            const aSort = a.cells[index].getAttribute('data-sort');
                            const bSort = b.cells[index].getAttribute('data-sort');

                            if (aSort !== null && bSort !== null) {
                                aCol = aSort;
                                bCol = bSort;
                                const aNum = parseFloat(aCol);
                                const bNum = parseFloat(bCol);
                                if (!isNaN(aNum) && !isNaN(bNum)) {
                                    return isAscending ? aNum - bNum : bNum - aNum;
                                }
                            } else {
                                const aClean = aCol.replace(/[^\d.-]/g, '');
                                const bClean = bCol.replace(/[^\d.-]/g, '');
                                const aNum = parseFloat(aClean);
                                const bNum = parseFloat(bClean);

                                if (aClean !== '' && bClean !== '' && !isNaN(aNum) && !isNaN(bNum) &&
                                    /^-?\d+(\.\d+)?$/.test(aClean) && /^-?\d+(\.\d+)?$/.test(bClean)) {
                                    return isAscending ? aNum - bNum : bNum - aNum;
                                }
                            }

                            return isAscending ? aCol.localeCompare(bCol, undefined, {numeric: true, sensitivity: 'base'}) : bCol.localeCompare(aCol, undefined, {numeric: true, sensitivity: 'base'});
                        });

                        validRows.forEach(row => tbody.appendChild(row));
                        header.dataset.order = isAscending ? 'asc' : 'desc';

                        headers.forEach((h) => {
                            const icon = h.querySelector('i');
                            if (icon) {
                                if (h === header) {
                                    icon.className = isAscending ? 'fas fa-sort-up ms-1' : 'fas fa-sort-down ms-1';
                                    icon.classList.remove('text-muted');
                                } else {
                                    icon.className = 'fas fa-sort text-muted ms-1';
                                    h.dataset.order = '';
                                }
                            }
                        });
                    });
                });
            });
        });
    </script>
