@model SchoolERP.Shared.Models.HomeWorkAddDetailsViewModel
@using System.Security.Claims
@using System.Text.Json

@{
    Layout = "_Layout";
    ViewData["Title"] = "Homework Details";

    // Permission loading for the view
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;
}
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-1 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Homework Details</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">

        @if (Model.Homeworks?.Status == 1)
        {
            <button class="btn btn-success top-btn" id="btnSaveHomework" onclick="saveHomework()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Homework/Index" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>

    </div>
</div>
<div class="row">
    @if (Model.Homeworks != null)
    {
        <div class="col-xl-4">
            <div class="card shadow-tbl-outer position-sticky"
                 style="top: 70px">
                <div class="card-body d-flex align-items-center flex-sm-nowrap flex-wrap row-gap-3">
                    <div class="flex-fill">
                        <div class="d-flex align-items-center mb-1">
                            <h6 class="mb-2 fw-semibold">
                                <a>Summary</a>
                            </h6>
                        </div>
                        <p class="mb-2 fs-13">
                            <span class="text-dark">Homework Date </span> : @Model.Homeworks?.HomeworkDate.ToString("dd MMM yyyy")
                        </p>
                        <p class="mb-2 fs-13">
                            <span class="text-dark">Submission Date</span> : @Model.Homeworks?.SubmissionDate.ToString("dd MMM yyyy")
                        </p>
                        <p class="mb-2 fs-13">
                            <span class="text-dark">Evaluation Date</span> : @Model.Homeworks?.EvaluationDate?.ToString("dd MMM yyyy")
                        </p>
                        <!-- <p class="mb-2 fs-13">
                                            <span class="text-dark">Designation</span> : Teacher
                                        </p> -->
                    </div>
                </div>
                <!-- end card body -->
                <ul class="list-group list-group-flush">
                    <li class="list-group-item list-group-item-action d-flex justify-content-between">
                        <span class="text-dark">Created By :</span> @Model.Homeworks?.CreatedByName
                    </li>
                    <li class="list-group-item list-group-item-action d-flex justify-content-between">
                        <span class="text-dark">Evaluated By :</span> @Model.Homeworks?.EvaluationByName
                    </li>
                    <li class="list-group-item list-group-item-action d-flex justify-content-between">
                        <span class="text-dark">Class :</span>@Model.Homeworks?.ClassName
                    </li>
                    <li class="list-group-item list-group-item-action d-flex justify-content-between">
                        <span class="text-dark">Section :</span> @Model.Homeworks?.SectionName
                    </li>
                    <li class="list-group-item list-group-item-action d-flex justify-content-between">
                        <span class="text-dark">Subject :</span> @Model.Homeworks?.SubjectName
                    </li>
                    <li class="list-group-item list-group-item-action d-flex justify-content-between">

                        @if (Model.Homeworks?.Status == 2)
                        {
                            <span class="text-dark">Status :</span>     <span class="badge bg-secondary">Submitted</span>
                        }
                        else if (Model.Homeworks?.Status == 3)
                        {
                            <span class="text-dark">Status :</span>      <span class="badge bg-success">Evaluated</span>
                        }
                        else if (Model.Homeworks?.Status == 4)
                        {
                            <span class="text-dark">Status :</span>        <span class="badge bg-danger">Late</span>
                        }
                        else
                        {
                            <span class="text-dark">Status :</span>           <span class="badge bg-secondary">Pending</span>
                        }

                    </li>
                </ul>
            </div>
            <!-- end card -->
        </div>
    }
    <div class="col-xl-8 ps-md-0">
        <div class="card shadow-tbl-outer">
            <div class="card-header">
                <form id="fromSubmission">
                    <input type="hidden" id="hdnHomeworkID" value="@Model.HomeworkID" />

                    <h6>Home Work Description</h6>
                    @Html.Raw(Model.Homeworks?.Description)
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label class="form-label">Message<span class="text-danger">*</span></label>
                            <textarea id="txtMessage" class="form-control" rows="5">@Model.Homeworks?.MESSAGE</textarea>
                            <div class="invalid-feedback" id="errTxtMessage"></div>
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label">Attach Document</label>
                            <input type="file" id="fileAttachment" class="form-control" multiple>
                        </div>
                    </div>
                </form>
            </div>
           
        </div>
    </div>

    <div class="col-xl-12 ps-md-0">
        <div class="card shadow-tbl-outer">
            <div class="card-header">
                <div>
                    <h6 class="fw-bold mb-0">Document View</h6>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle" id="attachmentTable">
                        <thead class="table-light">
                            <tr>
                                <th>File Name</th>
                                <th style="width: 140px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.HomeWorkSubmissionAttechment != null && Model.HomeWorkSubmissionAttechment.Any())
                            {
                                foreach (var doc in Model.HomeWorkSubmissionAttechment)
                                {
                                    <tr data-attachment-id="@doc.AttachmentID" data-file-path="@doc.AttachmentPath" data-file-name="@doc.AttachmentName">
                                        <td>@doc.AttachmentName</td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-primary" onclick="viewAttachment('@doc.AttachmentPath')">
                                                <i class="fa fa-eye"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="2" class="text-center text-muted">No uploaded documents found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    
</div>
<div class="modal fade" id="attachmentPreviewModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Document Preview</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="attachmentPreviewBody">
            </div>
        </div>
    </div>
</div>
@section Scripts {

    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/assets/js/HomeworkDetails.js"></script>
}
