@model SchoolERP.Net.Models.HomeworkPageViewModel
@using System.Security.Claims
@using System.Text.Json
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper

@{
    Layout = "_Layout";
    ViewData["Title"] = "Homework Management";

    // Permission loading for the view
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0) PermHelper.LoadPermissions(currentUserId);
    
    // Permission variables for JS and buttons
    var canAdd = PermHelper.HasPermissionByUrl("/Homework/Add", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/Homework/Add", "Edit");
    var canDelete = PermHelper.HasPermissionByUrl("/Homework/Add", "Delete");
    var canPrint = PermHelper.HasPermissionByUrl("/Homework/Add", "Print");
    var canExport = PermHelper.HasPermissionByUrl("/Homework/Add", "Export");
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Homework List</h6>
    </div>

    <div class="d-flex gap-1">
        @if (canAdd)
        {
            <button class="btn btn-primary" onclick="openAddModal()"><i class="ti ti-plus"></i> Add</button>
        }
        @if (canEdit)
        {
            <button id="btnEdit" class="btn btn-info" disabled onclick="editSelected()">
                <i class="ti ti-pencil me-1"></i>Edit
            </button>
        }
        @if (canDelete)
        {
            <button id="btnDelete" class="btn btn-danger" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i>Delete
            </button>
        }
        @if (canPrint)
        {
            <button class="btn btn-secondary d-inline-flex align-items-center" onclick="triggerExport(4)">
                <i class="ti ti-printer me-1"></i>Print
            </button>
        }
        @if (canExport)
        {
            <div class="dropdown d-inline-flex">
                <button class="btn btn-warning d-inline-flex align-items-center dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="ti ti-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(0)"><i class="ti ti-copy me-1"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(1)"><i class="ti ti-file-text me-1"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(2)"><i class="ti ti-file-spreadsheet me-1"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(3)"><i class="ti ti-file-description me-1"></i>PDF</a></li>
                </ul>
            </div>
        }
    </div>

</div>
<!-- End Page Header -->

<div id="pageNotice"></div>

<!-- start row -->
<div class="row">
    <div class="col-md-12">
        <div class="card shadow-tbl-outer mb-2">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3 bg-white">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text" id="txtSearch" class="form-control border-0 ps-2" style="min-width: 220px;" placeholder="Search..." onkeyup="filterTable()" />
                    </div>
                    <!--<input type="text" id="txtSearch" class="form-control w-25 me-3" placeholder="Search..." onkeyup="filterTable()" />-->
                    <ul class="nav nav-pills gap-1">
                        <li class="nav-item">
                            <a class="nav-link active" data-bs-toggle="pill" href="#upcoming" onclick="applyStatusFilter(true)">Upcoming Homework</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" data-bs-toggle="pill" href="#closed" onclick="applyStatusFilter(false)">Closed Homework</a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table" id="homeworkTable" style="display: none;">
                        <thead>
                            <tr>
                                <th style="width: 50px;">#</th>
                                <th>Class (Section)</th>
                                <th>Subject Group</th>
                                <th>Subject</th>
                                <th>Homework Date</th>
                                <th>Submission Date</th>
                                <th>Created By</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Homeworks != null && Model.Homeworks.Any())
                            {
                                foreach (var h in Model.Homeworks)
                                {
                                    <tr class="item-row" data-active="@h.IsActive" data-submission="@h.SubmissionDate.ToString("yyyy-MM-dd")" onclick="selectItem(@h.HomeworkID, this)" style="cursor: pointer;">
                                        <td class="text-center">
                                            <input type="radio" name="selectedHomework" class="form-check-input" value="@h.HomeworkID">
                                        </td>
                                        <td>
                                            <span>@h.ClassName</span> (@h.SectionName)
                                        </td>
                                        <td>@h.SubjectGroupName</td>
                                        <td>@h.SubjectName</td>
                                        <td>@h.HomeworkDate.ToString("dd MMM yyyy")</td>
                                        <td>@h.SubmissionDate.ToString("dd MMM yyyy")</td>
                                        <td>@h.CreatedByName</td>
                                        <td>                                            
                                            <span class="badge @(h.IsActive ? "bg-success" : "bg-secondary")" asp-permission="View" asp-permission-url="/Homework/Add" asp-permission-negate="true">@(h.IsActive ? "Active" : "Inactive")</span>
                                        </td>
                                        <td>
                                            <div class="form-check form-switch" onclick="event.stopPropagation()" asp-permission="Edit" asp-permission-url="/Homework/Add">
                                                <input class="form-check-input status-switch" type="checkbox" @(h.IsActive ? "checked" : "") onchange="toggleStatus(@h.HomeworkID, this.checked)">
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td class="text-center py-4 text-muted" colspan="8">No Homework Data Found</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="homeworkModal" tabindex="-1" aria-labelledby="homeworkModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header justify-content-between">
                <h5 class="modal-title" id="homeworkModalLabel">Add Homework</h5>
                <div class="d-flex gap-1">
                    @if (canAdd || canEdit)
                    {
                        <button id="btnSaveHomework" class="btn btn-success" onclick="saveHomework()">
                            <i class="ti ti-cloud me-1"></i> Save
                        </button>
                    }
                    <button class="btn btn-danger" data-bs-dismiss="modal">
                        <i class="ti ti-x me-1"></i> Close
                    </button>
                </div>
            </div>
            <div class="modal-body p-4">
                <div id="modalNotice"></div>
                <form id="homeworkForm" class="row">
                    <input type="hidden" id="txtHomeworkId" value="0">
                    
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Class<span class="text-danger">*</span></label>
                        <select id="ddlClass" class="form-select form-control" onchange="loadSections(this.value)">
                            <option value="">Select Class</option>
                            @foreach (var c in Model.Classes)
                            {
                                <option value="@c.ClassID">@c.ClassName</option>
                            }
                        </select>
                        <div class="invalid-feedback" id="errDdlClass"></div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Section<span class="text-danger">*</span></label>
                        <select id="ddlSection" class="form-select form-control" onchange="loadSubjectGroups()">
                            <option value="">Select Section</option>
                        </select>
                        <div class="invalid-feedback" id="errDdlSection"></div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Subject Group<span class="text-danger">*</span></label>
                        <select id="ddlSubjectGroup" class="form-select form-control" onchange="loadSubjects(this.value)">
                            <option value="">Select Group</option>
                        </select>
                        <div class="invalid-feedback" id="errDdlSubjectGroup"></div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Subject<span class="text-danger">*</span></label>
                        <select id="ddlSubject" class="form-select form-control">
                            <option value="">Select Subject</option>
                        </select>
                        <div class="invalid-feedback" id="errDdlSubject"></div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Homework Date <span class="text-danger">*</span></label>
                        <input type="date" id="txtHomeworkDate" class="form-control">
                        <div class="invalid-feedback" id="errTxtHomeworkDate"></div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Submission Date <span class="text-danger">*</span></label>
                        <input type="date" id="txtSubmissionDate" class="form-control">
                        <div class="invalid-feedback" id="errTxtSubmissionDate"></div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <div class="mb-3">
                            <label class="form-label">Max Marks </label>
                            <input type="number" id="txtMaxMarks" class="form-control" step="0.01">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Attach Document</label>
                            <input type="file" id="fileAttachment" class="form-control">
                        </div>
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="chkIsActive" checked>
                                <label class="form-check-label fw-semibold" for="chkIsActive">Active Status</label>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-8 mb-3">
                        <label class="form-label">Description<span class="text-danger">*</span></label>
                        <textarea id="txtDescription" class="form-control" rows="5"></textarea>
                        <div class="invalid-feedback" id="errTxtDescription"></div>
                    </div>

                    
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .item-row.bg-light-primary { background-color: rgba(13, 110, 253, 0.05); }
        .ck-editor__editable { min-height: 200px; }
        .dt-buttons { display: none !important; }

        #homeworkTable_filter{
            display:none;
        }
    </style>
}

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/41.1.0/classic/ckeditor.js"></script>
    <script>
        const permCanAdd = @Html.Raw(JsonSerializer.Serialize(canAdd));
        const permCanEdit = @Html.Raw(JsonSerializer.Serialize(canEdit));
        const permCanDelete = @Html.Raw(JsonSerializer.Serialize(canDelete));

        const homeworkModal = new bootstrap.Modal(document.getElementById('homeworkModal'));
        let selectedId = 0;
        let isUpcomingTab = true;
        let editorInstance;

        // Custom Base64 Upload Adapter
        class MyUploadAdapter {
            constructor(loader) {
                this.loader = loader;
            }
            upload() {
                return this.loader.file
                    .then(file => new Promise((resolve, reject) => {
                        const reader = new FileReader();
                        reader.onload = () => {
                            resolve({ default: reader.result });
                        };
                        reader.onerror = error => reject(error);
                        reader.onabort = () => reject();
                        reader.readAsDataURL(file);
                    }));
            }
            abort() { }
        }

        function MyCustomUploadAdapterPlugin(editor) {
            editor.plugins.get('FileRepository').createUploadAdapter = (loader) => {
                return new MyUploadAdapter(loader);
            };
        }

        const IV = {
            clearMap: (map) => Object.keys(map).forEach(k => {
                document.getElementById(k)?.classList.remove('is-invalid');
                const err = document.getElementById(map[k]); if(err) err.textContent = '';
            }),
            setFieldError: (id, errId, msg) => {
                document.getElementById(id)?.classList.add('is-invalid');
                const err = document.getElementById(errId); if(err) err.textContent = msg;
            },
            setNotice: (id, msg, type = 'danger') => {
                const el = document.getElementById(id);
                if(el) el.innerHTML = `<div class="alert alert-${type} alert-dismissible fade show" role="alert">${msg}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`;
            },
            clearNotice: (id) => { const el = document.getElementById(id); if(el) el.innerHTML = ''; }
        };

        const fieldMap = {
            ddlClass: 'errDdlClass',
            ddlSection: 'errDdlSection',
            ddlSubjectGroup: 'errDdlSubjectGroup',
            ddlSubject: 'errDdlSubject',
            txtHomeworkDate: 'errTxtHomeworkDate',
            txtSubmissionDate: 'errTxtSubmissionDate',
            txtDescription: 'errTxtDescription'
        };

        $(document).ready(function() {
            const table = $('#homeworkTable').DataTable({
                dom: 'Bfrtip',
                buttons: [
                    { extend: 'copy', exportOptions: { columns: [1, 2, 3, 4, 5, 6, 7] } },
                    { extend: 'csv', exportOptions: { columns: [1, 2, 3, 4, 5, 6, 7] } },
                    { extend: 'excel', exportOptions: { columns: [1, 2, 3, 4, 5, 6, 7] } },
                    { extend: 'pdf', exportOptions: { columns: [1, 2, 3, 4, 5, 6, 7] } },
                    { extend: 'print', exportOptions: { columns: [1, 2, 3, 4, 5, 6, 7] } }
                ],
                searching: true,
                paging: false,
                info: false
            });

            // Custom Search function for Tabs
            $.fn.dataTable.ext.search.push(
                function(settings, data, dataIndex) {
                    if (settings.nTable.id !== 'homeworkTable') return true;
                    
                    const row = settings.aoData[dataIndex].nTr;
                    const isActive = (row.getAttribute('data-active') || '').toLowerCase() === 'true';
                    const submissionDate = row.getAttribute('data-submission');
                    const today = new Date().toLocaleDateString('en-CA');
                    
                    if (isUpcomingTab) {
                        return (isActive && submissionDate >= today);
                    } else {
                        return (!isActive || submissionDate < today);
                    }
                }
            );

            applyStatusFilter(true);
            $('#homeworkTable').show();

            ClassicEditor
                .create(document.querySelector('#txtDescription'), {
                    extraPlugins: [MyCustomUploadAdapterPlugin],
                    toolbar: [
                        'heading', '|', 'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', 'insertTable', 'uploadImage', 'undo', 'redo'
                    ]
                })
                .then(editor => {
                    editorInstance = editor;
                })
                .catch(error => {
                    console.error(error);
                });
        });

        function triggerExport(index) {
            const table = $('#homeworkTable').DataTable();
            table.button(index).trigger();
        }

        function selectItem(id, row) {
            selectedId = id;
            document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light-primary'));
            row.classList.add('bg-light-primary');
            row.querySelector('input[type="radio"]').checked = true;
            if (permCanEdit) document.getElementById('btnEdit').disabled = false;
            if (permCanDelete) {
                document.getElementById('btnDelete').disabled = isUpcomingTab;
            }
        }

        async function loadSections(classId) {
            const ddl = $('#ddlSection');
            ddl.empty().append(new Option('Select Section', ''));
            $('#ddlSubjectGroup').empty().append(new Option('Select Group', ''));
            $('#ddlSubject').empty().append(new Option('Select Subject', ''));

            if (!classId) return;

            try {
                const resp = await fetch(`/Academics/GetSectionsByClass?id=${classId}`);
                const res = await resp.json();
                if (res.success && res.data) {
                    res.data.forEach(s => ddl.append(new Option(s.sectionName, s.sectionID)));
                }
            } catch (err) { console.error(err); }
        }

        async function loadSubjectGroups() {
            const classId = $('#ddlClass').val();
            const sectionId = $('#ddlSection').val();
            const sectionName = $('#ddlSection option:selected').text().trim();

            const ddl = $('#ddlSubjectGroup');
            ddl.empty().append(new Option('Select Group', ''));
            $('#ddlSubject').empty().append(new Option('Select Subject', ''));

            if (!classId || !sectionId) return;

            try {
                const resp = await fetch('/Homework/GetSubjectGroups');
                const res = await resp.json();
                if (res.success && res.data) {
                    const filtered = res.data.filter(g => 
                        g.classID == classId && 
                        (g.sectionNames || "").split(',').map(s => s.trim()).includes(sectionName)
                    );
                    filtered.forEach(g => ddl.append(new Option(g.name, g.subjectGroupID)));
                }
            } catch (err) { console.error(err); }
        }

        async function loadSubjects(groupId) {
            const ddl = $('#ddlSubject');
            ddl.empty().append(new Option('Select Subject', ''));

            if (!groupId) return;

            try {
                const resp = await fetch(`/Homework/GetSubjectGroupByID?id=${groupId}`);
                const res = await resp.json();
                if (res.success && res.data) {
                    // We need subject names, fetching from Subject Group details
                    // The SubjectGroupViewModel should have enough info or we fetch subjects
                    const subjectsResp = await fetch('/Homework/GetSubjects');
                    const subjectsRes = await subjectsResp.json();
                    if (subjectsRes.success) {
                        const filtered = subjectsRes.data.filter(s => res.data.subjectIds.includes(s.subjectID));
                        filtered.forEach(s => ddl.append(new Option(s.subjectName, s.subjectID)));
                    }
                }
            } catch (err) { console.error(err); }
        }

        function openAddModal() {
            selectedId = 0;
            IV.clearMap(fieldMap);
            IV.clearNotice('modalNotice');
            document.getElementById('homeworkForm').reset();
            if(editorInstance) editorInstance.setData('');
            document.getElementById('txtHomeworkId').value = "0";
            document.getElementById('homeworkModalLabel').textContent = "Add Homework";
            $('#ddlSection').empty().append(new Option('Select Section', ''));
            $('#ddlSubjectGroup').empty().append(new Option('Select Group', ''));
            $('#ddlSubject').empty().append(new Option('Select Subject', ''));
            homeworkModal.show();
        }

        async function editSelected() {
            if (selectedId === 0) return;
            IV.clearMap(fieldMap);
            IV.clearNotice('modalNotice');
            try {
                const resp = await fetch(`/Homework/GetHomeworkByID?id=${selectedId}`);
                const res = await resp.json();
                if (res.success) {
                    const h = res.data;
                    document.getElementById('txtHomeworkId').value = h.homeworkID;
                    document.getElementById('homeworkModalLabel').textContent = "Edit Homework";
                    document.getElementById('ddlClass').value = h.classID;
                    
                    await loadSections(h.classID);
                    document.getElementById('ddlSection').value = h.sectionID;
                    
                    await loadSubjectGroups();
                    document.getElementById('ddlSubjectGroup').value = h.subjectGroupID;
                    
                    await loadSubjects(h.subjectGroupID);
                    document.getElementById('ddlSubject').value = h.subjectID;
                    
                    document.getElementById('txtHomeworkDate').value = h.homeworkDate.split('T')[0];
                    document.getElementById('txtSubmissionDate').value = h.submissionDate.split('T')[0];
                    document.getElementById('txtMaxMarks').value = h.maxMarks;
                    if(editorInstance) editorInstance.setData(h.description || '');
                    document.getElementById('chkIsActive').checked = h.isActive;
                    
                    homeworkModal.show();
                }
            } catch (err) { console.error(err); }
        }

        async function saveHomework() {
            IV.clearMap(fieldMap);
            const description = editorInstance ? editorInstance.getData() : '';
            const data = {
                homeworkID: parseInt(document.getElementById('txtHomeworkId').value),
                classID: parseInt(document.getElementById('ddlClass').value),
                sectionID: parseInt(document.getElementById('ddlSection').value),
                subjectGroupID: parseInt(document.getElementById('ddlSubjectGroup').value),
                subjectID: parseInt(document.getElementById('ddlSubject').value),
                homeworkDate: document.getElementById('txtHomeworkDate').value,
                submissionDate: document.getElementById('txtSubmissionDate').value,
                maxMarks: document.getElementById('txtMaxMarks').value ? parseFloat(document.getElementById('txtMaxMarks').value) : null,
                description: description,
                isActive: document.getElementById('chkIsActive').checked
            };

            let hasError = false;
            if (!data.classID) { IV.setFieldError('ddlClass', 'errDdlClass', 'Please select a class'); hasError = true; }
            if (!data.sectionID) { IV.setFieldError('ddlSection', 'errDdlSection', 'Please select a section'); hasError = true; }
            if (!data.subjectGroupID) { IV.setFieldError('ddlSubjectGroup', 'errDdlSubjectGroup', 'Please select a subject group'); hasError = true; }
            if (!data.subjectID) { IV.setFieldError('ddlSubject', 'errDdlSubject', 'Please select a subject'); hasError = true; }
            if (!data.homeworkDate) { IV.setFieldError('txtHomeworkDate', 'errTxtHomeworkDate', 'Please select a homework date'); hasError = true; }
            if (!data.submissionDate) { IV.setFieldError('txtSubmissionDate', 'errTxtSubmissionDate', 'Please select a submission date'); hasError = true; }
            
            if (data.homeworkDate && data.submissionDate) {
                const hwDate = new Date(data.homeworkDate);
                const subDate = new Date(data.submissionDate);
                if (subDate < hwDate) {
                    IV.setFieldError('txtSubmissionDate', 'errTxtSubmissionDate', 'Submission date cannot be before homework date');
                    hasError = true;
                }
            }

            if (!description.trim() || description === '<p>&nbsp;</p>' || description === '') { 
                IV.setFieldError('txtDescription', 'errTxtDescription', 'Description is mandatory'); 
                hasError = true; 
            }

            if (hasError) return;

            const $btn = $('#btnSaveHomework');
            const originalHtml = $btn.html();
            $btn.prop('disabled', true).html('<div class="spinner-border spinner-border-sm me-1"></div> Saving...');

            try {
                const resp = await fetch('/Homework/UpsertHomework', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const res = await resp.json();
                if (res.success) {
                    location.reload();
                } else {
                    IV.setNotice('modalNotice', res.message);
                    $btn.prop('disabled', false).html(originalHtml);
                }
            } catch (err) { 
                console.error(err); 
                $btn.prop('disabled', false).html(originalHtml);
            }
        }

        async function deleteSelected() {
            if (selectedId === 0 || !confirm('Are you sure you want to delete?')) return;
            try {
                const resp = await fetch(`/Homework/DeleteHomework?id=${selectedId}`, { method: 'POST' });
                const res = await resp.json();
                if (res.success) location.reload();
                else alert(res.message);
            } catch (err) { console.error(err); }
        }

        async function toggleStatus(id, isActive) {
            try {
                const resp = await fetch(`/Homework/ToggleHomeworkStatus?id=${id}&isActive=${isActive}`, { method: 'POST' });
                const res = await resp.json();
                if (!res.success) { alert(res.message); }
                location.reload();
            } catch (err) { console.error(err); location.reload(); }
        }

        function filterTable() {
            const search = document.getElementById('txtSearch').value;
            $('#homeworkTable').DataTable().search(search).draw();
        }

        function applyStatusFilter(showActive) {
            isUpcomingTab = showActive;
            selectedId = 0;
            document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light-primary'));
            $('input[name="selectedHomework"]').prop('checked', false);
            if (permCanEdit) document.getElementById('btnEdit').disabled = true;
            if (permCanDelete) document.getElementById('btnDelete').disabled = true;

            $('#homeworkTable').DataTable().draw();
        }
    </script>
}
