@model SchoolERP.Shared.Models.HomeworkAddViewModel
@using System.Security.Claims
@using System.Text.Json

@{
    Layout = "_Layout";
    ViewData["Title"] = "Homework Management";

    // Permission loading for the view
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditHomeworks == null ? "Add Homework" : "Edit Homework")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveHomework()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        
        <a href="/Homework/Index" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<!-- End Page Header -->

<div id="pageNotice"></div>

<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <form id="homeworkForm" class="row">
                    <input type="hidden" id="txtHomeworkId" value="0">

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Class<span class="text-danger">*</span></label>
                        <select id="ddlClass" class="form-select form-control" onchange="loadSections(this.value)">
                            <option value="">Select Class</option>
                            @foreach (var c in Model.Classes)
                            {
                                <option value="@c.ClassID" selected="@(Model.EditHomeworks?.ClassID == c.ClassID)">@c.ClassName</option>
                            }
                        </select>
                        <div class="invalid-feedback" id="errDdlClass"></div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Section<span class="text-danger">*</span></label>
                        <select id="ddlSection" class="form-select form-control" onchange="loadSubjectGroups()">
                            <option value="">Select Section</option>
                        </select>
                        <div class="invalid-feedback" id="errDdlSection"></div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Subject Group<span class="text-danger">*</span></label>
                        <select id="ddlSubjectGroup" class="form-select form-control" onchange="loadSubjects(this.value)">
                            <option value="">Select Group</option>
                        </select>
                        <div class="invalid-feedback" id="errDdlSubjectGroup"></div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Subject<span class="text-danger">*</span></label>
                        <select id="ddlSubject" class="form-select form-control">
                            <option value="">Select Subject</option>
                        </select>
                        <div class="invalid-feedback" id="errDdlSubject"></div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Homework Date <span class="text-danger">*</span></label>
                        <input type="date" id="txtHomeworkDate" value="@Model.EditHomeworks?.HomeworkDate.ToString("dd-MM-yyyy")" class="form-control">
                        <div class="invalid-feedback" id="errTxtHomeworkDate"></div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label class="form-label">Submission Date <span class="text-danger">*</span></label>
                        <input type="date" id="txtSubmissionDate" value="@Model.EditHomeworks?.SubmissionDate.ToString("dd-MM-yyyy")" class="form-control">
                        <div class="invalid-feedback" id="errTxtSubmissionDate"></div>
                    </div>

                    <div class="col-md-4 mb-3">
                        <div class="mb-3">
                            <label class="form-label">Max Marks </label>
                            <input type="number" id="txtMaxMarks" value="@Model.EditHomeworks?.MaxMarks" class="form-control" step="0.01">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Attach Document</label>
                            <input type="file" id="fileAttachment" class="form-control">
                        </div>
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="chkIsActive" @(Model.EditHomeworks?.IsActive ?? true ? "checked" : "")>
                                <label class="form-check-label fw-semibold" for="chkIsActive">Active Status</label>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-8 mb-3">
                        <label class="form-label">Description<span class="text-danger">*</span></label>
                        <textarea id="txtDescription" class="form-control" rows="5">@Model.EditHomeworks?.Description</textarea>
                        <div class="invalid-feedback" id="errTxtDescription"></div>
                    </div>


                </form>
            </div>
        </div>
    </div>
</div>



@section Styles {
    <style>
        .item-row.bg-light-primary {
            background-color: rgba(13, 110, 253, 0.05);
        }

        .ck-editor__editable {
            min-height: 200px;
        }

        .dt-buttons {
            display: none !important;
        }

        #homeworkTable_filter {
            display: none;
        }
    </style>
}

@section Scripts {
    
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/assets/js/Homework.js"></script>
}
