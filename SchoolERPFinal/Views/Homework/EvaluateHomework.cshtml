@model SchoolERP.Shared.Models.HomeworkEvaluateViewModel
@using System.Security.Claims
@using System.Text.Json
@using System.Text.Encodings.Web

@{
    Layout = "_Layout";
    ViewData["Title"] = "Evaluate Homework";
    var p = Model.Permissions;
    const int MESSAGE_TRUNCATE_LENGTH = 50;
}

<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-1 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Evaluate Homework</h6>
    </div>
    <div class="d-flex gap-1">
        <div class="d-flex">
            <label class="form-label mb-1">Evaluation Date<span class="text-danger">*</span></label>
            <input type="date" id="txtEvaluationDate" class="form-control"
            value="@DateTime.Today.ToString("yyyy-MM-dd")" />
            <div class="invalid-feedback" id="errTxtEvaluationDate"></div>
        </div>
        <button class="btn btn-success top-btn" id="btnSaveEvaluation" onclick="saveEvaluation()">
            <i class="ti ti-device-floppy me-1"></i> Save
        </button>
        <a href="/Homework/Index" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>

</div>

<div class="row">

    <div class="col-xl-8 pe-md-0">
        <div class="card shadow-tbl-outer">
            <div class="card-body p-0">

                <input type="hidden" id="hdnHomeworkID" value="@Model.HomeworkID" />

                <table class="table align-middle mb-0" id="tblEvaluate">
                    <thead>
                        <tr>
                            <th>S.No</th>
                            <th style="width:22%">Student Name</th>
                            <th style="width:32%">Message</th>
                            <th style="width:20%">Uploaded Documents</th>
                            <th style="width:14%">Marks (@Model.Homeworks?.MaxMarks?.ToString("0.00"))</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.HomeworkSubmissions != null)
                        {
                            int sNo = 1;
                            foreach (var s in Model.HomeworkSubmissions)
                            {
                                
                                var rawMessage = s.Message ?? string.Empty;
                                var plainText = System.Text.RegularExpressions.Regex.Replace(rawMessage, "<.*?>", string.Empty);
                                var isMessageLong = plainText.Length > MESSAGE_TRUNCATE_LENGTH;
                                var shortMessage = isMessageLong
                                ? plainText.Substring(0, MESSAGE_TRUNCATE_LENGTH) + "..."
                                : plainText;

                                var fullMessage = Html.Raw(rawMessage);
                                var shortMessageJson = Html.Raw(shortMessage);
                                var attachments = (s.AttachmentList ?? new List<HomeworkAttachmentDto>())
                                .Where(a => !string.IsNullOrWhiteSpace(a.AttachmentName))
                                .ToList();

                                var attachmentsJson = JsonSerializer.Serialize(attachments.Select(a => new { name = a.AttachmentName, path = a.AttachmentPath }));

                                <tr class="eval-row" data-submission-id="@s.SubmissionID">
                                    <td>@sNo</td>
                                    <td>
                                        @s.FullName <span class="text-muted">(@s.AdmissionNo)</span>
                                    </td>
                                    <td>
                                        @if (isMessageLong)
                                        {
                                            <span class="msg-preview">@shortMessage</span>
                                            <a href="javascript:void(0)"
                                               class="ms-1 btn-view-message text-primary"
                                               data-student="@s.FullName"
                                               data-message="@rawMessage"
                                               title="View full message">
                                                <i class="ti ti-eye"></i>
                                            </a>
                                        }
                                        else if (string.IsNullOrWhiteSpace(rawMessage))
                                        {
                                            <span class="text-muted">No message</span>
                                        }
                                        else
                                        {
                                            <span>@fullMessage</span>
                                        }
                                    </td>
                                    <td>
                                        @if (attachments.Count == 0)
                                        {
                                            <span class="text-muted">No attachment</span>
                                        }
                                        else if (attachments.Count == 1)
                                        {
                                            <a href="@attachments[0].AttachmentPath"
                                               target="_blank"
                                               rel="noopener"
                                               class="text-primary text-decoration-none"
                                               title="View @attachments[0].AttachmentName">
                                                <i class="ti ti-eye me-1"></i>@attachments[0].AttachmentName
                                            </a>
                                        }
                                        else
                                        {
                                            <a href="javascript:void(0)"
                                               class="btn-view-docs text-primary text-decoration-none"
                                               data-student="Html.Raw(Json.Serialize(rawMessage))"
                                               data-attachments='@attachmentsJson'
                                               title="View all documents">
                                                <i class="ti ti-eye me-1"></i>@attachments.Count Documents
                                            </a>
                                        }
                                    </td>
                                    <td>
                                        <input type="number" step="0.01" min="0"
                                               class="form-control txtMarks"
                                               value="@s.MarksObtained"
                                               placeholder="Marks" />
                                    </td>
                                </tr>
                                <tr class="eval-note-row">
                                    <td></td>
                                    <td colspan="4">
                                        <textarea class="form-control txtNote" rows="2"
                                                  placeholder="Note">@s.Remark</textarea>
                                    </td>
                                </tr>
                                sNo++;
                            }
                        }
                    </tbody>
                </table>

            </div>

        </div>
    </div>

    <div class="col-xl-4 ps-md-0">
        <div class="card shadow-tbl-outer position-sticky" style="top: 70px">
            <div class="card-body">
                <h6 class="mb-2 fw-semibold">Summary</h6>
                <p class="mb-2 fs-13"><span class="text-dark">Homework Date</span> : @Model.Homeworks?.HomeworkDate.ToString("dd-MM-yyyy")</p>
                <p class="mb-2 fs-13"><span class="text-dark">Submission Date</span> : @Model.Homeworks?.SubmissionDate.ToString("dd-MM-yyyy")</p>
                <p class="mb-2 fs-13"><span class="text-dark">Evaluation Date</span> : @Model.Homeworks?.EvaluationDate?.ToString("dd-MM-yyyy")</p>
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-dark">Created By :</span> @Model.Homeworks?.CreatedByName
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-dark">Class :</span> @Model.Homeworks?.ClassName
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-dark">Section :</span> @Model.Homeworks?.SectionName
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-dark">Subject :</span> @Model.Homeworks?.SubjectName
                </li>
                <li class="list-group-item d-flex justify-content-between">
                    <span class="text-dark">Total Marks :</span> @Model.Homeworks?.MaxMarks
                </li>
            </ul>
        </div>
    </div>

</div>

<!-- Full Message Popup -->
<div class="modal fade" id="modalMessage" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title mb-0" id="modalMessageTitle">Message</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="modalMessageBody" style="white-space: pre-wrap;"></div>
        </div>
    </div>
</div>

<!-- Documents Popup -->
<div class="modal fade" id="modalDocuments" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title mb-0" id="modalDocumentsTitle">Uploaded Documents</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <ul class="list-group list-group-flush" id="modalDocumentsList"></ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
    </script>
    <script src="~/assets/js/Homeworkevaluate.js"></script>

    <script>
        (function () {
            var modalMessageEl = document.getElementById('modalMessage');
            var modalDocumentsEl = document.getElementById('modalDocuments');
            var modalMessage = new bootstrap.Modal(modalMessageEl);
            var modalDocuments = new bootstrap.Modal(modalDocumentsEl);

            document.getElementById('tblEvaluate').addEventListener('click', function (e) {
                var msgBtn = e.target.closest('.btn-view-message');
                        if (msgBtn) {
            document.getElementById('modalMessageTitle').textContent = msgBtn.getAttribute('data-student') + ' - Message';
            document.getElementById('modalMessageBody').innerHTML = msgBtn.getAttribute('data-message'); // innerHTML, not textContent
            modalMessage.show();
            return;
        }

                var docsBtn = e.target.closest('.btn-view-docs');
                if (docsBtn) {
                    var studentName = docsBtn.getAttribute('data-student');
                    var attachments = [];
                    try {
                        attachments = JSON.parse(docsBtn.getAttribute('data-attachments') || '[]');
                    } catch (err) {
                        attachments = [];
                    }

                    document.getElementById('modalDocumentsTitle').textContent = studentName + ' - Documents';

                    var listEl = document.getElementById('modalDocumentsList');
                    listEl.innerHTML = '';

                    attachments.forEach(function (a) {
                        var li = document.createElement('li');
                        li.className = 'list-group-item d-flex align-items-center justify-content-between';

                        var nameSpan = document.createElement('span');
                        nameSpan.className = 'text-truncate me-2';
                        nameSpan.textContent = a.name;
                        li.appendChild(nameSpan);

                        var actions = document.createElement('div');
                        actions.className = 'flex-shrink-0';

                        var viewLink = document.createElement('a');
                        viewLink.href = a.path;
                        viewLink.target = '_blank';
                        viewLink.rel = 'noopener';
                        viewLink.className = 'me-2 text-primary';
                        viewLink.title = 'View';
                        viewLink.innerHTML = '<i class="ti ti-eye"></i>';
                        actions.appendChild(viewLink);

                        var downloadLink = document.createElement('a');
                        downloadLink.href = a.path;
                        downloadLink.setAttribute('download', '');
                        downloadLink.className = 'text-primary';
                        downloadLink.title = 'Download';
                        downloadLink.innerHTML = '<i class="ti ti-download"></i>';
                        actions.appendChild(downloadLink);

                        li.appendChild(actions);
                        listEl.appendChild(li);
                    });

                    modalDocuments.show();
                }
            });
        })();
    </script>
}
