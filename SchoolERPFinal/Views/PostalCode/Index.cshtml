@model SchoolERP.Shared.Models.PostalCodePageViewModel
@using System.Security.Claims
@using System.Text.Json
@{
    Layout = "_Layout";
    ViewData["Title"] = "Postal Code";
    int totalPages = Model.PageSize > 0
                   ? (int)Math.Ceiling((double)Model.TotalRecords / Model.PageSize)
                   : 0;
    var p = Model.Permissions;
}

<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-1 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Postal Code</h6>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-1">
        @if (p.CanAdd)
        {
            <a href="/PostalCode/Add" class="btn btn-primary top-btn" id="btnAddPostalCode">
                <i class="ti ti-plus me-1"></i>Add
            </a>
        }
        @if (p.CanEdit)
        {
            <button id="btnEdit" class="btn btn-info top-btn" disabled onclick="editSelected()">
                <i class="ti ti-pencil me-1"></i>Edit
            </button>
        }
        @if (p.CanDelete)
        {
            <button id="btnDelete" class="btn btn-danger top-btn" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i>Delete
            </button>
        }
        @if (p.CanEdit)
        {
            <button id="btnActive" class="btn btn-success top-btn" disabled onclick="toggleStatus(0,true)">
                <i class="ti ti-circle-check"></i> Active
            </button>
            <button id="btnInactive" class="btn btn-danger top-btn" disabled onclick="toggleStatus(0,false)">
                <i class="ti ti-circle-x"></i> Inactive
            </button>
        }
        @if (p.CanPrint)
        {
            <button class="btn btn-secondary top-btn" onclick="triggerExport(4)">
                <i class="ti ti-printer me-1"></i>Print
            </button>
        }
        @if (p.CanExport)
        {
            <div class="dropdown d-inline-flex">
                <button class="btn btn-warning dropdown-toggle top-btn" type="button" data-bs-toggle="dropdown">
                    <i class="ti ti-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(0)"><i class="ti ti-copy me-1"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(1)"><i class="ti ti-file-text me-1"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(2)"><i class="ti ti-file-spreadsheet me-1"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(3)"><i class="ti ti-file-description me-1"></i>PDF</a></li>
                </ul>
            </div>
        }
    </div>
</div>

<div id="classPageNotice"></div>

<div class="row">
    <div class="col-xl-12">
        <div class="card mb-2 shadow-tbl-outer">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text" name="search" id="txtSearchInput" value="@Model.SearchTerm"
                               class="form-control border-0 ps-2" placeholder="Search by postal code..."
                               style="min-width: 320px;" />
                    </div>

                    <form method="get" asp-action="Index" id="frmSearch" style="display:none;">
                        <input type="hidden" name="pageIndex" id="hdnPageIndex" value="1" />
                        <input type="hidden" name="search" id="hdnSearch" value="@Model.SearchTerm" />
                        <input type="hidden" name="companyId" id="hdnCompanyId" value="@Model.CompanyId" />
                        <input type="hidden" name="countryId" id="hdnCountryId" value="@Model.CountryId" />
                        <input type="hidden" name="stateId" id="hdnStateId" value="@Model.StateId" />
                        <input type="hidden" name="cityId" id="hdnCityId" value="@Model.CityId" />
                        <input type="hidden" name="pageSize" id="hdnPageSize" value="@Model.PageSize" />
                    </form>

                    <div class="dropdown">
                        <a href="#" id="btnFilterToggle"
                           class="btn btn-white border rounded btn-md text-dark fs-14 align-items-center d-flex fw-normal"
                           data-bs-toggle="dropdown" data-bs-auto-close="outside">
                            <i class="ti ti-filter text-gray-5 me-1"></i>Filters
                        </a>

                        <div class="dropdown-menu dropdown-lg dropdown-menu-end filter-dropdown p-0 shadow-tbl" id="filter-dropdown">
                            <div class="d-flex align-items-center justify-content-between border-bottom filter-header">
                                <h6 class="mb-0 fw-bold">Select Criteria</h6>
                                <div class="d-flex align-items-center justify-content-end">
                                    <button type="button" class="btn btn-light btn-md me-2 fw-medium" onclick="resetAllFilters()">Reset</button>
                                    <button type="button" class="btn text-primary fs-6 fw-medium" id="btnApplyFilters">Filter</button>
                                </div>
                            </div>

                            <div class="filter-body pb-0">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Company</label>
                                        <select class="form-select form-control select2" id="ddlFilterCompany" data-placeholder="Select company">
                                            <option value="">All</option>
                                            @foreach (var c in Model.Companies ?? new List<MstCompanyViewModel>())
                                            {
                                                <option value="@c.CompanyId" selected="@(Model.CompanyId == c.CompanyId)">@c.SchoolName</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <!-- Country drives State, State drives City below -->
                                        <label class="form-label mb-1">Country</label>
                                        <select class="form-select form-control select2" id="ddlFilterCountry" data-placeholder="Select country">
                                            <option value="">All</option>
                                            @foreach (var ut in Model.Country)
                                            {
                                                <option value="@ut.CountryId" selected="@(Model.CountryId == ut.CountryId)">@ut.CountryName</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">State</label>
                                        <select class="form-select form-control select2" id="ddlFilterState" data-placeholder="Select state">
                                            <option value="">All</option>
                                            @foreach (var ut in Model.State)
                                            {
                                                <option value="@ut.StateId" selected="@(Model.StateId == ut.StateId)">@ut.StateName</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">City</label>
                                        <select class="form-select form-control select2" id="ddlFilterCity" data-placeholder="Select city">
                                            <option value="">All</option>
                                            @foreach (var ut in Model.City)
                                            {
                                                <option value="@ut.CityId" selected="@(Model.CityId == ut.CityId)">@ut.CityName</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-12" id="activeFilterBadges" style="display: none;">
        <div class="card shadow-tbl border-0 py-2 mb-2">
            <div class="card-body p-2 d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold ms-2 me-2"><i class="ti ti-filter-check me-1"></i>Active Filters:</span>
                <div id="badgeContainer" class="d-flex flex-wrap gap-2"></div>
                <button class="btn btn-sm btn-link text-danger p-0 ms-auto me-2 fw-bold text-decoration-none" onclick="resetAllFilters()">
                    <i class="ti ti-trash me-1"></i>Clear All
                </button>
            </div>
        </div>
    </div>

    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table" id="tblPostalCode">
                        <thead>
                            <tr class="bg-light">
                                <th class="ps-4" style="width: 50px;">Select</th>
                                <th>Postal Code</th>
                                <th>City Name</th>
                                <th>State Name</th>
                                <th>Country Name</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.PostalCode != null && Model.PostalCode.Any())
                            {
                                @foreach (var c in Model.PostalCode)
                                {
                                    <tr class="item-row" onclick="selectItem(@c.PostalCodeId, this)" style="cursor: pointer;">
                                        <td class="ps-4 text-center">
                                            <input type="checkbox" name="selectedPostalCode" class="form-check-input student-checkbox"
                                                   onclick="event.stopPropagation(); selectItem(@c.PostalCodeId, this)" value="@c.PostalCodeId">
                                        </td>
                                        <td>@c.PostalCode</td>
                                        <td>@c.CityName</td>
                                        <td>@c.StateName</td>
                                        <td>@c.CountryName</td>
                                        <td>
                                            @if (p.CanEdit)
                                            {
                                                <div class="form-check form-switch" onclick="event.stopPropagation()">
                                                    <input class="form-check-input class-status-switch" type="checkbox"
                                                    @(c.IsActive ? "checked" : "")
                                                           onchange="toggleStatus(@c.PostalCodeId, this.checked)">
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="badge @(c.IsActive ? "bg-success" : "bg-secondary")">@(c.IsActive ? "Active" : "Inactive")</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4"><span class="text-muted">No records found.</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @if (totalPages > 1)
                    {
                        <div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2 mb-3">
                            <div class="text-muted small">
                                Showing <strong>@(((Model.PageNumber - 1) * Model.PageSize) + 1)</strong>
                                – <strong>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalRecords))</strong>
                                of <strong>@Model.TotalRecords</strong> records
                            </div>
                            <nav aria-label="PostalCode pagination">
                                <ul class="pagination pagination-sm mb-0">
                                    <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                                        <a class="page-link" href="?pageIndex=1&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&countryId=@Model.CountryId&stateId=@Model.StateId&cityId=@Model.CityId"><i class="ti ti-chevrons-left"></i></a>
                                    </li>
                                    <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                                        <a class="page-link" href="?pageIndex=@(Model.PageNumber - 1)&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&countryId=@Model.CountryId&stateId=@Model.StateId&cityId=@Model.CityId"><i class="ti ti-chevron-left"></i></a>
                                    </li>
                                    @{
                                        int start = Math.Max(1, Model.PageNumber - 2);
                                        int end = Math.Min(totalPages, start + 4);
                                        start = Math.Max(1, end - 4);
                                    }
                                    @for (int pg = start; pg <= end; pg++)
                                    {
                                        <li class="page-item @(pg == Model.PageNumber ? "active" : "")">
                                            <a class="page-link" href="?pageIndex=@pg&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&countryId=@Model.CountryId&stateId=@Model.StateId&cityId=@Model.CityId">@pg</a>
                                        </li>
                                    }
                                    <li class="page-item @(Model.PageNumber >= totalPages ? "disabled" : "")">
                                        <a class="page-link" href="?pageIndex=@(Model.PageNumber + 1)&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&countryId=@Model.CountryId&stateId=@Model.StateId&cityId=@Model.CityId"><i class="ti ti-chevron-right"></i></a>
                                    </li>
                                    <li class="page-item @(Model.PageNumber >= totalPages ? "disabled" : "")">
                                        <a class="page-link" href="?pageIndex=@totalPages&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&countryId=@Model.CountryId&stateId=@Model.StateId&cityId=@Model.CityId"><i class="ti ti-chevrons-right"></i></a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .dt-buttons { display: none !important; }

        .select2-container--default .select2-selection--multiple {
            border: 1px solid #ced4da;
            border-radius: 0.375rem;
            min-height: 38px;
            padding: 2px 5px;
        }

        .select2-container--default.select2-container--focus .select2-selection--multiple {
            border-color: #86b7fe;
            outline: 0;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
        }

        .select2-container { width: 100% !important; }
        .select2-dropdown { z-index: 1060; }
    </style>
}

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>
    <script src="~/assets/js/PostalCode.js"></script>
}
