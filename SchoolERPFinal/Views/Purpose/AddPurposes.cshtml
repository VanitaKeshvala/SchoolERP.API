@model SchoolERP.Shared.Models.PurposesAddPageViewModel
@using System.Security.Claims
@using System.Text.Json
@{
    ViewData["Title"] = "Purpose";

    // Permission loading for the view
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;

}
<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditPurposes == null ? "Add Purpose" : "Edit Purpose")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button type="submit" onclick="saveRecord()" class="btn btn-success top-btn">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Purpose/Index" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<form id="callLogForm">

    <div class="row">
        <div class="col-xl-12">
            <div class="card shadow-tbl-outer">
                <div class="card-body">
                    <input type="hidden" id="recordId" value="@Model.EditPurposes?.PurposeID">
                    <div class="row row-gap-3">
                        <div class="col-md-12">
                            <label class="form-label" id="nameLabel">Purpose <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtName" value="@Model.EditPurposes?.Name" placeholder="Enter name">
                            <div class="text-danger small mt-1 d-none" id="nameError">Name is required.</div>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" id="txtDescription" rows="3" placeholder="Enter description">@Model.EditPurposes?.Description</textarea>
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="chkIsActive" @(Model.EditPurposes?.IsActive ?? true ? "checked" : "")>
                                <label class="form-check-label" for="chkIsActive">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>


@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/assets/js/Purposes.js"></script>
}
