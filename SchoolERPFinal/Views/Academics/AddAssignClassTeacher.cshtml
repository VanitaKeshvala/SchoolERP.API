@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.AssignClassTeacherAddViewModel
@{
    ViewData["Title"] = "Add Hostel";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditAssignments == false ? "Add Hostel" : "Edit Hostel")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveAssignment()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Academics/AssignClassTeacher" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <input type="hidden" id="txtOriginalClassId" value="0">
                <input type="hidden" id="txtOriginalSectionId" value="0">
                <div class="row row-gap-3">
                    <div class="col-md-6">
                        <label class="form-label">Class <span class="text-danger">*</span></label>
                        <select id="modalClassID" class="form-select form-control" onchange="onClassChange()">
                            <option value="">Select</option>
                            @if (Model.Classes != null)
                            {
                                @foreach (var item in Model.Classes)
                                {
                                    <option value="@item.ClassID">@item.ClassName</option>
                                }
                            }

                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Section <span class="text-danger">*</span></label>
                        <select id="modalSectionID" class="form-select form-control">
                            <option value="">Select</option>
                        </select>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label">Class Teacher <span class="text-danger">*</span></label>
                        <select class="form-control" id="choices-multiple-remove-button" multiple>
                            @if (Model.Staff != null)
                            {
                                @foreach (var s in Model.Staff)
                                {
                                    <option value="@s.StaffID">@s.FirstName @s.LastName (@s.StaffCode)</option>
                                }
                            }

                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
        //window.initSelect2('#choices-multiple-remove-button',{ placeholder: "Select Room Type" });
         
                // ── Read all params from URL ──────────────────────────────────────────
        // URL: /Academics/AddAssignClassTeacher/5?sectionId=3&staffIds=10,11,12
        function getUrlParams() {
            const params  = new URLSearchParams(window.location.search);
            const segments = window.location.pathname.split('/').filter(Boolean);

            // classId — from route segment (last part of path)
            const lastSegment = segments[segments.length - 1];
            const classId = parseInt(lastSegment, 10) > 0
                            ? parseInt(lastSegment, 10)
                            : parseInt(params.get('classId') || '0', 10);

            // sectionId — from querystring
            const sectionId = parseInt(params.get('sectionId') || '0', 10);

            // staffIds — comma-separated → array of integers
            const staffRaw  = params.get('staffIds') || '';
            const staffIds  = staffRaw
                                ? staffRaw.split(',')
                                          .map(s => parseInt(s.trim(), 10))
                                          .filter(n => !isNaN(n) && n > 0)
                                : [];

            return { classId, sectionId, staffIds };
        }

        // ── Auto-load on page ready ───────────────────────────────────────
        document.addEventListener('DOMContentLoaded', async function () {



              // Initialize Choices manually
            const element = document.querySelector('#choices-multiple-remove-button');
            if (element) {
                teacherChoices = new Choices(element, {
                    removeItemButton: true,
                    placeholderValue: 'Select Teachers',
                    searchPlaceholderValue: 'Search teachers...'
                });
            }
                const { classId, sectionId, staffIds } = getUrlParams();

        // Only call editSelected if classId exists (edit mode)
        if (classId > 0) {
            await editSelected(classId, sectionId, staffIds);
        }
        });


               async function editSelected(classId, sectionId, staffIds) {
            try {
                if (!classId || classId <= 0) return;

                // ── Set Class dropdown ────────────────────────────────────────
                const classSelect = document.getElementById('modalClassID');
                if (classSelect) {
                    classSelect.value = classId;
                    $('#txtOriginalClassId').val(classId);
                }

              

                // ── Load Sections for this class, then set sectionId ──────────
                await new Promise((resolve) => {
                    $.get(`/Academics/GetSectionsByClass/${classId}`, function (res) {
                        if (res.success) {
                            const sectionSelect = $('#modalSectionID');
                            sectionSelect.empty().append('<option value="">Select</option>');

                            res.data.forEach(s => {
                                sectionSelect.append(
                                    `<option value="${s.sectionID}">${s.sectionName}</option>`
                                );
                            });

                            // Set sectionId if provided
                            if (sectionId > 0) {
                                sectionSelect.val(sectionId);
                                $('#txtOriginalSectionId').val(sectionId);
                            }
                        }
                        resolve();
                    });
                });

                // ── Set Staff (Choices.js multi-select) ───────────────────────
                if (staffIds && staffIds.length > 0 && typeof teacherChoices !== 'undefined') {
                    teacherChoices.removeActiveItems();
                    teacherChoices.setChoiceByValue(staffIds.map(String));
                }

                // ── Update page heading ───────────────────────────────────────
                const titleEl = document.getElementById('modalTitle');
                if (titleEl) titleEl.textContent = 'Edit Class Teacher Assignment';

            } catch (err) {
                console.error('editSelected error:', err);
                showToast('Failed to load assignment details. Please try again.', 'error');
            }
        }
         function saveAssignment() {
            const classId = $('#modalClassID').val();
            const sectionId = $('#modalSectionID').val();
            const staffIds = teacherChoices.getValue(true);

            const originalClassId = parseInt($('#txtOriginalClassId').val());
            const originalSectionId = parseInt($('#txtOriginalSectionId').val());

            if (!classId || !sectionId || !staffIds || staffIds.length === 0) {
                alert('Please fill all required fields (Class, Section, and at least one Teacher).');
                return;
            }

            const data = {
                ClassID: parseInt(classId),
                SectionID: parseInt(sectionId),
                StaffIDs: staffIds.map(Number)
            };

            const performSave = async () => {              

                            try {

                            const r = await fetch('/Academics/SaveClassTeacher', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(data)
                            })
                            const res = await r.json();
                            if (res.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Saved!',
                                    text: 'Hostel has been added successfully.',
                                    confirmButtonText: 'OK',
                                    customClass: { confirmButton: 'btn btn-success' },
                                    buttonsStyling: false
                                }).then(() => {
                                    window.location.href = '/Academics/AssignClassTeacher';
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error',
                                    text: res.message || 'Failed to save hostel.',
                                    confirmButtonText: 'OK',
                                    customClass: { confirmButton: 'btn btn-danger' },
                                    buttonsStyling: false
                                });
                            }

                        } catch (err) {
                            console.error(err);
                            IV.setNotice('classModalNotice', 'Could not save hostel.');
                    }
            };

            // If Class or Section changed, delete the old assignment first
            if (originalClassId > 0 && originalSectionId > 0 && (originalClassId !== parseInt(classId) || originalSectionId !== parseInt(sectionId))) {
                $.ajax({
                    url: `/Academics/DeleteClassTeacherByClassSection?classId=${originalClassId}&sectionId=${originalSectionId}`,
                    type: 'POST',
                    success: function (res) {
                        if (res.success) {
                            performSave();
                        } else {
                            alert('Failed to update old assignment: ' + res.message);
                        }
                    }
                });
            } else {
                performSave();
            }
        }

        function onClassChange() {
            const classId = $('#modalClassID').val();
            const sectionSelect = $('#modalSectionID');
            sectionSelect.empty().append('<option value="">Select</option>');

            if (classId) {
                $.get('/Academics/GetSectionsByClass/' + classId, function (res) {
                    if (res.success) {
                        res.data.forEach(s => {
                            sectionSelect.append(`<option value="${s.sectionID}">${s.sectionName}</option>`);
                        });
                    }
                });
            }
        }
    </script>
}