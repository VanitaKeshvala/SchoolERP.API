@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.MstSubjectGroupAddViewModel
@{
    ViewData["Title"] = "Add Subject Group Management";
    var p = Model.Permissions;
    var selectedIds = Model.EditSubjectGroups?.SectionIds?
        .Split(',')
        .Select(x => x.Trim())
        .ToList() ?? new List<string>();

    var selectedSubjectIds = Model.EditSubjectGroups?.SubjectIds?
    .Split(',')
    .Select(x => x.Trim())
    .ToList() ?? new List<string>();
}

<style>
    .dt-buttons {
        display: none !important;
    }

    .is-invalid + .select2-container .select2-selection {
        border-color: #dc3545 !important;
    }

    .is-invalid ~ .invalid-feedback {
        display: block !important;
    }
</style>

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditSubjectGroups == null ? "Add Subject Group" : "Edit Subject Group")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveItem()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Academics/SubjectGroup" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">

            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <input type="hidden" id="txtItemId" value="@(Model.EditSubjectGroups?.SubjectGroupID ?? 0)">
                    <input type="hidden" id="hdnUserID" value="@(Model.EditSubjectGroups?.CreatedBy ?? 0)">

                    @* <input type="hidden" id="txtItemId" value="0"> *@
                    <div class="row row-gap-3">
                        <div class="col-md-8">
                            <label class="form-label">Name <span class="text-danger">*</span></label>
                            <input type="text" id="txtName" value="@Model.EditSubjectGroups?.Name" class="form-control" placeholder="Group Name" autocomplete="off">
                            <div class="invalid-feedback" id="errTxtName"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Class <span class="text-danger">*</span></label>
                            <select id="ddlClass" class="form-select form-control" onchange="loadSectionsByClass(this.value, 'ddlSections')">
                                <option value="">Select Class</option>
                                @if (Model.Classes != null)
                                {
                                    @foreach (var c in Model.Classes)
                                    {
                                        <option value="@c.ClassID" selected="@(c.ClassID == Model.EditSubjectGroups?.ClassID)">@c.ClassName</option>
                                    }
                                }

                            </select>
                            <div class="invalid-feedback" id="errDdlClass"></div>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Section <span class="text-danger">*</span></label>
                            <select id="ddlSections" class="form-select form-control select2" multiple data-placeholder="Select Sections">
                                @* Sections populated dynamically based on class *@
                            </select>
                            <div class="invalid-feedback" id="errDdlSections"></div>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Subjects <span class="text-danger">*</span></label>
                            <select id="ddlSubjects" class="form-select form-control select2" multiple data-placeholder="Select Subjects">
                                @if (Model.Subjects != null)
                                {
                                    @foreach (var sub in Model.Subjects)
                                    {
                                        bool isSelected = selectedSubjectIds.Contains(sub.SubjectID.ToString());
                                        if (isSelected)
                                        {
                                            <option value="@sub.SubjectID" selected="selected">@sub.SubjectName</option>
                                        }
                                        else
                                        {
                                            <option value="@sub.SubjectID">@sub.SubjectName</option>
                                        }
                                        @* <option value="@sub.SubjectID" selected="@(Model.EditSubjectGroups?.SubjectIds?.Contains(sub.SubjectID) == true)">@sub.SubjectName</option> *@
                                    }
                                }

                            </select>
                            <div class="invalid-feedback" id="errDdlSubjects"></div>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Description</label>
                            <textarea id="txtDescription" class="form-control" rows="2">@Model.EditSubjectGroups?.Description</textarea>
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="isActive" @(Model.EditSubjectGroups?.IsActive == true ? "checked" : "")>
                                <label class="form-check-label" for="isActive">Active Status</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<link href="~/assets/css/select2.min.css" rel="stylesheet" />

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
        window.allSections = @Html.Raw(JsonSerializer.Serialize(Model.Sections));
        const editClassId = @(Model.EditSubjectGroups?.ClassID ?? 0);

        window.editSectionIds =@(Model.EditSubjectGroups?.SectionIds);
    </script>

    <script src="~/assets/js/SubjectGroup.js"></script>
}