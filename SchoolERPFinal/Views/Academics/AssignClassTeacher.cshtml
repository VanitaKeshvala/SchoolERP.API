@model SchoolERP.Shared.Models.AssignClassTeacherPageViewModel
@using System.Security.Claims
@using System.Text.Json
@{
    ViewData["Title"] = "Class Teachers";
    var currentUserId = int.TryParse(User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? User.FindFirst("UserId")?.Value, out var id) ? id : 0;

    var p = Model.Permissions;
    var groupedAssignments = (Model.Assignments ?? new List<ClassTeacherViewModel>())
    .Where(a => a != null)
    .GroupBy(a => new
    {
        ClassID = a.ClassID,
        ClassName = a.ClassName ?? string.Empty,
        SectionID = a.SectionID,
        SectionName = a.SectionName ?? string.Empty
    })
    .Select(g => new
    {
        g.Key.ClassID,
        g.Key.ClassName,
        g.Key.SectionID,
        g.Key.SectionName,
        Teachers = string.Join(", ", g
                    .Where(t => t != null && !string.IsNullOrWhiteSpace(t.StaffName))
                    .Select(t => t.StaffName)),
        StaffIDs = g
                    .Where(t => t != null && t.StaffID > 0)
                    .Select(t => t.StaffID)
                    .ToList()
    })
    .ToList();

    int totalPages = Model.PageSize > 0
               ? (int)Math.Ceiling((double)Model.TotalRecords / Model.PageSize)
               : 0;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Class Teachers</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <a href="/Academics/AddAssignClassTeacher" class="btn btn-primary top-btn"><i class="ti ti-plus me-1"></i> Add</a>
        }
        @if (p.CanEdit)
        {
            <button id="btnEdit" class="btn btn-info top-btn" disabled onclick="editSelected()"><i class="ti ti-pencil me-1"></i>Edit</button>
        }
        @if (p.CanDelete)
        {
            <button id="btnDelete" class="btn btn-danger top-btn" disabled onclick="deleteSelected()"><i class="ti ti-trash me-1"></i>Delete</button>
        }
        @if (p.CanPrint)
        {
            <button class="btn btn-secondary d-inline-flex align-items-center top-btn" onclick="triggerExport(4)">
                <i class="ti ti-printer me-1"></i>Print
            </button>
        }
        @if (p.CanExport)
        {
            <div class="dropdown d-inline-flex">
                <button class="btn btn-warning dropdown-toggle top-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(0)"><i class="ti ti-copy me-1"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(1)"><i class="ti ti-file-text me-1"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(2)"><i class="ti ti-file-spreadsheet me-1"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(3)"><i class="ti ti-file-description me-1"></i>PDF</a></li>
                </ul>
            </div>
        }
    </div>
</div>

<!-- start row -->
<div class="row">
    <div class="col-xl-12">
        <div class="card mb-2 shadow-tbl-outer">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">

                    <!-- ── Search box (name="search" so form submits it) ── -->
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text"
                               name="search"
                               id="txtSearchInput"
                               value="@Model.SearchTerm"
                               class="form-control border-0 ps-2"
                               placeholder="Search by class, section..."
                               style="min-width: 320px;" />
                    </div>

                    <!-- Hidden form for filter submission — outside Bootstrap dropdown -->
                    <form method="get" asp-action="AssignClassTeacher" id="frmSearch" style="display:none;">
                        <input type="hidden" name="pageIndex" id="hdnPageIndex" value="1" />
                        <input type="hidden" name="search" id="hdnSearch" value="@Model.SearchTerm" />
                        <input type="hidden" name="sessionID" id="hdnSessionID" value="" />
                        <input type="hidden" name="companyId" id="hdnCompanyId" value="" />
                        <input type="hidden" name="sectionID" id="hdnSectionID" value="" />
                        <input type="hidden" name="classId" id="hdnClassID" value="" />
                        <input type="hidden" name="staffID" id="hdnStaffID" value="" />
                        <input type="hidden" name="pageSize" id="hdnPageSize" value="@Model.PageSize" />
                    </form>

                    <div class="dropdown">
                        <a href="#" id="btnFilterToggle"
                           class="btn btn-white border rounded btn-md text-dark fs-14 align-items-center d-flex fw-normal"
                           data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            <i class="ti ti-filter text-gray-5 me-1"></i>Filters
                        </a>

                        <div class="dropdown-menu dropdown-lg dropdown-menu-end filter-dropdown p-0 shadow-tbl"
                             id="filter-dropdown">

                            <div class="d-flex align-items-center justify-content-between border-bottom filter-header">
                                <h6 class="mb-0 fw-bold">Select Criteria</h6>
                                <div class="d-flex align-items-center justify-content-end">
                                    <button type="button" class="btn btn-light btn-md me-2 fw-medium" onclick="resetAllFilters()" id="btnResetFilters">Reset</button>
                                    <button type="button" class="btn text-primary fs-6 fw-medium" id="btnApplyFilters">Filter</button>
                                </div>
                            </div>

                            <div class="filter-body pb-0">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Session</label>
                                        <select class="form-select form-control select2"
                                                id="ddlFilterSessions"
                                                data-placeholder="Select session">
                                            <option value="">All</option>
                                            @foreach (var ut in Model.Sessions)
                                            {
                                                <option value="@ut.SessionId" selected="@(Model.SessionId == ut.SessionId)">
                                                    @ut.SessionTitle
                                                </option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Company</label>
                                        <select class="form-select form-control select2"
                                                id="ddlFilterCompany"
                                                data-placeholder="Select company">
                                            <option value="">All</option>
                                            @foreach (var c in Model.Companies ?? new List<MstCompanyViewModel>())
                                            {
                                                <option value="@c.CompanyId" selected="@(Model.CompanyId == c.CompanyId)">
                                                    @c.SchoolName
                                                </option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Class <span class="text-danger">*</span></label>
                                        <select id="ddlFilterClassID" class="form-select form-control" onchange="onClassChange()">
                                            <option value="">Select</option>
                                            @if (Model.Classes != null)
                                            {
                                                @foreach (var item in Model.Classes)
                                                {
                                                    <option value="@item.ClassID">@item.ClassName</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Section <span class="text-danger">*</span></label>
                                        <select id="ddlFilterSectionID" class="form-select form-control">
                                            <option value="">Select</option>
                                        </select>
                                    </div>
                                    @* <div class="col-md-12">
                                        <label class="form-label">Class Teacher <span class="text-danger">*</span></label>
                                        <select class="form-control" id="ddlFilterStaff" multiple>
                                            @if (Model.Staff != null)
                                            {
                                                @foreach (var s in Model.Staff)
                                                {
                                                    <option value="@s.StaffID">@s.FirstName @s.LastName (@s.StaffCode)</option>
                                                }
                                            }

                                        </select>
                                    </div> *@
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- Active filter badges -->
    <div class="col-xl-12" id="activeFilterBadges" style="display: none;">
        <div class="card shadow-tbl border-0 py-2 mb-2">
            <div class="card-body p-2 d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold ms-2 me-2">
                    <i class="ti ti-filter-check me-1"></i>Active Filters:
                </span>
                <div id="badgeContainer" class="d-flex flex-wrap gap-2"></div>
                <button class="btn btn-sm btn-link text-danger p-0 ms-auto me-2 fw-bold text-decoration-none"
                        id="btnResetAllFilters" onclick="resetAllFilters()">
                    <i class="ti ti-trash me-1"></i>Clear All
                </button>
            </div>
        </div>
    </div>


    <div class="col-xl-12">
        <div class="card overflow-auto shadow-tbl">
            <div class="card-body p-0 overflow-auto">
                <div class="table-responsive">
                    <table class="table table-nowrap mb-0" id="assignmentsTable">
                        <thead>
                            <tr>
                                <th style="width: 50px;">Select</th>
                                <th>Class</th>
                                <th>Section</th>
                                <th>Class Teacher</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (groupedAssignments.Any())
                            {
                                foreach (var item in groupedAssignments)
                                {
                                    <tr class="item-row" style="cursor: pointer;" onclick="selectItem(this)"
                                        data-class-id="@item.ClassID"
                                        data-section-id="@item.SectionID"
                                        data-staff-ids='@Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(item.StaffIDs))'>
                                        <td>
                                            <input type="checkbox"
                                                   class="form-check-input student-checkbox"
                                                   data-class-id="@item.ClassID"
                                                   data-section-id="@item.SectionID">

                                        </td>
                                        <td>@item.ClassName</td>
                                        <td>@item.SectionName</td>
                                        <td>@item.Teachers</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center">No assignments found</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <!-- ── Pagination ─────────────────────────────────────────────── -->
                    @if (totalPages > 1)
                    {
                        <div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2 mb-3">
                            <!-- Record info -->
                            <div class="text-muted small">
                                Showing
                                <strong>@(((Model.PageNumber - 1) * Model.PageSize) + 1)</strong>
                                –
                                <strong>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalRecords))</strong>
                                of
                                <strong>@Model.TotalRecords</strong> users
                            </div>

                            <nav aria-label="Subject pagination">
                                <ul class="pagination pagination-sm mb-0">

                                    <!-- First -->
                                    <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                                        <a class="page-link"
                                           href="?pageIndex=1&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&sessionID=@Model.SessionId">
                                            <i class="ti ti-chevrons-left"></i>
                                        </a>
                                    </li>

                                    <!-- Prev -->
                                    <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                                        <a class="page-link"
                                           href="?pageIndex=@(Model.PageNumber - 1)&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&sessionID=@Model.SessionId">
                                            <i class="ti ti-chevron-left"></i>
                                        </a>
                                    </li>

                                    <!-- Page numbers — show 5 around current -->
                                    @{
                                        int start = Math.Max(1, Model.PageNumber - 2);
                                        int end = Math.Min(totalPages, start + 4);
                                        start = Math.Max(1, end - 4);
                                    }
                                    @for (int pg = start; pg <= end; pg++)
                                    {
                                        <li class="page-item @(pg == Model.PageNumber ? "active" : "")">
                                            <a class="page-link"
                                               href="?pageIndex=@pg&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&sessionID=@Model.SessionId">@pg</a>
                                        </li>
                                    }

                                    <!-- Next -->
                                    <li class="page-item @(Model.PageNumber >= totalPages ? "disabled" : "")">
                                        <a class="page-link"
                                           href="?pageIndex=@(Model.PageNumber + 1)&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&sessionID=@Model.SessionId">
                                            <i class="ti ti-chevron-right"></i>
                                        </a>
                                    </li>

                                    <!-- Last -->
                                    <li class="page-item @(Model.PageNumber >= totalPages ? "disabled" : "")">
                                        <a class="page-link"
                                           href="?pageIndex=@totalPages&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&sessionID=@Model.SessionId">
                                            <i class="ti ti-chevrons-right"></i>
                                        </a>
                                    </li>

                                </ul>
                            </nav>

                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>


@section Styles {
    <style>
        .dt-buttons {
            display: none !important;
        }
    </style>
}

@section Scripts {
    <script>

         function onClassChange() {
            const classId = $('#ddlFilterClassID').val();
            const filterSelect =$("#ddlFilterSectionID");
            filterSelect.empty().append('<option value="">Select</option>');

            if (classId) {
                $.get('/Academics/GetSectionsByClass/' + classId, function (res) {
                    if (res.success) {
                        res.data.forEach(s => {
                            filterSelect.append(`<option value="${s.sectionID}">${s.sectionName}</option>`);
                        });
                    }
                });
            }
        }

        function triggerExport(index) {
            if ($.fn.DataTable.isDataTable('#assignmentsTable')) {
                const table = $('#assignmentsTable').DataTable();
                table.button(index).trigger();
            }
        }
        // ========================================
        // Filter badges — sessionStorage persistence
        // ========================================
        const FILTER_KEY = 'appliedFilters_assignments';
        let appliedFilters = {};
        try {
            const stored = sessionStorage.getItem(FILTER_KEY);
            if (stored) appliedFilters = JSON.parse(stored);
        } catch (e) { appliedFilters = {}; }

        function saveAppliedFilters() {
            try { sessionStorage.setItem(FILTER_KEY, JSON.stringify(appliedFilters)); }
            catch (e) { console.warn('sessionStorage unavailable'); }
        }

        function clearAppliedFilters() {
            appliedFilters = {};
            try { sessionStorage.removeItem(FILTER_KEY); } catch (e) { }
        }

        function submitForm() {
            // Sync hidden form fields from dropdowns before submit
            const sessionEl = document.getElementById('ddlFilterSessions');
            const companyEl = document.getElementById('ddlFilterCompany');
            const sectionEl = document.getElementById('ddlFilterSection');
            const classEl = document.getElementById('ddlFilterClassID');
            const sectionID = document.getElementById('ddlFilterSectionID');
            if (sessionEl) document.getElementById('hdnSessionID').value = sessionEl.value;
            if (companyEl) document.getElementById('hdnCompanyId').value = companyEl.value;
            if (sectionEl) document.getElementById('hdnSectionID').value = sectionEl.value;
            if (classEl) document.getElementById('hdnClassID').value = classEl.value;
            if (sectionID) document.getElementById('hdnStaffID').value = classEl.value;
            document.getElementById('frmSearch').submit();
        }

        function applyFilters() {
            const sessionEl = document.getElementById('ddlFilterSessions');
            const companyEl = document.getElementById('ddlFilterCompany');
            const sectionEl = document.getElementById('ddlFilterSection');
            const classEl = document.getElementById('ddlFilterClassID');
            const sectionID = document.getElementById('ddlFilterSectionID');
            const searchEl = document.getElementById('txtSearchInput');

            // Search
            const searchVal = searchEl?.value.trim();
            if (searchVal) appliedFilters['txtSearchInput'] = { label: 'Search', text: searchVal };
            else delete appliedFilters['txtSearchInput'];

            // Session
            if (sessionEl?.value && sessionEl.value !== '') {
                appliedFilters['ddlFilterSessions'] = {
                    label: 'Session',
                    text: sessionEl.options[sessionEl.selectedIndex]?.text || sessionEl.value
                };
            } else delete appliedFilters['ddlFilterSessions'];

            // Company
            if (companyEl?.value && companyEl.value !== '') {
                appliedFilters['ddlFilterCompany'] = {
                    label: 'Company',
                    text: companyEl.options[companyEl.selectedIndex]?.text || companyEl.value
                };
            } else delete appliedFilters['ddlFilterCompany'];

            // Section
            if (sectionEl?.value && sectionEl.value !== '') {
                appliedFilters['ddlFilterSection'] = {
                    label: 'Section',
                    text: sectionEl.options[sectionEl.selectedIndex]?.text || sectionEl.value
                };
            } else delete appliedFilters['ddlFilterSection'];
            if (classEl?.value && classEl.value !== '') {
                appliedFilters['ddlFilterClassID'] = {
                    label: 'Section',
                    text: classEl.options[classEl.selectedIndex]?.text || classEl.value
                };
            } else delete appliedFilters['ddlFilterClassID'];

            if (sectionID?.value && sectionID.value !== '') {
                appliedFilters['ddlFilterSectionID'] = {
                    label: 'Section',
                    text: sectionID.options[sectionID.selectedIndex]?.text || sectionID.value
                };
            } else delete appliedFilters['ddlFilterSectionID'];

            saveAppliedFilters();
        }

        function renderFilterBadges() {
            const container = document.getElementById('badgeContainer');
            const mainContainer = document.getElementById('activeFilterBadges');
            if (!container || !mainContainer) return;

            container.innerHTML = '';
            const activeCount = Object.keys(appliedFilters).length;

            Object.entries(appliedFilters).forEach(([id, { label, text }]) => {
                const badge = document.createElement('span');
                badge.className = 'badge bg-primary-subtle text-primary border border-primary-subtle d-flex align-items-center gap-1 fw-medium px-2 py-1';
                badge.innerHTML = `${label}: ${text} <i class="ti ti-x ms-1 cursor-pointer" onclick="removeFilter('${id}')" style="font-size:10px;"></i>`;
                container.appendChild(badge);
            });

            mainContainer.style.display = activeCount > 0 ? 'block' : 'none';
        }

        function removeFilter(filterId) {
            // Clear the matching dropdown/input
            if (filterId === 'ddlFilterSessions') {
                const el = document.getElementById('ddlFilterSessions');
                if (el) {
                    el.value = '';
                    if (window.jQuery && jQuery(el).data('select2')) jQuery(el).val('').trigger('change');
                }
            } else if (filterId === 'ddlFilterCompany') {
                const el = document.getElementById('ddlFilterCompany');
                if (el) {
                    el.value = '';
                    if (window.jQuery && jQuery(el).data('select2')) jQuery(el).val('').trigger('change');
                }
            } else if (filterId === 'txtSearchInput') {
                const el = document.getElementById('txtSearchInput');
                if (el) el.value = '';
                document.getElementById('hdnSearch').value = '';
            } else if (filterId === 'ddlFilterSection') {
                const el = document.getElementById('ddlFilterSection');
                if (el) {
                    el.value = '';
                    if (window.jQuery && jQuery(el).data('select2')) jQuery(el).val('').trigger('change');
                }
            }
            else if (filterId === 'ddlFilterClassID') {
                const el = document.getElementById('ddlFilterClassID');
                if (el) {
                    el.value = '';
                    if (window.jQuery && jQuery(el).data('select2')) jQuery(el).val('').trigger('change');
                }
            }
            else if (filterId === 'ddlFilterSection') {
                const el = document.getElementById('ddlFilterSection');
                if (el) {
                    el.value = '';
                    if (window.jQuery && jQuery(el).data('select2')) jQuery(el).val('').trigger('change');
                }
            }

            delete appliedFilters[filterId];
            saveAppliedFilters();
            document.getElementById('hdnPageIndex').value = 1;
            submitForm();
        }

        function resetAllFilters() {
            document.getElementById('txtSearchInput').value = '';
            document.getElementById('hdnSearch').value = '';

            ['ddlFilterSessions', 'ddlFilterCompany','ddlFilterSection','ddlFilterClassID','ddlFilterSection'].forEach(id => {
                const el = document.getElementById(id);
                if (!el) return;
                el.value = '';
                if (window.jQuery && jQuery(el).data('select2')) jQuery(el).val('').trigger('change');
            });

            clearAppliedFilters();
            document.getElementById('hdnPageIndex').value = 1;
            submitForm();
        }

        // ========================================
        // DOMContentLoaded — init DataTable + UI
        // ========================================
        document.addEventListener('DOMContentLoaded', () => {

            // ── DataTable (export only) ───────────────────────────────────────
            if ($.fn.DataTable.isDataTable('#assignmentsTable')) {
                $('#assignmentsTable').DataTable().destroy();
            }
            $.fn.dataTable.ext.errMode = 'none';
            window.exportTable = $('#assignmentsTable').DataTable({
                dom: 'Bfrtip',
                buttons: [
                    { extend: 'copy', exportOptions: { columns: [1, 2, 3, 4] } },
                    { extend: 'csv', exportOptions: { columns: [1, 2, 3, 4] } },
                    { extend: 'excel', exportOptions: { columns: [1, 2, 3, 4] } },
                    { extend: 'pdf', exportOptions: { columns: [1, 2, 3, 4] } },
                    { extend: 'print', exportOptions: { columns: [1, 2, 3, 4] } }
                ],
                searching: false,
                paging: false,
                info: false,
                ordering: false
            });

            // ── Select2 ───────────────────────────────────────────────────────
            try {
                if (window.jQuery && typeof jQuery.fn.select2 === 'function') {
                    jQuery('#ddlFilterSessions, #ddlFilterCompany','#ddlFilterSection','#ddlFilterClassID','#ddlFilterSection').select2({
                        width: '100%',
                        dropdownParent: jQuery('#filter-dropdown'),
                        allowClear: true,
                        placeholder: function () { return jQuery(this).data('placeholder') || 'Select'; }
                    });
                }
            } catch (e) {
                console.warn('Select2 init skipped:', e);
            }

            // ── Keep filter dropdown open while interacting inside ────────────
            document.getElementById('filter-dropdown')?.addEventListener('click', e => e.stopPropagation());

            // ── Apply Filters ─────────────────────────────────────────────────
            document.getElementById('btnApplyFilters')?.addEventListener('click', () => {
                document.getElementById('hdnPageIndex').value = 1;
                document.getElementById('hdnSearch').value = document.getElementById('txtSearchInput').value;
                applyFilters();
                submitForm();
            });

            // ── Reset Filters ─────────────────────────────────────────────────
            document.getElementById('btnResetFilters')?.addEventListener('click', () => {
                document.getElementById('txtSearchInput').value = '';
                document.getElementById('hdnSearch').value = '';
                ['ddlFilterSessions', 'ddlFilterCompany','ddlFilterSection','ddlFilterClassID','ddlFilterSection'].forEach(id => {
                    const el = document.getElementById(id);
                    if (!el) return;
                    el.value = '';
                    if (window.jQuery && jQuery(el).data('select2')) jQuery(el).val('').trigger('change');
                });
                clearAppliedFilters();
                document.getElementById('hdnPageIndex').value = 1;
                submitForm();
            });

            // ── Render badges on load ─────────────────────────────────────────
            renderFilterBadges();
        });


                // ✅ Auto-apply filter as user types (300ms debounce)
        const searchInput = document.getElementById('txtSearchInput');
        if (searchInput) {
            let debounceTimer = null;

            searchInput.addEventListener('input', function () {
                const val = this.value.trim();

                // Update hidden field immediately
                document.getElementById('hdnSearch').value = val;

                // Update applied filters badge
                if (val) {
                    appliedFilters['txtSearchInput'] = { label: 'Search', text: val };
                } else {
                    delete appliedFilters['txtSearchInput'];
                }
                saveAppliedFilters();

                // Debounce — wait 300ms after user stops typing, then submit
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(function () {
                    document.getElementById('hdnPageIndex').value = 1;
                    submitForm();
                }, 300);
            });

            // Enter key — submit immediately without waiting for debounce
            searchInput.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    clearTimeout(debounceTimer);
                    document.getElementById('hdnSearch').value = this.value.trim();
                    document.getElementById('hdnPageIndex').value = 1;
                    applyFilters();
                    submitForm();
                }
            });
        }

        let teacherChoices;
        let selectedRow = null;

        $(document).ready(function () {
            $('#assignmentsTable').DataTable({
                dom: 'Bfrtip',
                buttons: [
                    { extend: 'copy', exportOptions: { columns: [1, 2, 3] } },
                    { extend: 'csv', exportOptions: { columns: [1, 2, 3] } },
                    { extend: 'excel', exportOptions: { columns: [1, 2, 3] } },
                    { extend: 'pdf', exportOptions: { columns: [1, 2, 3] } },
                    { extend: 'print', exportOptions: { columns: [1, 2, 3] } }
                ],
                searching: false,
                paging: false,
                info: false
            });

            // Initialize Choices manually
            const element = document.querySelector('#choices-multiple-remove-button');
            if (element) {
                teacherChoices = new Choices(element, {
                    removeItemButton: true,
                    placeholderValue: 'Select Teachers',
                    searchPlaceholderValue: 'Search teachers...'
                });
            }

            // Search functionality
            $("#tableSearch").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#assignmentsTable tbody tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });

        function selectItem(row) {
            selectedRow = $(row);
            $(".item-row").removeClass("bg-light");
            selectedRow.addClass("bg-light");


            $("#btnEdit").prop("disabled", false);
            $("#btnDelete").prop("disabled", false);
            let checkedCount = $('.student-checkbox:checked').length;
            $('#btnDelete').prop('disabled', checkedCount === 0);
            // Edit sirf 1 record select hone par
            $('#btnEdit').prop('disabled', checkedCount !== 1);
        }





        function editSelected() {
            if (!selectedRow) return;

            const classId = selectedRow.data("class-id");
            const sectionId = selectedRow.data("section-id");
            const staffIds = selectedRow.data("staff-ids");
                try {

                    if (classId) {
            const staffParam = Array.isArray(staffIds)
                ? staffIds.join(',')
                : (staffIds || '');

            location.href = `/Academics/AddAssignClassTeacher/${classId}`
                          + `?sectionId=${sectionId || ''}`
                          + `&staffIds=${staffParam}`;
        }

        } catch (err) {
            console.error(err);
        }
        }


        function deleteSelected() {

                 var classIds = [];
                 var sectionIds = [];
                $('.student-checkbox:checked').each(function () {
                    classIds.push($(this).data('class-id'));
                    sectionIds.push($(this).data('section-id'));
                });

                if (classIds.length === 0) {
                    alert('Please select at least one record.');
                    return;
                }

                 Swal.fire({
                title: 'Are you sure?',
                text: "You are about to delete this class teachers record. This action cannot be undone!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!',
                customClass: {
                    confirmButton: 'btn btn-danger me-2',
                    cancelButton: 'btn btn-secondary'
                },
                buttonsStyling: false
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                         url: '/Academics/DeleteClassTeacherByClassSection',
                        type: 'POST',
                        traditional: true,
                        data: {
                            classId: classIds,
                            sectionId: sectionIds
                        },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire('Deleted!', 'Class teachers record has been deleted.', 'success')
                                    .then(() => location.reload());
                            } else {
                                Swal.fire('Error!', res.message || 'Failed to delete class teachers.', 'error');
                            }
                        },
                        error: function () {
                            Swal.fire('Error!', 'An unexpected error occurred.', 'error');
                        }
                    });
                }
            });

        }
    </script>
}
