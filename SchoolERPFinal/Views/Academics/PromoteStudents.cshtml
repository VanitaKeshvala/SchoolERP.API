@model SchoolERP.Shared.Models.PromoteStudentsPageViewModel
@using System.Security.Claims
@using System.Text.Json
@{
    ViewData["Title"] = "Promote Students";
    var currentUserId = int.TryParse(User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? User.FindFirst("UserId")?.Value, out var id) ? id : 0;
    var p = Model.Permissions;
}
<style>
    .promot-student {
        display: flex;
        gap: 0.25rem;
    }
</style>
<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Promote Students</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1 ">
        <button class="btn btn-success" id="btnSave" disabled onclick="confirmPromotion()"><i class="ti ti-cloud me-1"></i> Save</button>

    </div>
</div>

<!-- End Page Header -->
<!-- start row -->
<div class="row">
    <div class="col-xl-12">
        <div class="card mb-2 shadow-tbl-outer">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">

                    <!-- ── Search box (name="search" so form submits it) ── -->
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text"
                               name="search"
                               id="txtSearchInput"
                               value="@Model?.SearchTerm"
                               class="form-control border-0 ps-2"
                               placeholder="Search by class, section..."
                               style="min-width: 320px;" />
                    </div>

                    <!-- Hidden form for filter submission — outside Bootstrap dropdown -->
                    <form method="get" asp-action="PromoteStudents" id="frmSearch" style="display:none;">
                        <input type="hidden" name="pageIndex" id="hdnPageIndex" value="1" />
                        <input type="hidden" name="search" id="hdnSearch" value="@Model?.SearchTerm" />
                        <input type="hidden" name="sessionID" id="hdnSessionID" value="" />
                        <input type="hidden" name="companyId" id="hdnCompanyId" value="" />
                        <input type="hidden" name="sectionID" id="hdnSectionID" value="" />
                        <input type="hidden" name="classId" id="hdnclassId" value="" />
                        <input type="hidden" name="pageSize" id="hdnPageSize" value="@Model?.PageSize" />
                    </form>

                    <div class="dropdown">
                        <a href="#" id="btnFilterToggle"
                           class="btn btn-white border rounded btn-md text-dark fs-14 align-items-center d-flex fw-normal"
                           data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            <i class="ti ti-filter text-gray-5 me-1"></i>Filters
                        </a>

                        <div class="dropdown-menu dropdown-lg dropdown-menu-end filter-dropdown p-0 shadow-tbl"
                             id="filter-dropdown">

                            <div class="d-flex align-items-center justify-content-between border-bottom filter-header">
                                <h6 class="mb-0 fw-bold">Select Criteria</h6>
                                <div class="d-flex align-items-center justify-content-end">
                                    <button type="button" class="btn btn-light btn-md me-2 fw-medium" onclick="resetAllFilters()" id="btnResetFilters">Reset</button>
                                    <button type="button" class="btn text-primary fs-6 fw-medium" id="btnApplyFilters">Filter</button>
                                </div>
                            </div>

                            <div class="filter-body pb-0">
                                <div class="row">
                                   
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Session</label>
                                        <select class="form-select form-control select2"
                                                id="ddlFilterSessions"
                                                data-placeholder="Select session">
                                            <option value="">All</option>
                                            @foreach (var ut in Model.Sessions)
                                            {
                                                <option value="@ut.SessionId" selected="@(Model.SessionId == ut.SessionId)">
                                                    @ut.SessionTitle
                                                </option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Company</label>
                                        <select class="form-select form-control select2"
                                                id="ddlFilterCompany"
                                                data-placeholder="Select company">
                                            <option value="">All</option>
                                            @foreach (var c in Model.Companies ?? new List<MstCompanyViewModel>())
                                            {
                                                <option value="@c.CompanyId" selected="@(Model.CompanyId == c.CompanyId)">
                                                    @c.SchoolName
                                                </option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Class<span class="text-danger">*</span></label>
                                        <select name="classId" id="FilterClassID" class="form-select form-control" onchange="onFilterClassChange()" required>
                                            <option value="">Select</option>
                                            @foreach (var c in Model?.Classes)
                                            {
                                                <option value="@c.ClassID" selected="@(Model?.SelectedClassId == c.ClassID)">@c.ClassName</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Section<span class="text-danger">*</span></label>
                                        <select name="sectionId" id="FilterSectionID" class="form-select form-control" required>
                                            <option value="">Select</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
    
    <div class="col-xl-12" id="activeFilterBadges" style="display: none;">
        <div class="card shadow-tbl border-0 py-2 mb-2">
            <div class="card-body p-2 d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold ms-2 me-2"><i class="ti ti-filter-check me-1"></i>Active Filters:</span>
                <div id="badgeContainer" class="d-flex flex-wrap gap-2"></div>
                <button class="btn btn-sm btn-link text-danger p-0 ms-auto me-2 fw-bold text-decoration-none" id="btnResetAllFilters" onclick="resetAllFilters()">
                    <i class="ti ti-trash me-1"></i>Clear All
                </button>
            </div>
        </div>
    </div>

    <div class="col-xl-12">
        <div class="card overflow-auto shadow-tbl">
            <div class="card-body p-0 overflow-auto">
                <div class="table-responsive">
                    <table class="table table-nowrap mb-0" id="studentsTable">
                        <thead>
                            <tr>
                                <th><input type="checkbox" class="form-check-input" id="selectAll"></th>
                                <th>Admission No</th>
                                <th>Student Name</th>
                                <th>Father Name</th>
                                <th>Date Of Birth</th>
                                <th>Promotion Class</th>
                                <th>Next Session</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Students.Any())
                            {
                                foreach (var s in Model?.Students)
                                {
                                    
                                    <tr class="student-row" data-id="@s.StudentID">
                                        <td>
                                            <input type="hidden" id="hdnNEXTCLASSID" value="@s.NEXTCLASSID" />
                                            <input type="hidden" id="hdnNEXTSESSIONTITLE" value="@s.NEXTSESSIONID" />
                                            <input type="checkbox" onchange="selectItem(@s.StudentID,this)" class="form-check-input student-checkbox">
                                        </td>
                                        <td>@s.AdmissionNo</td>
                                        <td>@s.StudentName</td>
                                        <td>@s.FatherName</td>
                                        <td>@(s.DOB?.ToString("dd-MM-yyyy") ?? "-")</td>
                                        <td>@s.NextClassName</td>
                                        <td>@s.NEXTSESSIONTITLE</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-4">No students found. Please apply filters.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>



@section Styles {
    <style>
        .dt-buttons { display: none !important; }
    </style>
}

@section Scripts {
    <script src="~/assets/js/PromoteStudents.js"></script>
}
