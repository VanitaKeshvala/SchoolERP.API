@*
    ======================================================================
    VIEW: Academics / SubjectGroup.cshtml
    PURPOSE: User interface for managing Subject Groups.
    ======================================================================
*@
@model SchoolERP.Shared.Models.MstSubjectGroupPageViewModel
@using System.Security.Claims
@using System.Text.Json
@{
    Layout = "_Layout";
    ViewData["Title"] = "Subject Group Management";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Subject Group</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <a href="/Academics/AddSubjectGroup" class="btn btn-primary top-btn">
                <i class="ti ti-plus me-1"></i> Add
            </a>
        }
        @if (p.CanEdit)
        {
            <button id="btnEdit" class="btn btn-info top-btn" disabled onclick="editSelected()">
                <i class="ti ti-pencil me-1"></i>Edit
            </button>
        }
        @if (p.CanDelete)
        {
            <button id="btnDelete" class="btn btn-danger top-btn" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i>Delete
            </button>
        }
        @if (p.CanEdit)
        {
            <button id="btnActive" class="btn btn-success top-btn" disabled onclick="toggleStatus(0,true)">
                <i class="ti ti-circle-check"></i> Active
            </button>
            <button id="btnInactive" class="btn btn-danger top-btn" disabled onclick="toggleStatus(0,false)">
                <i class="ti ti-circle-x"></i> Inactive
            </button>
        }
        @if (p.CanPrint)
        {
            <button class="btn btn-secondary d-inline-flex align-items-center top-btn" onclick="triggerExport(4)">
                <i class="ti ti-printer me-1"></i>Print
            </button>
        }
        @if (p.CanExport)
        {
            <div class="dropdown d-inline-flex">
                <button class="btn btn-warning dropdown-toggle top-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(0)"><i class="ti ti-copy me-1"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(1)"><i class="ti ti-file-text me-1"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(2)"><i class="ti ti-file-spreadsheet me-1"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(3)"><i class="ti ti-file-description me-1"></i>PDF</a></li>
                </ul>
            </div>
        }
    </div>
</div>

<div id="pageNotice"></div>

<!-- start row -->
<div class="row">
    <div class="col-md-12">
        <div class="card shadow-tbl-outer mb-2">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3 bg-white">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text" class="form-control border-0 ps-2" id="txtSearchInput" style="min-width: 220px;" placeholder="Search..." onkeyup="filterTable()" />
                    </div>
                    <!--<input type="text" id="txtSearch" class="form-control w-25 me-3" placeholder="Search..." onkeyup="filterTable()" />-->
                    <div class="d-flex align-items-center flex-wrap gap-2 flex-shrink-0">
                        <div class="dropdown">
                            <a href="#" id="btnFilterToggle" class="btn btn-white border rounded btn-md text-dark fs-14 align-items-center d-flex fw-normal"
                            data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                <i class="ti ti-filter text-gray-5 me-1"></i>Filters
                            </a>
                            <div class="dropdown-menu dropdown-lg dropdown-menu-end filter-dropdown p-0 shadow-tbl" id="filter-dropdown">
                                <div class="d-flex align-items-center justify-content-between border-bottom filter-header">
                                    <h6 class="mb-0 fw-bold ms-3">Select Criteria</h6>
                                    <div class="d-flex align-items-center justify-content-end">
                                        <button type="button" class="btn text-primary fs-6 fw-medium" onclick="applyFilter()">Filter</button>
                                    </div>
                                </div>
                                <div class="filter-body pb-0 p-3">
                                    <div class="mb-3">
                                        <label class="form-label mb-1">Class</label>
                                        <select id="filterClass" class="form-select select2" onchange="loadSectionsByClass(this.value, 'filterSection')">
                                            <option value="">All Classes</option>
                                            @if(Model.Classes !=null)
                                            {
                                                @foreach (var c in Model.Classes)
                                                {
                                                    <option value="@c.ClassID" data-name="@c.ClassName">@c.ClassName</option>
                                                }
                                            }

                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label mb-1">Section</label>
                                        <select id="filterSection" class="form-select select2">
                                            <option value="">All Sections</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-12" id="activeFilterBadges" style="display: none;">
        <div class="card shadow-tbl border-0 py-2 mb-2">
            <div class="card-body p-2 d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold ms-2 me-2"><i class="ti ti-filter-check me-1"></i>Active Filters:</span>
                <div id="badgeContainer" class="d-flex flex-wrap gap-2"></div>
                <button class="btn btn-sm btn-link text-danger p-0 ms-auto me-2 fw-bold text-decoration-none" id="btnResetAllFilters" onclick="resetAllFilters()">
                    <i class="ti ti-trash me-1"></i>Clear All
                </button>
            </div>
        </div>
    </div>

    <div class="col-xl-12">
        <div class="card overflow-auto shadow-tbl">
            <div class="card-body p-0 overflow-auto">
                <div class="table-responsive">
                    <table class="table table-nowrap mb-0" id="groupsTable">
                        <thead class="bg-light">
                            <tr>
                                <th style="width: 50px;">#</th>
                                <th>Name</th>
                                <th>Class (Sections)</th>
                                <th>Subjects</th>

                                <th>Created On</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.SubjectGroups != null && Model.SubjectGroups.Any())
                            {
                                foreach (var g in Model.SubjectGroups)
                                {
                                    <tr class="item-row" onclick="selectItem(@g.SubjectGroupID, this)" style="cursor: pointer;">
                                        <td class="text-center">
                                            <input type="checkbox" name="selectedGroup"
                                            class="form-check-input student-checkbox"
                                            value="@g.SubjectGroupID">

                                        </td>
                                        <td class="fw-medium">@g.Name</td>
                                        <td>
                                            <span class="fw-bold">@g.ClassName</span>
                                            <br/><small class="text-muted">(@g.SectionNames)</small>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(g.SubjectNames))
                                            {
                                                foreach (var sub in g.SubjectNames.Split(','))
                                                {
                                                    <span class="badge bg-light fw-normal text-dark border me-1 mb-1">@sub.Trim()</span>
                                                }
                                            }
                                        </td>
                                        <td>@g.CreatedOn.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @if (p.CanEdit)
                                            {
                                                <div class="form-check form-switch" onclick="event.stopPropagation()">
                                                    <input class="form-check-input status-switch" type="checkbox" @(g.IsActive ? "checked" : "") onchange="toggleStatus(@g.SubjectGroupID, this.checked)">
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="badge @(g.IsActive ? "bg-success" : "bg-secondary")">@(g.IsActive ? "Active" : "Inactive")</span>
                                            }
                                        </td>

                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">No subject groups found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="itemModal">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header d-flex justify-content-between align-items-center">
                <h5 class="modal-title" id="modalTitle">Add Subject Group</h5>
                <div>
                    <button class="btn btn-success" onclick="saveItem()">
                        <i class="ti ti-cloud me-1"></i> Save
                    </button>
                    <button class="btn btn-danger" data-bs-dismiss="modal">
                        <i class="ti ti-x me-1"></i>Close
                    </button>
                </div>
            </div>
            <div class="modal-body p-4">
                <div id="modalNotice"></div>
                <form id="itemForm">
                    <input type="hidden" id="txtItemId" value="0">
                    <div class="row row-gap-3">
                        <div class="col-md-8">
                            <label class="form-label">Name <span class="text-danger">*</span></label>
                            <input type="text" id="txtName" class="form-control" placeholder="Group Name" autocomplete="off">
                            <div class="invalid-feedback" id="errTxtName"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Class <span class="text-danger">*</span></label>
                            <select id="ddlClass" class="form-select form-control" onchange="loadSectionsByClass(this.value, 'ddlSections')">
                                <option value="">Select Class</option>
                                @if (Model.Classes !=null)
                                {
                                    @foreach (var c in Model.Classes)
                                    {
                                        <option value="@c.ClassID">@c.ClassName</option>
                                    }
                                }

                            </select>
                            <div class="invalid-feedback" id="errDdlClass"></div>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Section <span class="text-danger">*</span></label>
                            <select id="ddlSections" class="form-select form-control select2" multiple data-placeholder="Select Sections">
                                @* Sections populated dynamically based on class *@
                            </select>
                            <div class="invalid-feedback" id="errDdlSections"></div>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Subjects <span class="text-danger">*</span></label>
                            <select id="ddlSubjects" class="form-select form-control select2" multiple data-placeholder="Select Subjects">
                                @if (Model.Subjects != null)
                                {
                                    @foreach (var sub in Model.Subjects)
                                    {
                                        <option value="@sub.SubjectID">@sub.SubjectName</option>
                                    }
                                    
                                }                                

                            </select>
                            <div class="invalid-feedback" id="errDdlSubjects"></div>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Description</label>
                            <textarea id="txtDescription" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="isActive" checked>
                                <label class="form-check-label" for="isActive">Active Status</label>                        
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


@section Styles {
    <!--<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />-->
    <style>
        .dt-buttons { display: none !important; }
        .select2-container--default .select2-selection--multiple {
            padding-bottom: 0px; 
            margin-top: 0px; 
            border: 1px solid #33333340 !important;
            padding-left: 5px;
        }
    </style>
}

@section Scripts {
    <!--<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>-->
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
        window.allSections = @Html.Raw(JsonSerializer.Serialize(Model.Sections));
    </script>

    <script src="~/assets/js/SubjectGroup.js"></script>
}
