@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.MstSubjectAddViewModel
@{
    ViewData["Title"] = "Add Subject";
    var p = Model.Permissions;
}

<style>
    .dt-buttons {
        display: none !important;
    }

    .is-invalid + .select2-container .select2-selection {
        border-color: #dc3545 !important;
    }

    .is-invalid ~ .invalid-feedback {
        display: block !important;
    }
</style>

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditSubjects == null ? "Add Subject" : "Edit Subject")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveItem()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Academics/Subject" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">

            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <input type="hidden" id="txtItemId" value="@(Model.EditSubjects?.SubjectID ?? 0)">
                    <input type="hidden" id="hdnUserID" value="@(Model.EditSubjects?.CreatedBy ?? 0)">
                    @* <input type="hidden" id="txtItemId" value="0"> *@
                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Subject Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" value="@Model.EditSubjects?.SubjectName" id="txtSubjectName" placeholder="e.g. Mathematics" autocomplete="off">
                            <div class="invalid-feedback" id="errTxtSubjectName"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Subject Code</label>
                            <input type="text" class="form-control" value="@Model.EditSubjects?.SubjectCode" id="txtSubjectCode" placeholder="e.g. MATH101" autocomplete="off">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Subject Type <span class="text-danger">*</span></label>
                            <select class="form-select select2" id="ddlSubjectType">
                                <option value="">Select Type</option>
                                <option value="Theory" selected="@(Model.EditSubjects?.SubjectType == "Theory")">Theory</option>
                                <option value="Practical" selected="@(Model.EditSubjects?.SubjectType == "Practical")">Practical</option>

                            </select>
                            <div class="invalid-feedback" id="errDdlSubjectType"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="isActive" @(Model.EditSubjects?.IsActive == true ? "checked" : "")>
                                <label class="form-check-label fw-semibold" for="isActive">Active Status</label>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/assets/js/Subject.js"></script>
}