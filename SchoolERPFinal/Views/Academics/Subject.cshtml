@*
    ======================================================================
    VIEW: Academics / Subject.cshtml
    PURPOSE: User interface for managing Subjects.
    ======================================================================
*@
@model SchoolERP.Shared.Models.MstSubjectPageViewModel
@using System.Security.Claims
@using System.Text.Json
@{
    Layout = "_Layout";
    ViewData["Title"] = "Subject Management";

    var currentUserId = int.TryParse(User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? User.FindFirst("UserId")?.Value, out var id) ? id : 0;
    var p = Model.Permissions;
}

<style>
    .dt-buttons { display: none !important; }
    .is-invalid + .select2-container .select2-selection {
    border-color: #dc3545 !important;
    }
    .is-invalid ~ .invalid-feedback {
    display: block !important;
    }
</style>

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Subject Management</h6>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-1">
        @if(p.CanAdd)
        {
            <a href="/Academics/AddSubject" class="btn btn-primary shadow-sm top-btn" id="btnAddSubject">
                <i class="ti ti-plus me-1"></i>Add
            </a>
        }
        @if (p.CanEdit)
        {
            <button id="btnEdit" class="btn btn-info shadow-sm top-btn" disabled onclick="editSelected()">
                <i class="ti ti-pencil me-1"></i>Edit
            </button>
        }
        
        @if (p.CanDelete)
        {
            <button id="btnDelete" class="btn btn-danger shadow-sm top-btn" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i>Delete
            </button>
        }
        
        @if(p.CanEdit)
        {
            <button id="btnActive" class="btn btn-success top-btn" disabled onclick="toggleStatus(0,true)">
                <i class="ti ti-circle-check"></i> Active
            </button>
            <button id="btnInactive" class="btn btn-danger top-btn" disabled onclick="toggleStatus(0,false)">
                <i class="ti ti-circle-x"></i> Inactive
            </button>
        }
        @if (p.CanPrint)
        {
            <button class="btn btn-secondary shadow-sm d-inline-flex align-items-center top-btn" onclick="triggerExport(4)">
                <i class="ti ti-printer me-1"></i>Print
            </button>
        }
        @if (p.CanExport)
        {
            <div class="dropdown d-inline-flex">
                <button class="btn btn-warning dropdown-toggle shadow-sm top-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(0)"><i class="ti ti-copy me-1"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(1)"><i class="ti ti-file-text me-1"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(2)"><i class="ti ti-file-spreadsheet me-1"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(3)"><i class="ti ti-file-description me-1"></i>PDF</a></li>
                </ul>
            </div>
        }
    </div>
</div>

<div id="pageNotice"></div>

<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl border-0 overflow-hidden">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table" id="subjectsTable">
                        <thead>
                            <tr>
                                <th class="ps-4" style="width: 50px;">Select</th>
                                <th>Subject Name</th>
                                <th>Subject Code</th>
                                <th>Subject Type</th>                                
                                <th>Created On</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Subjects != null && Model.Subjects.Any())
                            {
                                foreach (var s in Model.Subjects)
                                {
                                    <tr class="item-row" onclick="selectItem(@s.SubjectID, this)" style="cursor: pointer;">
                                        <td class="ps-4 text-center">
                                            <input type="checkbox" name="selectedSubject"
                                                   class="form-check-input student-checkbox"
                                                   value="@s.SubjectID">                                        
                                        </td>
                                        <td>@s.SubjectName</td>
                                        <td><span class="badge bg-light text-dark fw-normal border">@(string.IsNullOrEmpty(s.SubjectCode) ? "N/A" : s.SubjectCode)</span></td>
                                        <td>@s.SubjectType</td>
                                        <td>@s.CreatedOn.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @if (p.CanEdit)
                                            {
                                                <div class="form-check form-switch" onclick="event.stopPropagation()">
                                                    <input class="form-check-input status-switch" type="checkbox" @(s.IsActive ? "checked" : "") onchange="toggleStatus(@s.SubjectID, this.checked)">
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="badge @(s.IsActive ? "bg-success" : "bg-secondary")">@(s.IsActive ? "Active" : "Inactive")</span>
                                            }
                                        </td>
                                        
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted text-danger">No subjects found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/assets/js/Subject.js"></script>
}
