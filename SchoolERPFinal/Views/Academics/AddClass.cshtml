@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.MstClassAddViewModel
@{
    ViewData["Title"] = "Add Class";
    var p = Model.Permissions;
    var selectedIds = Model.EditClasses?.SectionIds?
        .Split(',')
        .Select(x => x.Trim())
        .ToList() ?? new List<string>();
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditClasses == null ? "Add Class" : "Edit Class")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveItem()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Academics/Class" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
          
            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <input type="hidden" id="txtItemId" value="@(Model.EditClasses?.ClassID ?? 0)">
                    <input type="hidden" id="hdnUserID" value="@(Model.EditClasses?.CreatedBy ?? 0)">
                    
                    <div class="row">
                        
                        <div class="col-md-5 mb-3">
                            <label class="form-label fw-semibold">Class Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtClassName"
                                   value="@Model.EditClasses?.ClassName"
                            placeholder="e.g. 1st Class" autocomplete="off">
                            <div class="invalid-feedback" id="errTxtClassName"></div>
                        </div>
                        <div class="col-md-5 mb-">
                            <label class="form-label fw-semibold">Assign Sections <span class="text-danger">*</span></label>
                            <select id="ddlSections" class="form-control select2" multiple data-placeholder="Select Sections">
                                @if (Model.AvailableSections != null)
                                {
                                    @foreach (var s in Model.AvailableSections)
                                    {
                                         <!-- Mark selected if this section is in the saved list -->
                                        //bool isSelected = Model.EditClasses?.SectionIds?.Contains(s.SectionIds) ?? false;
                                        //bool isSelected = selectedIds.Contains(s.SectionID?.ToString());
                                        bool isSelected = selectedIds.Contains(s.SectionID.ToString());
                                        if (isSelected)
                                        {
                                            <option value="@s.SectionID" selected="selected">@s.SectionName</option>
                                        }
                                        else
                                        {
                                            <option value="@s.SectionID">@s.SectionName</option>
                                        }
                                    }
                                }

                            </select>
                            <div class="invalid-feedback" id="errDdlSections"></div>
                        </div>
                        <div class="col-md-2 mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="isActive"
                                @(Model.EditClasses?.IsActive ?? true ? "checked" : "")>                               
                                <label class="form-check-label fw-bold" for="isActive">Active</label>
                            </div>
                        </div>
                        
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<link href="~/assets/css/select2.min.css" rel="stylesheet" />

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/assets/js/Class.js"></script>
}