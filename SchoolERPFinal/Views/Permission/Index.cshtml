@*
    ======================================================================
    VIEW: Permission / Index.cshtml
    PURPOSE: User interface rendering for the Permission module.
    ======================================================================
*@
@model SchoolERP.Shared.Models.MstUserManagementPageViewModel
@using System.Security.Claims
@using System.Text.Json
@{
    Layout = "_Layout";
    ViewData["Title"] = "Permission Management";


    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var pb = Model.PermissionsButton;
}

@* Local alert div removed in favor of global toast system *@

<style>
    .dt-buttons { display: none !important; }
</style>

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Permission Management</h6>
    </div>

    <div class="d-flex flex-wrap align-items-center gap-1">
        @if(pb.CanAdd)
        {
            <button class="btn btn-primary shadow-sm top-btn" id="btnAddPermission" onclick="openAddModal()">
                <i class="ti ti-plus me-1"></i>Add
            </button>
        }   
        @if(pb.CanEdit)
        {
            <button id="btnEdit" class="btn btn-info shadow-sm top-btn" disabled onclick="editSelected()">
                <i class="ti ti-pencil me-1"></i>Edit
            </button>
        }
        @if(pb.CanDelete)
        {
            <button id="btnDelete" class="btn btn-danger shadow-sm top-btn" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i>Delete
            </button>
        }        
        @if (pb.CanEdit)
        {
            <button id="btnActive" class="btn btn-success top-btn" disabled onclick="toggleStatus(0,true)">
                <i class="ti ti-circle-check"></i> Active
            </button>
            <button id="btnInactive" class="btn btn-danger top-btn" disabled onclick="toggleStatus(0,false)">
                <i class="ti ti-circle-x"></i> Inactive
            </button>
        }
        @if (pb.CanPrint)
        {
            <button class="btn btn-secondary d-inline-flex align-items-center shadow-sm top-btn" onclick="triggerExport('print')">
                <i class="ti ti-printer me-1"></i> Print
            </button>
        }
        @if (pb.CanExport)
        {
            <div class="dropdown d-inline-block">
                <button class="btn btn-warning dropdown-toggle d-inline-flex align-items-center shadow-sm top-btn" type="button" data-bs-toggle="dropdown">
                    <i class="ti ti-download me-1"></i> Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport('copy')"><i class="ti ti-copy me-2"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport('csv')"><i class="ti ti-file-text me-2"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport('excel')"><i class="ti ti-file-spreadsheet me-2"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport('pdf')"><i class="ti ti-file-description me-2"></i>PDF</a></li>
                </ul>
            </div>
        }
    </div>
</div>

<div class="row">
    <div class="col-xl-12">
        <div class="card mb-2 shadow-tbl-outer">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3 ">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text" class="form-control border-0 ps-2" id="txtSearchInput"
                               placeholder="Search permission..." style="min-width: 220px;">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

