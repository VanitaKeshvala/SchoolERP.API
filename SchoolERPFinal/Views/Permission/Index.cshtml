    <div class="row">
        <div class="col-xl-12">
        <div class="card shadow-tbl">
               @*  <div class="card-header bg-white py-3 border-bottom-0">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                        <h5 class="mb-0 fw-bold text-dark">Master Permissions (Actions)</h5>
                        <div class="position-relative">
                            <i class="fas fa-search search-icon-input"></i>
                            <input type="text" class="form-control form-control-sm ps-4" id="searchInput" placeholder="Search permissions...">
                        </div>
                    </div>
                </div> *@
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table align-items-center mb-0" id="permissionsTable">
                            <thead>
                                <tr>
                                    <th style="width: 50px;">Select</th>
                                    <th style="width:220px;">Permission Name (Action)</th>
                                    <th style="width:220px;">Display Label</th>
                                    <th>Status</th>
                                    <th>Created On</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var p in Model.Permissions)
                                {
                                    <tr class="item-row" onclick="selectItem(@p.PermissionID, this)" style="cursor: pointer;">
                                        <td class="ps-4 text-center">
                                        <input type="checkbox" name="selectedPermission"
                                               class="form-check-input student-checkbox"
                                               value="@p.PermissionID">
                                            
                                        </td>
                                        <td>
                                            @p.PermissionName
                                        </td>
                                        <td>@p.DisplayLabel</td>
                                        <td>                                            
                                            <span class="badge @(p.IsActive ? "bg-success" : "bg-secondary")" asp-permission="View" asp-permission-url="/Permission" asp-permission-negate="true">@(p.IsActive ? "Active" : "Inactive")</span>
                                        </td>
                                        <td><span class="text-xs">@p.CreatedOn.ToString("dd MMM yyyy")</span></td>
                                    <td onclick="event.stopPropagation()">
                                        <div class="form-check form-switch" asp-permission="Edit" asp-permission-url="/Permission">
                                            <input class="form-check-input" type="checkbox" checked="@p.IsActive" onchange="toggleStatus(@p.PermissionID, this.checked)">
