@model SchoolERP.Shared.Models.AccountEntryPageViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Expense Management";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;
}

<style>
    .was-validated .select2-hidden-accessible:invalid + .select2-container .select2-selection {
        border-color: #dc3545 !important;
    }

    .was-validated .select2-hidden-accessible:valid + .select2-container .select2-selection {
        border-color: #198754 !important;
    }
.dt-buttons { display: none !important; }
</style>


<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Expense List</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <a href="javascript:void(0)" class="btn btn-primary top-btn" onclick="openAddModal()">
                <i class="ti ti-plus me-1"></i> Add
            </a>
        }
        @if (p.CanEdit)
        {
            <button id="btnEdit" class="btn btn-info top-btn" disabled onclick="editSelected()">
                <i class="ti ti-pencil me-1"></i> Edit
            </button>
        }
        @if (p.CanDelete)
        {
            <button id="btnDelete" class="btn btn-danger top-btn" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i> Delete
            </button>
        }
        @if (p.CanPrint)
        {
            <button class="btn btn-secondary d-inline-flex align-items-center top-btn" onclick="triggerExport(4)">
                <i class="ti ti-printer me-1"></i>Print
            </button>
        }
        @if (p.CanExport)
        {
            <div class="dropdown d-inline-flex">
                <button class="btn btn-warning dropdown-toggle top-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(0)"><i class="ti ti-copy me-1"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(1)"><i class="ti ti-file-text me-1"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(2)"><i class="ti ti-file-spreadsheet me-1"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(3)"><i class="ti ti-file-description me-1"></i>PDF</a></li>
                </ul>
            </div>
        }

    </div>
</div>

<div class="row">

    <!-- Filters -->
    <div class="col-md-12">
        <div class="card shadow-tbl-outer mb-2">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3 ">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text" class="form-control border-0 ps-2" id="txtSearchInput"
                               placeholder="Search by name, invoice..." style="min-width: 220px;">
                    </div>
                </div>
            </div>
        </div>
    </div>

    

    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0" id="tblExpense">
                        <thead>
                            <tr>
                                <th style="width: 50px;">Select</th>
                                <th>Name</th>
                                <th>Head</th>
                                <th>Invoice No</th>
                                <th>Date</th>
                                <th>Amount</th>
                                <th style="width: 100px;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr class="item-row" onclick="selectItem(@item.AccountEntryID, this)" style="cursor: pointer;">
                                    <td class="ps-3">
                                        <input type="checkbox" name="selectedItem"
                                               class="form-check-input student-checkbox"
                                               value="@item.AccountEntryID">                                    
                                    </td>
                                    <td>@item.Name</td>
                                    <td>@item.HeadName</td>
                                    <td>@item.InvoiceNo</td>
                                    <td>@item.Date.ToString("dd-MMM-yyyy")</td>
                                    <td>@item.Amount.ToString("N2")</td>
                                    <td>
                                        <div class="form-check form-switch" onclick="event.stopPropagation()">
                                            <input class="form-check-input" type="checkbox" 
                                                   onchange="toggleStatus(@item.AccountEntryID, this.checked)"
                                                   @(item.IsActive ? "checked" : "")
                                            @(p.CanEdit ? "" : "disabled")>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Items.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-4">
                                        @if (ViewBag.ErrorMessage != null)
                                        {
                                            <div class="text-danger">Error: @ViewBag.ErrorMessage</div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No records found.</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="entryModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header d-flex justify-content-between align-items-center">
                <h5 class="modal-title" id="modalTitle">Add Expense</h5>
                <div>
                    <button class="btn btn-success" onclick="saveRecord()">
                        <i class="ti ti-cloud me-1"></i> Save
                    </button>
                    <button class="btn btn-danger" data-bs-dismiss="modal">
                        <i class="ti ti-x me-1"></i> Close
                    </button>
                </div>
            </div>
            <div class="modal-body">
                <form id="entryForm" novalidate>
                    <input type="hidden" id="hdnAccountEntryID" value="0">
                    <input type="hidden" id="hdnEntryType" value="Expense">
                    <div class="row row-gap-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Expense Head <span class="text-danger">*</span></label>
                            <select class="form-select select2" id="ddlAccountHead" required>
                                <option value="">-- Select --</option>
                                @foreach (var head in Model.Heads)
                                {
                                    <option value="@head.AccountHeadID">@head.HeadName</option>
                                }
                            </select>
                            <div class="invalid-feedback">Please select an expense head.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtName" required>
                            <div class="invalid-feedback">Please enter a name.</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Invoice No</label>
                            <input type="text" class="form-control" id="txtInvoiceNo">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="txtDate" required value="@DateTime.Today.ToString("yyyy-MM-dd")">
                            <div class="invalid-feedback">Please select a date.</div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Amount <span class="text-danger">*</span></label>
                            <input type="number" step="0.01" class="form-control" id="txtAmount" required>
                            <div class="invalid-feedback">Please enter a valid amount.</div>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Description</label>
                            <textarea class="form-control" id="txtDescription" rows="2"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Attach Document</label>
                            <input type="file" class="form-control" id="fileAttachment">
                            <small id="currentFile" class="text-info" style="display:none;"></small>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch mt-4">
                                <input class="form-check-input" type="checkbox" id="chkActive" checked>
                                <label class="form-check-label" for="chkActive">Active</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {

<script>
    let selectedId = 0;
        const canEdit = @p.CanEdit.ToString().ToLower();
        const canDelete = @p.CanDelete.ToString().ToLower();

        function triggerExport(index) {
            if ($.fn.DataTable.isDataTable('#tblExpense')) {
                const table = $('#tblExpense').DataTable();
                table.button(index).trigger();
            }
        }

        $(document).ready(function () {
            $('#tblExpense').DataTable({
                dom: 'Bfrtip',
                buttons: [
                    { extend: 'copy', exportOptions: { columns: [1, 2, 3, 4, 5] } },
                    { extend: 'csv', exportOptions: { columns: [1, 2, 3, 4, 5] } },
                    { extend: 'excel', exportOptions: { columns: [1, 2, 3, 4, 5] } },
                    { extend: 'pdf', exportOptions: { columns: [1, 2, 3, 4, 5] } },
                    { extend: 'print', exportOptions: { columns: [1, 2, 3, 4, 5] } }
                ],
                searching: false,
                paging: false,
                info: false
            });
        })


    $(document).ready(function() {
        $('#entryModal').on('shown.bs.modal', function () {
            $('#ddlAccountHead').select2({
                dropdownParent: $('#entryModal'),
                width: '100%'
            });
        });
    });

    function selectItem(id, row) {
        selectedId = id;
        document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light'));
        row.classList.add('bg-light');
        //row.querySelector('input[type="radio"]').checked = true;

        if (canEdit) document.getElementById('btnEdit').disabled = false;
        if (canDelete) document.getElementById('btnDelete').disabled = false;
                let checkedCount = $('.student-checkbox:checked').length;
        $('#btnDelete').prop('disabled', checkedCount === 0);
        // Edit sirf 1 record select hone par
        $('#btnEdit').prop('disabled', checkedCount !== 1);
    }

        document.getElementById('txtSearchInput').addEventListener('keyup', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#tblExpense tbody tr').forEach(row => {
            if (row.classList.contains('item-row')) {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            }
        });
    });

    function openAddModal() {
        document.getElementById('modalTitle').textContent = 'Add Expense';
        document.getElementById('hdnAccountEntryID').value = 0;
        const form = document.getElementById('entryForm');
        form.reset();
        form.classList.remove('was-validated');
        document.getElementById('txtDate').value = new Date().toISOString().split('T')[0];
        document.getElementById('chkActive').checked = true;
        document.getElementById('currentFile').style.display = 'none';
        $('#ddlAccountHead').val('').trigger('change');
        new bootstrap.Modal(document.getElementById('entryModal')).show();
    }

    function editSelected() {
        if (!selectedId) return;
        fetch(`/Expense/GetAccountEntryByID/${selectedId}`)
            .then(r => r.json())
            .then(res => {
                if (!res.success) { showToast(res.message, 'danger'); return; }
                const d = res.data;
                document.getElementById('modalTitle').textContent = 'Edit Expense';
                document.getElementById('entryForm').classList.remove('was-validated');
                document.getElementById('hdnAccountEntryID').value = d.accountEntryID;
                document.getElementById('txtName').value = d.name;
                document.getElementById('txtInvoiceNo').value = d.invoiceNo || '';
                document.getElementById('txtDate').value = d.date.split('T')[0];
                document.getElementById('txtAmount').value = d.amount;
                document.getElementById('txtDescription').value = d.description || '';
                document.getElementById('chkActive').checked = d.isActive;
                
                if (d.attachDocName) {
                    document.getElementById('currentFile').textContent = `Current: ${d.attachDocName}`;
                    document.getElementById('currentFile').style.display = 'block';
                } else {
                    document.getElementById('currentFile').style.display = 'none';
                }

                $('#ddlAccountHead').val(d.accountHeadID).trigger('change');
                new bootstrap.Modal(document.getElementById('entryModal')).show();
            });
    }

    async function saveRecord() {
        const form = document.getElementById('entryForm');
        form.classList.add('was-validated');
        if (!form.checkValidity()) { return; }

        const fileInput = document.getElementById('fileAttachment');
        let fileData = null;
        let fileName = null;
        let fileType = null;

        if (fileInput.files.length > 0) {
            const file = fileInput.files[0];
            fileName = file.name;
            fileType = file.type;
            fileData = await convertFileToBase64(file);
        }

        const data = {
            accountEntryID: parseInt(document.getElementById('hdnAccountEntryID').value) || 0,
            accountHeadID:  parseInt(document.getElementById('ddlAccountHead').value),
            entryType:      'Expense',
            name:           document.getElementById('txtName').value.trim(),
            invoiceNo:      document.getElementById('txtInvoiceNo').value.trim() || null,
            date:           document.getElementById('txtDate').value,
            amount:         parseFloat(document.getElementById('txtAmount').value),
            description:    document.getElementById('txtDescription').value.trim() || null,
            isActive:       document.getElementById('chkActive').checked,
            attachDoc:      fileData,
            attachDocName:  fileName,
            attachDocType:  fileType
        };

        fetch('/Expense/UpsertAccountEntry', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(res => {
            showToast(res.message, res.success ? 'success' : 'danger');
            if (res.success) {
                bootstrap.Modal.getInstance(document.getElementById('entryModal')).hide();
                setTimeout(() => location.reload(), 800);
            }
        });
    }

    function deleteSelected() {
        if (!selectedId) return;

        let selectedIds = [];
        $('.student-checkbox:checked').each(function () {
                 selectedIds.push(parseInt($(this).val()));
             });
        if (selectedIds.length === 0) {
                 alert("Please select at least one student.");
                 return;
             }
         Swal.fire({
             title: 'Are you sure?',
                 text: "You are about to delete this expense  record. This action cannot be undone!",
             icon: 'warning',
             showCancelButton: true,
             confirmButtonColor: '#d33',
             cancelButtonColor: '#3085d6',
             confirmButtonText: 'Yes, delete it!',
             customClass: {
                 confirmButton: 'btn btn-danger me-2',
                 cancelButton: 'btn btn-secondary'
             },
             buttonsStyling: false
         }).then((result) => {
             if (result.isConfirmed) {
                 $.ajax({
                     url: '/Expense/DeleteAccountEntry',
                     type: 'POST',
                     contentType: 'application/json',
                     data: JSON.stringify(selectedIds),
                     success: function (res) {
                         if (res.success) {
                                 Swal.fire('Deleted!', 'Expense record has been deleted.', 'success')
                                 .then(() => location.reload());
                         } else {
                                 Swal.fire('Error!', res.message || 'Failed to delete expense.', 'error');
                         }
                     },
                     error: function () {
                         Swal.fire('Error!', 'An unexpected error occurred.', 'error');
                     }
                 });
             }
         });

           }

    function toggleStatus(id, isActive) {
        fetch(`/Expense/ToggleAccountEntryStatus?id=${id}&isActive=${isActive}`, { method: 'POST' })
            .then(r => r.json())
            .then(res => showToast(res.message, res.success ? 'success' : 'danger'));
    }

    function convertFileToBase64(file) {
        return new Promise((resolve, reject) => {
            const reader = new FileReader();
            reader.readAsDataURL(file);
            reader.onload = () => resolve(reader.result.split(',')[1]);
            reader.onerror = error => reject(error);
        });
    }

    function showToast(msg, type = 'success') {
        const wrapper = document.createElement('div');
        wrapper.innerHTML = `<div class="toast align-items-center text-bg-${type} border-0 show position-fixed bottom-0 end-0 m-3" role="alert" style="z-index:9999">
            <div class="d-flex"><div class="toast-body">${msg}</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div></div>`;
        document.body.appendChild(wrapper);
        setTimeout(() => wrapper.remove(), 3000);
    }
</script>
}
