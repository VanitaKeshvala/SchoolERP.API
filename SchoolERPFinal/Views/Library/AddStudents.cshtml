@model SchoolERP.Shared.Models.HRStudentsMembershipPageViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Library Students Membership";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;
    int totalPages = Model.PageSize > 0
                   ? (int)Math.Ceiling((double)Model.TotalRecords / Model.PageSize)
                   : 0;
}

<style>
    .dt-buttons {
        display: none !important;
    }

    .row-input {
        width: 80px;
    }

    .card-input {
        width: 120px;
    }

    .date-input {
        width: 140px;
    }
</style>

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Library Students Membership</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button type="button" id="btnRegisterSelected" class="btn btn-primary top-btn" onclick="saveBulkMembership()">
                <i class="ti ti-id-badge-2 me-1"></i>Save
            </button>
        }
        @if (p.CanPrint)
        {
            <button class="btn btn-secondary d-inline-flex align-items-center top-btn" onclick="triggerExport(4)">
                <i class="ti ti-printer me-1"></i>Print
            </button>
        }
        @if (p.CanExport)
        {
            <div class="dropdown d-inline-flex">
                <button class="btn btn-warning dropdown-toggle top-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(0)"><i class="ti ti-copy me-1"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(1)"><i class="ti ti-file-text me-1"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(2)"><i class="ti ti-file-spreadsheet me-1"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(3)"><i class="ti ti-file-description me-1"></i>PDF</a></li>
                </ul>
            </div>
        }
    </div>
</div>

<!-- start row -->
<div class="row">

    <!-- ── All filters shown inline — no popup ── -->
    <div class="col-xl-12">
        <div class="card mb-2 shadow-tbl-outer">
            <div class="card-body p-3">
                <div class="d-flex align-items-center flex-wrap gap-2">                    
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3 mt-4" style="flex: 1 1 240px; min-width: 220px;">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text"
                               name="search"
                               id="txtSearchInput"
                               value="@Model.SearchTerm"
                               class="form-control border-0 ps-2"
                               placeholder="Search by class, section..." />
                    </div>

                    <div class="col-sm-6 col-md-4 d-none" >
                        <select class="form-select form-control select2"
                                id="ddlFilterCompany"
                                data-placeholder="All Companies">
                            <option value="">All Companies</option>
                            @foreach (var c in Model.Companies ?? new List<MstCompanyViewModel>())
                            {
                                <option value="@c.CompanyId" selected="@(Model.CompanyId == c.CompanyId)">
                                    @c.SchoolName
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-sm-3 col-md-3">
                        <label class="form-label fw-semibold">Classes <span class="text-danger">*</span></label>
                        <select id="fClass" class="form-select form-control select2" onchange="loadSections()" data-placeholder="All Classes">
                            <option value="">All Classes</option>
                            @foreach (var c in Model.Classes)
                            {
                                <option value="@c.ClassID" selected="@(Model.ClassId == c.ClassID)">@c.ClassName</option>
                            }
                        </select>
                    </div>

                    <div class="col-sm-3 col-md-3">
                        <label class="form-label fw-semibold">Sections <span class="text-danger">*</span></label>
                        <select id="fSection" class="form-select form-control select2" data-placeholder="All Sections">
                            <option value="">All Sections</option>
                        </select>
                    </div>
                    <div class="col-sm-2 col-md-2">
                        <label class="form-label fw-semibold">Expiry Date</label>
                        <input type="date" class="form-control expiry-input"  onchange="calcDays(this,1)" id="topExpiry">
                    </div>
                    <div class="col-sm-2 col-md-2">
                        <label class="form-label fw-semibold">Return Date </label>
                        <input type="date" class="form-control renew-input" onchange="calcDays(this,1)" id="topRenew">
                    </div>
                    <div class="col-sm-2 col-md-2">
                        <label class="form-label fw-semibold">NOD</label>
                        <input type="number" class="form-control" id="topNOD">
                    </div>
                    <div class="col-sm-2 col-md-2">
                        <label class="form-label fw-semibold days-input">Days</label>
                        <input type="number" class="form-control" id="topDays" readonly>
                    </div>
                    <div class="col-sm-4 col-md-4 mt-4">
                        <button type="button" class="btn btn-secondary top-btn" id="btnFill" onclick="fillAllRows()">
                            Fill
                        </button>
                        <button type="button" class="btn btn-primary top-btn" id="btnApplyFilters">
                            <i class="ti ti-filter-check me-1"></i>Search
                        </button>
                        <button type="button" class="btn btn-light top-btn" id="btnResetFilters" onclick="resetAllFilters()">
                            Reset
                        </button>
                    </div>
                    

                    <!-- Hidden form for filter submission -->
                    <form method="get" asp-action="AddStudents" id="frmSearch" style="display:none;">
                        <input type="hidden" name="pageIndex" id="hdnPageIndex" value="1" />
                        <input type="hidden" name="search" id="hdnSearch" value="@Model.SearchTerm" />
                        <input type="hidden" name="companyId" id="hdnCompanyId" value="" />
                        <input type="hidden" name="sectionID" id="hdnSectionID" value=@Model.SectionId />
                        <input type="hidden" name="classId" id="hdnClassId" value=@Model.ClassId />
                        <input type="hidden" name="pageSize" id="hdnPageSize" value="@Model.PageSize" />
                    </form>

                </div>
            </div>
        </div>
    </div>

    <!-- Active filter badges -->
    <div class="col-xl-12" id="activeFilterBadges" style="display: none;">
        <div class="card shadow-tbl border-0 py-2 mb-2">
            <div class="card-body p-2 d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold ms-2 me-2">
                    <i class="ti ti-filter-check me-1"></i>Active Filters:
                </span>
                <div id="badgeContainer" class="d-flex flex-wrap gap-2"></div>
                <button class="btn btn-sm btn-link text-danger p-0 ms-auto me-2 fw-bold text-decoration-none"
                        id="btnResetAllFilters" onclick="resetAllFilters()">
                    <i class="ti ti-trash me-1"></i>Clear All
                </button>
            </div>
        </div>
    </div>

    <!-- Supply a real session year value here (see model note) -->
    <input type="hidden" id="hdnSessionYear" value="@Model.SessionYear" />

    <div class="col-xl-12">
        <div class="card shadow-tbl overflow-auto">
            <div class="card-body p-0">
                @if (p.CanAdd)
                {
                    <div class="px-3 pt-3 text-muted small">
                        Tick students, set Expiry / Renew date (Days auto-calculates), fill NOD / Card No, then click Save above.
                    </div>
                }
                <div class="table-responsive">
                    <table class="table table-nowrap mb-0" id="tblMembers">
                        <thead>
                            <tr>
                                <th style="width:36px;"><input type="checkbox" id="chkSelectAll" onchange="toggleSelectAll(this)"></th>
                                <th style="width:40px;">#</th>
                                <th>Roll No</th>
                                <th>Adm No</th>
                                <th>Student Name</th>
                                <th>Father</th>
                                <th>Class (Section)</th>
                                <th style="width:150px;">Expiry Date</th>
                                <th style="width:150px;">Renew Date</th>
                                <th style="width:90px;">NOD</th>
                                <th style="width:90px;">Days</th>
                                <th style="width:160px;">Card No</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Items != null && Model.Items.Any())
                            {
                                int rowNum = ((Model.PageNumber - 1) * Model.PageSize) + 1;
                                @foreach (var c in Model.Items)
                                {
                                    bool isRegistered = c.LibraryCardNo != null;
                                    <tr class="item-row"
                                        data-student-id="@c.StudentID"
                                        data-admission-no="@c.AdmissionNo"
                                        data-library-member-id="@c.LibraryMemberID"
                                        data-is-existing="@(isRegistered ? "1" : "0")">
                                        <td>
                                            @if (p.CanEdit)
                                            {
                                                <input type="checkbox" class="form-check-input row-check" onchange="updateSelectedCount()">
                                            }
                                        </td>
                                        <td>@rowNum</td>
                                        <td>@c.RollNo</td>
                                        <td>@c.AdmissionNo</td>
                                        <td>@c.Name</td>
                                        <td>@c.FatherName</td>
                                        <td>@c.ClassName</td>

                                        <td class="text-center">
                                            @if (p.CanEdit)
                                            {
                                                <input type="date" value="@(c.ExpiryDate?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm date-input expiry-input" onchange="calcDays(this,0)">
                                            }
                                        </td>

                                        <td class="text-center">
                                            @if (p.CanEdit)
                                            {
                                                <input type="date" value="@(c.RenewDate?.ToString("yyyy-MM-dd"))" class="form-control form-control-sm date-input renew-input" onchange="calcDays(this,0)">
                                            }
                                        </td>

                                        <td class="text-center">
                                            @if (p.CanEdit)
                                            {
                                                <input type="number" class="form-control form-control-sm row-input nod-input" value="@(c.NoOfDaysOverdue ?? 7)" min="1">
                                            }
                                        </td>

                                        <td class="text-center">
                                            @if (p.CanEdit)
                                            {
                                                <input type="number" value="@(c.MaxIssueDays ?? 7)" class="form-control form-control-sm row-input days-input" min="1" readonly>
                                            }
                                        </td>

                                        <td class="text-center">
                                            @if (isRegistered)
                                            {
                                                <span class="fw-medium me-2">@c.LibraryCardNo</span>
                                            }
                                            else if (p.CanEdit)
                                            {
                                                <input type="text" class="form-control form-control-sm card-input cardno-input" placeholder="Auto / manual">
                                            }
                                        </td>
                                    </tr>
                                    rowNum++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="11" class="text-center py-4">
                                        <span class="text-muted">Please select filters to load students.</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <!-- ── Pagination ─────────────────────────────────────────────── -->
                    @if (totalPages > 1)
                    {
                        <div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2 mb-3">
                            <div class="text-muted small">
                                Showing
                                <strong>@(((Model.PageNumber - 1) * Model.PageSize) + 1)</strong>
                                –
                                <strong>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalRecords))</strong>
                                of
                                <strong>@Model.TotalRecords</strong> users
                            </div>

                            <nav aria-label="Subject pagination">
                                <ul class="pagination pagination-sm mb-0">

                                    <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                                        <a class="page-link"
                                           href="?pageIndex=1&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&classId=@Model.ClassId&sectionId=@Model.SectionId">
                                            <i class="ti ti-chevrons-left"></i>
                                        </a>
                                    </li>

                                    <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                                        <a class="page-link"
                                           href="?pageIndex=@(Model.PageNumber - 1)&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&classId=@Model.ClassId&sectionId=@Model.SectionId">
                                            <i class="ti ti-chevron-left"></i>
                                        </a>
                                    </li>

                                    @{
                                        int start = Math.Max(1, Model.PageNumber - 2);
                                        int end = Math.Min(totalPages, start + 4);
                                        start = Math.Max(1, end - 4);
                                    }
                                    @for (int pg = start; pg <= end; pg++)
                                    {
                                        <li class="page-item @(pg == Model.PageNumber ? "active" : "")">
                                            <a class="page-link"
                                               href="?pageIndex=@pg&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&classId=@Model.ClassId&sectionId=@Model.SectionId">@pg</a>
                                        </li>
                                    }

                                    <li class="page-item @(Model.PageNumber >= totalPages ? "disabled" : "")">
                                        <a class="page-link"
                                           href="?pageIndex=@(Model.PageNumber + 1)&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&classId=@Model.ClassId&sectionId=@Model.SectionId">
                                            <i class="ti ti-chevron-right"></i>
                                        </a>
                                    </li>

                                    <li class="page-item @(Model.PageNumber >= totalPages ? "disabled" : "")">
                                        <a class="page-link"
                                           href="?pageIndex=@totalPages&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&classId=@Model.ClassId&sectionId=@Model.SectionId">
                                            <i class="ti ti-chevrons-right"></i>
                                        </a>
                                    </li>

                                </ul>
                            </nav>

                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/assets/plugins/sweetalert/sweetalert2.all.min.js"></script>
    <script src="~/assets/js/LibraryStudentsMembership.js"></script>
}
