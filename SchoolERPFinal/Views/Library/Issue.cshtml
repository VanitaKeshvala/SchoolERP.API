
@{
    ViewData["Title"] = "Issue";
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Issue Book</h6>
    </div>

    <div class="d-flex gap-1">
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#examModal"><i class="ti ti-plus"></i> Add Issued Book</button>
        <!-- <button class="btn btn-info"><i
        class="ti ti-pencil me-1"></i>Edit</button> -->
        <a href="#" class="btn btn-secondary"><i class="ti ti-printer me-1"></i> Print</a>
        <button data-bs-toggle="modal" data-bs-target="#return" class="btn btn-teal">
            <i class="ti ti-share-3 me-1"></i>Return
        </button>
        
    </div>

</div>
<!-- End Page Header -->
<!-- start row -->
<div class="row">
    <div class="col-xl-4">
        <div class="card shadow-tbl-outer position-sticky" style="top: 70px;">
            <div class="card-body d-flex align-items-center flex-sm-nowrap flex-wrap row-gap-3">
                <div class="me-3 doctor-profile-img" style="width: 85px;">
                    <a href="#"><img src="assets/img/doctors/doctor-01.jpg" class="rounded" alt=""></a>
                </div>
                <div class="flex-fill">
                    <div class="d-flex align-items-center  mb-1">
                        <h6 class="mb-2 fw-semibold">
                            <a href="#" id="memberNamePlaceholder">-</a>
                        </h6>
                    </div>
                    <p class="mb-2 fs-13">
                        <span class="text-dark">Admission No </span> : <span id="admissionNoPlaceholder">-</span>
                    </p>
                    <p class="mb-2 fs-13">
                        <span class="text-dark">Member ID</span> : <span id="memberIDPlaceholder">-</span>
                    </p>
                    <!-- <p class="mb-2 fs-13">
                        <span class="text-dark">Designation</span> : Teacher
                    </p> -->
                </div>
            </div>
            <!-- end card body -->
            <ul class="list-group list-group-flush">
                <li class="list-group-item list-group-item-action d-flex justify-content-between"><span class="text-dark">Library Card No. :</span> <span id="cardNoPlaceholder">-</span></li>
                <li class="list-group-item list-group-item-action d-flex justify-content-between"><span class="text-dark">Member Type :</span> <span id="memberTypePlaceholder">-</span></li>
                <li class="list-group-item list-group-item-action d-flex justify-content-between"><span class="text-dark">Gender :</span> <span id="genderPlaceholder">-</span></li>
                <li class="list-group-item list-group-item-action d-flex justify-content-between"><span class="text-dark">Mobile :</span> <span id="mobilePlaceholder">-</span></li>
            </ul>
        </div>
        <!-- end card -->
    </div>
    <div class="col-xl-8 ps-md-0">
        <div class="card shadow-tbl">
            <div class="card-header">
                <h6 class="mb-0">Book Issued</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th style="width: 50px;">#</th>
                                <th>Book Title</th>
                                <th>Book Number</th>
                                <th>Issue Date</th>
                                <th>Due Return Date</th>
                                <th>Return Date</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody id="issuedBooksTableBody">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <!-- end col -->
</div>
<!-- end row -->
<!----Add Modal----->
<div class="modal fade" id="examModal" tabindex="-1" aria-labelledby="examModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="issueBookForm">
                <div class="modal-header justify-content-between">
                    <h5 class="modal-title" id="examModalLabel">Add Issued Book</h5>
                    <div class="d-flex gap-1">
                        <button type="submit" class="btn btn-success">
                            <i class="ti ti-cloud me-1"></i> Save
                        </button>
                        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">
                            <i class="ti ti-x me-1"></i> Close
                        </button>
                    </div>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label class="form-label">Book <span class="text-danger">*</span></label>
                            <select id="bookSelect" class="form-select select2" required style="width: 100%;">
                                <option value="">Select Book</option>
                            </select>
                        </div>

                        <div class="col-md-12 mb-3">
                            <label class="form-label">Due Return Date <span class="text-danger">*</span></label>
                            <input type="date" id="dueReturnDate" class="form-control" required>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!----Add Modal----->
<div class="modal fade" id="return" tabindex="-1" aria-labelledby="examModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="returnBookForm">
                <div class="modal-header justify-content-between">
                    <h5 class="modal-title" id="examModalLabel">Confirm Return</h5>
                    <div class="d-flex gap-1">
                        <button type="submit" class="btn btn-success">
                            <i class="ti ti-cloud me-1"></i> Save
                        </button>
                        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">
                            <i class="ti ti-x me-1"></i> Close
                        </button>
                    </div>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label class="form-label">Return Date <span class="text-danger">*</span></label>
                            <input type="date" id="returnDate" class="form-control" required>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const memberId = @ViewBag.LibraryMemberID;
        let selectedIssueId = 0;

        $(document).ready(function () {
            loadMemberDetails();
            loadIssuedBooks();
            loadBooks();

            $('#issueBookForm').on('submit', function (e) {
                e.preventDefault();
                const req = {
                    libraryMemberID: memberId,
                    bookID: $('#bookSelect').val(),
                    issueDate: new Date().toISOString(),
                    dueReturnDate: $('#dueReturnDate').val()
                };

                $.ajax({
                    url: '/Library/IssueBook',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(req),
                    success: function (res) {
                        if (res.success) {
                            $('#examModal').modal('hide');
                            loadIssuedBooks();
                            Swal.fire('Success', res.message, 'success');
                        } else {
                            Swal.fire('Error', res.message, 'error');
                        }
                    }
                });
            });

            $('#returnBookForm').on('submit', function (e) {
                e.preventDefault();
                $.post('/Library/ReturnBook', { issueId: selectedIssueId, returnDate: $('#returnDate').val() }, function (res) {
                    if (res.success) {
                        $('#return').modal('hide');
                        loadIssuedBooks();
                        Swal.fire('Success', res.message, 'success');
                    } else {
                        Swal.fire('Error', res.message, 'error');
                    }
                });
            });
        });

        function loadMemberDetails() {
            $.get('/Library/GetMemberDetails', { id: memberId }, function (res) {
                if (res.success) {
                    const m = res.data;
                    $('#memberNamePlaceholder').text(m.memberName);
                    $('#admissionNoPlaceholder').text(m.admissionNo);
                    $('#memberIDPlaceholder').text(m.libraryMemberID);
                    $('#cardNoPlaceholder').text(m.libraryCardNo || '-');
                    $('#memberTypePlaceholder').text(m.memberType);
                    $('#genderPlaceholder').text(m.gender);
                    $('#mobilePlaceholder').text(m.mobileNo);
                }
            });
        }

        function loadIssuedBooks() {
            $.get('/Library/GetIssuedBooks', { memberId: memberId }, function (res) {
                if (res.success) {
                    let html = '';
                    res.data.forEach((b, index) => {
                        const isReturned = b.status === 2;
                        html += `
                            <tr>
                                <td>${index + 1}</td>
                                <td>${b.bookTitle}</td>
                                <td>${b.bookNo}</td>
                                <td>${new Date(b.issueDate).toLocaleDateString()}</td>
                                <td>${new Date(b.dueReturnDate).toLocaleDateString()}</td>
                                <td>${b.returnDate ? new Date(b.returnDate).toLocaleDateString() : '-'}</td>
                                <td class="text-end">
                                    ${!isReturned ? `<button class="btn btn-sm btn-outline-apply" onclick="openReturnModal(${b.issueReturnID})">Return</button>` : '<span class="badge bg-success">Returned</span>'}
                                </td>
                            </tr>`;
                    });
                    $('#issuedBooksTableBody').html(html);
                }
            });
        }

        function loadBooks() {
            $.get('/Library/GetBookList', function (res) {
                if (res.success) {
                    let html = '<option value="">Select Book</option>';
                    res.data.forEach(b => {
                        html += `<option value="${b.bookID}">${b.bookTitle} (${b.bookNo})</option>`;
                    });
                    $('#bookSelect').html(html);
                    $('#bookSelect').select2({ dropdownParent: $('#examModal') });
                }
            });
        }

        function openReturnModal(id) {
            selectedIssueId = id;
            $('#returnDate').val(new Date().toISOString().split('T')[0]);
            $('#return').modal('show');
        }
    </script>
}

