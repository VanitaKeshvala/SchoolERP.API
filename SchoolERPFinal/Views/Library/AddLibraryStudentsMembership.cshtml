@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.HRStudentsMembershipAddViewModel
@{
    ViewData["Title"] = "Add Class";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Set Student Library Card Number</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveData()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Library/AddStudents" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">

            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <input type="hidden" id="hdnStudentId" value="@Model.StudentId">
                    <input type="hidden" id="hdnLibraryMemberID" value="@Model.EditItem?.LibraryMemberID">
                    <div class="row">
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-semibold">Library Card Number</label>
                            <input type="text" id="txtCardNo" value="@Model.EditItem?.LibraryCardNo" class="form-control" placeholder="Enter card number (optional)" oninput="$('#modalError').text('')">
                            <div id="modalError" class="text-danger small mt-1"></div>                            
                        </div> 
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<link href="~/assets/css/select2.min.css" rel="stylesheet" />

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/assets/js/LibraryStudentsMembership.js"></script>
}