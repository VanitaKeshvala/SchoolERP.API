@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.HRStudentsMembershipAddViewModel
@{
    ViewData["Title"] = "Student Registration";
    var p = Model.Permissions;
}
<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Student Registration</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" id="btnSaveBulk" onclick="saveBulkData()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Library/AddStudents" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>

<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">

                <!-- Filter bar -->
                <div class="row g-2 align-items-end mb-3">
                    <div class="col-md-2">
                        <label class="form-label fw-semibold mb-1">Class</label>
                        <select id="fClass" class="form-select select2" onchange="loadSections()">
                            <option value="">All Classes</option>
                            @foreach (var c in Model.Classes)
                            {
                                <option value="@c.ClassID">@c.ClassName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold mb-1">Section</label>
                        <select id="fSection" class="form-select select2">
                            <option value="">All Sections</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold mb-1">Session</label>
                        <input type="text" id="txtSession" class="form-control" value="@Model.CurrentSession" readonly>
                    </div>
                    <div class="col-md-1">
                        <label class="form-label fw-semibold mb-1">No Of Doc</label>
                        <input type="number" id="txtDefaultNOD" class="form-control" value="10" min="1">
                    </div>
                    <div class="col-md-1">
                        <label class="form-label fw-semibold mb-1">Max Days</label>
                        <input type="number" id="txtDefaultDays" class="form-control" value="7" min="1">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold mb-1">Search</label>
                        <input type="text" id="txtSearchInput" class="form-control" placeholder="Name / Adm No">
                    </div>
                    <div class="col-md-2 d-flex gap-1">
                        <button type="button" class="btn btn-primary flex-fill" id="btnSearch" onclick="loadStudents()">
                            <i class="ti ti-search me-1"></i> Search
                        </button>
                        <button type="button" class="btn btn-outline-secondary flex-fill" id="btnFill" onclick="fillDefaults()">
                            <i class="ti ti-wand me-1"></i> Fill
                        </button>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-bordered align-middle" id="tblBulkMembers">
                        <thead class="table-light">
                            <tr>
                                <th style="width:36px;"><input type="checkbox" id="chkSelectAll" onchange="toggleSelectAll(this)"></th>
                                <th style="width:40px;">#</th>
                                <th>Adm No</th>
                                <th>Student Name</th>
                                <th>Father</th>
                                <th>Class (Section)</th>
                                <th style="width:90px;">NOD</th>
                                <th style="width:90px;">Days</th>
                                <th style="width:140px;">Card No</th>
                            </tr>
                        </thead>
                        <tbody id="tblBulkMembersBody">
                            <tr><td colspan="9" class="text-center text-muted py-3">Select filters and search to load students.</td></tr>
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-2">
                    <span id="lblRecordCount" class="text-muted small">Showing 0 record(s)</span>
                    <span id="lblSelectedCount" class="text-muted small">0 selected</span>
                </div>

            </div>
        </div>
    </div>
</div>

<link href="~/assets/css/select2.min.css" rel="stylesheet" />
@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
        
    </script>
    <script src="~/assets/js/LibraryStudentsMembership.js"></script>
}
