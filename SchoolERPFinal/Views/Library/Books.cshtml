@model SchoolERP.Shared.Models.HRDepartmentPageViewModel
@using System.Security.Claims
@using System.Text.Json
@{
    ViewData["Title"] = "Library Books";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;
    int totalPages = Model.PageSize > 0
                   ? (int)Math.Ceiling((double)Model.TotalRecords / Model.PageSize)
                   : 0;

    // Common query-string tail so every pagination link keeps all active filters.
    // NOTE: kept as a local function so any future filter only needs adding here once.
    string PageLink(int pg) =>
        $"?pageIndex={pg}&pageSize={Model.PageSize}&search={Model.SearchTerm}" +
        $"&companyId={Model.CompanyId}&publisherId={Model.PublisherId}" +
        $"&authorId={Model.AuthorId}&subjectId={Model.SubjectId}" +
        $"&categoryId={Model.CategoryId}&languageId={Model.LanguageId}" +
        $"&seriesId={Model.SeriesId}&documentId={Model.DocumentId}" +
        $"&isActive={Model.IsActiveFilter}&sortColumn={Model.SortColumn}&sortDir={Model.SortDir}";
}
<style>
    .dt-buttons {
        display: none !important;
    }
</style>

<!-- Page Header -->
<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Book List</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <a href="/Library/AddBooks" class="btn btn-primary d-inline-flex align-items-center top-btn">
                <i class="ti ti-plus me-1"></i>Add
            </a>
        }
        @if (p.CanEdit)
        {
            <button id="btnEdit" class="btn btn-info d-inline-flex align-items-center top-btn" disabled onclick="editSelected()">
                <i class="ti ti-pencil me-1"></i>Edit
            </button>
        }
        @if (p.CanDelete)
        {
            <button id="btnDelete" class="btn btn-danger d-inline-flex align-items-center top-btn" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i>Delete
            </button>
        }
        @if (p.CanEdit)
        {
            <button id="btnActive" class="btn btn-success top-btn" disabled onclick="toggleStatus(0,true)">
                <i class="ti ti-circle-check"></i> Active
            </button>
            <button id="btnInactive" class="btn btn-danger top-btn" disabled onclick="toggleStatus(0,false)">
                <i class="ti ti-circle-x"></i> Inactive
            </button>
        }
        @if (p.CanPrint)
        {
            <button class="btn btn-secondary d-inline-flex align-items-center top-btn" onclick="triggerExport(4)">
                <i class="ti ti-printer me-1"></i>Print
            </button>
        }
        @if (p.CanAdd)
        {
            <a href="/Library/ImportBook" class="btn btn-warning btn-sm top-btn d-none">
                <i class="ti ti-file-import me-1"></i>Import
            </a>
        }
        @if (p.CanExport)
        {
            <div class="dropdown d-inline-flex">
                <button class="btn btn-warning dropdown-toggle top-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(0)"><i class="ti ti-copy me-1"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(1)"><i class="ti ti-file-text me-1"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(2)"><i class="ti ti-file-spreadsheet me-1"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(3)"><i class="ti ti-file-description me-1"></i>PDF</a></li>
                </ul>
            </div>
        }

    </div>
</div>

<!-- start row -->
<div class="row">

    <div class="col-xl-12">
        <div class="card mb-2 shadow-tbl-outer">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">

                    <!-- ── Search box (name="search" so form submits it) ── -->
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text"
                               name="search"
                               id="txtSearchInput"
                               value="@Model.SearchTerm"
                               class="form-control border-0 ps-2"
                               placeholder="Search by title, ISBN, book no..."
                               style="min-width: 320px;" />
                    </div>

                    <!-- Hidden form for filter submission — outside Bootstrap dropdown -->
                    <form method="get" asp-action="Books" id="frmSearch" style="display:none;">
                        <input type="hidden" name="pageIndex" id="hdnPageIndex" value="1" />
                        <input type="hidden" name="search" id="hdnSearch" value="@Model.SearchTerm" />
                        <input type="hidden" name="sessionID" id="hdnSessionID" value="" />
                        <input type="hidden" name="pageSize" id="hdnPageSize" value="@Model.PageSize" />

                        <input type="hidden" name="companyId" id="hdnCompanyId" value="@Model.CompanyId" />
                        <input type="hidden" name="publisherId" id="hdnPublisherId" value="@Model.PublisherId" />
                        <input type="hidden" name="authorId" id="hdnAuthorId" value="@Model.AuthorId" />
                        <input type="hidden" name="subjectId" id="hdnSubjectId" value="@Model.SubjectId" />
                        <input type="hidden" name="categoryId" id="hdnCategoryId" value="@Model.CategoryId" />
                        <input type="hidden" name="languageId" id="hdnLanguageId" value="@Model.LanguageId" />
                        <input type="hidden" name="seriesId" id="hdnSeriesId" value="@Model.SeriesId" />
                        <input type="hidden" name="documentId" id="hdnDocumentId" value="@Model.DocumentId" />
                        <input type="hidden" name="isActive" id="hdnIsActive" value="@Model.IsActiveFilter" />
                        <input type="hidden" name="sortColumn" id="hdnSortColumn" value="@Model.SortColumn" />
                        <input type="hidden" name="sortDir" id="hdnSortDir" value="@Model.SortDir" />
                    </form>

                    <div class="dropdown">
                        <a href="#" id="btnFilterToggle"
                           class="btn btn-white border rounded btn-md text-dark fs-14 align-items-center d-flex fw-normal"
                           data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            <i class="ti ti-filter text-gray-5 me-1"></i>Filters
                        </a>

                        <div class="dropdown-menu dropdown-lg dropdown-menu-end filter-dropdown p-0 shadow-tbl"
                             id="filter-dropdown">

                            <div class="d-flex align-items-center justify-content-between border-bottom filter-header">
                                <h6 class="mb-0 fw-bold">Select Criteria</h6>
                                <div class="d-flex align-items-center justify-content-end">
                                    <button type="button" class="btn btn-light btn-md me-2 fw-medium" onclick="resetAllFilters()" id="btnResetFilters">Reset</button>
                                    <button type="button" class="btn text-primary fs-6 fw-medium" id="btnApplyFilters">Filter</button>
                                </div>
                            </div>

                            <div class="filter-body pb-0">
                                <div class="row">
                                    <div class="col-md-12 mb-3">
                                        <label class="form-label mb-1">Company</label>
                                        <select class="form-select form-control select2"
                                                id="ddlFilterCompany"
                                                data-placeholder="Select company">
                                            <option value="">All</option>
                                            @foreach (var c in Model.Companies ?? new List<MstCompanyViewModel>())
                                            {
                                                <option value="@c.CompanyId" selected="@(Model.CompanyId == c.CompanyId)">
                                                    @c.SchoolName
                                                </option>
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Publisher</label>
                                        <select class="form-select form-control select2"
                                                id="ddlFilterPublisher"
                                                data-placeholder="Select publisher">
                                            <option value="">All</option>
                                            @foreach (var x in Model.Publishers ?? new())
                                            {
                                                <option value="@x.Id" selected="@(Model.PublisherId == x.Id)">@x.Name</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Author</label>
                                        <select class="form-select form-control select2"
                                                id="ddlFilterAuthor"
                                                data-placeholder="Select author">
                                            <option value="">All</option>
                                            @foreach (var x in Model.Authors ?? new())
                                            {
                                                <option value="@x.Id" selected="@(Model.AuthorId == x.Id)">@x.Name</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Category</label>
                                        <select class="form-select form-control select2"
                                                id="ddlFilterCategory"
                                                data-placeholder="Select category">
                                            <option value="">All</option>
                                            @foreach (var x in Model.Categories ?? new())
                                            {
                                                <option value="@x.Id" selected="@(Model.CategoryId == x.Id)">@x.Name</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Subject</label>
                                        <select class="form-select form-control select2"
                                                id="ddlFilterSubject"
                                                data-placeholder="Select subject">
                                            <option value="">All</option>
                                            @foreach (var x in Model.Subjects ?? new())
                                            {
                                                <option value="@x.Id" selected="@(Model.SubjectId == x.Id)">@x.Name</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Language</label>
                                        <select class="form-select form-control select2"
                                                id="ddlFilterLanguage"
                                                data-placeholder="Select language">
                                            <option value="">All</option>
                                            @foreach (var x in Model.Languages ?? new())
                                            {
                                                <option value="@x.Id" selected="@(Model.LanguageId == x.Id)">@x.Name</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Series</label>
                                        <select class="form-select form-control select2"
                                                id="ddlFilterSeries"
                                                data-placeholder="Select series">
                                            <option value="">All</option>
                                            @foreach (var x in Model.SeriesList ?? new())
                                            {
                                                <option value="@x.Id" selected="@(Model.SeriesId == x.Id)">@x.Name</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Document type</label>
                                        <select class="form-select form-control select2"
                                                id="ddlFilterDocumentType"
                                                data-placeholder="Select document type">
                                            <option value="">All</option>
                                            @foreach (var x in Model.DocumentTypes ?? new())
                                            {
                                                <option value="@x.Id" selected="@(Model.DocumentId == x.Id)">@x.Name</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Status</label>
                                        <select class="form-select form-control select2" id="ddlFilterIsActive" data-placeholder="Select status">
                                            <option value="">All</option>
                                            <option value="true" selected="@(Model.IsActiveFilter == true)">Active</option>
                                            <option value="false" selected="@(Model.IsActiveFilter == false)">Inactive</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- Active filter badges -->
    <div class="col-xl-12" id="activeFilterBadges" style="display: none;">
        <div class="card shadow-tbl border-0 py-2 mb-2">
            <div class="card-body p-2 d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold ms-2 me-2">
                    <i class="ti ti-filter-check me-1"></i>Active Filters:
                </span>
                <div id="badgeContainer" class="d-flex flex-wrap gap-2"></div>
                <button class="btn btn-sm btn-link text-danger p-0 ms-auto me-2 fw-bold text-decoration-none"
                        id="btnResetAllFilters" onclick="resetAllFilters()">
                    <i class="ti ti-trash me-1"></i>Clear All
                </button>
            </div>
        </div>
    </div>


    <div class="col-xl-12">
        <div class="card shadow-tbl overflow-auto">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-nowrap mb-0" id="tblBooks">
                        <thead>
                            <tr>
                                <th style="width: 50px;">Select</th>
                                <th>Book Title</th>
                                <th>Book No</th>
                                <th>Publisher Name</th>
                                <th>Author Names</th>
                                <th>Price</th>
                                <th>Post Date</th>
                                <th>Status</th>

                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.ItemsBooks != null)
                            {
                                @foreach (var c in Model.ItemsBooks)
                                {
                                    <tr class="item-row" style="cursor: pointer;">
                                        <td class="ps-4 text-center">
                                            <input type="checkbox" name="selectedClass"
                                                   class="form-check-input student-checkbox" onclick="selectItem(@c.BookID, this)"
                                                   value="@c.BookID">
                                        </td>
                                        <td>
                                            <a href="/Library/BookDetails/@c.BookID" target="_blank" class="btn btn-sm btn-white border px-2 py-1" title="Set Accession Status">
                                                @c.BookTitle
                                            </a>
                                        </td>
                                        <td>@c.BookNo</td>
                                        <td>@c.PublisherName</td>
                                        <td>@c.AuthorNames</td>
                                        <td>@c.Price</td>
                                        <td>@c.PostDate?.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @if (p.CanEdit)
                                            {
                                                <div class="form-check form-switch" onclick="event.stopPropagation()">
                                                    <input class="form-check-input class-status-switch" type="checkbox" @(c.IsActive ? "checked" : "") onchange="toggleStatus(@c.BookID, this.checked)">
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="badge @(c.IsActive ? "bg-success" : "bg-secondary")">@(c.IsActive ? "Active" : "Inactive")</span>
                                            }
                                        </td>

                                    </tr>
                                }

                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4">
                                        <span class="text-muted">No records found.</span>
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                    <!-- ── Pagination ─────────────────────────────────────────────── -->
                    @if (totalPages > 1)
                    {
                        <div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2 mb-3">
                            <!-- Record info -->
                            <div class="text-muted small">
                                Showing
                                <strong>@(((Model.PageNumber - 1) * Model.PageSize) + 1)</strong>
                                –
                                <strong>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalRecords))</strong>
                                of
                                <strong>@Model.TotalRecords</strong> users
                            </div>

                            <nav aria-label="Subject pagination">
                                <ul class="pagination pagination-sm mb-0">

                                    <!-- First -->
                                    <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                                        <a class="page-link" href="@PageLink(1)">
                                            <i class="ti ti-chevrons-left"></i>
                                        </a>
                                    </li>

                                    <!-- Prev -->
                                    <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                                        <a class="page-link" href="@PageLink(Model.PageNumber - 1)">
                                            <i class="ti ti-chevron-left"></i>
                                        </a>
                                    </li>

                                    <!-- Page numbers — show 5 around current -->
                                    @{
                                        int start = Math.Max(1, Model.PageNumber - 2);
                                        int end = Math.Min(totalPages, start + 4);
                                        start = Math.Max(1, end - 4);
                                    }
                                    @for (int pg = start; pg <= end; pg++)
                                    {
                                        <li class="page-item @(pg == Model.PageNumber ? "active" : "")">
                                            <a class="page-link" href="@PageLink(pg)">@pg</a>
                                        </li>
                                    }

                                    <!-- Next -->
                                    <li class="page-item @(Model.PageNumber >= totalPages ? "disabled" : "")">
                                        <a class="page-link" href="@PageLink(Model.PageNumber + 1)">
                                            <i class="ti ti-chevron-right"></i>
                                        </a>
                                    </li>

                                    <!-- Last -->
                                    <li class="page-item @(Model.PageNumber >= totalPages ? "disabled" : "")">
                                        <a class="page-link" href="@PageLink(totalPages)">
                                            <i class="ti ti-chevrons-right"></i>
                                        </a>
                                    </li>

                                </ul>
                            </nav>

                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal (unchanged) -->
<div class="modal fade" id="upsertModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header d-flex justify-content-between align-items-center">
                <h5 class="modal-title" id="modalTitle">Add Book</h5>
                <div>

                    <button class="btn btn-success btn-sm" onclick="saveData()">
                        <i class="ti ti-cloud me-1"></i>Save
                    </button>
                    <button class="btn btn-danger btn-sm" data-bs-dismiss="modal">
                        <i class="ti ti-x me-1"></i>Close
                    </button>
                </div>
            </div>
            <div class="modal-body">
                <form id="upsertForm">
                    <input type="hidden" id="hdnId" value="0" />
                    <div class="row row-gap-3">
                        <div class="col-md-6">
                            <label class="form-label">Book Title <span class="text-danger">*</span></label>
                            <input type="text" id="txtTitle" class="form-control" required placeholder="Enter book title">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Book Number</label>
                            <input type="text" id="txtNo" class="form-control" placeholder="e.g., LIB-001">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">ISBN Number</label>
                            <input type="text" id="txtISBN" class="form-control">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Publisher</label>
                            <input type="text" id="txtPublisher" class="form-control">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Author</label>
                            <input type="text" id="txtAuthor" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Subject</label>
                            <input type="text" id="txtSubject" class="form-control">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Rack Number</label>
                            <input type="text" id="txtRack" class="form-control" placeholder="e.g., A-12">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Qty <span class="text-danger">*</span></label>
                            <input type="number" id="txtQty" class="form-control" required min="0" value="1">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Book Price (₹)</label>
                            <input type="number" id="txtPrice" class="form-control" step="0.01" value="0.00">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Post Date</label>
                            <input type="date" id="txtDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Description</label>
                            <textarea id="txtDescription" class="form-control" rows="3" placeholder="Optional description..."></textarea>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/assets/plugins/sweetalert/sweetalert2.all.min.js"></script>
    <script src="~/assets/js/Books.js">
    </script>
}
