@model SchoolERP.Shared.Models.HRDepartmentPageViewModel
@using System.Security.Claims
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    ViewData["Title"] = "Library Staff Membership";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0) PermHelper.LoadPermissions(currentUserId);

    var canPrint = PermHelper.HasPermissionByUrl("/Library/Books", "Print");
    var canExport = PermHelper.HasPermissionByUrl("/Library/Books", "Export");
}

<style>
.dt-buttons { display: none !important; }
</style>

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Library Staff Membership</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (canPrint)
        {
            <button class="btn btn-secondary d-inline-flex align-items-center top-btn" onclick="triggerExport(4)">
                <i class="ti ti-printer me-1"></i>Print
            </button>
        }
        @if (canExport)
        {
            <div class="dropdown d-inline-flex">
                <button class="btn btn-warning dropdown-toggle top-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(0)"><i class="ti ti-copy me-1"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(1)"><i class="ti ti-file-text me-1"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(2)"><i class="ti ti-file-spreadsheet me-1"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(3)"><i class="ti ti-file-description me-1"></i>PDF</a></li>
                </ul>
            </div>
        }
    </div>
</div>

<!-- start row -->
<div class="row">
    <div class="col-md-12">
        <div class="card shadow-tbl-outer mb-2">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3 bg-white">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text" id="txtSearchInput" class="form-control border-0 ps-2" style="min-width: 220px;" placeholder="Search by name or staff code..." onkeyup="loadData()" />
                    </div>
                    <div class="dropdown">
                        <a href="#" id="btnFilterToggle" class="btn btn-white border rounded btn-md text-dark fs-14 align-items-center d-flex fw-normal"
                           data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            <i class="ti ti-filter text-gray-5 me-1"></i>Filters
                        </a>
                        <div class="dropdown-menu dropdown-lg dropdown-menu-end filter-dropdown p-0 shadow-tbl" id="filter-dropdown">
                            <div class="d-flex align-items-center justify-content-between border-bottom filter-header py-2">
                                <h6 class="mb-0">Select Criteria</h6>
                                <div class="d-flex align-items-center justify-content-end">
                                    <button type="button" class="btn text-primary fs-6 fw-medium" onclick="loadData()">Filter</button>
                                </div>
                            </div>
                            <div class="filter-body pb-0 p-3">
                                <div class="mb-3">
                                    <label class="form-label mb-1">Department</label>
                                    <select id="fDept" class="form-select form-control select2">
                                        <option value="">All Departments</option>
                                        @foreach (var d in ViewBag.Departments)
                                        {
                                            <option value="@d.DepartmentID">@d.DepartmentName</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-12" id="activeFilterBadges" style="display: none;">
        <div class="card shadow-tbl py-2 mb-2">
            <div class="card-body p-2 d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold ms-2 me-2"><i class="ti ti-filter-check me-1"></i>Active Filters:</span>
                <div id="badgeContainer" class="d-flex flex-wrap gap-2"></div>
                <button class="btn btn-sm btn-link text-danger p-0 ms-auto me-2 fw-bold text-decoration-none" id="btnResetAllFilters" onclick="resetAllFilters()">
                    <i class="ti ti-trash me-1"></i>Clear All
                </button>
            </div>
        </div>
    </div>

    <div class="col-xl-12">
        <div class="card shadow-tbl overflow-auto">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-nowrap mb-0" id="tblMembers">
                        <thead>
                            <tr>
                                <th style="width: 50px;" class="ps-3">#</th>
                                <th>Staff Code</th>
                                <th>Staff Name</th>
                                <th>Department</th>
                                <th>Card No</th>
                                <th>Gender</th>
                                <th>Mobile Number</th>
                                <th>Registered On</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="listBody">
                           
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Member Modal (Simplified) -->
<div class="modal fade" id="cardModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header d-flex justify-content-between align-items-center">
                <h5 class="modal-title">Set Library Card Number</h5>
                <div>
                    <button class="btn btn-success btn-sm" onclick="saveData()">
                        <i class="ti ti-device-floppy me-1"></i>Save
                    </button>
                    <button class="btn btn-danger btn-sm" data-bs-dismiss="modal">
                        <i class="ti ti-x me-1"></i>Close
                    </button>
                </div>
            </div>
            <div class="modal-body">
                <div class="row row-gap-3">
                    <div class="col-md-12">
                        <h6 class="mb-2 fw-bold text-primary">Staff: <span id="spanStaff" class="text-dark"></span></h6>
                        <label class="form-label">Library Card Number <span class="text-danger">*</span></label>
                        <input type="text" id="txtCardNo" class="form-control" placeholder="Enter card number" oninput="$('#modalError').text(''); $(this).removeClass('is-invalid');">
                        <div id="modalError" class="text-danger small mt-1"></div>
                        <input type="hidden" id="hdnStaffId" value="0">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/assets/plugins/sweetalert/sweetalert2.all.min.js"></script>
    <script>

function triggerExport(index) {
        if ($.fn.DataTable.isDataTable('#tblMembers')) {
                const table = $('#tblMembers').DataTable();
            table.button(index).trigger();
        }
    }
        let memberTable;
$(document).ready(function () {
            memberTable = $('#tblMembers').DataTable({
            dom: 'Bfrtip',
            buttons: [
                { extend: 'copy', exportOptions: { columns: [1, 2, 3, 4, 5, 6,7] } },
                    { extend: 'csv', exportOptions: { columns: [1, 2, 3, 4, 5, 6,7] } },
                    { extend: 'excel', exportOptions: { columns: [1, 2, 3, 4, 5, 6,7] } },
                    { extend: 'pdf', exportOptions: { columns: [1, 2, 3, 4, 5, 6,7] } },
                    { extend: 'print', exportOptions: { columns: [1, 2, 3, 4, 5, 6,7] } }
            ],
            searching: false,
            paging: false,
            info: false,
                language: {
                    emptyTable: "Please select Department to load staff."
                }
        });
})

        $(document).ready(function () {
            $('.select2').select2({ width: '100%' });
            $('#filter-dropdown').on('click', function (e) {
                e.stopPropagation();
            });
            renderFilterBadges();
        });

        function loadData() {

            const deptId = $('#fDept').val();
            const search = $('#txtSearchInput').val();

            if (!deptId && !search) {

                memberTable.clear().draw();

                renderFilterBadges();

                return;
            }

            $.get('/Library/GetMemberList',
                {
                    type: 'Staff',
                    deptId: deptId || '',
                    search: search || ''
                },
                function (res) {

                    memberTable.clear();

                    if (res.success && res.data && res.data.length > 0) {

                        res.data.forEach((item, index) => {

                            const isMember = item.libraryMemberID > 0;

                            memberTable.row.add([
                                index + 1,
                                item.admissionNo || '',
                                `<span class="text-primary">${item.name || ''}</span>`,
                                item.className || '',
                                item.libraryCardNo || '-',
                                item.gender || '',
                                item.mobileNo || '',
                                item.registeredOn
                                    ? new Date(item.registeredOn).toLocaleDateString('en-GB')
                                    : '-',
                                isMember
                                    ? `<button class="btn btn-outline-danger btn-sm px-3"
                                            onclick="deleteMembership(${item.staffID})">
                                            <i class="ti ti-trash me-1"></i>Remove
                                       </button>`
                                    : `<button class="btn btn-outline-success btn-sm px-3"
                                            onclick="openCardModal(${item.staffID}, '${item.name.replace(/'/g, "\\'")}')">
                                            <i class="ti ti-plus me-1"></i>Add
                                       </button>`
                            ]);
                        });
                    }

                    memberTable.draw();

                    renderFilterBadges();

                    const toggle = document.getElementById('btnFilterToggle');

                    if (toggle) {
                        bootstrap.Dropdown.getOrCreateInstance(toggle).hide();
                    }
                });
        }

        // --- Filter Badges Logic ---
        function renderFilterBadges() {
            const container = document.getElementById('badgeContainer');
            const mainContainer = document.getElementById('activeFilterBadges');
            if (!container) return;
            container.innerHTML = '';

            const filters = [
                { id: 'txtSearchInput', label: 'Search', type: 'text' },
                { id: 'fDept', label: 'Department', type: 'select' }
            ];

            let activeCount = 0;

            filters.forEach(f => {
                const el = document.getElementById(f.id);
                if (!el) return;

                let value = el.value;
                let text = '';

                if (f.type === 'text') {
                    if (value.trim()) {
                        text = value;
                        activeCount++;
                    }
                } else if (f.type === 'select') {
                    if (value && value !== 'all' && value !== '') {
                        const selectedOption = el.options[el.selectedIndex];
                        if (selectedOption && selectedOption.value !== "") {
                            text = selectedOption.text;
                            activeCount++;
                        }
                    }
                }

                if (text) {
                    const badge = document.createElement('span');
                    badge.className = 'badge bg-primary-subtle text-primary border border-primary-subtle d-flex align-items-center gap-1 fw-medium px-2 py-1';
                    badge.innerHTML = `${f.label}: ${text} <i class="ti ti-x ms-1 cursor-pointer" onclick="removeFilter('${f.id}')" style="font-size: 10px;"></i>`;
                    container.appendChild(badge);
                }
            });

            if (activeCount > 0) {
                mainContainer.style.display = 'block';
            } else {
                mainContainer.style.display = 'none';
            }
        }

        function removeFilter(filterId) {
            const el = document.getElementById(filterId);
            if (!el) return;

            if (el.tagName === 'INPUT' && filterId === 'txtSearchInput') {
                el.value = '';
                loadData();
            } else {
                el.value = '';
                if (window.jQuery && jQuery(el).data('select2')) {
                    jQuery(el).trigger('change.select2');
                }
                loadData();
            }
        }

        function resetAllFilters() {
            $('#txtSearchInput').val('');
            $('#fDept').val('').trigger('change');
            loadData();
            renderFilterBadges();
        }

        function openCardModal(id, name) {
            $('#hdnStaffId').val(id);
            $('#spanStaff').text(name);
            $('#txtCardNo').val('');
            $('#modalError').text('');
            $('#cardModal').modal('show');
        }

        function saveData() {
            const id = $('#hdnStaffId').val();
            const cardNo = $('#txtCardNo').val().trim();

            if (!cardNo) {
                $('#modalError').text('Card Number is required');
                $('#txtCardNo').addClass('is-invalid');
                return;
            }

            const data = {
                memberType: 'Staff',
                staffID: id,
                libraryCardNo: cardNo
            };

            $.ajax({
                url: '/Library/AddMember',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (res) {
                    if (res.success) {
                        showToast(res.message, 'success');
                        $('#cardModal').modal('hide');
                        loadData();
                    } else {
                        $('#modalError').text(res.message);
                    }
                }
            });
        }

        function deleteMembership(staffId) {
            Swal.fire({
                title: 'Cancel Membership?',
                text: "Are you sure you want to remove this staff member from library membership?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, cancel it!',
                customClass: { confirmButton: 'btn btn-danger me-2', cancelButton: 'btn btn-secondary' },
                buttonsStyling: false
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Library/DeleteMember', { id: 0, staffId: staffId }, function (res) {
                        if (res.success) {
                            showToast(res.message, 'success');
                            loadData();
                        } else {
                            Swal.fire('Error!', res.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}
