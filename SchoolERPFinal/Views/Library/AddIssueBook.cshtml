@using System.Text.Json
@model SchoolERP.Shared.Models.IssueBookAddViewModel
@{
    ViewData["Title"] = "Add Issued Book";
    var p = Model.Permissions;
}

<style>
    #tblIssueBody input.rmk-input {
        border: 1px solid transparent;
        background: transparent;
        width: 100%;
        font-size: 12.5px;
        padding: 2px 4px;
        border-radius: 4px;
    }

        #tblIssueBody input.rmk-input:hover,
        #tblIssueBody input.rmk-input:focus {
            border-color: #ced4da;
            background: #fff;
        }

    .pincode-dropdown {
        position: absolute;
        width: 100%;
        max-height: 260px;
        overflow-y: auto;
        z-index: 1050; /* sit above sibling cards / sticky elements */
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 0 0 6px 6px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
        margin-top: 2px;
        padding: 0;
        list-style: none;
    }

        .pincode-dropdown .list-group-item {
            border-left: none;
            border-right: none;
            padding: 8px 12px;
        }

            .pincode-dropdown .list-group-item:first-child {
                border-top: none;
            }

            .pincode-dropdown .list-group-item:last-child {
                border-bottom: none;
            }

        /* thin, unobtrusive scrollbar */
        .pincode-dropdown::-webkit-scrollbar {
            width: 6px;
        }

        .pincode-dropdown::-webkit-scrollbar-thumb {
            background: #c1c9d2;
            border-radius: 3px;
        }
</style>

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Add Issued Book</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveIssue()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Library/Issue/@Model.LibraryMemberID" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>

<div class="row">

    <div class="col-xl-4">
        <div class="card shadow-tbl-outer position-sticky" style="top: 70px">
            <div class="p-2">
                <div class="col-md-12 mb-3">
                    <label class="form-label fw-semibold">Member Type <span class="text-danger">*</span></label>
                    <select id="ddlMemberType" name="MemberType" class="form-select">
                        <option value="">-- Select Member Type --</option>
                        <option value="Student">Student</option>
                        <option value="Staff">Staff</option>
                    </select>
                </div>
                <div class="col-md-12 mb-3">
                    <label class="form-label fw-semibold">Search Card no <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="txtsearchText" placeholder="Search Card no" autocomplete="off">
                    <ul id="pinCardSuggestions" class="pincode-dropdown list-group">
                    </ul>
                </div>
            </div>
            <div id="memberDetailCard" class="card" style="display:none;">
                <div class="card-body d-flex align-items-center flex-sm-nowrap flex-wrap row-gap-3">
                    <div class="me-3 doctor-profile-img" style="width: 85px">
                        <a href="#">
                            <img id="memberPhoto" src="assets/img/doctors/doctor-01.jpg" class="rounded" alt="" />
                        </a>
                    </div>
                    <div class="flex-fill">
                        <div class="d-flex align-items-center mb-1">
                            <h6 class="mb-2 fw-semibold">
                                <a href="#" id="memberName">-</a>
                            </h6>
                            <span class="badge bg-info ms-2" id="memberTypeBadge">-</span>
                        </div>

                        <!-- Student-only fields -->
                        <div id="studentOnlyFields">
                            <p class="mb-2 fs-13">
                                <span class="text-dark">Admission No</span> : <span id="memberAdmissionNo">-</span>
                            </p>
                            <p class="mb-2 fs-13">
                                <span class="text-dark">Roll Number</span> : <span id="memberRollNo">-</span>
                            </p>
                        </div>

                        <!-- Staff-only fields -->
                        <div id="staffOnlyFields" style="display:none;">
                            <p class="mb-2 fs-13">
                                <span class="text-dark">Staff Code</span> : <span id="memberStaffCode">-</span>
                            </p>
                            <p class="mb-2 fs-13">
                                <span class="text-dark">Department</span> : <span id="memberDepartment">-</span>
                            </p>
                        </div>
                    </div>
                </div>
                <!-- end card body -->

                <ul class="list-group list-group-flush">
                    <!-- Student-only rows -->
                    <li class="list-group-item list-group-item-action d-flex justify-content-between studentOnlyRow">
                        <span class="text-dark">Class :</span> <span id="memberClassName">-</span>
                    </li>
                    <li class="list-group-item list-group-item-action d-flex justify-content-between studentOnlyRow">
                        <span class="text-dark">Section :</span> <span id="memberSectionName">-</span>
                    </li>
                    <li class="list-group-item list-group-item-action d-flex justify-content-between studentOnlyRow">
                        <span class="text-dark">No Of Documents:</span> <span id="memberNoOfDocuments">-</span>
                    </li>
                    <li class="list-group-item list-group-item-action d-flex justify-content-between studentOnlyRow">
                        <span class="text-dark">MAX Days :</span> <span id="memberMAXDays">-</span>
                    </li>
                    <!-- Staff-only rows -->
                    <li class="list-group-item list-group-item-action d-flex justify-content-between staffOnlyRow" style="display:none;">
                        <span class="text-dark">Designation :</span> <span id="memberDesignation">-</span>
                    </li>

                    <!-- Common rows -->
                    <li class="list-group-item list-group-item-action d-flex justify-content-between">
                        <span class="text-dark">Gender :</span> <span id="memberGender">-</span>
                    </li>
                    <li class="list-group-item list-group-item-action d-flex justify-content-between">
                        <span class="text-dark">Mobile No :</span> <span id="memberMobileNo">-</span>
                    </li>
                    <li class="list-group-item list-group-item-action d-flex justify-content-between">
                        <span class="text-dark">Email :</span> <span id="memberEmail">-</span>
                    </li>
                    <li class="list-group-item list-group-item-action d-flex justify-content-between">
                        <span class="text-dark">Library Card No :</span> <span id="memberLibraryCardNo">-</span>
                    </li>
                    <li class="list-group-item list-group-item-action d-flex justify-content-between">
                        <span class="text-dark">Expiry Date :</span> <span id="memberExpiryDate">-</span>
                    </li>
                    <li class="list-group-item list-group-item-action d-flex justify-content-between">
                        <span class="text-dark">Status :</span> <span id="memberIsActive">-</span>
                    </li>
                </ul>
            </div>
        </div>
        <!-- end card -->
    </div>
    <div class="col-xl-8">
        <div class="card shadow-tbl-outer mb-2">
            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <!-- put this right after #memberDetailCard, still inside the same sticky column -->
                    <div id="memberLimitAlert" class="alert alert-warning mt-2 py-2 px-3 fs-13" style="display:none;"></div>
                    <div class="row align-items-end">
                        <div class="col-md-3 mb-3">
                            <label class="form-label fw-semibold">Issue No <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtIssueNo" value="@Model.IssueNo"
                                   placeholder="Scan or type accession no" disabled autocomplete="off">
                        </div>
                        <div class="col-md-9 mb-3" style="position: relative;">
                            <label class="form-label fw-semibold">Accession No <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtAccessionNo"
                                   placeholder="Scan or type accession no" autocomplete="off">
                            <ul id="accessionSuggestions" class="pincode-dropdown list-group"></ul>
                            <div class="invalid-feedback" id="errAccessionNo"></div>
                        </div>
                        <div class="col-md-3 mb-3 d-none">
                            <label class="form-label fw-semibold">Book Title</label>
                            <input type="text" class="form-control" id="txtBookTitle" readonly placeholder="--">
                        </div>
                        <div class="col-md-3 mb-3 d-none">
                            <label class="form-label fw-semibold">Author</label>
                            <input type="text" class="form-control" id="txtAuthor" readonly placeholder="--">
                        </div>

                        <div class="col-md-3 mb-3 d-none">
                            <label class="form-label fw-semibold">Document Type</label>
                            <select class="form-select select2" id="ddlDocumentStatus" style="width: 100%;">
                                <option value="">-- Select --</option>
                                @foreach (var rt in Model.DocumentStatus)
                                {
                                    <option value="@rt.Id">@rt.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label fw-semibold">Due Return Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="txtDueDate">
                            <div class="invalid-feedback" id="errDueDate"></div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Remarks</label>
                            <input type="text" class="form-control" id="txtRemarks" placeholder="Optional remarks for this copy">
                        </div>
                        <div class="col-md-2 mb-4">
                            <label class="form-check-label fw-semibold" for="chkBookBank">Book Bank</label>
                            <input type="checkbox" class="form-check-input" id="chkBookBank">
                            
                        </div>
                        <div class="col-md-3 mb-3 d-flex align-items-end">
                            <button type="button" class="btn btn-primary w-100" onclick="addAccession()">
                                <i class="ti ti-plus me-1"></i>Add to List
                            </button>
                        </div>
                    </div>
                    <div class="row">
                    </div>
                </form>
            </div>
        </div>
        <div class="card shadow-tbl-outer">
            <div class="card-body p-0">
                <div class="d-flex align-items-center justify-content-between px-3 pt-3">
                    <h6 class="fw-bold mb-0">
                        Books to Issue
                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle ms-1" id="lblListCount">0</span>
                    </h6>
                </div>
                <div class="table-responsive mt-2">
                    <table class="table table-nowrap mb-0" id="tblIssue">
                        <thead>
                            <tr>
                                <th style="width:50px;" class="ps-3">#</th>
                                <th>Accession No</th>
                                <th>Book Title</th>                                
                                <th>Due Date</th>
                                <th>Remarks</th>
                                <th style="width:40px;"></th>
                            </tr>
                        </thead>
                        <tbody id="tblIssueBody">
                            <tr id="rowEmptyState">
                                <td colspan="8" class="text-center py-4 text-muted">No accessions added yet.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
   
</div>

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.CURRENT_MEMBER_ID = @Model.LibraryMemberID;
    </script>
    <script src="~/assets/plugins/sweetalert/sweetalert2.all.min.js"></script>
    <script src="~/assets/js/IssuedBooks.js"></script>
}
