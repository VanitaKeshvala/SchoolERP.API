@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.IssueBookAddViewModel
@{
    ViewData["Title"] = "Add Issued Book";
    var p = Model.Permissions;
}

<form id="issueBookForm">
    <!-- Page Header -->
    <div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
        <div>
            <h6 class="fw-bold mb-0">@(Model.EditIssueBooks == null ? "Add Issued Book" : "Add Issued Book")</h6>
        </div>
        <div class="d-flex align-items-center flex-wrap gap-1">
            @if (p.CanAdd)
            {
                <button class="btn btn-success top-btn">
                    <i class="ti ti-device-floppy me-1"></i> Save
                </button>
            }
            <a href="/Library/Issue/@Model.LibraryMemberID" class="btn btn-secondary top-btn">
                <i class="ti ti-arrow-left me-1"></i> Back
            </a>
        </div>
    </div>
    <div class="row">
        <div class="col-xl-12">
            <div class="card shadow-tbl-outer">
                <div class="card-body">
                    <div class="row row-gap-3">
                        <input type="hidden" name="id" id="hdnid" value=@Model.LibraryMemberID />
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Book <span class="text-danger">*</span></label>
                            <select id="bookSelect" class="form-select select2" required style="width: 100%;">
                                <option value="">Select Book</option>
                                @foreach (var c in Model.BookViewModels ?? new List<BookViewModel>())
                                {
                                    <option value="@c.BookID">
                                        @c.BookTitle
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Due Return Date <span class="text-danger">*</span></label>
                            <input type="date" id="dueReturnDate" class="form-control" required>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    
</form>
@section Scripts {

    <link href="~/assets/css/select2.min.css" rel="stylesheet" />
    <script src="~/assets/js/select2.min.js"></script>
    <script src="~/assets/js/IssuedBooks.js"></script>

}