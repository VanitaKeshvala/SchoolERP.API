@using System.Text.Json
@model SchoolERP.Shared.Models.IssueBookAddViewModel
@{
    ViewData["Title"] = "Confirm Return";
    var p = Model.Permissions;
}

<!--
    CHANGE SUMMARY
    ==============
    1. Page no longer only shows books for the LibraryMemberID baked into the URL.
       It now has a Member Type + Search Card No/Name box (same pattern as
       IssueBookAdd.cshtml) so staff can look up ANY student/staff and pull
       their currently-issued (unreturned) books into the table via AJAX.

    2. If the page IS opened with a LibraryMemberID in the route (e.g. clicked
       "Return" from the Issue list), that member's books are auto-loaded on
       page load — search is only needed to switch to a different member.

    3. The table body is no longer server-rendered from Model.BookReturnViewModels.
       It is rendered/re-rendered client-side from a NEW endpoint:

           GET /Library/GetIssuedBooksByMember?libraryMemberID={id}
           -> { success: true, data: [
                 { issueReturnID, bookTitle, bookNo, issueDate, dueReturnDate, status }
               ]}

       *** This endpoint needs to be added on the backend if it doesn't exist. ***
       It should return the same shape as Model.BookReturnViewModels used to
       supply, just as JSON instead of via the Razor model.

    4. Fine Amount is now auto-calculated: whenever the Return Date changes or
       a row is checked/unchecked, the total fine for all *checked, overdue*
       rows is computed as (overdue days * FINE_PER_DAY) and written into
       #commonFineAmount. Staff can still override the number manually.
-->

<form id="returnBookForm">
    <!-- Page Header -->
    <div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
        <div>
            <h6 class="fw-bold mb-0">Confirm Return</h6>
        </div>
        <div class="d-flex align-items-center flex-wrap gap-1">
            @if (p.CanAdd)
            {
                <button type="submit" id="btnSaveReturns" class="btn btn-success top-btn">
                    <i class="ti ti-device-floppy me-1"></i> Save
                </button>
            }
            <a href="/Library/Issue/@Model.LibraryMemberID" class="btn btn-secondary top-btn">
                <i class="ti ti-arrow-left me-1"></i> Back
            </a>
        </div>
    </div>

    <input type="hidden" name="id" id="hdnLibraryMemberID" value="@Model.LibraryMemberID" />

    <div class="row">

        <!-- ── Member search (Student / Staff) ─────────────────────────────── -->
        <div class="col-xl-4">
            <div class="card shadow-tbl-outer position-sticky" style="top: 70px">
                <div class="p-2">
                    <div class="col-md-12 mb-3" style="position: relative;">
                        <label class="form-label fw-semibold">Accession No <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="txtAccessionNo"
                               placeholder="Scan or type accession no" autocomplete="off">
                        <ul id="accessionSuggestions" class="pincode-dropdown list-group"></ul>
                        <div class="invalid-feedback" id="errAccessionNo"></div>
                    </div>
                    <div class="col-md-12 mb-3">
                        <label class="form-label fw-semibold">Member Type</label>
                        <select id="ddlMemberType" class="form-select">
                            <option value="">-- Select Member Type --</option>
                            <option value="Student">Student</option>
                            <option value="Staff">Staff</option>
                        </select>
                    </div>
                    <div class="col-md-12 mb-3" style="position: relative;">
                        <label class="form-label fw-semibold">Search Card No / Name</label>
                        <input type="text" class="form-control" id="txtsearchText"
                               placeholder="Search card no / name" autocomplete="off">
                        <ul id="pinCardSuggestions" class="pincode-dropdown list-group"></ul>
                    </div>
                </div>

                <div id="memberDetailCard" class="card" style="display:none;">
                    <div class="card-body d-flex align-items-center flex-sm-nowrap flex-wrap row-gap-3">
                        <div class="me-3 doctor-profile-img" style="width: 85px">
                            <a href="#">
                                <img id="memberPhoto" src="assets/img/doctors/doctor-01.jpg" class="rounded" alt="" />
                            </a>
                        </div>
                        <div class="flex-fill">
                            <div class="d-flex align-items-center mb-1">
                                <h6 class="mb-2 fw-semibold">
                                    <a href="#" id="memberName">-</a>
                                </h6>
                                <span class="badge bg-info ms-2" id="memberTypeBadge">-</span>
                            </div>

                            <!-- Student-only fields -->
                            <div id="studentOnlyFields">
                                <p class="mb-2 fs-13">
                                    <span class="text-dark">Admission No</span> : <span id="memberAdmissionNo">-</span>
                                </p>
                                <p class="mb-2 fs-13">
                                    <span class="text-dark">Roll Number</span> : <span id="memberRollNo">-</span>
                                </p>
                            </div>

                            <!-- Staff-only fields -->
                            <div id="staffOnlyFields" style="display:none;">
                                <p class="mb-2 fs-13">
                                    <span class="text-dark">Staff Code</span> : <span id="memberStaffCode">-</span>
                                </p>
                                <p class="mb-2 fs-13">
                                    <span class="text-dark">Department</span> : <span id="memberDepartment">-</span>
                                </p>
                            </div>
                        </div>
                    </div>
                    <!-- end card body -->

                    <ul class="list-group list-group-flush">
                        <!-- Student-only rows -->
                        <li class="list-group-item list-group-item-action d-flex justify-content-between studentOnlyRow">
                            <span class="text-dark">Class :</span> <span id="memberClassName">-</span>
                        </li>
                        <li class="list-group-item list-group-item-action d-flex justify-content-between studentOnlyRow">
                            <span class="text-dark">Section :</span> <span id="memberSectionName">-</span>
                        </li>
                        <li class="list-group-item list-group-item-action d-flex justify-content-between studentOnlyRow">
                            <span class="text-dark">No Of Documents:</span> <span id="memberNoOfDocuments">-</span>
                        </li>
                        <li class="list-group-item list-group-item-action d-flex justify-content-between studentOnlyRow">
                            <span class="text-dark">MAX Days :</span> <span id="memberMAXDays">-</span>
                        </li>
                        <!-- Staff-only rows -->
                        <li class="list-group-item list-group-item-action d-flex justify-content-between staffOnlyRow" style="display:none;">
                            <span class="text-dark">Designation :</span> <span id="memberDesignation">-</span>
                        </li>

                        <!-- Common rows -->
                        <li class="list-group-item list-group-item-action d-flex justify-content-between">
                            <span class="text-dark">Gender :</span> <span id="memberGender">-</span>
                        </li>
                        <li class="list-group-item list-group-item-action d-flex justify-content-between">
                            <span class="text-dark">Mobile No :</span> <span id="memberMobileNo">-</span>
                        </li>
                        <li class="list-group-item list-group-item-action d-flex justify-content-between">
                            <span class="text-dark">Email :</span> <span id="memberEmail">-</span>
                        </li>
                        <li class="list-group-item list-group-item-action d-flex justify-content-between">
                            <span class="text-dark">Library Card No :</span> <span id="memberLibraryCardNo">-</span>
                        </li>
                        <li class="list-group-item list-group-item-action d-flex justify-content-between">
                            <span class="text-dark">Expiry Date :</span> <span id="memberExpiryDate">-</span>
                        </li>
                        <li class="list-group-item list-group-item-action d-flex justify-content-between">
                            <span class="text-dark">Status :</span> <span id="memberIsActive">-</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-xl-8">
            <div class="card mb-2 shadow-tbl-outer">
                <div class="card-body p-3">
                    <div id="noMemberAlert" class="alert alert-info py-2 px-3 fs-13 mb-3">
                        Search and select a student/staff above to load their issued books.
                    </div>

                    <div class="row g-2 align-items-end mb-2" id="returnToolbar" style="display:none;">
                        <div class="col-sm-6 col-md-4">
                            <label class="form-label fw-semibold">Return Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="commonReturnDate">
                            <div class="invalid-feedback" id="errReturnDate"></div>
                        </div>
                        <div class="col-sm-6 col-md-4">
                            <label class="form-label fw-semibold">Fine Amount</label>
                            <div class="input-group">
                                <input type="number" step="0.01" min="0" class="form-control" id="commonFineAmount" value="0.00">
                                <button type="button" class="btn btn-outline-secondary" id="btnRecalcFine" title="Recalculate from overdue days">
                                    <i class="ti ti-refresh"></i>
                                </button>
                            </div>
                            <div class="form-text fs-12 d-none" id="fineHint">Auto-calculated for overdue, checked books.</div>
                        </div>
                        <div class="col-sm-6 col-md-4">
                            <label class="form-label fw-semibold">Remark</label>
                            <input type="text" class="form-control" id="commonRemark">
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-tbl-outer">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-nowrap mb-0" id="tblReturnBooks">
                            <thead>
                                <tr>
                                    <th style="width: 36px;">
                                        <input type="checkbox" id="chkSelectAll" class="form-check-input">
                                    </th>
                                    <th style="width: 50px;">S.No</th>
                                    <th>Book Title</th>
                                    <th>AccessionNo</th>
                                    <th>Book No</th>
                                    <th>Issue Date</th>
                                    <th>Due Return Date</th>
                                    <th>Overdue Days</th>
                                    <th>Fine</th>
                                    <th class="text-end">Status</th>
                                </tr>
                            </thead>
                            <tbody id="issuedBooksTableBody">
                                <tr id="rowEmptyState">
                                    <td colspan="9" class="text-center py-4 text-muted">
                                        No member selected yet.
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="text-muted small mt-2" id="helperText" style="display:none;">
                        Set the shared Return Date / Fine Amount / Remark above, check the books to return, then click Save.
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<style>
    .pincode-dropdown {
        position: absolute;
        width: 100%;
        max-height: 260px;
        overflow-y: auto;
        z-index: 1050;
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 0 0 6px 6px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
        margin-top: 2px;
        padding: 0;
        list-style: none;
    }

        .pincode-dropdown .list-group-item {
            border-left: none;
            border-right: none;
            padding: 8px 12px;
            cursor: pointer;
        }
</style>

@section Scripts {
    <link href="~/assets/css/select2.min.css" rel="stylesheet" />
    <script src="~/assets/js/select2.min.js"></script>
    <script src="~/assets/plugins/sweetalert/sweetalert2.all.min.js"></script>
    <script>
        // Existing member id from route (0 if navigating fresh via search only)
        window.CURRENT_MEMBER_ID = @Model.LibraryMemberID;
        // TODO: wire this to real per-day fine config (e.g. Model.FinePerDay) once available
        window.FINE_PER_DAY = 5;
    </script>
    <script src="~/assets/js/Returnbook.js"></script>
}
