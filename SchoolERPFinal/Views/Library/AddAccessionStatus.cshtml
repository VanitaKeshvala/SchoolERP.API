@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.AccessionAddViewModel
@{
    ViewData["Title"] = "Accession Status";
    var p = Model.Permissions;
}
<style>
    .barcode-box {
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #eaf3fb;
        border: 2px solid #7fb3e0;
        border-radius: 8px;
        padding: 10px 20px;
        min-height: calc(1.5em + 0.75rem + 2px); /* match .form-control height */
        max-width: fit-content;
    }

        .barcode-box svg {
            display: block;
            height: 60px; /* keep barcode compact instead of stretching the row */
            width: auto;
        }

    .barcode-number {
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.5px;
        margin-top: 4px;
    }

    .accession-dropdown {
        position: absolute;
        width: 100%;
        max-height: 260px;
        overflow-y: auto;
        z-index: 1050;
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 0 0 6px 6px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
        margin-top: 2px;
        padding: 0;
        list-style: none;
    }

        .accession-dropdown .list-group-item {
            border-left: none;
            border-right: none;
            padding: 8px 12px;
            cursor: pointer;
        }
</style>
<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.Items == null ? "Add Accession Status" : "Edit Accession Status")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" id="btnSaveStatus" onclick="saveStatus()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Library/Accession" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <input type="hidden" id="txtItemId" value="@(Model.Items?.AccessionId ?? 0)">
                    <input type="hidden" id="hdnAccessionNo" value="@(Model.Items?.AccessionNo)">

                    <div id="issuedWarning" class="alert alert-warning py-2 px-3 fs-13" style="display:none;">
                        This copy is currently issued to a member. Its status can't be changed until it's returned.
                    </div>

                    <div class="row align-items-start">
                        <div class="col-md-6 mb-3" style="position: relative;">
                            <label class="form-label fw-semibold">Accession No <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="txtAccessionNo"
                                       placeholder="Scan, type, or search accession no" autocomplete="off">
                                <button class="btn btn-outline-secondary" type="button" id="btnClearAccession" title="Search a different copy">
                                    <i class="ti ti-x"></i>
                                </button>
                            </div>
                            <ul id="accessionSuggestions" class="accession-dropdown list-group"></ul>
                            <div class="invalid-feedback" id="errtxtAccessionNo"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold d-block">&nbsp;</label>
                            <div class="barcode-box" id="barcodeBox">
                                <svg id="barcodeSvg"></svg>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Book Title</label>
                            <input type="text" class="form-control" id="txtBookTitle" readonly
                                   placeholder="--">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Sub Title</label>
                            <input type="text" class="form-control" id="txtSubTitle" readonly
                                   placeholder="--">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Location</label>
                            <input type="text" class="form-control" id="txtLocation" readonly
                                   placeholder="--">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Document Status <span class="text-danger">*</span></label>
                            <select class="form-select select2" id="ddlDocumentStatus" style="width: 100%;" disabled>
                                <option value="">-- Select --</option>
                                @foreach (var rt in Model.DocumentStatus)
                                {
                                    <option value="@rt.Id">@rt.Name</option>
                                }
                            </select>
                            <div class="invalid-feedback" id="errddlDocumentStatus"></div>
                            <div class="form-text fs-12">Scan or select an accession no above to enable this.</div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/assets/js/Accession.js"></script>
    <script src="~/js/JsBarcode.all.min.js"></script>
}
