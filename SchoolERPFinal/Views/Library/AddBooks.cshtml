@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.HRDepartmentAddPageViewModel
@{
    ViewData["Title"] = "Add Books";
    var p = Model.Permissions;
}
<style>
    /* ============ Wizard UI ============ */
    .wizard-steps-indicator {
        user-select: none;
    }

    .wizard-step {
        display: flex;
        align-items: center;
        gap: 8px;
        color: grey;
        transition: all 0.3s ease;
    }

        .wizard-step.active {
            color: #5e72e4;
        }

        .wizard-step.completed {
            color: #22b14c;
        }

    .step-num {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: #e9ecef;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 700;
        transition: all 0.3s ease;
    }

    .wizard-step.active .step-num {
        background: #5e72e4;
        color: #fff;
        box-shadow: 0 0 0 4px rgba(94, 114, 228, 0.2);
    }

    .wizard-step.completed .step-num {
        background: #2dce89;
        color: #fff;
    }

    .wizard-step-line {
        flex: 1;
        height: 2px;
        background: #e9ecef;
        min-width: 30px;
    }

    .wizard-pane {
        display: none;
        animation: fadeIn 0.3s ease;
    }

        .wizard-pane.active {
            display: block;
        }

    .tree-grid-container {
        border: 1px solid #e0e0e0 !important;
    }

    .top-6 {
        top: 6px;
    }

    .dt-buttons {
        display: none !important;
    }
    /* Depth-0 highlight for parent nodes */
    .tree-row.depth-0 {
        background-color: #f8f9fc;
    }

        .tree-row.depth-0 .tree-label {
            font-weight: 500;
            color: #32325d;
        }

    .form-check.form-switch {
        margin-left: 10px;
    }

    .form-check-input:disabled {
        background-color: #33333360;
    }

    .invalid-feedback-file {
        display: none;
        color: #fb6340;
        font-size: .8rem;
        margin-top: .25rem;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

</style>
<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditBooks == null ? "Add Books" : "Edit Books")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            @* <button class="btn btn-success top-btn" onclick="saveData()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button> *@
        }
        <button type="button" class="btn btn-sm btn-primary shadow-sm top-btn" id="btnWizardNext" onclick="moveWizard(1)">
            Next <i class="ti ti-arrow-narrow-right ms-1"></i>
        </button>

        <button type="button" class="btn btn-sm btn-success shadow-sm d-none top-btn" id="btnWizardFinish" onclick="finishWizard()">
            <i class="ti ti-cloud me-1"></i> Save
        </button>
        <a href="/Library/Books" id="btnBack" class="btn btn-sm btn-info d-inline-flex align-items-center top-btn">
            <i class="ti ti-arrow-narrow-left me-1"></i>Back
        </a>
        <button type="button" class="btn btn-sm btn-info d-none top-btn" id="btnWizardPrev" onclick="moveWizard(-1)">
            <i class="ti ti-arrow-narrow-left me-1"></i> Back
        </button>
    </div>
</div>
<form id="itemForm" class="needs-validation" novalidate>
    <input type="hidden" id="hdnId" value="@(Model.EditBooks?.BookID ?? 0)" />
    <div class="row">
        <div class="col-xl-12">
            <div class="card shadow-tbl-outer">
                <div class="card-header">
                    <ul class="nav nav-pills gap-2">
                        <li class="nav-item"><a data-step="1" onclick="goToWizardStep(1)" class="nav-link active">Book Details</a></li>
                        <li class="nav-item"><a data-step="2" onclick="goToWizardStep(2)" class="nav-link">Cover Page</a></li>
                        <li class="nav-item"><a data-step="3" onclick="goToWizardStep(3)" class="nav-link">Authors Details</a></li>
                        <li class="nav-item"><a data-step="4" onclick="goToWizardStep(4)" class="nav-link">Accessioning Details </a></li>
                    </ul>
                </div>
                <div class="card-body">
                    <div class="tab-content">
                        <div class="wizard-pane active" id="step1">
                            <div class="row">
                                <div class="row row-gap-3">
                                    <div class="col-md-12">
                                        <label class="form-label">Book Find </label>
                                        <input type="text" id="txtTitleFind" class="form-control" autocomplete="off" placeholder="Type to search an existing book...">
                                        <ul id="bookSuggestions" class="pincode-dropdown list-group">
                                        </ul>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Book Title <span class="text-danger">*</span></label>
                                        <input type="text" id="txtTitle" value="@Model.EditBooks?.BookTitle" class="form-control" required placeholder="Enter book title">
                                        <div class="invalid-feedback">Book title is required.</div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Sub Title <span class="text-danger">*</span></label>
                                        <!-- FIX: this previously duplicated id="txtTitle", which meant document.getElementById('txtTitle')
                                             always returned the FIRST match (Book Title) and this field's value was never read. -->
                                        <input type="text" id="txtSubTitle" value="@Model.EditBooks?.SubTitle" class="form-control" required placeholder="Enter sub title">
                                        <div class="invalid-feedback">Sub title is required.</div>
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">Document Type</label>
                                        <select class="form-select select2" id="ddlDocumentType" style="width: 100%;">
                                            @* <option value="">-- Select --</option> *@
                                            @foreach (var rt in Model.DocumentType)
                                            {
                                                <option value="@rt.Id" selected="@(Model.EditBooks?.DocumentId == rt.Id)">@rt.Name</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">Category</label>
                                        <select class="form-select select2" id="ddlCategory" onchange="loadSubjectByCategory(this.value)" style="width: 100%;">
                                            <option value="">-- Select --</option>
                                            @foreach (var rt in Model.Category)
                                            {
                                                <option value="@rt.Id" selected="@(Model.EditBooks?.CategoryId == rt.Id)">@rt.Name</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">Subject</label>
                                        <select class="form-select select2" id="ddlSubject" style="width: 100%;">
                                            <option value="">-- Select --</option>
                                        </select>
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">Language</label>
                                        <select class="form-select select2" id="ddlLanguage" style="width: 100%;">
                                            <option value="">-- Select --</option>
                                            @foreach (var rt in Model.Language)
                                            {
                                                <option value="@rt.Id" selected="@(Model.EditBooks?.LanguageId == rt.Id)">@rt.Name</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">Publisher</label>
                                        <select class="form-select select2" id="ddlPublisher" style="width: 100%;">
                                            <option value="">-- Select --</option>
                                            @foreach (var rt in Model.Publisher)
                                            {
                                                <option value="@rt.Id" selected="@(Model.EditBooks?.PublisherId == rt.Id)">@rt.Name</option>
                                            }
                                        </select>
                                    </div>


                                    <div class="col-md-4">
                                        <label class="form-label">Edition</label>
                                        <input type="text" id="txtEdition" value="@Model.EditBooks?.Edition" class="form-control">
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label">Post Date</label>
                                        <input type="date" id="txtDate" class="form-control" value="@(Model.EditBooks?.PostDate?.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))">
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label">ISBN Number</label>
                                        <input type="text" id="txtISBN" value="@Model.EditBooks?.ISBNNo" class="form-control">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Class No</label>
                                        <input type="text" id="txtClassNo" value="@Model.EditBooks?.ClassNo" class="form-control">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Book Number</label>
                                        <input type="text" id="txtNo" value="@Model.EditBooks?.BookNo" class="form-control" placeholder="e.g., LIB-001">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Volume</label>
                                        <input type="text" id="txtVolume" value="@Model.EditBooks?.Volume" class="form-control">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">No Of Pages</label>
                                        <input type="number" id="txtNoOfPages" value="@Model.EditBooks?.NoOfPages" class="form-control" min="0" placeholder="e.g., 1">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold">Series</label>
                                        <select class="form-select select2" id="ddlSeries" style="width: 100%;">
                                            <option value="">-- Select --</option>
                                            @foreach (var rt in Model.Series)
                                            {
                                                <option value="@rt.Id" selected="@(Model.EditBooks?.SeriesId == rt.Id)">@rt.Name</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Key Word</label>
                                        <!-- FIX: type="number" on a free-text keyword field blocks normal words/phrases -->
                                        <input type="text" id="txtKeyWord" value="@Model.EditBooks?.KeyWord" class="form-control">
                                    </div>


                                    <div class="col-md-12">
                                        <label class="form-label">Remarks</label>
                                        <textarea id="txtRemarks" class="form-control" rows="3" placeholder="Optional description...">@Model.EditBooks?.Remarks</textarea>
                                    </div>
                                    <div class="col-md-12">
                                        <label class="form-label">Description</label>
                                        <textarea id="txtDescription" class="form-control" rows="3" placeholder="Optional description...">@Model.EditBooks?.Description</textarea>
                                    </div>
                                    <div class="col-md-12">
                                        <div class="form-check form-switch mt-2">
                                            <input class="form-check-input" type="checkbox" id="chkActive"
                                            @(Model.EditBooks?.IsActive ?? true ? "checked" : "")>
                                            <label class="form-check-label" for="chkActive">Active</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-content">
                        <div class="wizard-pane" id="step2">
                            <div class="row">
                                <!-- Show Book Name-->
                                <div class="tab-pane" id="divbookName">
                                    <div class="alert alert-info mb-0">
                                        <strong>Book Title :</strong>
                                        <span id="lblBookTitle2"></span>
                                    </div>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label">Attachment</label>
                                    <input type="file" class="form-control" id="attachmentFile" name="attachmentFile" accept=".jpg,.jpeg,.png,.pdf">
                                    <small class="text-muted" id="fileInfo"></small>
                                    <div class="invalid-feedback-file" id="fileError"></div>

                                    @if (!string.IsNullOrEmpty(Model.EditBooks?.CoverPageImage))
                                    {
                                        <div id="existingFileInfo" class="mt-1 d-flex align-items-center gap-2">
                                            <a href="@Model.EditBooks.CoverPageImage" target="_blank" class="small">
                                                <i class="ti ti-paperclip me-1"></i>@Model.EditBooks.FileName
                                            </a>
                                            <button type="button" class="btn btn-sm btn-outline-danger py-0 px-1" onclick="removeExistingFile()">
                                                <i class="ti ti-x"></i>
                                            </button>
                                        </div>
                                    }
                                    <!-- Tells the backend whether to keep, replace, or delete the existing file -->
                                    <input type="hidden" id="hdnExistingFile" name="ExistingFileName" value="@Model.EditBooks?.FileName">
                                    <input type="hidden" id="hdnRemoveFile" name="RemoveAttachment" value="false">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-content">
                        <div class="wizard-pane" id="step3">
                            <!-- Show Book Name-->
                            <div class="tab-pane" id="divbookName">
                                <div class="alert alert-info mb-0">
                                    <strong>Book Title :</strong>
                                    <span id="lblBookTitle3"></span>
                                </div>
                            </div>
                            <div class="row">
                                
                                <div class="col-md-12">
                                    <label class="form-label">Author</label>
                                    <!-- Selected authors are applied in JS from window.editBookData.authorIds (comma separated ids),
                                         so select2 (which re-renders the DOM) always reflects them correctly. -->
                                    <select id="ddlAuthor" class="form-select form-control select2" multiple data-placeholder="Select Author">
                                        @if (Model.Author != null)
                                        {
                                            @foreach (var sub in Model.Author)
                                            {
                                                <option value="@sub.Id">@sub.Name</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-content">
                        <div class="wizard-pane" id="step4">
                            <!-- Show Book Name-->
                            <div class="tab-pane" id="divbookName">
                                <div class="alert alert-info mb-0">
                                    <strong>Book Title :</strong>
                                    <span id="lblBookTitle4"></span>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Budget</label>
                                    <select class="form-select select2" id="ddlBudget" style="width: 100%;">
                                        <option value="">-- Select --</option>
                                        @foreach (var rt in Model.Budget)
                                        {
                                            <!-- FIX: was comparing against SeriesId instead of BudgetId -->
                                            <option value="@rt.Id" selected="@(Model.EditBooks?.BudgetId == rt.Id)">@rt.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold">Supplier</label>
                                    <select class="form-select select2" id="ddlSupplier" style="width: 100%;">
                                        <option value="">-- Select --</option>
                                        @foreach (var rt in Model.Supplier)
                                        {
                                            <!-- FIX: was comparing against SeriesId instead of SupplierId -->
                                            <option value="@rt.Id" selected="@(Model.EditBooks?.SupplierId == rt.Id)">@rt.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Bill No</label>
                                    <!-- FIX: was bound to KeyWord (copy/paste bug). Adjust the property name below
                                         if your EditBooks view model names it differently. -->
                                    <input type="text" id="txtBillNo" value="@Model.EditBooks?.BillNo" class="form-control">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Bill Date</label>
                                    <input type="date" id="txtBillDate" class="form-control" value="@(Model.EditBooks?.BillDate?.ToString("yyyy-MM-dd"))">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Location</label>
                                    <input type="text" id="txtLocation" value="@Model.EditBooks?.Location" class="form-control">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Price</label>
                                    <input type="number" step="0.01" min="0" id="txtPrice" value="@Model.EditBooks?.Price" class="form-control">
                                </div>                                
                                <div class="col-md-4">                                    
                                    <label class="form-label">Quantity <span class="text-danger">*</span></label>
                                    <input type="number" min="1" id="txtQuantity" value="@Model.EditBooks?.Quantity" class="form-control" required>
                                    <div class="invalid-feedback">Quantity is required.</div>
                                </div>
                                <div class="col-md-4 d-none">
                                    <label class="form-label">Accession No</label>
                                    <input type="text" id="txtAccessionNo" value="@Model.EditBooks?.AccessionNo" class="form-control">
                                </div>
                                <div class="col-md-4 d-none">
                                    <label class="form-label fw-bold">Document Status</label>
                                    <select class="form-select select2" id="ddlDocumentStatus" style="width: 100%;">
                                        <option value="">-- Select --</option>
                                        @foreach (var rt in Model.DocumentStatus)
                                        {
                                            if (rt.Name.Equals("Available", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <option value="@rt.Id" selected>@rt.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@rt.Id">@rt.Name</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>


                </div>
            </div>
        </div>
    </div>
</form>
@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);

        // Bootstraps the JS wizard with everything it needs to correctly re-select
        // dropdown/multi-select values on edit, without guessing at server-rendered
        // "selected" state for cascading/multi-select controls.
        window.editBookData = @Html.Raw(Model.EditBooks == null
             ? "null"
             : JsonSerializer.Serialize(new
             {
        bookId = Model.EditBooks.BookID,
        categoryId = Model.EditBooks.CategoryId,
        subjectId = Model.EditBooks.SubjectId,
        authorIds = Model.EditBooks.AuthorId // expected as comma-separated string e.g. "5,8,9"
             }));
    </script>

    <script src="~/assets/js/Books.js"></script>
}
