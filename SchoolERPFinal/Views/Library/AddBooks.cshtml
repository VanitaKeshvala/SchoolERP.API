@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.HRDepartmentAddPageViewModel
@{
    ViewData["Title"] = "Add Books";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditBooks == null ? "Add Books" : "Edit Books")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveData()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Library/Books" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">

            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <input type="hidden" id="hdnId" value="@Model.EditBooks?.BookID ?? 0" />
                    <div class="row row-gap-3">
                        <div class="col-md-6">
                            <label class="form-label">Book Title <span class="text-danger">*</span></label>
                            <input type="text" id="txtTitle" value="@Model.EditBooks?.BookTitle" class="form-control" required placeholder="Enter book title">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Book Number</label>
                            <input type="text" id="txtNo" value="@Model.EditBooks?.BookNo" class="form-control" placeholder="e.g., LIB-001">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">ISBN Number</label>
                            <input type="text" id="txtISBN" value="@Model.EditBooks?.ISBNNo" class="form-control">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Publisher</label>
                            <input type="text" id="txtPublisher" value="@Model.EditBooks?.Publisher" class="form-control">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Author</label>
                            <input type="text" id="txtAuthor" value="@Model.EditBooks?.Author" class="form-control">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Subject</label>
                            <input type="text" id="txtSubject" value="@Model.EditBooks?.Subject" class="form-control">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Rack Number</label>
                            <input type="text" id="txtRack" class="form-control" value="@Model.EditBooks?.RackNo" placeholder="e.g., A-12">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Qty <span class="text-danger">*</span></label>
                            <input type="number" id="txtQty" value="@Model.EditBooks?.TotalQty ?? 1" class="form-control" required min="0">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Book Price (₹)</label>
                            <input type="number" id="txtPrice" class="form-control" value="@Model.EditBooks?.BookPrice ?? 0" step="0.01">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Post Date</label>
                            <input type="date" id="txtDate" class="form-control" value="@(Model.EditBooks?.PostDate?.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))">
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Description</label>
                            <textarea id="txtDescription" class="form-control" rows="3" placeholder="Optional description...">@Model.EditBooks?.Description</textarea>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<link href="~/assets/css/select2.min.css" rel="stylesheet" />

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/assets/js/Books.js"></script>
}