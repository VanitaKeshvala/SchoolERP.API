@model SchoolERP.Shared.Models.PagePermissions
@{
    ViewData["Title"] = "Member";

    // Permission loading for the view
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.Identity != null ? User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId") : null;
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model;
}

@section Styles {
<style>
    .dt-buttons { display: none !important; }
</style>
}

<!-- Page Header -->
<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Members</h6>
    </div>

    <div class="d-flex gap-1">
        @if(p.CanPrint)
        {
            <a href="javascript:void(0)" class="btn btn-secondary top-btn" onclick="triggerExport(4)"><i class="ti ti-printer me-1"></i> Print</a>
        }
        @if(p.CanExport)
        {
            <div class="dropdown d-inline-flex">
                <button class="btn btn-warning d-inline-flex align-items-center dropdown-toggle top-btn" type="button" data-bs-toggle="dropdown">
                    <i class="ti ti-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(0)"><i class="ti ti-copy me-1"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(1)"><i class="ti ti-file-text me-1"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(2)"><i class="ti ti-file-spreadsheet me-1"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(3)"><i class="ti ti-file-description me-1"></i>PDF</a></li>
                </ul>
            </div>
        }        
        @if (p.CanEdit)
        {
            <a href="javascript:void(0);" id="btnTopIssueReturn" class="btn btn-teal">
                <i class="ti ti-logout me-1"></i>Issue Return
            </a>
        }
    </div>

</div>
<!-- End Page Header -->
<!-- start row -->

<div class="row">

    <div class="col-md-12">
        <div class="card shadow-tbl-outer mb-2">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3 bg-white">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text" id="searchInput" class="form-control border-0 ps-2" style="min-width: 220px;" placeholder="Search..."  />
                    </div>
                    <!--<input type="text" id="searchInput" class="form-control w-25 me-3" placeholder="Search..." /> -->
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-body">
                <div class="tab-content">
                    <!-----System Pane---->
                    <div class="tab-pane active" id="system">
                        <div class="table-responsive">
                            <table class="table mb-0" id="tblMembers">
                                <thead>
                                    <tr>
                                        <th style="width: 50px;">#</th>
                                        <th>Member ID</th>
                                        <th>Library Card No</th>
                                        <th>Admission No</th>
                                        <th>Name</th>
                                        <th>Member Type</th>
                                        <th class="text-end">Phone</th>
                                    </tr>
                                </thead>
                                <tbody id="memberTableBody">
                                   


                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-----Student Pane---->
                    <div class="tab-pane" id="std">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            Transport
                                        </td>
                                        <td class="text-end">
                                            <div class="form-check form-switch ">
                                                <input class="form-check-input float-end" type="checkbox" role="switch" id="switchCheckChecked" checked>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Transport
                                        </td>
                                        <td class="text-end">
                                            <div class="form-check form-switch ">
                                                <input class="form-check-input float-end" type="checkbox" role="switch" id="switchCheckChecked" checked>
                                            </div>
                                        </td>
                                    </tr>

                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-----Parent Pane---->
                    <div class="tab-pane" id="prt">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            Transport
                                        </td>
                                        <td class="text-end">
                                            <div class="form-check form-switch ">
                                                <input class="form-check-input float-end" type="checkbox" role="switch" id="switchCheckChecked" checked>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            Transport
                                        </td>
                                        <td class="text-end">
                                            <div class="form-check form-switch ">
                                                <input class="form-check-input float-end" type="checkbox" role="switch" id="switchCheckChecked" checked>
                                            </div>
                                        </td>
                                    </tr>

                                </tbody>
                            </table>
                        </div>
                    </div>



                </div>

            </div>
            <!-- end card-body -->
        </div>
        <!-- end card -->
    </div>
    <!-- end col -->

</div>
<!-- end row -->

@section Scripts {
    <script>
        $(document).ready(function () {
            loadMembers();

            $('#searchInput').on('keyup', function () {
                loadMembers($(this).val());
            });

            $('#btnTopIssueReturn').on('click', function () {
                const selected = $('.member-radio:checked');
                if (selected.length === 0) {
                    Swal.fire('Info', 'Please select a member first', 'info');
                    return;
                }
                const id = selected.data('id');
                window.location.href = `/Library/Issue/${id}`;
            });
        });

        function loadMembers(search = '') {
            $.get('/Library/GetMemberList', { type: 'All', search: search }, function (res) {
                if (res.success) {
                    let html = '';
                    res.data.forEach((m, index) => {
                        if (m.libraryCardNo && m.libraryCardNo.length != 0) {
                            html += `
                                    <tr>
                                        <td><input type="radio" name="memberSelect" class="form-check-input member-radio" data-id="${m.libraryMemberID}"></td>
                                        <td>${m.libraryMemberID}</td>
                                        <td>${m.libraryCardNo || '-'}</td>
                                        <td>${m.admissionNo || '-'}</td>
                                        <td>${m.name}</td>
                                        <td>${m.memberType}</td>
                                        <td class="text-end">${m.mobileNo || '-'}</td>
                                    </tr>`;
                        }
                    });
                    
                    if ($.fn.DataTable.isDataTable('#tblMembers')) {
                        $('#tblMembers').DataTable().destroy();
                    }
                    
                    $('#memberTableBody').html(html);
                    
                    $('#tblMembers').DataTable({
                        dom: 'Bfrtip',
                        buttons: [
                            { extend: 'copy', exportOptions: { columns: [1, 2, 3, 4, 5, 6] } },
                            { extend: 'csv', exportOptions: { columns: [1, 2, 3, 4, 5, 6] } },
                            { extend: 'excel', exportOptions: { columns: [1, 2, 3, 4, 5, 6] } },
                            { extend: 'pdf', exportOptions: { columns: [1, 2, 3, 4, 5, 6] } },
                            { extend: 'print', exportOptions: { columns: [1, 2, 3, 4, 5, 6] } }
                        ],
                        searching: false,
                        paging: false,
                        info: false
                    });
                }
            });
        }

        function triggerExport(index) {
            const table = $('#tblMembers').DataTable();
            table.button(index).trigger();
        }
    </script>
}

