@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.LibrarySupplierAddViewModel
@{
    ViewData["Title"] = "Add Supplier";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditSupplier == null ? "Add Supplier" : "Edit Supplier")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveItem()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/LibrarySupplier/Index" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <input type="hidden" id="txtItemId" value="@(Model.EditSupplier?.SupplierId ?? 0)">
                    <input type="hidden" id="hdnUserID" value="@(Model.EditSupplier?.CreatedBy ?? 0)">

                    <div class="row">

                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Supplier Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtSupplierName"
                                   value="@Model.EditSupplier?.SupplierName"
                                   placeholder="e.g. Thoms" autocomplete="off">
                            <div class="invalid-feedback" id="errtxtSupplierName"></div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Phone</label>
                            <input type="text" class="form-control" id="txtPhone"
                                   value="@Model.EditSupplier?.Phone"
                                   placeholder="e.g. 7952458745" autocomplete="off">
                            <div class="invalid-feedback" id="errtxtPhone"></div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Email</label>
                            <input type="text" class="form-control" id="txtEmail"
                                   value="@Model.EditSupplier?.Email"
                                   placeholder="e.g. LBH" autocomplete="off">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Address</label>
                            <input type="text"
                                   value="@Model.EditSupplier?.Address"
                                   class="form-control" id="txtAddress">
                        </div>
                        <div class="col-md-3 position-relative">
                            <label class="form-label fw-bold">Pin Code</label>
                            <input type="text"
                                   value="@Model.EditSupplier?.PostalCode"
                                   class="form-control" id="txtPinCode"
                                   autocomplete="off" />
                            <ul id="pinCodeSuggestions" class="pincode-dropdown list-group">
                            </ul>
                        </div>
                        <div class="d-block col-md-3 mb-3">
                            <label class="form-label fw-bold">Country Name</label>
                            <select class="form-select select2" id="ddlCountry" style="width: 100%;">
                                <option value="">-- Select --</option>
                                @foreach (var rt in Model.Country.Where(x => x.IsActive))
                                {
                                    <option value="@rt.CountryId" selected="@(Model.EditSupplier?.CountryId == rt.CountryId)">@rt.CountryName</option>
                                }
                            </select>
                        </div>

                        <div class="d-block col-md-3 mb-3">
                            <input type="hidden" id="hdnSelectedStateId" value="@Model.EditSupplier?.StateId" />
                            <input type="hidden" id="hdnSelectedCityId" value="@Model.EditSupplier?.CityId" />
                            <label class="form-label fw-bold">State Name</label>
                            <select class="form-select select2" id="ddlState" style="width: 100%;">
                                <option value="">-- Select Country First --</option>
                            </select>
                        </div>

                        <div class="d-block col-md-3 mb-3">
                            <label class="form-label fw-bold">City Name</label>
                            <select class="form-select select2" id="ddlCity" style="width: 100%;">
                                <option value="">-- Select Country First --</option>
                            </select>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Contact Number</label>
                            <input type="text" class="form-control" id="txtFAX"
                                   value="@Model.EditSupplier?.FAX"
                                   placeholder="e.g. 079-26547896" autocomplete="off">
                            <div class="invalid-feedback" id="errtxtFAX"></div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Web Site</label>
                            <input type="text" class="form-control" id="txtWebSite"
                                   value="@Model.EditSupplier?.WebSite"
                                   placeholder="https://www.example.com" autocomplete="off">
                            <div class="invalid-feedback" id="errtxtWebSite"></div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Mobile No</label>
                            <input type="text" class="form-control" id="txtMobileNo"
                                   value="@Model.EditSupplier?.MobileNo"
                                   placeholder="e.g. 9876543210" autocomplete="off">
                            <div class="invalid-feedback" id="errtxtMobileNo"></div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Contact Person</label>
                            <input type="text" class="form-control" id="txtContactPerson"
                                   value="@Model.EditSupplier?.ContactPerson"
                                   placeholder="e.g. Thoms" autocomplete="off">
                            <div class="invalid-feedback" id="errtxtContactPerson"></div>
                        </div>
                        <div class="col-md-12 mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="isActive"
                                @(Model.EditSupplier?.IsActive ?? true ? "checked" : "")>
                                <label class="form-check-label fw-bold" for="isActive">Active</label>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/assets/js/LibrarySupplier.js"></script>
}