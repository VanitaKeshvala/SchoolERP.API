@model SchoolERP.Shared.Models.FOPostalDispatchPageViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Postal Dispatch";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;
}

<style>
.dt-buttons { display: none !important; }
</style>


<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Postal Dispatch List</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <a href="javascript:void(0)" class="btn btn-primary top-btn" onclick="openAddModal()">
                <i class="ti ti-plus me-1"></i> Add
            </a>
        }
        @if (p.CanEdit)
        {
            <button id="btnEdit" class="btn btn-info top-btn" disabled onclick="editSelected()">
                <i class="ti ti-pencil me-1"></i> Edit
            </button>
        }
        @if (p.CanDelete)
        {
            <button id="btnDelete" class="btn btn-danger top-btn" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i> Delete
            </button>
        }
        @if (p.CanPrint)
        {
            <button class="btn btn-secondary d-inline-flex align-items-center top-btn" onclick="triggerExport(4)">
                <i class="ti ti-printer me-1"></i>Print
            </button>
        }
        @if (p.CanExport)
        {
            <div class="dropdown d-inline-flex">
                <button class="btn btn-warning dropdown-toggle top-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(0)"><i class="ti ti-copy me-1"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(1)"><i class="ti ti-file-text me-1"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(2)"><i class="ti ti-file-spreadsheet me-1"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(3)"><i class="ti ti-file-description me-1"></i>PDF</a></li>
                </ul>
            </div>
        }

    </div>
</div>

<div class="row">
    <!-- Filters -->
    <div class="col-md-12">
        <div class="card shadow-tbl-outer mb-2">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3 ">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text" class="form-control border-0 ps-2" id="txtSearchInput"
                               placeholder="Search by title, reference..." style="min-width: 220px;">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0" id="tblPostalDispatch">
                        <thead>
                            <tr>
                                <th style="width: 50px;" class="ps-3">Select</th>
                                <th>To Title</th>
                                <th>Reference No</th>
                                <th>From Title</th>
                                <th>Date</th>
                                <th>Doc</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr class="item-row" onclick="selectItem(@item.PostalDispatchID, this)" style="cursor: pointer;">
                                    <td class="ps-3">
                                        <input type="checkbox" name="selectedItem"
                                               class="form-check-input student-checkbox"
                                               value="@item.PostalDispatchID">
                                    
                                    </td>
                                    <td>@item.ToTitle</td>
                                    <td>@item.ReferenceNo</td>
                                    <td>@item.FromTitle</td>
                                    <td>@item.Date.ToString("dd-MM-yyyy")</td>
                                    <td>
                                        @if (item.Attachment != null && item.Attachment.Length > 0)
                                        {
                                            <a href="/FrontOffice/DownloadDispatchAttachment/@item.PostalDispatchID" target="_blank" class="btn btn-sm btn-white border px-2 py-1" title="View Attachment">
                                                <i class="ti ti-paperclip fs-5"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted fs-7">-</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="form-check form-switch" onclick="event.stopPropagation()">
                                            <input class="form-check-input" type="checkbox" 
                                                   onchange="toggleStatus(@item.PostalDispatchID, this.checked)"
                                                   @(item.IsActive ? "checked" : "")
                                            @(p.CanEdit ? "" : "disabled")>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @if (!Model.Items.Any())
                            {
                                <tr><td colspan="7" class="text-center text-muted py-4">No records found.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add / Edit Modal -->
<div class="modal fade" id="postalModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header d-flex justify-content-between align-items-center">
                <h5 class="modal-title" id="modalTitle">Add Postal Dispatch</h5>
                <div>
                    <button class="btn btn-success" onclick="saveRecord()">
                        <i class="ti ti-cloud me-1"></i> Save
                    </button>
                    <button class="btn btn-danger" data-bs-dismiss="modal">
                        <i class="ti ti-x me-1"></i> Close
                    </button>
                </div>
            </div>
            <div class="modal-body">
                <form id="postalForm">
                    <input type="hidden" id="hdnPostalDispatchID" value="0">
                    <div class="row row-gap-3">
                        <div class="col-md-6">
                            <label class="form-label">To Title <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtToTitle" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">From Title</label>
                            <input type="text" class="form-control" id="txtFromTitle">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Reference No</label>
                            <input type="text" class="form-control" id="txtReferenceNo">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Address</label>
                            <textarea class="form-control" id="txtAddress" rows="2"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Note</label>
                            <textarea class="form-control" id="txtNote" rows="2"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="txtDate" required value="@DateTime.Now.ToString("yyyy-MM-dd")">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Attachment</label>
                            <input type="file" class="form-control" id="fileAttachment">
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="chkActive" checked>
                                <label class="form-check-label" for="chkActive">Active</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let selectedId = 0;
        const canEdit = @p.CanEdit.ToString().ToLower();
        const canDelete = @p.CanDelete.ToString().ToLower();

        function triggerExport(index) {
            if ($.fn.DataTable.isDataTable('#tblPostalDispatch')) {
                const table = $('#tblPostalDispatch').DataTable();
                table.button(index).trigger();
            }
        }

    $(document).ready(function () {
            $('#tblPostalDispatch').DataTable({
                dom: 'Bfrtip',
                buttons: [
                    { extend: 'copy', exportOptions: { columns: [1, 2, 3, 4] } },
                    { extend: 'csv', exportOptions: { columns: [1, 2, 3, 4] } },
                    { extend: 'excel', exportOptions: { columns: [1, 2, 3, 4] } },
                    { extend: 'pdf', exportOptions: { columns: [1, 2, 3, 4] } },
                    { extend: 'print', exportOptions: { columns: [1, 2, 3, 4] } }
                ],
                searching: false,
                paging: false,
                info: false
            });
    })
       



    function selectItem(id, row) {
        selectedId = id;
        document.querySelectorAll('.item-row').forEach(r => r.classList.remove('bg-light'));
        row.classList.add('bg-light');
        //row.querySelector('input[type="radio"]').checked = true;

        if (canEdit) document.getElementById('btnEdit').disabled = false;
        if (canDelete) document.getElementById('btnDelete').disabled = false;
                let checkedCount = $('.student-checkbox:checked').length;
        $('#btnDelete').prop('disabled', checkedCount === 0);
        // Edit sirf 1 record select hone par
        $('#btnEdit').prop('disabled', checkedCount !== 1);
    }

    // Search
        document.getElementById('txtSearchInput').addEventListener('keyup', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('#tblPostalDispatch tbody tr').forEach(row => {
            if (row.classList.contains('item-row')) {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            }
        });
    });

    function openAddModal() {
        document.getElementById('modalTitle').textContent = 'Add Postal Dispatch';
        document.getElementById('hdnPostalDispatchID').value = 0;
        document.getElementById('postalForm').reset();
        document.getElementById('txtDate').value = new Date().toISOString().split('T')[0];
        document.getElementById('chkActive').checked = true;
        new bootstrap.Modal(document.getElementById('postalModal')).show();
    }

    function editSelected() {
        if (!selectedId) return;
        fetch(`/FrontOffice/GetPostalDispatch?id=${selectedId}`)
            .then(r => r.json())
            .then(res => {
                if (!res.success) { showToast(res.message, 'danger'); return; }
                const d = res.data;
                document.getElementById('modalTitle').textContent = 'Edit Postal Dispatch';
                document.getElementById('hdnPostalDispatchID').value = d.postalDispatchID;
                document.getElementById('txtToTitle').value = d.toTitle;
                document.getElementById('txtFromTitle').value = d.fromTitle || '';
                document.getElementById('txtReferenceNo').value = d.referenceNo || '';
                document.getElementById('txtAddress').value = d.address || '';
                document.getElementById('txtNote').value = d.note || '';
                document.getElementById('txtDate').value = d.date.split('T')[0];
                document.getElementById('chkActive').checked = d.isActive;

                new bootstrap.Modal(document.getElementById('postalModal')).show();
            });
    }

    function saveRecord() {
        const form = document.getElementById('postalForm');
        if (!form.checkValidity()) { form.reportValidity(); return; }

        const formData = new FormData();
        formData.append('postalDispatchID', parseInt(document.getElementById('hdnPostalDispatchID').value) || 0);
        formData.append('toTitle',          document.getElementById('txtToTitle').value.trim());
        formData.append('fromTitle',        document.getElementById('txtFromTitle').value.trim() || '');
        formData.append('referenceNo',      document.getElementById('txtReferenceNo').value.trim() || '');
        formData.append('address',          document.getElementById('txtAddress').value.trim() || '');
        formData.append('note',             document.getElementById('txtNote').value.trim() || '');
        formData.append('date',             document.getElementById('txtDate').value);
        formData.append('isActive',         document.getElementById('chkActive').checked);

        const fileInput = document.getElementById('fileAttachment');
        if (fileInput.files[0]) {
            formData.append('attachmentFile', fileInput.files[0]);
        }

        fetch('/FrontOffice/SavePostalDispatch', {
            method: 'POST',
            body: formData
        })
        .then(r => r.json())
        .then(res => {
            showToast(res.message, res.success ? 'success' : 'danger');
            if (res.success) {
                bootstrap.Modal.getInstance(document.getElementById('postalModal')).hide();
                setTimeout(() => location.reload(), 800);
            }
        });
    }

    function deleteSelected() {
        if (!selectedId) return;
       

                   let selectedIds = [];
        $('.student-checkbox:checked').each(function () {
                 selectedIds.push(parseInt($(this).val()));
             });
        if (selectedIds.length === 0) {
                 alert("Please select at least one student.");
                 return;
             }
         Swal.fire({
             title: 'Are you sure?',
             text: "You are about to delete this student record. This action cannot be undone!",
             icon: 'warning',
             showCancelButton: true,
             confirmButtonColor: '#d33',
             cancelButtonColor: '#3085d6',
             confirmButtonText: 'Yes, delete it!',
             customClass: {
                 confirmButton: 'btn btn-danger me-2',
                 cancelButton: 'btn btn-secondary'
             },
             buttonsStyling: false
         }).then((result) => {
             if (result.isConfirmed) {
                 $.ajax({
                          url: '/FrontOffice/DeletePostalDispatch',
                     type: 'POST',
                     contentType: 'application/json',
                     data: JSON.stringify(selectedIds),
                     success: function (res) {
                         if (res.success) {
                             Swal.fire('Deleted!', 'Student record has been deleted.', 'success')
                                 .then(() => location.reload());
                         } else {
                             Swal.fire('Error!', res.message || 'Failed to delete student.', 'error');
                         }
                     },
                     error: function () {
                         Swal.fire('Error!', 'An unexpected error occurred.', 'error');
                     }
                 });
             }
         });
    }

    function toggleStatus(id, isActive) {
        fetch(`/FrontOffice/TogglePostalDispatchStatus?id=${id}&isActive=${isActive}`, { method: 'POST' })
            .then(r => r.json())
            .then(res => showToast(res.message, res.success ? 'success' : 'danger'));
    }

    function showToast(msg, type = 'success') {
        const wrapper = document.createElement('div');
        wrapper.innerHTML = `<div class="toast align-items-center text-bg-${type} border-0 show position-fixed bottom-0 end-0 m-3" role="alert" style="z-index:9999">
            <div class="d-flex"><div class="toast-body">${msg}</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div></div>`;
        document.body.appendChild(wrapper);
        setTimeout(() => wrapper.remove(), 3000);
    }
</script>
}
