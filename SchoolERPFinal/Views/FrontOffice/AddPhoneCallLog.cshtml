@model SchoolERP.Shared.Models.FOPhoneCallLogAddPageViewModel
@using System.Security.Claims
@using System.Text.Json
@{
    ViewData["Title"] = "Phone Call Log";

    // Permission loading for the view
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;

}
<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditItems == null ? "Add Phone Call Log" : "Edit Phone Call Log")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button type="submit" onclick="saveRecord()" class="btn btn-success top-btn">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/FrontOffice/PhoneCallLog" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>

<form id="callLogForm">

    <div class="row">
        <div class="col-xl-12">
            <div class="card shadow-tbl-outer">
                <div class="card-body">

                    <input type="hidden" id="hdnPhoneCallLogID" value="@Model.EditItems?.PhoneCallLogID">
                    <div class="row row-gap-3">
                        <div class="col-md-6">
                            <label class="form-label">Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" value="@Model.EditItems?.Name" id="txtName">
                            <div id="errName" class="invalid-feedback" style="display: none;">Name is required.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Phone</label>
                            <input type="text" class="form-control" value="@Model.EditItems?.Phone" id="txtPhone">
                            <div id="errPhone" class="invalid-feedback"></div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Date <span class="text-danger">*</span></label>
                            <input type="date"
                                   class="form-control"
                                   id="txtDate"
                                   name="Date"
                                   value="@(Model.EditItems?.Date.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))" />
                            <div id="errDate" class="invalid-feedback" style="display: none;">Date is required.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" id="txtDescription" rows="1">@Model.EditItems?.Description</textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Next Follow Up Date</label>
                            <input type="date" class="form-control" value="@(Model.EditItems?.NextFollowUpDate?.ToString("yyyy-MM-dd"))" id="txtNextFollowUpDate">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Call Duration</label>
                            <input type="text" class="form-control" value="@Model.EditItems?.CallDuration" id="txtCallDuration" placeholder="e.g. 5 mins">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Call Type <span class="text-danger">*</span></label>
                            <select class="form-select" id="ddlCallType">
                                <option value="">-- Select --</option>
                                <option value="Incoming" selected="@(Model.EditItems?.CallType == "Incoming")">Incoming</option>
                                <option value="Outgoing" selected="@(Model.EditItems?.CallType == "Outgoing")">Outgoing</option>
                            </select>
                            <div id="errCallType" class="invalid-feedback" style="display: none;">Call Type is required.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Note</label>
                            <textarea class="form-control" id="txtNote" rows="1">@Model.EditItems?.Note</textarea>
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="chkActive" @(Model.EditItems?.IsActive ?? true ? "checked" : "")>
                                <label class="form-check-label" for="chkActive">Active</label>
                            </div>
                        </div>
                    </div>


                </div>
            </div>
        </div>
    </div>
</form>
@section Scripts {
    <script>
            window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
            window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
            window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
   
    </script>
    <script src="~/js/inline-form-validation.js"></script>
    <script src="~/assets/js/PhoneCallLog.js"></script>

}
