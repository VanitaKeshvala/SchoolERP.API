@model SchoolERP.Shared.Models.AddAdmissionInquiryPageViewModel
@using System.Security.Claims
@using System.Text.Json
@{
    ViewData["Title"] = "Admission Enquiry";

    // Permission loading for the view
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;

}
<form id="inquiryForm">
<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditInquiries == null ? "Add Admission Enquiry" : "Edit Admission Enquiry")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button type="submit" onclick="saveRecord()" class="btn btn-success top-btn">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/FrontOffice/AdmissionInquiry" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>

<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
               
                    <input type="hidden" name="InquiryID" id="InquiryID" value="@Model.Inquiries.InquiryID" />
                    
                   
                        <div class="row row-gap-3">
                            <div class="col-md-6">
                                <label class="form-label">Name <span class="text-danger">*</span></label>
                                <input type="text" name="Name" value="@Model.Inquiries.Name" id="InqName" class="form-control" required>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Phone <span class="text-danger">*</span></label>
                            <input type="text" name="Phone" value="@Model.Inquiries.Phone" id="InqPhone" class="form-control" required maxlength="10">
                                <div id="errPhone" class="invalid-feedback"></div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Email</label>
                            <input type="text" name="Email" value="@Model.Inquiries.Email" id="InqEmail" class="form-control">
                                <div id="errEmail" class="invalid-feedback"></div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Address</label>
                            <textarea name="Address" id="InqAddress" value="@Model.Inquiries.Address" class="form-control"></textarea>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Description</label>
                            <textarea name="Description" id="InqDescription" class="form-control">@Model.Inquiries.Description</textarea>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Note</label>
                            <textarea name="Note" id="InqNote" class="form-control">@Model.Inquiries.Note</textarea>
                            </div>

                            <div class="col-md-2">
                                <label class="form-label">Date <span class="text-danger">*</span></label>
                            <input type="date" name="Date" id="InqDate"
                                   value="@(Model.Inquiries.Date.ToString("yyyy-MM-dd"))"
                            class="form-control" required>
                            </div>

                            <div class="col-md-2">
                                <label class="form-label">Next Follow Up Date</label>
                            <input type="date" name="NextFollowUpDate" 
                            value="@(Model.Inquiries.NextFollowUpDate.HasValue ? Model.Inquiries.NextFollowUpDate.Value.ToString("yyyy-MM-dd") : "")"
                            id="InqNextFollowUpDate" class="form-control">
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Assign To</label>
                                <select name="AssignedTo" id="InqAssignedTo" class="form-select select2">
                                    <option value="">Select</option>
                                    @foreach (var st in Model.Staff)
                                    {
                                    <option value="@st.StaffID" selected="@(Model.Inquiries?.AssignedTo == st.StaffID)">
                                        @($"{st.FirstName} {st.LastName} ({st.StaffID})")</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Reference</label>
                                <select name="ReferenceID" id="InqReferenceID" class="form-select select2">
                                    <option value="">Select</option>
                                    @foreach (var r in Model.References)
                                    {
                                    <option value="@r.ReferenceID" selected="@(Model.Inquiries?.ReferenceID == r.ReferenceID)">@r.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Source</label>
                                <select name="SourceID" id="InqSourceID" class="form-select select2">
                                    <option value="">Select</option>
                                    @foreach (var s in Model.Sources)
                                    {
                                    <option value="@s.SourceID" selected="@(Model.Inquiries?.SourceID == s.SourceID)">@s.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Class</label>
                                <select name="ClassID" id="InqClassID" class="form-select select2">
                                    <option value="">Select</option>
                                    @foreach (var c in Model.Classes)
                                    {
                                    <option value="@c.ClassID" selected="@(Model.Inquiries?.ClassID == c.ClassID)">@c.ClassName</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Number Of Child </label>
                            <input type="number" name="NoOfChild" value="@Model.Inquiries?.NoOfChild" id="InqNoOfChild" class="form-control" value="1">
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Status</label>
                            <select name="Status" id="InqStatus" class="form-select select2">
                                <option value="Active" selected="@(Model.Inquiries?.Status == "Active")">Active</option>
                                <option value="Passive" selected="@(Model.Inquiries?.Status == "Passive")">Passive</option>
                                <option value="Dead" selected="@(Model.Inquiries?.Status == "Dead")">Dead</option>
                            </select>
                            </div>
                        </div>
                    
                
            </div>
        </div>
    </div>
</div>
</form>
@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>
    <script src="~/js/inline-form-validation.js"></script>
    <script src="~/assets/js/AdmissionInquiry.js"></script>
}
