@model SchoolERP.Shared.Models.FOComplaintAddPageViewModel
@using System.Security.Claims
@using System.Text.Json
@{
    ViewData["Title"] = "Complaint Type";

    // Permission loading for the view
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;

}
<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.Complaints == null ? "Add Complaint Type" : "Edit Complaint Type")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button type="submit" onclick="saveComplaint()" class="btn btn-success top-btn">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/FrontOffice/Complaint" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>

<form id="complaintForm">
    <div class="row">
        <div class="col-xl-12">
            <div class="card shadow-tbl-outer">
                <div class="card-body">
                    <input type="hidden" id="hdnComplaintID" value="@Model.Complaints?.ComplaintID">
                    <div class="row row-gap-3">
                        <div class="col-md-6">
                            <label class="form-label">Complaint Type <span class="text-danger">*</span></label>
                            <select class="form-select select2" id="ddlComplaintType" required>
                                <option value="">Select</option>
                                @foreach (var t in Model.ComplaintTypes)
                                {
                                    <option value="@t.ComplaintTypeID" selected="@(Model.Complaints?.ComplaintID == t.ComplaintTypeID)">@t.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Source <span class="text-danger">*</span></label>
                            <select class="form-select select2" id="ddlSource" required>
                                <option value="">Select</option>
                                @foreach (var s in Model.Sources)
                                {
                                    <option value="@s.SourceID" selected="@(Model.Complaints?.SourceID == s.SourceID)">@s.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Complaint By <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" value="@Model.Complaints?.ComplaintBy" id="txtComplaintBy" placeholder="Name" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Phone</label>
                            <input type="text" class="form-control" id="txtPhone" value="@Model.Complaints?.Phone" placeholder="Phone number">
                            <div id="errPhone" class="invalid-feedback"></div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" id="txtEmail" value="@Model.Complaints?.Email" placeholder="Email address">
                            <div id="errEmail" class="invalid-feedback"></div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="txtDate" required value="@(Model.Complaints?.ComplaintDate.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Assigned To</label>
                            <input type="text" class="form-control" id="txtAssignedTo" value="@Model.Complaints?.AssignedTo" placeholder="Name of staff">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Action Taken</label>
                            <input type="text" class="form-control" value="@Model.Complaints?.ActionTaken" id="txtActionTaken">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" id="txtDescription" rows="2">@Model.Complaints?.Description</textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Note</label>
                            <textarea class="form-control" id="txtNote" rows="2">@Model.Complaints?.Note</textarea>
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="chkActive" @(Model.Complaints?.IsActive ?? true ? "checked" : "")>
                                <label class="form-check-label" for="chkActive">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>
@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);

    </script>
    <script src="~/js/inline-form-validation.js"></script>
    <script src="~/assets/js/Complaint.js"></script>

}
