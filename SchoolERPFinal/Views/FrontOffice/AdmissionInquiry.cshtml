        border-left: 3px solid #0d6efd !important;
    }
    .btn-apply {
        background-color: #345a67;
        color: white;
    }
    .btn-apply:hover {
        background-color: #2a4852;
        color: white;
    }
    .bg-light { background-color: #f8f9fa !important; }
</style>
