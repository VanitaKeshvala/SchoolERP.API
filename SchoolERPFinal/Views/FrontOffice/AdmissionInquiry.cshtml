@model SchoolERP.Shared.Models.FOAdmissionInquiryPageViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Admission Enquiry";

    // Permission loading for the view
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;

}
<style>
    .dt-buttons {
        display: none !important;
    }
</style>

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Admission Enquiry</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button onclick="resetInquiryForm()" class="btn btn-primary top-btn" data-bs-toggle="modal" data-bs-target="#addModal"><i class="ti ti-plus me-1"></i> Add</button>
        }
        @if (p.CanEdit)
        {
            <button onclick="editSelectedInquiry()" class="btn btn-info top-btn"><i class="ti ti-pencil me-1"></i> Edit</button>
        }
        @if (p.CanDelete)
        {
            <button onclick="deleteSelectedInquiry()" class="btn btn-danger top-btn"><i class="ti ti-trash me-1"></i> Delete</button>
        }
        @if (p.CanPrint)
        {
            <button class="btn btn-secondary d-inline-flex align-items-center top-btn" onclick="triggerExport(4)">
                <i class="ti ti-printer me-1"></i>Print
            </button>
        }
        @if (p.CanEdit)
        {
            <button onclick="followUpSelectedInquiry()" class="btn btn-apply top-btn"><i class="ti ti-phone-ringing me-1"></i> Follow Up</button>
        }
        @if (p.CanExport)
        {
            <div class="dropdown d-inline-flex">
                <button class="btn btn-warning dropdown-toggle top-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(0)"><i class="ti ti-copy me-1"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(1)"><i class="ti ti-file-text me-1"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(2)"><i class="ti ti-file-spreadsheet me-1"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(3)"><i class="ti ti-file-description me-1"></i>PDF</a></li>
                </ul>
            </div>
        }

        
    </div>
</div>

<!-- End Page Header -->
<!-- start row -->
<div class="row">
    <div class="col-md-12">
        <div class="card shadow-tbl-outer mb-2">
            <div class="card-body p-3">
                <form id="filterForm" method="get">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="position-relative border d-flex align-items-center rounded-2 px-3 ">
                            <i class="fas fa-search search-icon-input"></i>
                            <input type="text" class="form-control border-0 ps-2" id="tableSearch"
                                   placeholder="Search..." style="min-width: 220px;">
                        </div>
                        <!--<input type="text" id="tableSearch" class="form-control w-25 me-3" placeholder="Search..." />-->
                        <div class="d-flex align-items-center flex-wrap gap-2 flex-shrink-0">
                            <div class="dropdown">
                                <a href="#" class="btn btn-white border btn-lg" data-bs-toggle="dropdown">
                                    <i class="ti ti-filter text-gray-5 me-1"></i>Filters
                                </a>
                                <div class="dropdown-menu dropdown-lg dropdown-menu-end filter-dropdown p-0" id="filter-dropdown">
                                    <div class="d-flex align-items-center justify-content-between border-bottom filter-header py-2">
                                        <h6 class="mb-0 fw-bold">Select Criteria</h6>
                                        <div class="d-flex align-items-center justify-content-end">
                                            <button type="submit" class="btn text-primary fs-6">Filter</button>
                                        </div>
                                    </div>
                                    <div class="filter-body pb-0 row p-3">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label mb-1">Class</label>
                                            <select name="classId" id="filterClass" class="form-select form-control select2">
                                                <option value="0">All</option>
                                                @foreach (var item in Model.Classes)
                                                {
                                                    <option value="@item.ClassID">@item.ClassName</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label mb-1">Source</label>
                                            <select name="sourceId" id="filterSource" class="form-select form-control select2">
                                                <option value="0">All</option>
                                                @foreach (var item in Model.Sources)
                                                {
                                                    <option value="@item.SourceID">@item.Name</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label mb-1">Enquiry From Date</label>
                                            <input type="date" name="fromDate" id="filterFromDate" class="form-control">
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label mb-1">Enquiry To Date</label>
                                            <input type="date" name="toDate" id="filterToDate" class="form-control">
                                        </div>
                                        <div class="col-md-12 mb-3">
                                            <label class="form-label mb-1">Status</label>
                                            <select name="status" id="filterStatus" class="form-select form-control select2">
                                                <option value="">All</option>
                                                <option value="Active">Active</option>
                                                <option value="Passive">Passive</option>
                                                <option value="Dead">Dead</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-12" id="activeFilterBadges" style="display: none;">
        <div class="card shadow-tbl border-0 py-2 mb-2">
            <div class="card-body p-2 d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold ms-2 me-2"><i class="ti ti-filter-check me-1"></i>Active Filters:</span>
                <div id="badgeContainer" class="d-flex flex-wrap gap-2"></div>
                <button class="btn btn-sm btn-link text-danger p-0 ms-auto me-2 fw-bold text-decoration-none" id="btnResetAllFilters" onclick="resetAllFilters()">
                    <i class="ti ti-trash me-1"></i>Clear All
                </button>
            </div>
        </div>
    </div>

    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-nowrap mb-0" id="inquiryTable">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Phone</th>
                                <th>Source</th>
                                <th>Enquiry Date</th>
                                <th>Last Follow Up</th>
                                <th>Next Follow Up</th>
                                <th>Status</th>
                                
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Inquiries)
                            {
                                <tr>
                                    <td>
                                        <input type="checkbox" name="selectedInquiry"
                                               class="form-check-input student-checkbox"
                                               value="@item.InquiryID">
                                        
                                    <td>@item.Name</td>
                                    <td>@item.Phone</td>
                                    <td>@item.SourceName</td>
                                    <td>@item.Date.ToString("dd-MM-yyyy")</td>
                                    <td>@(item.LastFollowUpDate?.ToString("dd-MM-yyyy") ?? "-")</td>
                                    <td>@(item.NextFollowUpDate?.ToString("dd-MM-yyyy") ?? "-")</td>
                                    <td>
                                        @{
                                            var badgeClass = item.Status == "Active" ? "bg-success" : (item.Status == "Passive" ? "bg-warning" : "bg-danger");
                                        }
                                        <span class="badge @badgeClass rounded-pill">@item.Status</span>
                                    </td>
                                   
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="addModal">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content">
            <form id="inquiryForm">
                <input type="hidden" name="InquiryID" id="InquiryID" value="0" />
                <div class="modal-header d-flex justify-content-between align-items-center">
                    <h5 class="modal-title" id="modalTitle">Admission Enquiry</h5>
                    <div>
                        <button type="submit" class="btn btn-success"><i class="ti ti-cloud me-1"></i> Save</button>
                        <button type="button" class="btn btn-danger" data-bs-dismiss="modal"><i class="ti ti-x me-1"></i> Close</button>
                    </div>
                </div>
                <div class="modal-body">
                    <div class="row row-gap-3">
                        <div class="col-md-6">
                            <label class="form-label">Name <span class="text-danger">*</span></label>
                            <input type="text" name="Name" id="InqName" class="form-control" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Phone <span class="text-danger">*</span></label>
                            <input type="text" name="Phone" id="InqPhone" class="form-control" required maxlength="10">
                            <div id="errPhone" class="invalid-feedback"></div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Email</label>
                            <input type="text" name="Email" id="InqEmail" class="form-control">
                            <div id="errEmail" class="invalid-feedback"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Address</label>
                            <textarea name="Address" id="InqAddress" class="form-control"></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Description</label>
                            <textarea name="Description" id="InqDescription" class="form-control"></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Note</label>
                            <textarea name="Note" id="InqNote" class="form-control"></textarea>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Date <span class="text-danger">*</span></label>
                            <input type="date" name="Date" id="InqDate" class="form-control" required>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Next Follow Up Date</label>
                            <input type="date" name="NextFollowUpDate" id="InqNextFollowUpDate" class="form-control">
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Assign To</label>
                            <select name="AssignedTo" id="InqAssignedTo" class="form-select select2">
                                <option value="">Select</option>
                                @foreach (var st in Model.Staff)
                                {
                                    <option value="@st.StaffID">@($"{st.FirstName} {st.LastName} ({st.StaffID})")</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Reference</label>
                            <select name="ReferenceID" id="InqReferenceID" class="form-select select2">
                                <option value="">Select</option>
                                @foreach (var r in Model.References)
                                {
                                    <option value="@r.ReferenceID">@r.Name</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Source</label>
                            <select name="SourceID" id="InqSourceID" class="form-select select2">
                                <option value="">Select</option>
                                @foreach (var s in Model.Sources)
                                {
                                    <option value="@s.SourceID">@s.Name</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Class</label>
                            <select name="ClassID" id="InqClassID" class="form-select select2">
                                <option value="">Select</option>
                                @foreach (var c in Model.Classes)
                                {
                                    <option value="@c.ClassID">@c.ClassName</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Number Of Child </label>
                            <input type="number" name="NoOfChild" id="InqNoOfChild" class="form-control" value="1">
                        </div>

                        <div class="col-md-4">
                            <label class="form-label">Status</label>
                            <select name="Status" id="InqStatus" class="form-select select2">
                                <option value="Active">Active</option>
                                <option value="Passive">Passive</option>
                                <option value="Dead">Dead</option>
                            </select>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>



@section Scripts {
    <script src="~/js/inline-form-validation.js"></script>
    <script src="~/assets/js/AdmissionInquiry.js"></script>
}

