@model SchoolERP.Shared.Models.FOAdmissionInquiryViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Inquiry Follow Up";
}

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-tbl-outer mb-2">
            <div class="card-body p-3">
                <div class="row g-0">
                    <div class="col-lg-7 p-4 border-end">
                        <form id="followUpForm">
                            <input type="hidden" name="InquiryID" id="FollowUpInquiryID" />
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Follow Up Date <span class="text-danger">*</span></label>
                                    <input type="date" name="FollowUpDate" id="FollowUpDate" class="form-control" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Next Follow Up Date <span class="text-danger">*</span></label>
                                    <input type="date" name="NextFollowUpDate" id="FollowUpNextDate" class="form-control" required>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">Response <span class="text-danger">*</span></label>
                                    <textarea name="Response" id="FollowUpResponse" class="form-control" rows="3" required></textarea>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Note</label>
                                    <textarea name="Note" id="FollowUpNote" class="form-control" rows="3"></textarea>
                                </div>
                            </div>
                            <div class="text-end">
                                <button type="submit" class="btn btn-success px-4"><i class="ti ti-cloud me-1"></i> Save Follow Up</button>
                            </div>
                        </form>

                        <div class="mt-4">
                            <h6 class="fw-bold mb-3">Timeline</h6>
                            <div id="followUpTimeline" class="timeline">
                                @* @if (Model.followUps && d.followUps.length > 0) 
                                {
                                } *@
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-5 p-4 bg-light">
                        <div class="summary-sidebar">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h5 class="mb-0" id="SideName">Summary</h5>
                                    <small class="text-muted" id="SideAssigned">Assigned: -</small>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-primary" id="SideStatus">Active</span>
                                </div>
                            </div>

                            <div class="mt-4">
                                <p class="mb-2"><strong>Phone:</strong> <span id="SidePhone">-</span></p>
                                <p class="mb-2"><strong>Email:</strong> <span id="SideEmail">-</span></p>
                                <p class="mb-2"><strong>Address:</strong> <span id="SideAddress">-</span></p>
                                <p class="mb-2"><strong>Class:</strong> <span id="SideClass">-</span></p>
                                <p class="mb-2"><strong>Source:</strong> <span id="SideSource">-</span></p>
                                <p class="mb-2"><strong>Reference:</strong> <span id="SideReference">-</span></p>
                                <p class="mb-2"><strong>Child Count:</strong> <span id="SideChild">-</span></p>
                                <hr />
                                <p class="mb-2"><strong>Enquiry Date:</strong> <span id="SideEnqDate">-</span></p>
                                <p class="mb-2"><strong>Next Follow Up:</strong> <span id="SideNextDate">-</span></p>
                                <p class="mb-2"><strong>Description:</strong> <br /><span id="SideDesc" class="small text-muted">-</span></p>
                                <p class="mb-2"><strong>Note:</strong> <br /><span id="SideNote" class="small text-muted">-</span></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/inline-form-validation.js"></script>
    <script src="~/assets/js/AdmissionInquiry.js"></script>
}
<style>
    .timeline {
        max-height: 300px;
        overflow-y: auto;
        padding-right: 5px;
    }

    .timeline-item {
        border-left: 3px solid #0d6efd !important;
    }

    .btn-apply {
        background-color: #345a67;
        color: white;
    }

        .btn-apply:hover {
            background-color: #2a4852;
            color: white;
        }

    .bg-light {
        background-color: #f8f9fa !important;
    }
</style>
