@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.WardensAddViewModel
@{
    ViewData["Title"] = "Add Wardens";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditWardens == null ? "Add Warden" : "Edit Warden")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveItem()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Wardens/Index" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>

<div id="wardenPageNotice"></div>

<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <input type="hidden" id="txtItemId" value="@(Model.EditWardens?.WardenId ?? 0)">
                    <input type="hidden" id="hdnUserID" value="@(Model.EditWardens?.CreatedBy ?? 0)">
                    <input type="hidden" id="hdnCompanyID" value="@(Model.EditWardens?.CompanyID ?? 0)">
                    <input type="hidden" id="hdnSessionID" value="@(Model.EditWardens?.SessionID ?? 0)">
                    <input type="hidden" id="hdnPhotoPath" value="@Model.EditWardens?.Photo">

                    <div class="row">

                        <!-- Hostel -->
                        <div class="d-block col-md-4 mb-3">
                            <label class="form-label fw-bold">Hostel<span class="text-danger">*</span></label>
                            <select class="form-select select2" id="ddlHostel" style="width: 100%;">
                                <option value="">-- Select --</option>
                                @foreach (var rt in Model.HostelModel.Where(x => x.IsActive))
                                {
                                    <option value="@rt.HostelID" selected="@(Model.EditWardens?.HostelID == rt.HostelID)">@rt.HostelName</option>
                                }
                            </select>
                            <div class="invalid-feedback" id="errddlHostel"></div>
                        </div>

                        <!-- Warden Name -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Warden Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtWardenName"
                                   value="@Model.EditWardens?.WardenName"
                                   placeholder="Enter warden name" autocomplete="off" maxlength="100">
                            <div class="invalid-feedback" id="errtxtWardenName"></div>
                        </div>

                        <!-- Gender -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Gender <span class="text-danger">*</span></label>
                            <select class="form-select" id="ddlGender">
                                <option value="">-- Select --</option>
                                <option value="Male" selected="@(Model.EditWardens?.Gender == "Male")">Male</option>
                                <option value="Female" selected="@(Model.EditWardens?.Gender == "Female")">Female</option>
                                <option value="Other" selected="@(Model.EditWardens?.Gender == "Other")">Other</option>
                            </select>
                            <div class="invalid-feedback" id="errddlGender"></div>
                        </div>

                        <!-- Contact -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Warden Contact <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtWardenContact"
                                   value="@Model.EditWardens?.WardenContact"
                                   placeholder="10-digit mobile number" autocomplete="off" maxlength="15">
                            <div class="invalid-feedback" id="errtxtWardenContact"></div>
                        </div>

                        <!-- Email -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Warden Email</label>
                            <input type="email" class="form-control" id="txtWardenEmail"
                                   value="@Model.EditWardens?.WardenEmail"
                                   placeholder="warden@example.com" autocomplete="off" maxlength="100">
                            <div class="invalid-feedback" id="errtxtWardenEmail"></div>
                        </div>

                        <!-- Emergency Contact -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Emergency Contact Number</label>
                            <input type="text" class="form-control" id="txtEmergencyContactNumber"
                                   value="@Model.EditWardens?.EmergencyContactNumber"
                                   placeholder="10-digit mobile number" autocomplete="off" maxlength="15">
                            <div class="invalid-feedback" id="errtxtEmergencyContactNumber"></div>
                        </div>

                        <!-- Birth Date -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Date of Birth</label>
                            <input type="date" class="form-control" id="txtBirthDate"
                                   value="@(Model.EditWardens?.BirthDate?.ToString("yyyy-MM-dd"))">
                            <div class="invalid-feedback" id="errtxtBirthDate"></div>
                        </div>

                        <!-- Joining Date -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Date of Joining <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="txtJoiningDate"
                                   value="@(Model.EditWardens?.JoiningDate?.ToString("yyyy-MM-dd"))">
                            <div class="invalid-feedback" id="errtxtJoiningDate"></div>
                        </div>

                        <!-- Qualification -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Qualification</label>
                            <input type="text" class="form-control" id="txtQualification"
                                   value="@Model.EditWardens?.Qualification"
                                   placeholder="e.g. B.A., M.Sc." autocomplete="off" maxlength="100">
                        </div>

                        <!-- Experience -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Experience (Years)</label>
                            <input type="number" class="form-control" id="txtExperienceYears" min="0" max="60"
                                   value="@Model.EditWardens?.ExperienceYears">
                            <div class="invalid-feedback" id="errtxtExperienceYears"></div>
                        </div>

                        <!-- Aadhar -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Aadhar Number</label>
                            <input type="text" class="form-control" id="txtAadharNumber"
                                   value="@Model.EditWardens?.AadharNumber"
                                   placeholder="12-digit Aadhar number" autocomplete="off" maxlength="12" inputmode="numeric">
                            <div class="invalid-feedback" id="errtxtAadharNumber"></div>
                        </div>

                        <!-- Photo -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Photo</label>
                            <input type="file" class="form-control" id="filePhoto" accept="image/png,image/jpeg,image/jpg">
                            <div class="invalid-feedback" id="errfilePhoto"></div>
                            <div class="mt-2">
                                <img id="imgPhotoPreview"
                                     src="@(string.IsNullOrEmpty(Model.EditWardens?.Photo) ? "#" : Model.EditWardens.Photo)"
                                     style="max-height:80px; @(string.IsNullOrEmpty(Model.EditWardens?.Photo) ? "display:none;" : "")"
                                     class="rounded border" alt="Photo preview" />
                            </div>
                        </div>

                        <!-- Address -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Address</label>
                            <input type="text" class="form-control" id="txtAddress"
                                   value="@Model.EditWardens?.Address"
                                   placeholder="House no, street, area" autocomplete="off" maxlength="255">
                        </div>

                        <!-- Country -->
                        <div class="d-block col-md-4 mb-3">
                            <label class="form-label fw-bold">Country</label>
                            <select class="form-select select2" id="ddlCountry" onchange="loadStatesByCountry(this.value,0)" style="width: 100%;">
                                <option value="">-- Select --</option>
                                @foreach (var rt in Model.Country.Where(x => x.IsActive))
                                {
                                    <option value="@rt.CountryId" selected="@(Model.EditWardens?.CountryId == rt.CountryId)">@rt.CountryName</option>
                                }
                            </select>
                        </div>

                        <!-- State (country-wise) -->
                        <div class="d-block col-md-4 mb-3">
                            <label class="form-label fw-bold">State</label>
                            <select class="form-select select2" id="ddlState" style="width: 100%;">
                                <option value="">-- Select Country First --</option>
                            </select>
                        </div>

                        <!-- PinCode -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">PinCode</label>
                            <input type="text" class="form-control" id="txtPinCode"
                                   value="@Model.EditWardens?.PinCode"
                                   placeholder="6-digit pin code" autocomplete="off" maxlength="6" inputmode="numeric">
                            <div class="invalid-feedback" id="errtxtPinCode"></div>
                        </div>

                        <!-- Active -->
                        <div class="col-md-2 mb-3">
                            <div class="form-check form-switch mt-4">
                                <input class="form-check-input" type="checkbox" id="isActive"
                                @(Model.EditWardens?.IsActive ?? true ? "checked" : "")>
                                <label class="form-check-label fw-bold" for="isActive">Active</label>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<link href="~/assets/css/select2.min.css" rel="stylesheet" />

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
        // Preselect state on edit (post-load, after cascading dropdown is populated)
        window.editSelectedStateId = @(Model.EditWardens?.StateId ?? 0);
        window.editSelectedCountryId = @(Model.EditWardens?.CountryId ?? 0);
    </script>

    <script src="~/assets/js/Wardens.js"></script>
}