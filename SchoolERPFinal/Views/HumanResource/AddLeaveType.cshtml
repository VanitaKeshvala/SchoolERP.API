@model SchoolERP.Shared.Models.HRLeaveTypeAddPageViewModel
@using System.Security.Claims
@using System.Text.Json
@{
    ViewData["Title"] = "Add Leave Type";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions ?? new PagePermissions();
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditItems == null ? "Add Leave Type" : "Edit Leave Type")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveRecord()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }


        <a href="/HumanResource/LeaveType" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>

<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <form id="entryForm">
                    <input type="hidden" id="hdnLeaveTypeID" value="@(Model.EditItems?.LeaveTypeID ?? 0)">
                    <div class="row row-gap-3">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Designation Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" value="@Model.EditItems?.LeaveTypeName" id="txtName" required maxlength="100">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Display Name </label>
                            <input type="text" class="form-control" id="txtDisplayLabel"
                                   value="@Model.EditItems?.DisplayLabel"
                                   placeholder="e.g. Girls Hostel" autocomplete="off">
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="chkActive" @((Model.EditItems?.IsActive ?? true) ? "checked" : "")>
                                <label class="form-check-label" for="chkActive">Active</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
                  window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
                        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
                        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    <script src="~/assets/js/LeaveType.js"> </script>
}