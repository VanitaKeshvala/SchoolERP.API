@model SchoolERP.Shared.Models.HRStaffPageViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Disabled Staff Directory";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;
}
<style>
    .dt-buttons {
        display: none !important;
    }
</style>
<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Disabled Staff Directory</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanPrint)
        {
            <button class="btn btn-secondary d-inline-flex align-items-center top-btn" onclick="triggerExport(4)">
                <i class="ti ti-printer me-1"></i>Print
            </button>
        }
        @if (p.CanExport)
        {
            <div class="dropdown d-inline-flex">
                <button class="btn btn-warning dropdown-toggle top-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(0)"><i class="ti ti-copy me-1"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(1)"><i class="ti ti-file-text me-1"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(2)"><i class="ti ti-file-spreadsheet me-1"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(3)"><i class="ti ti-file-description me-1"></i>PDF</a></li>
                </ul>
            </div>
        }

    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-tbl-outer mb-2">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3 bg-white">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text" id="txtSearchInput" class="form-control border-0 ps-2" style="min-width: 220px;" placeholder="Search by name or code..." onkeyup="filterStaff()" />
                    </div>
                    <div class="d-flex align-items-center flex-wrap gap-2 flex-shrink-0">
                        <div class="dropdown">
                            <a href="#" id="btnFilterToggle" class="btn btn-white border rounded btn-md text-dark fs-14 align-items-center d-flex fw-normal"
                               data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                                <i class="ti ti-filter text-gray-5 me-1"></i>Filters
                            </a>
                            <div class="dropdown-menu dropdown-lg dropdown-menu-end filter-dropdown p-0 shadow-tbl" id="filter-dropdown">
                                <div class="d-flex align-items-center justify-content-between border-bottom filter-header py-2">
                                    <h6 class="mb-0 fw-bold">Select Criteria</h6>
                                    <div class="d-flex align-items-center justify-content-end me-2">
                                        <button type="button" class="btn text-primary fs-6 fw-medium" onclick="filterStaff()">Apply</button>
                                    </div>
                                </div>
                                <div class="filter-body pb-0 p-3">
                                    <div class="mb-3">
                                        <label class="form-label mb-1">Role</label>
                                        <select id="fltRole" class="form-select form-control select2">
                                            <option value="">All Roles</option>
                                            @foreach (var r in Model.Roles)
                                            {
                                                <option value="@r.RoleName">@r.RoleName</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label mb-1">Department</label>
                                        <select id="fltDept" class="form-select form-control select2">
                                            <option value="">All Departments</option>
                                            @foreach (var d in Model.Departments)
                                            {
                                                <option value="@d.DepartmentName">@d.DepartmentName</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label mb-1">Designation</label>
                                        <select id="fltDesig" class="form-select form-control select2">
                                            <option value="">All Designations</option>
                                            @foreach (var d in Model.Designations)
                                            {
                                                <option value="@d.DesignationName">@d.DesignationName</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="bg-white border border-muted rounded px-1 py-1 d-flex gap-1 shadow-sm">
                            <button onclick="switchView('list')" id="btn-list-view" class="btn btn-sm rounded btn-primary">
                                <i class="ti ti-list fs-14"></i>
                            </button>
                            <button onclick="switchView('card')" id="btn-card-view" class="btn btn-sm rounded btn-white border">
                                <i class="ti ti-layout-grid fs-14"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-12" id="activeFilterBadges" style="display: none;">
        <div class="card shadow-tbl border-0 py-2 mb-2">
            <div class="card-body p-2 d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold ms-2 me-2"><i class="ti ti-filter-check me-1"></i>Active Filters:</span>
                <div id="badgeContainer" class="d-flex flex-wrap gap-2"></div>
                <button class="btn btn-sm btn-link text-danger p-0 ms-auto me-2 fw-bold text-decoration-none" id="btnResetAllFilters" onclick="resetFilters()">
                    <i class="ti ti-trash me-1"></i>Clear All
                </button>
            </div>
        </div>
    </div>

    <!-- View Containers -->
    <div class="col-12" id="staffContainer">
        <div id="card-view-container" class="row d-none"></div>
        <div id="list-view-container" class="card shadow-tbl">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table mb-0" id="disabledStaffTable">
                        <thead>
                            <tr>
                                <th>Staff ID</th>
                                <th>Name</th>
                                <th>Role</th>
                                <th>Department</th>
                                <th>Designation</th>
                                <th>Mobile</th>
                            </tr>
                        </thead>
                        <tbody id="list-tbody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let allStaff = [];
        let currentView = 'list';
        let selectedStaffID = null;
        const canEdit = false;
        const canDelete = false;

        function triggerExport(index) {
            if ($.fn.DataTable.isDataTable('#disabledStaffTable')) {
                const table = $('#disabledStaffTable').DataTable();
                table.button(index).trigger();
            }
        }
        function initializeDataTable() {

            if ($.fn.DataTable.isDataTable('#disabledStaffTable')) {
                $('#disabledStaffTable').DataTable().destroy();
            }

            $('#disabledStaffTable').DataTable({
                destroy: true,
                dom: 'Bfrtip',
                buttons: [
                    { extend: 'copy', exportOptions: { columns: [0, 1, 2, 3, 4, 5] } },
                    { extend: 'csv', exportOptions: { columns: [0, 1, 2, 3, 4, 5] } },
                    { extend: 'excel', exportOptions: { columns: [0, 1, 2, 3, 4, 5] } },
                    { extend: 'pdf', exportOptions: { columns: [0, 1, 2, 3, 4, 5] } },
                    { extend: 'print', exportOptions: { columns: [0, 1, 2, 3, 4, 5] } }
                ],
                searching: false,
                paging: false,
                info: false,
                ordering: false,
                language: {
                    emptyTable: "No disabled staff records found."
                }
            });
        }

        $(document).ready(function () {
           
        })



        $(document).ready(function () {
            $('.select2').select2({ width: '100%' });
            $('#filter-dropdown').on('click', function (e) {
                e.stopPropagation();
            });
            loadStaff();
        });

        function loadStaff() {
            $('#list-tbody').html('<tr><td colspan="6" class="text-center py-5"><div class="spinner-border text-primary"></div></td></tr>');
            $('#card-view-container').html('<div class="col-12 text-center py-5"><div class="spinner-border text-primary"></div></div>');

            fetch('/HumanResource/GetAllStaff?isActive=false')
                .then(r => r.json())
                .then(res => {
                    if (res.success) {
                        allStaff = res.data || [];
                        renderStaff(allStaff);
                        initializeDataTable();
                    } else {
                        alert(res.message || 'Error loading staff');
                    }
                })
                .catch(err => {
                    console.error(err);
                    $('#list-tbody').html('<tr><td colspan="6" class="text-center text-danger py-4">Failed to load staff records.</td></tr>');
                    $('#card-view-container').html('<div class="col-12 text-center text-danger py-4">Failed to load staff records.</div>');
                });
        }

        function renderStaff(data) {
            const listBody = document.getElementById('list-tbody');
            const cardContainer = document.getElementById('card-view-container');
            listBody.innerHTML = '';
            cardContainer.innerHTML = '';
            selectedStaffID = null;
            toggleTopButtons();

            if (data.length === 0) {
                listBody.innerHTML = '<tr><td colspan="6" class="text-center py-4 text-danger">No disabled staff records found.</td></tr>';
                cardContainer.innerHTML = '<div class="col-12 text-center py-5 text-danger">No disabled staff records found.</div>';
                return;
            }

            data.forEach(s => {
                let roleBadges = '';
                if (s.displayRoles && s.displayRoles.length > 0) {
                    s.displayRoles.forEach(r => {
                        roleBadges += `<span class="badge bg-soft-primary text-primary me-1">${r}</span>`;
                    });
                } else {
                    roleBadges = '<span class="badge bg-soft-secondary text-secondary">No Role</span>';
                }

                // List Row
                const row = `<tr>
                        <td><span>${s.staffCode}</span></td>
                        <td>
                            <div class="d-flex align-items-center">
                                <a href="/HumanResource/StaffDetails/${s.staffID}" class="text-dark">${s.firstName} ${s.lastName || ''}</a>
                            </div>
                        </td>
                        <td><span class="">${roleBadges}</span></td>
                        <td>${s.departmentName || 'N/A'}</td>
                        <td>${s.designationName || 'N/A'}</td>
                        <td>${s.mobileNo || 'N/A'}</td>
                    </tr>`;
                listBody.insertAdjacentHTML('beforeend', row);

                // Card
                const card = `<div class="col-xl-3 col-md-4 col-sm-6 mb-3">
                        <div class="card border shadow-sm h-100 staff-card position-relative border-danger-subtle">
                            <div class="card-body text-center p-3">
                                

                                <a href="/HumanResource/StaffDetails/${s.staffID}" class="text-dark fw-semibold">
                                    <h6 class="mb-0 text-truncate">${s.firstName} ${s.lastName || ''}</h6>
                                </a>
                                <small class="text-muted d-block mb-2 text-truncate">${s.designationName || 'No Designation'}</small>
                                <div class="d-flex flex-column gap-1 text-start fs-13 mt-2 border-top pt-2">
                                    <span class="text-truncate"><i class="ti ti-id me-1 text-primary"></i>${s.staffCode}</span>
                                    <span class="text-truncate"><i class="ti ti-building me-1 text-primary"></i>${s.departmentName || 'N/A'}</span>
                                    <span class="text-truncate"><i class="ti ti-shield me-1 text-primary"></i>${roleBadges}</span>
                                    <span class="text-truncate"><i class="ti ti-phone me-1 text-primary"></i>${s.mobileNo || 'N/A'}</span>
                                </div>
                            </div>
                        </div>
                    </div>`;
                cardContainer.insertAdjacentHTML('beforeend', card);
            });
        }

        function selectStaff(id) { }
        function selectStaffCard(id, el) { }
        function toggleTopButtons() { }
        function handleEdit() { }
        function handleDelete() { }

        function filterStaff() {
            const search = document.getElementById('txtSearchInput').value.toLowerCase();
            const role = document.getElementById('fltRole').value;
            const dept = document.getElementById('fltDept').value;
            const desig = document.getElementById('fltDesig').value;

            const filtered = allStaff.filter(s => {
                const matchesSearch = (s.firstName + ' ' + (s.lastName || '')).toLowerCase().includes(search) ||
                    s.staffCode.toLowerCase().includes(search);
                const matchesRole = !role || (s.displayRoles && s.displayRoles.includes(role));
                const matchesDept = !dept || s.departmentName === dept;
                const matchesDesig = !desig || s.designationName === desig;
                return matchesSearch && matchesRole && matchesDept && matchesDesig;
            });

            renderStaff(filtered);
            renderFilterBadges();
            
            const toggle = document.getElementById('btnFilterToggle');
            if (toggle) {
                bootstrap.Dropdown.getOrCreateInstance(toggle).hide();
            }
        }

        // --- Filter Badges Logic ---
        function renderFilterBadges() {
            const container = document.getElementById('badgeContainer');
            const mainContainer = document.getElementById('activeFilterBadges');
            if (!container) return;
            container.innerHTML = '';

            const filters = [
                { id: 'txtSearchInput', label: 'Search', type: 'text' },
                { id: 'fltRole', label: 'Role', type: 'select' },
                { id: 'fltDept', label: 'Department', type: 'select' },
                { id: 'fltDesig', label: 'Designation', type: 'select' }
            ];

            let activeCount = 0;

            filters.forEach(f => {
                const el = document.getElementById(f.id);
                if (!el) return;

                let value = el.value;
                let text = '';

                if (f.type === 'text') {
                    if (value.trim()) {
                        text = value;
                        activeCount++;
                    }
                } else if (f.type === 'select') {
                    if (value && value !== 'all' && value !== '') {
                        const selectedOption = el.options[el.selectedIndex];
                        if (selectedOption && selectedOption.value !== "") {
                            text = selectedOption.text;
                            activeCount++;
                        }
                    }
                }

                if (text) {
                    const badge = document.createElement('span');
                    badge.className = 'badge bg-primary-subtle text-primary border border-primary-subtle d-flex align-items-center gap-1 fw-medium px-2 py-1';
                    badge.innerHTML = `${f.label}: ${text} <i class="ti ti-x ms-1 cursor-pointer" onclick="removeFilter('${f.id}')" style="font-size: 10px;"></i>`;
                    container.appendChild(badge);
                }
            });

            if (activeCount > 0) {
                mainContainer.style.display = 'block';
            } else {
                mainContainer.style.display = 'none';
            }
        }

        function removeFilter(filterId) {
            const el = document.getElementById(filterId);
            if (!el) return;

            if (el.tagName === 'INPUT' && filterId === 'txtSearchInput') {
                el.value = '';
                filterStaff();
            } else {
                el.value = '';
                if (window.jQuery && jQuery(el).data('select2')) {
                    jQuery(el).trigger('change.select2');
                }
                filterStaff();
            }
        }

        function resetFilters() {
            document.getElementById('txtSearchInput').value = '';
            $('#fltRole, #fltDept, #fltDesig').val('').trigger('change');
            filterStaff();
        }

        function switchView(view) {
            currentView = view;
            if (view === 'list') {
                $('#list-view-container').removeClass('d-none');
                $('#card-view-container').addClass('d-none');
                $('#btn-list-view').addClass('btn-primary').removeClass('btn-white border');
                $('#btn-card-view').removeClass('btn-primary').addClass('btn-white border');
            } else {
                $('#list-view-container').addClass('d-none');
                $('#card-view-container').removeClass('d-none');
                $('#btn-card-view').addClass('btn-primary').removeClass('btn-white border');
                $('#btn-list-view').removeClass('btn-primary').addClass('btn-white border');
            }
        }

        function deleteStaff(id) {
            if (!confirm('Are you sure you want to delete this staff record? This will also delete their user account.')) return;

            fetch(`/HumanResource/DeleteStaff/${id}`, { method: 'POST' })
                .then(r => r.json())
                .then(res => {
                    if (res.success) {
                        alert(res.message);
                        loadStaff();
                    } else {
                        alert(res.message);
                    }
                });
        }
    </script>
}
