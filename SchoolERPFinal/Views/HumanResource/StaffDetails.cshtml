@model SchoolERP.Shared.Models.HRStaffViewModel
@using System.Linq
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    ViewData["Title"] = "Staff Profile - " + Model.FirstName + " " + Model.LastName;

    bool IsFieldActive(string fieldName) {
        var field = Model.SystemFields.FirstOrDefault(f => 
            f.FieldName.Replace(" ", "").Equals(fieldName.Replace(" ", ""), StringComparison.OrdinalIgnoreCase));
        return field == null || field.IsActive; // Default to active if not found
    }
}

   <style>
    /* Remove validation icons */
    .was-validated .form-control:valid, .was-validated .form-control:invalid,
    .was-validated .form-select:valid, .was-validated .form-select:invalid {
        background-image: none !important;
        padding-right: 0.75rem !important;
    }
</style>

<!-- Page Header -->
                <div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
                    <div>
                        <h6 class="fw-bold mb-0">Staff Profile</h6>
                    </div>
                    <div class="d-flex align-items-center flex-wrap gap-1">
                        <a asp-action="AddStaff" asp-route-id="@Model.StaffID" class="btn btn-warning d-inline-flex align-items-center me-1 top-btn" asp-permission="Edit" asp-permission-url="/HumanResource/StaffDetails">
                            <i class="ti ti-edit me-1"></i> Edit
                        </a>
                        @if (Model.UserID.HasValue && Model.UserID > 0)
                        {
                            <button type="button" class="btn btn-info d-inline-flex align-items-center me-1 top-btn" onclick="showChangePasswordModal()" asp-permission="Edit" asp-permission-url="/HumanResource/StaffDetails">
                                <i class="ti ti-key me-1"></i> Change Password
                            </button>
                        }
                        @if (Model.IsActive)
                        {
                            <button type="button" class="btn btn-danger d-inline-flex align-items-center me-1 top-btn" onclick="toggleStaffStatus(false)" asp-permission="Edit" asp-permission-url="/HumanResource/StaffDetails">
                                <i class="ti ti-user-x me-1"></i> Disable
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-success d-inline-flex align-items-center me-1 top-btn" onclick="toggleStaffStatus(true)" asp-permission="Edit" asp-permission-url="/HumanResource/StaffDetails">
                                <i class="ti ti-user-check me-1"></i> Enable
                            </button>
                        }
        <button type="button" class="btn btn-secondary d-inline-flex align-items-center top-btn" data-bs-toggle="offcanvas" data-bs-target="#offcanvasStaff"><i class="ti ti-list me-1"></i> Staff</button>
                    </div>
                </div>
                <!-- End Page Header -->

                <!-- start row -->
                <div class="row">
                    <div class="col-xl-4">
                        <div class="card position-sticky" style="top: 70px;">
                            <div class="card-body d-flex align-items-center flex-sm-nowrap flex-wrap row-gap-3">
                                <div class="me-3 doctor-profile-img">
                                    @if (Model.PhotoDoc != null && Model.PhotoDoc.Length > 0)
                                    {
                                        var base64 =Model.PhotoDoc;// Convert.ToBase64String(Model.PhotoDoc);
                                        var imgSrc = $"data:{Model.PhotoDocType};base64,{base64}";
                                        <img src="@imgSrc" class="rounded" alt="Staff Photo" style="width: 100px; height: 100px; object-fit: cover;">
                                    }
                                    else
                                    {
                                        <img src="~/assets/img/profiles/avatar-01.jpg" class="rounded" alt="Default Photo" style="width: 100px; height: 100px; object-fit: cover;">
                                    }
                                </div>
                                <div class="flex-fill">
                                    <div class="d-flex align-items-center justify-content-between mb-1">
                                        <h6 class="mb-2 fw-semibold">
                                            <a href="#">@Model.FirstName @Model.LastName</a>
                                            @if (Model.IsActive)
                                            {
                                                <span class="badge bg-success-subtle text-success ms-1">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger-subtle text-danger ms-1">Inactive</span>
                                            }
                                        </h6>
                                    </div>
                                    <p class="mb-2 fs-13">
                                        <span class="text-dark">Staff ID</span> : @(string.IsNullOrEmpty(Model.StaffCode) ? "-" : Model.StaffCode)
                                    </p>
                                    <p class="mb-2 fs-13">
                                        <span class="text-dark">Role</span> : @Model.RoleName
                                    </p>
                                    <p class="mb-2 fs-13">
                                        <span class="text-dark">Designation</span> : @(string.IsNullOrEmpty(Model.DesignationName) ? "-" : Model.DesignationName)
                                    </p>
                                </div>
                            </div>
                            <!-- end card body -->
                            <ul class="list-group list-group-flush">
                                @if (IsFieldActive("Department")) { <li class="list-group-item list-group-item-action"><span class="text-dark">Department :</span> @(string.IsNullOrEmpty(Model.DepartmentName) ? "-" : Model.DepartmentName)</li> }
                                @if (IsFieldActive("Payroll")) {
                                    <li class="list-group-item list-group-item-action"><span class="text-dark">EPF No. :</span> @(string.IsNullOrEmpty(Model.EPFNo) ? "-" : Model.EPFNo)</li>
                                    <li class="list-group-item list-group-item-action"><span class="text-dark">Basic Salary :</span> Rs. @Model.BasicSalary.ToString("N0")</li>
                                    <li class="list-group-item list-group-item-action"><span class="text-dark">Contract Type :</span> @(string.IsNullOrEmpty(Model.ContractType) ? "-" : Model.ContractType)</li>
                                    <li class="list-group-item list-group-item-action"><span class="text-dark">Work Shift :</span> @(string.IsNullOrEmpty(Model.WorkShift) ? "-" : Model.WorkShift)</li>
                                    <li class="list-group-item list-group-item-action"><span class="text-dark">Work Location :</span> @(string.IsNullOrEmpty(Model.WorkLocation) ? "-" : Model.WorkLocation)</li>
                                }
                                @if (IsFieldActive("DateOfJoining")) { <li class="list-group-item list-group-item-action"><span class="text-dark">Date Of Joining :</span> @(Model.DOJ?.ToString("dd MMM yyyy") ?? "-")</li> }
                                <li class="list-group-item list-group-item-action"><span class="text-dark">Barcode :</span> -</li>
                                <li class="list-group-item list-group-item-action"><span class="text-dark">QR Code :</span> -</li>
                            </ul>
                        </div>
                        <!-- end card -->
                    </div>
                    <div class="col-xl-8">
                        <div class="card">
                            <div class="card-header">
                                <ul class="nav nav-pills mb-4 gap-1">
                                    <li class="nav-item"><a href="#profile" data-bs-toggle="pill" class="nav-link active">Profile</a></li>
                                    @if (IsFieldActive("Payroll")) { <li class="nav-item"><a href="#payroll" data-bs-toggle="pill" class="nav-link">Payroll</a></li> }
                                    @if (IsFieldActive("Leaves")) { <li class="nav-item"><a href="#leave" data-bs-toggle="pill" class="nav-link">Leaves</a></li> }
                                    <li class="nav-item"><a href="#attendance" data-bs-toggle="pill" class="nav-link">Attendance</a></li>
                                    <li class="nav-item"><a href="#docs" data-bs-toggle="pill" class="nav-link">Documents</a></li>
                                    <li class="nav-item"><a href="#timeline" data-bs-toggle="pill" class="nav-link">Timeline</a></li>
                                </ul>
                                <div class="tab-content">
                                    <div class="tab-pane active" id="profile">
                                        <div class="row">
                                            <div class="col-md-12 mb-3">
                                                <div>
                                                    <ul class="list-group">
                                                        <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Phone :</span> @(string.IsNullOrEmpty(Model.MobileNo) ? "-" : Model.MobileNo)</li>
                                                        @if (IsFieldActive("EmergencyContact")) { <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Emergency Contact Number :</span> @(string.IsNullOrEmpty(Model.EmergencyMobileNo) ? "-" : Model.EmergencyMobileNo)</li> }
                                                        <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Email :</span> @(string.IsNullOrEmpty(Model.Email) ? "-" : Model.Email)</li>
                                                        @if (IsFieldActive("Gender")) { <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Gender :</span> @(string.IsNullOrEmpty(Model.Gender) ? "-" : Model.Gender)</li> }
                                                        @if (IsFieldActive("DateOfBirth")) { <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Date Of Birth :</span> @(Model.DOB?.ToString("dd MMM yyyy") ?? "-")</li> }
                                                        @if (IsFieldActive("MaritalStatus")) { <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Marital Status :</span> @(string.IsNullOrEmpty(Model.MaritalStatus) ? "-" : Model.MaritalStatus)</li> }
                                                        @if (IsFieldActive("FatherName")) { <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Father Name :</span> @(string.IsNullOrEmpty(Model.FatherName) ? "-" : Model.FatherName)</li> }
                                                        @if (IsFieldActive("MotherName")) { <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Mother Name :</span> @(string.IsNullOrEmpty(Model.MotherName) ? "-" : Model.MotherName)</li> }
                                                        @if (IsFieldActive("Qualification")) { <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Qualification :</span> @(string.IsNullOrEmpty(Model.Qualification) ? "-" : Model.Qualification)</li> }
                                                        @if (IsFieldActive("WorkExperience")) { <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Work Experience :</span> @(string.IsNullOrEmpty(Model.WorkExperience) ? "-" : Model.WorkExperience)</li> }
                                                        <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Note :</span> @(string.IsNullOrEmpty(Model.Note) ? "-" : Model.Note)</li>
                                                    </ul>
                                                </div>
                                            </div>
                                            @if (IsFieldActive("Address") || IsFieldActive("PermanentAddress"))
                                            {
                                                <div class="col-md-12 mb-3">
                                                    <div>
                                                        <ul class="list-group">
                                                            <li class="list-group-item"><b>Address Details</b></li>
                                                            @if (IsFieldActive("Address")) { <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Current Address :</span> @(string.IsNullOrEmpty(Model.CurrentAddress) ? "-" : Model.CurrentAddress)</li> }
                                                            @if (IsFieldActive("PermanentAddress")) { <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Permanent Address :</span> @(string.IsNullOrEmpty(Model.PermanentAddress) ? "-" : Model.PermanentAddress)</li> }
                                                        </ul>
                                                    </div>
                                                </div>
                                            }
                                            @if (IsFieldActive("BankDetails"))
                                            {
                                                <div class="col-md-12 mb-3">
                                                    <div>
                                                        <ul class="list-group">
                                                            <li class="list-group-item"><b>Bank Account Details</b></li>
                                                            <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Account Title :</span> @(string.IsNullOrEmpty(Model.AccountTitle) ? "-" : Model.AccountTitle)</li>
                                                            <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Bank Name :</span> @(string.IsNullOrEmpty(Model.BankName) ? "-" : Model.BankName)</li>
                                                            <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Bank Branch Name :</span> @(string.IsNullOrEmpty(Model.BankBranchName) ? "-" : Model.BankBranchName)</li>
                                                            <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Bank Account Number :</span> @(string.IsNullOrEmpty(Model.BankAccountNo) ? "-" : Model.BankAccountNo)</li>
                                                            <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">IFSC Code :</span> @(string.IsNullOrEmpty(Model.IFSCCode) ? "-" : Model.IFSCCode)</li>
                                                        </ul>
                                                    </div>
                                                </div>
                                            }
                                            @if (IsFieldActive("SocialMedia"))
                                            {
                                                <div class="col-md-12">
                                                    <div>
                                                        <ul class="list-group">
                                                            <li class="list-group-item"><b>Social Media Link</b></li>
                                                            <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Facebook URL :</span> @(string.IsNullOrEmpty(Model.FacebookURL) ? "-" : Model.FacebookURL)</li>
                                                            <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Twitter URL :</span> @(string.IsNullOrEmpty(Model.TwitterURL) ? "-" : Model.TwitterURL)</li>
                                                            <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Linkedin URL :</span> @(string.IsNullOrEmpty(Model.LinkedinURL) ? "-" : Model.LinkedinURL)</li>
                                                            <li class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"><span class="text-dark">Instagram URL :</span> @(string.IsNullOrEmpty(Model.InstagramURL) ? "-" : Model.InstagramURL)</li>
                                                        </ul>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    <div class="tab-pane" id="payroll">
                                        <div class="row">
                                            <div class="col-xl-6 d-flex">
                                                <div class="card shadow-sm flex-fill w-100 mb-3">
                                                    <div class="card-body">
                                                        <div class="d-flex align-items-center justify-content-between">
                                                            <div>
                                                                <p class="mb-2">Total Net Salary Paid</p>
                                                                <div class="d-flex align-items-center gap-1">
                                                                    <h5 class="fw-bold mb-0" id="pay_totalNet">0</h5>
                                                                    <span class="badge fw-medium bg-success flex-shrink-0" id="pay_totalNetBadge">+0%</span>
                                                                </div>
                                                            </div>
                                                            <span class="avatar border border-primary text-primary rounded-2 flex-shrink-0"><i class="ti ti-coin-rupee fs-20"></i></span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-xl-6 d-flex">
                                                <div class="card shadow-sm flex-fill w-100 mb-3">
                                                    <div class="card-body">
                                                        <div class="d-flex align-items-center justify-content-between">
                                                            <div>
                                                                <p class="mb-2">Total Gross Salary</p>
                                                                <div class="d-flex align-items-center gap-1">
                                                                    <h5 class="fw-bold mb-0" id="pay_totalGross">0</h5>
                                                                    <span class="badge fw-medium bg-success flex-shrink-0" id="pay_totalGrossBadge">+0%</span>
                                                                </div>
                                                            </div>
                                                            <span class="avatar border border-primary text-primary rounded-2 flex-shrink-0"><i class="ti ti-coin-rupee-filled fs-20"></i></span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-xl-6 d-flex">
                                                <div class="card shadow-sm flex-fill w-100">
                                                    <div class="card-body">
                                                        <div class="d-flex align-items-center justify-content-between">
                                                            <div>
                                                                <p class="mb-2">Total Earning</p>
                                                                <div class="d-flex align-items-center gap-1">
                                                                    <h5 class="fw-bold mb-0" id="pay_totalEarning">0</h5>
                                                                    <span class="badge fw-medium bg-success flex-shrink-0" id="pay_totalEarningBadge">+0%</span>
                                                                </div>
                                                            </div>
                                                            <span class="avatar border border-primary text-primary rounded-2 flex-shrink-0"><i class="ti ti-users fs-20"></i></span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-xl-6 d-flex">
                                                <div class="card shadow-sm flex-fill w-100">
                                                    <div class="card-body p-3">
                                                        <div class="d-flex align-items-center justify-content-between">
                                                            <div>
                                                                <p class="mb-2">Total Deduction</p>
                                                                <div class="d-flex align-items-center gap-1">
                                                                    <h5 class="fw-bold mb-0" id="pay_totalDeduction">0</h5>
                                                                    <span class="badge fw-medium bg-success flex-shrink-0" id="pay_totalDeductionBadge">+0%</span>
                                                                </div>
                                                            </div>
                                                            <span class="avatar border border-primary text-primary rounded-2 flex-shrink-0"><i class="ti ti-coin-rupee fs-20"></i></span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-xl-12">
                                                <div class="card">
                                                    <div class="card-header">
                                                        <div class="d-flex align-items-center">
                                                            <input type="text" class="form-control flex-fill me-3" placeholder="Search...">
                                                            <div class="d-flex align-items-center flex-wrap gap-2 flex-shrink-0">
                                                                <button class="btn btn-icon btn-outline-primary" title="Copy" asp-permission="Export" asp-permission-url="/HumanResource/StaffDetails">
                                                                    <i class="ti ti-copy fs-5"></i>
                                                                </button>
                                                                <button class="btn btn-icon btn-outline-secondary" title="Excel" asp-permission="Export" asp-permission-url="/HumanResource/StaffDetails">
                                                                    <i class="ti ti-file-excel fs-5"></i>
                                                                </button>
                                                                <button class="btn btn-icon btn-outline-info" title="CSV" asp-permission="Export" asp-permission-url="/HumanResource/StaffDetails">
                                                                    <i class="ti ti-file-barcode fs-5"></i>
                                                                </button>
                                                                <button class="btn btn-icon btn-outline-danger" title="Pdf" asp-permission="Export" asp-permission-url="/HumanResource/StaffDetails">
                                                                    <i class="ti ti-file-type-pdf fs-5"></i>
                                                                </button>
                                                                <button class="btn btn-icon btn-outline-success" title="Print" asp-permission="Print" asp-permission-url="/HumanResource/StaffDetails">
                                                                    <i class="ti ti-printer fs-5"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="card-body">

                                                        <div class="table-responsive">
                                                            <table class="table mb-0">
                                                                <thead>
                                                                    <tr>
                                                                        <th>Payslip #</th>
                                                                        <th>Month-Year</th>
                                                                        <th>Date</th>
                                                                        <th>Mode</th>
                                                                        <th>Status</th>
                                                                        <th>Net Salary</th>
                                                                        <th class="text-end">Action</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody id="payrollTableBody">
                                                                    <tr>
                                                                        <td colspan="7" class="text-center text-danger">No Data Found</td>
                                                                    </tr>
                                                                </tbody>
                                                            </table>
                                                        </div>

                                                    </div>
                                                    <!-- end card-body -->
                                                </div>
                                                <!-- end card -->
                                            </div>

                                        </div>
                                    </div>
                                    <div class="tab-pane" id="leave">
                                        <div class="row">
                                            <div class="col-xl-12">
                                                <div class="card">
                                                    <div class="card-header">
                                                        <div class="d-flex align-items-center">
                                                            <input type="text" class="form-control flex-fill me-3" placeholder="Search...">
                                                            <div class="d-flex align-items-center flex-wrap gap-2 flex-shrink-0">
                                                                <button class="btn btn-icon btn-outline-primary" title="Copy" asp-permission="Export" asp-permission-url="/HumanResource/StaffDetails">
                                                                    <i class="ti ti-copy fs-5"></i>
                                                                </button>
                                                                <button class="btn btn-icon btn-outline-secondary" title="Excel" asp-permission="Export" asp-permission-url="/HumanResource/StaffDetails">
                                                                    <i class="ti ti-file-excel fs-5"></i>
                                                                </button>
                                                                <button class="btn btn-icon btn-outline-info" title="CSV" asp-permission="Export" asp-permission-url="/HumanResource/StaffDetails">
                                                                    <i class="ti ti-file-barcode fs-5"></i>
                                                                </button>
                                                                <button class="btn btn-icon btn-outline-danger" title="Pdf" asp-permission="Export" asp-permission-url="/HumanResource/StaffDetails">
                                                                    <i class="ti ti-file-type-pdf fs-5"></i>
                                                                </button>
                                                                <button class="btn btn-icon btn-outline-success" title="Print" asp-permission="Print" asp-permission-url="/HumanResource/StaffDetails">
                                                                    <i class="ti ti-printer fs-5"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="card-body">

                                                        <div class="table-responsive">
                                                            <table class="table mb-0">
                                                                <thead>
                                                                    <tr>
                                                                        <th>Leave Type</th>
                                                                        <th>Leave Date</th>
                                                                        <th>Days</th>
                                                                        <th>Apply Date</th>
                                                                        <th>Status</th>
                                                                        <th class="text-end">Action</th>

                                                                    </tr>
                                                                </thead>
                                                                <tbody id="leaveTableBody">
                                                                    <tr>
                                                                        <td colspan="7" class="text-center text-danger">No Data Found</td>
                                                                    </tr>
                                                                </tbody>
                                                            </table>
                                                        </div>

                                                    </div>
                                                    <!-- end card-body -->
                                                </div>
                                                <!-- end card -->
                                            </div>
                                        </div>
                                    </div>
                                    <div class="tab-pane" id="attendance">
                                        <div class="row">
                                            <div class="col-xl-4 d-flex">
                                                <div class="card shadow-sm flex-fill w-100 mb-3">
                                                    <div class="card-body">
                                                        <div class="d-flex align-items-center justify-content-between">
                                                            <div>
                                                                <p class="mb-2">Total Present</p>
                                                                <div class="d-flex align-items-center gap-1">
                                                                    <h5 class="fw-bold mb-0" id="att_present">0</h5>
                                                                </div>
                                                            </div>
                                                            <span class="avatar border border-primary text-primary rounded-2 flex-shrink-0"><i class="ti ti-user fs-20"></i></span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="col-xl-4 d-flex">
                                                <div class="card shadow-sm flex-fill w-100 mb-3">
                                                    <div class="card-body">
                                                        <div class="d-flex align-items-center justify-content-between">
                                                            <div>
                                                                <p class="mb-2">Total Late</p>
                                                                <div class="d-flex align-items-center gap-1">
                                                                    <h5 class="fw-bold mb-0" id="att_late">0</h5>
                                                                </div>
                                                            </div>
                                                            <span class="avatar border border-primary text-primary rounded-2 flex-shrink-0"><i class="ti ti-user fs-20"></i></span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-xl-4 d-flex">
                                                <div class="card shadow-sm flex-fill w-100 mb-3">
                                                    <div class="card-body">
                                                        <div class="d-flex align-items-center justify-content-between">
                                                            <div>
                                                                <p class="mb-2">Total Absent</p>
                                                                <div class="d-flex align-items-center gap-1">
                                                                    <h5 class="fw-bold mb-0" id="att_absent">0</h5>
                                                                </div>
                                                            </div>
                                                            <span class="avatar border border-primary text-primary rounded-2 flex-shrink-0"><i class="ti ti-user fs-20"></i></span>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-xl-4 d-flex">
                                                <div class="card shadow-sm flex-fill w-100 mb-3">
