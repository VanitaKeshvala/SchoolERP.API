@model SchoolERP.Shared.Models.TeacherTimeTablePageViewModel
@{
    ViewData["Title"] = "Teacher Time Table";
    var days = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };

    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;
    var slotAccents = new[] { "#4361ee", "#7209b7", "#f72585", "#3a86ff", "#fb8500", "#2dc653", "#e63946" };
}

@section Styles {
<style>
    .dt-buttons {
    display: none !important;
    }

    /* ── 3-per-row layout ───────────────────────────── */
    .tt-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-bottom: 14px;
    }

    /* Last row: if fewer than 3, don't stretch to fill */
    @@media (max-width: 992px) {
    .tt-grid {
    grid-template-columns: repeat(2, 1fr);
    }
    }

    @@media (max-width: 600px) {
    .tt-grid {
    grid-template-columns: 1fr;
    }
    }

    /* ── Day card ────────────────────────────────────── */
    .day-card {
    display: flex;
    flex-direction: column;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,.08);
    border: 1px solid #e9ecef;
    min-height: 220px;
    }

    .day-card-header {
    flex-shrink: 0;
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: .4px;
    color: #fff;
    }

    .slot-count-badge {
    margin-left: auto;
    background: rgba(255,255,255,.22);
    color: #fff;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 10px;
    border-radius: 20px;
    }

    /* ── Period list ─────────────────────────────────── */
    .day-card-body {
    flex: 1;
    padding: 10px;
    background: #f8f9fc;
    display: flex;
    flex-direction: column;
    gap: 8px;
    }

    .period-block {
    background: #fff;
    border-radius: 8px;
    padding: 10px 12px;
    border-left: 4px solid transparent;
    box-shadow: 0 1px 4px rgba(0,0,0,.06);
    transition: transform .15s, box-shadow .15s;
    }

    .period-block:hover {
    transform: translateY(-1px);
    box-shadow: 0 3px 10px rgba(0,0,0,.1);
    }

    .period-subject {
    font-size: 13px;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 5px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    }

    .period-time-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 20px;
    margin-bottom: 5px;
    }

    .period-meta-row {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11.5px;
    color: #6c757d;
    margin-top: 2px;
    }

    /* ── Empty state ─────────────────────────────────── */
    .day-empty {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    color: #adb5bd;
    background: #f8f9fc;
    padding: 24px 16px;
    text-align: center;
    }

    .day-empty i {
    font-size: 28px;
    }

    .day-empty span {
    font-size: 12px;
    font-weight: 500;
    }

    /* ── Holiday card ────────────────────────────────── */
    .holiday-card {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 20px 16px;
    text-align: center;
    }

    .holiday-type-pill {
    font-size: 10px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 20px;
    color: #fff;
    display: inline-block;
    }

    /* ── Day header gradients ────────────────────────── */
    .day-header-0 {
    background: linear-gradient(135deg, #4361ee, #3a0ca3);
    }

    .day-header-1 {
    background: linear-gradient(135deg, #7209b7, #560bad);
    }

    .day-header-2 {
    background: linear-gradient(135deg, #3a86ff, #023e8a);
    }

    .day-header-3 {
    background: linear-gradient(135deg, #f72585, #b5179e);
    }

    .day-header-4 {
    background: linear-gradient(135deg, #fb8500, #e85d04);
    }

    .day-header-5 {
    background: linear-gradient(135deg, #2dc653, #007f5f);
    }

    .day-header-6 {
    background: linear-gradient(135deg, #e63946, #9d0208);
    }

    /* ── Filter badge ────────────────────────────────── */
    .filter-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    font-weight: 500;
    background: #eef2ff;
    color: #4361ee;
    border: 1px solid #c7d2fe;
    border-radius: 20px;
    padding: 3px 10px;
    }

    .filter-badge i {
    font-size: 10px;
    cursor: pointer;
    }

    .filter-badge i:hover {
    color: #e63946;
    }

    .filter-dropdown {
    overflow: visible !important;
    }

    .select2-container {
    width: 100% !important;
    }

    .select2-container--open,
    .select2-dropdown {
    z-index: 999999 !important;
    }
</style>
}
<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Lesson Plan</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1 responsive-btn-group">
        @if (p.CanPrint)
        {
            <button class="btn btn-secondary d-inline-flex align-items-center top-btn" onclick="triggerExport(4)">
                <i class="ti ti-printer me-1"></i>Print
            </button>
        }

    </div>
</div>
<!-- End Page Header -->
<!-- start row -->
<div class="row">
    <div class="col-md-12">
        <div class="card shadow-tbl-outer mb-2">
            <div class="card-body">
                <form id="filterForm" method="get" action="/ManageLessonPlan/Index">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                        <div class="position-relative border d-flex align-items-center rounded-2 px-3 bg-white flex-grow-1 search-box-wrap" style="max-width:420px;">
                            <i class="fas fa-search search-icon-input"></i>
                            <input type="text" class="form-control border-0 ps-2 search-input-responsive" id="tableSearch" placeholder="Search..." />
                        </div>
                        @* <input type="text" id="tableSearch" class="form-control w-25 me-3" placeholder="Search..." /> *@
                        <div class="d-flex align-items-center flex-wrap gap-2 flex-shrink-0">
                            <div class="dropdown">
                                <a href="#" class="btn btn-white border btn-lg" data-bs-toggle="dropdown">
                                    <i class="ti ti-filter text-gray-5 me-1"></i>Filters
                                </a>
                                <div class="dropdown-menu dropdown-lg dropdown-menu-end filter-dropdown p-0" id="filter-dropdown">
                                    <div class="d-flex align-items-center justify-content-between border-bottom filter-header">
                                        <h6 class="mb-0 fw-bold">Select Criteria</h6>
                                        <div class="d-flex align-items-center justify-content-end">
                                            <button type="submit" class="btn text-primary fs-6 fw-medium" id="btnApplyFilters">
                                                <i class="ti ti-filter me-1"></i>Apply
                                            </button>
                                            <button type="button" class="btn btn-icon btn-sm ms-1 d-md-none" id="btnCloseFilter" aria-label="Close">
                                                <i class="ti ti-x"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="filter-body pb-0 p-3">
                                        <div class="mb-3">
                                            <label class="form-label mb-1">Teacher<span class="text-danger">*</span></label>
                                            <select name="staffId" id="FilterStaffID" class="form-select form-control select2" required>
                                                <option value="">Select Teacher</option>
                                                @foreach (var item in Model.Staff)
                                                {
                                                    <option value="@item.StaffID" selected="@(Model.SelectedStaffId == item.StaffID)">@item.FirstName @item.LastName</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-12" id="activeFilterBadges" style="display: none;">
        <div class="card shadow-tbl border-0 py-2 mb-2">
            <div class="card-body p-2 d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold ms-2 me-2"><i class="ti ti-filter-check me-1"></i>Active Filters:</span>
                <div id="badgeContainer" class="d-flex flex-wrap gap-2"></div>
                <button class="btn btn-sm btn-link text-danger p-0 ms-auto me-2 fw-bold text-decoration-none" id="btnResetAllFilters" onclick="resetAllFilters()">
                    <i class="ti ti-trash me-1"></i>Clear All
                </button>
            </div>
        </div>
    </div>
    <div class="tt-grid">
        @if (days.Length > 0)
        {

            @for (int di = 0; di < days.Length; di++)
            {
                //var daySlots = Model.TimeTableSlots.Where(x => x.Day == day).OrderBy(x => x.StartTime).ToList();
                var day = days[di];
                var daySlots = Model.TimeTableSlots.Where(x => x.Day == day).OrderBy(x => x.StartTime).ToList()
                .Where(x => x.Day == day)
                .OrderBy(x => x.StartTime)
                .ToList();

                // HOLIDAY CHECK — first slot with IsHoliday = true
                var holidaySlot = daySlots.FirstOrDefault(x => x.IsHoliday);

                // Resolve colour from holiday type or fall back to red
                var hColour = holidaySlot != null && !string.IsNullOrEmpty(holidaySlot.ColourCode)
                ? holidaySlot.ColourCode
                : "#e63946";
                var hBg = hColour + "18";

                // Normal period slots only (exclude the sentinel holiday row)
                var normalSlots = daySlots.Where(x => !x.IsHoliday).ToList();
                <div class="day-card">

                    <!-- ── Day header ── -->
                    <div class="day-card-header day-header-@di">
                        <i class="ti ti-calendar-week"></i>
                        @day
                        @if (holidaySlot != null)
                        {
                            <span class="slot-count-badge" style="background:rgba(255,255,255,.30);">
                                🎉 Holiday
                            </span>
                        }
                        else
                        {
                            <span class="slot-count-badge">
                                @normalSlots.Count period@(normalSlots.Count != 1 ? "s" : "")
                            </span>

                        }
                    </div>

                    <!-- ── Holiday banner ── -->
                    @if (daySlots.Any())
                    {
                        <!-- ── Normal period cards ── -->
                        <div class="day-card-body">
                            @for (int si = 0; si < daySlots.Count; si++)
                            {
                                var slot = daySlots[si];
                                var accent = slotAccents[si % slotAccents.Length];
                                <div class="period-block" style="border-left-color:@accent;">
                                    <div class="period-header">
                                        <div class="period-subject">
                                            <span class="subject-dot" style="background:@accent;"></span>
                                            @slot.SubjectName
                                        </div>
                                        <div class="period-actions">


                                            @if (slot.LessonPlanId != 0)
                                            {
                                                @if (p.CanEdit)
                                                {
                                                    <a href="/ManageLessonPlan/Add?timeTableID=@slot.TimeTableID&lessonPlanId=@slot.LessonPlanId"
                                                    class="action-icon" title="Add Lesson Plan">
                                                        <i class="ti ti-pencil"></i>
                                                    </a>
                                                }
                                                <a href="/ManageLessonPlan/LessonPlanDetail/@slot.LessonPlanId" class="action-icon" title="View Lesson Plans">
                                                    <i class="ti ti-list-details"></i>
                                                </a>
                                            }
                                            else
                                            {
                                                    @if (p.CanAdd)
                                                    {
                                                        <a href="/ManageLessonPlan/Add?timeTableID=@slot.TimeTableID"
                                                           class="action-icon" title="Add Lesson Plan">
                                                            <i class="ti ti-plus"></i>
                                                        </a>
                                                    }
                                                    @if (p.CanDelete)
                                                    {
                                                        <a href="#" class="action-icon action-icon-danger" title="Delete Period">
                                                            <i class="ti ti-trash"></i>
                                                        </a>
                                                    }
                                            }
                                            
                                            

                                            
                                        </div>
                                    </div>

                                    <span class="period-time-badge" style="background:@(accent)18; color:@accent;">
                                        <i class="ti ti-clock" style="font-size:11px;"></i>
                                        @slot.StartTime – @slot.EndTime
                                    </span>

                                    <div class="period-meta-row">
                                        <i class="ti ti-user"></i>
                                        <span>@slot.StaffName</span>
                                    </div>
                                    <div class="period-meta-row">
                                        <i class="ti ti-building"></i>
                                        <span>Room @(slot.RoomNo ?? "—")</span>
                                    </div>
                                </div>
                        }
                    </div>
                }
                else
                {


                    <!-- ── No schedule ── -->
                    <div class="day-empty">
                        <i class="ti ti-calendar-off"></i>
                        <span>No schedule available</span>
                    </div>
                }

            </div>
        }
    }
        </div>
</div>
<!-- end row -->

<div class="d-none">
    <table id="tblTimeTable" class="table">
        <thead>
            <tr>
                <th>Day</th>
                <th>Subject</th>
                <th>Time</th>
                <th>Class</th>
                <th>Room No</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.SelectedStaffId > 0)
            {
                foreach (var day in days)
                {
                    var daySlots = Model.TimeTableSlots.Where(x => x.Day == day).OrderBy(x => x.StartTime).ToList();
                    if (daySlots.Any())
                    {
                        foreach (var slot in daySlots)
                        {
                            <tr>
                                <td>@day</td>
                                <td>@slot.SubjectName</td>
                                <td>@slot.StartTime - @slot.EndTime</td>
                                <td>@slot.ClassName (@slot.SectionName)</td>
                                <td>@(slot.RoomNo ?? "-")</td>
                            </tr>
                        }
                    }
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        function triggerExport(index) {
            const selectedStaffId = @Model.SelectedStaffId;
            if (selectedStaffId === 0) {
                if (window.Swal) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'No Data',
                        text: 'Please select a Teacher and click Filter first!'
                    });
                } else {
                    alert('Please select a Teacher and click Filter first!');
                }
                return;
            }
            if ($.fn.DataTable.isDataTable('#tblTimeTable')) {
                const table = $('#tblTimeTable').DataTable();
                table.button(index).trigger();
            }
        }

        $(document).ready(function () {
            $('.select2').select2();

            // Prevent dropdown from closing when clicking inside
            $('.filter-dropdown').on('click', function (e) {
                e.stopPropagation();
            });

            const selectedStaffId = @Model.SelectedStaffId;
            if (selectedStaffId > 0) {
                $('#tblTimeTable').DataTable({
                    dom: 'Bfrtip',
                    buttons: [
                        { extend: 'copy', exportOptions: { columns: [0, 1, 2, 3, 4] } },
                        { extend: 'csv', exportOptions: { columns: [0, 1, 2, 3, 4] } },
                        { extend: 'excel', exportOptions: { columns: [0, 1, 2, 3, 4] } },
                        { extend: 'pdf', exportOptions: { columns: [0, 1, 2, 3, 4] } },
                        { extend: 'print', exportOptions: { columns: [0, 1, 2, 3, 4] } }
                    ],
                    searching: false,
                    paging: false,
                    info: false
                });
            }

            renderFilterBadges();

            // Table Search
            $('#tableSearch').on('keyup', function () {
                var q = $(this).val().toLowerCase();
                $(".day-card").filter(function () {
                    $(this).parent().toggle($(this).text().toLowerCase().indexOf(q) > -1)
                });
                renderFilterBadges();
            });
        });

        // --- Filter Badges Logic ---
        function renderFilterBadges() {
            const container = document.getElementById('badgeContainer');
            const mainContainer = document.getElementById('activeFilterBadges');
            if (!container) return;
            container.innerHTML = '';

            const filters = [
                { id: 'tableSearch', label: 'Search', type: 'text' },
                { id: 'FilterStaffID', label: 'Teacher', type: 'select' }
            ];

            let activeCount = 0;

            filters.forEach(f => {
                const el = document.getElementById(f.id);
                if (!el) return;

                let value = el.value;
                let text = '';

                if (f.type === 'text') {
                    if (value.trim()) {
                        text = value;
                        activeCount++;
                    }
                } else if (f.type === 'select') {
                    if (value && value !== 'all' && value !== '') {
                        const selectedOption = el.options[el.selectedIndex];
                        if (selectedOption && selectedOption.value !== "") {
                            text = selectedOption.text;
                            activeCount++;
                        }
                    }
                }

                if (text) {
                    const badge = document.createElement('span');
                    badge.className = 'badge bg-primary-subtle text-primary border border-primary-subtle d-flex align-items-center gap-1 fw-medium px-2 py-1';
                    badge.innerHTML = `${f.label}: ${text} <i class="ti ti-x ms-1 cursor-pointer" onclick="removeFilter('${f.id}')" style="font-size: 10px;"></i>`;
                    container.appendChild(badge);
                }
            });

            if (activeCount > 0) {
                mainContainer.style.display = 'block';
            } else {
                mainContainer.style.display = 'none';
            }
        }

        function removeFilter(filterId) {
            const el = document.getElementById(filterId);
            if (!el) return;

            if (el.tagName === 'INPUT') {
                el.value = '';
                $(el).trigger('keyup');
            } else {
                el.value = '';
                $('#filterForm').submit();
            }

            if (window.jQuery && jQuery(el).data('select2')) {
                jQuery(el).trigger('change.select2');
            }
        }

        function resetAllFilters() {
            document.getElementById('tableSearch').value = '';
            document.getElementById('FilterStaffID').value = '';

            $('.select2').trigger('change.select2');
            $('#tableSearch').trigger('keyup');

            $('#filterForm').submit();
        }
    </script>
    <style>
        .border-bottom-dashed {
            border-bottom: 1px dashed #dee2e6;
        }

            .border-bottom-dashed:last-child {
                border-bottom: none;
            }

        .period-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 8px;
            margin-bottom: 5px;
        }

        .period-subject {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            font-weight: 700;
            color: #1a1a2e;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .subject-dot {
            flex-shrink: 0;
            width: 7px;
            height: 7px;
            border-radius: 50%;
        }

        .period-actions {
            display: flex;
            align-items: center;
            gap: 2px;
            flex-shrink: 0;
            opacity: 0;
            transform: translateX(4px);
            transition: opacity .15s, transform .15s;
        }

        .period-block:hover .period-actions {
            opacity: 1;
            transform: translateX(0);
        }

        .action-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 24px;
            height: 24px;
            border-radius: 6px;
            color: #6c757d;
            font-size: 13px;
            transition: background .15s, color .15s;
        }

            .action-icon:hover {
                background: #f1f3f9;
                color: #1a1a2e;
            }

        .action-icon-danger:hover {
            background: #fdecea;
            color: #e63946;
        }
    </style>
}
