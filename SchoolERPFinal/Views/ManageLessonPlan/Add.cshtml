@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.ManageLessonPlanAddViewModel
@{
    ViewData["Title"] = "Add Lesson Plan";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditManageLessonPlan == null ? "Add Lesson Plan" : "Edit Lesson Plan")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveItem()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/ManageLessonPlan/Index" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>

<div id="lessonPlanPageNotice"></div>

<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <input type="hidden" id="txtItemId" value="@(Model.EditManageLessonPlan?.LessonPlanId ?? 0)">
                    <input type="hidden" id="hdnUserID" value="@(Model.EditManageLessonPlan?.CreatedBy ?? 0)">
                    <input type="hidden" id="hdnLectureVideoPath" value="@Model.EditManageLessonPlan?.LectureVideoPath">
                    <input type="hidden" id="hdnAttachmentPath" value="@Model.EditManageLessonPlan?.AttachmentPath">
                    <input type="hidden" id="hdnClassID" value="@Model.ClassID">
                    <input type="hidden" id="hdnSectionID" value="@Model.SectionID">
                    <input type="hidden" id="hdnSubjectGroupID" value="@Model.SubjectGroupID">
                    <input type="hidden" id="hdnSubjectID" value="@Model.SubjectID">
                    <input type="hidden" id="hdnTimeTableID" value="@Model.TimeTableID">

                    <div class="row">

                        <!-- Lesson -->
                        <div class="d-block col-md-4 mb-3">
                            <label class="form-label fw-bold">Lesson<span class="text-danger">*</span></label>
                            <select class="form-select select2" id="ddlLesson" style="width: 100%;" onchange="loadTopicsByLesson(this.value, @(Model.EditManageLessonPlan?.TopicMapId ?? 0))">
                                <option value="">-- Select --</option>
                                @foreach (var l in Model.BindLesson)
                                {
                                    <option value="@l.LessonMapId" selected="@(Model.EditManageLessonPlan?.LessonMapId == l.LessonMapId)">@l.LessonName</option>
                                }
                            </select>
                            <div class="invalid-feedback" id="errddlLesson"></div>
                        </div>

                        <!-- Topic (cascades from Lesson) -->
                        <div class="d-block col-md-4 mb-3">
                            <label class="form-label fw-bold">Topic<span class="text-danger">*</span></label>
                            <select class="form-select select2" id="ddlTopic" style="width: 100%;">
                                <option value="">-- Select Lesson First --</option>
                            </select>
                            <div class="invalid-feedback" id="errddlTopic"></div>
                        </div>

                        <!-- Sub Topic -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Sub Topic</label>
                            <input type="text" class="form-control" id="txtSubTopic"
                                   value="@Model.EditManageLessonPlan?.SubTopic"
                                   placeholder="Enter sub topic" autocomplete="off" maxlength="200">
                            <div class="invalid-feedback" id="errtxtSubTopic"></div>
                        </div>

                        <!-- Plan Date -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Date <span class="text-danger">*</span></label>
                            <input type="date" class="form-control" id="txtPlanDate"
                                   value="@(Model.EditManageLessonPlan?.PlanDate.ToString("yyyy-MM-dd"))">
                            <div class="invalid-feedback" id="errtxtPlanDate"></div>
                        </div>

                        <!-- Time From -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Time From</label>
                            <input type="time" class="form-control" id="txtTimeFrom"
                                   value="@Model.EditManageLessonPlan?.TimeFrom">
                            <div class="invalid-feedback" id="errtxtTimeFrom"></div>
                        </div>

                        <!-- Time To -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Time To</label>
                            <input type="time" class="form-control" id="txtTimeTo"
                                   value="@Model.EditManageLessonPlan?.TimeTo">
                            <div class="invalid-feedback" id="errtxtTimeTo"></div>
                        </div>

                        <!-- Lecture YouTube URL -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Lecture YouTube URL</label>
                            <input type="text" class="form-control" id="txtLectureYoutubeUrl"
                                   value="@Model.EditManageLessonPlan?.LectureYoutubeUrl"
                                   placeholder="https://youtube.com/..." autocomplete="off" maxlength="500">
                            <div class="invalid-feedback" id="errtxtLectureYoutubeUrl"></div>
                        </div>

                        <!-- Lecture Video (drag & drop, single file, with edit-time preview) -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Lecture Video</label>
                            <div class="dropzone-upload" id="dzLectureVideo" onclick="document.getElementById('fileLectureVideo').click()">
                                <i class="ti ti-cloud-upload me-1"></i>
                                <span id="dzLectureVideoText">Drag and drop a file here or click</span>
                            </div>
                            <input type="file" id="fileLectureVideo" class="d-none" accept="video/*">
                            <div id="videoPreviewContainer" class="mt-2"></div>
                            <input type="hidden" id="hdnLectureVideoPath" value="@Model.EditManageLessonPlan?.LectureVideoPath">
                            <input type="hidden" id="hdnRemoveVideo" value="false">
                            <div class="invalid-feedback" id="errfileLectureVideo"></div>
                        </div>

                        <!-- Attachments (drag & drop, MULTIPLE files, with edit-time previews) -->
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Attachments</label>
                            <div class="dropzone-upload" id="dzAttachment" onclick="document.getElementById('fileAttachment').click()">
                                <i class="ti ti-cloud-upload me-1"></i>
                                <span id="dzAttachmentText">Drag and drop files here or click</span>
                            </div>
                            <input type="file" id="fileAttachment" class="d-none" 
                                   accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg">
                            <div id="attachmentPreviewList" class="mt-2 d-flex flex-wrap gap-2"></div>
                            <input type="hidden" id="hdnRemovedAttachmentIds" value="[]">
                            <div class="invalid-feedback" id="errfileAttachment"></div>
                        </div>

                        <!-- Teaching Method -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Teaching Method</label>
                            <input type="text" class="form-control" id="txtTeachingMethod"
                                   value="@Model.EditManageLessonPlan?.TeachingMethod"
                                   placeholder="e.g. Lecture, Demonstration, Group Discussion" autocomplete="off">
                        </div>

                        <!-- General Objectives -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">General Objectives</label>
                            <input type="text" class="form-control" id="txtGeneralObjectives"
                                   value="@Model.EditManageLessonPlan?.GeneralObjectives"
                                   placeholder="Enter general objectives" autocomplete="off">
                        </div>

                        <!-- Previous Knowledge -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Previous Knowledge</label>
                            <input type="text" class="form-control" id="txtPreviousKnowledge"
                                   value="@Model.EditManageLessonPlan?.PreviousKnowledge"
                                   placeholder="Enter previous knowledge required" autocomplete="off">
                        </div>

                        <!-- Comprehensive Questions -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Comprehensive Questions</label>
                            <input type="text" class="form-control" id="txtComprehensiveQuestions"
                                   value="@Model.EditManageLessonPlan?.ComprehensiveQuestions"
                                   placeholder="Enter comprehensive questions" autocomplete="off">
                        </div>

                        <!-- Presentation (Rich Text) -->
                        <div class="col-md-12 mb-3">
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <label class="form-label fw-semibold mb-0">Presentation</label>
                                <button type="button" class="btn btn-dark btn-sm" onclick="openAddImageDialog()">
                                    <i class="ti ti-photo me-1"></i> Add Image
                                </button>
                            </div>
                            <textarea id="txtPresentation" class="form-control" rows="12">@Model.EditManageLessonPlan?.Presentation</textarea>
                            <div class="invalid-feedback" id="errtxtPresentation"></div>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


<!-- Image Picker Modal -->
<!-- Image Picker Modal -->
<div class="modal fade" id="mediaPickerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title fw-bold mb-0">Select Image</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="text" id="txtMediaSearch" class="form-control mb-3"
                       placeholder="Search by file name..." autocomplete="off">

                <div class="text-muted small mb-2" id="mediaPickerCount">Total Record : 0</div>

                <div class="d-flex flex-wrap gap-3" id="mediaPickerGrid"></div>

                <div id="mediaPickerLoading" class="text-center text-muted py-4 d-none">Loading...</div>
                <div id="mediaPickerEmpty" class="text-center text-muted py-4 d-none">No documents found.</div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-dark" id="btnAddSelectedImage" disabled>Add</button>
            </div>
        </div>
    </div>
</div>

<style>
    .dropzone-upload {
        border: 1px dashed #c9c9c9;
        border-radius: 6px;
        padding: 0.5rem 0.75rem;
        text-align: center;
        color: #8a8a8a;
        font-size: 0.85rem;
        cursor: pointer;
        background-color: #fafafa;
    }

        .dropzone-upload:hover {
            background-color: #f1f1f1;
        }

    
    #mediaPickerGrid {
        --thumb-w: 170px;
        --thumb-h: 170px;
    }

    /* lock each column to a fixed width instead of letting bootstrap stretch it */
    #mediaPickerGrid > [class*="col-"] {
        flex: 0 0 auto;
        width: var(--thumb-w);
        max-width: var(--thumb-w);
    }

    #mediaPickerGrid .media-card {
        width: var(--thumb-w);
        height: calc(var(--thumb-h) + 40px); /* thumb + filename strip */
        display: flex;
        flex-direction: column;
        border-radius: 8px;
        overflow: hidden;
        border: 2px solid transparent;
    }

    #mediaPickerGrid .media-thumb {
        width: var(--thumb-w);
        height: var(--thumb-h);
        background: #f7f8fa;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        flex-shrink: 0;
    }

        #mediaPickerGrid .media-thumb img {
            width: 100%;
            height: 100%;
            object-fit: contain; /* keeps full image visible, no cropping */
        }

    #mediaPickerGrid .media-name {
        flex: 1;
        display: flex;
        align-items: center;
        padding: 6px 10px;
        font-size: 0.8rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        border-top: 1px solid #f0f0f0;
    }

    #mediaPickerGrid .media-card.selectable {
        cursor: pointer;
        transition: border-color 0.15s ease;
    }

        #mediaPickerGrid .media-card.selectable:hover {
            border-color: #c9c9c9;
        }

        #mediaPickerGrid .media-card.selectable.selected {
            border-color: #28a745;
            box-shadow: 0 0 0 1px #28a745;
        }

</style>

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);

        // Preselect topic on edit (post-load, after cascading dropdown is populated)
        window.editSelectedLessonMapId = @(Model.EditManageLessonPlan?.LessonPlanId ?? 0);
        window.editSelectedTopicMapId = @(Model.EditManageLessonPlan?.TopicMapId ?? 0);


        window.editSelectedLessonMapId = @(Model.EditManageLessonPlan?.LessonPlanId ?? 0);
        window.editSelectedTopicMapId = @(Model.EditManageLessonPlan?.TopicMapId ?? 0);

        // Existing video (edit mode)
        window.existingVideoPath = @JsonSerializer.Serialize(Model.EditManageLessonPlan?.LectureVideoPath);

    </script>
    
    <script src="~/assets/js/ManageLessonPlan.js"></script>
}
