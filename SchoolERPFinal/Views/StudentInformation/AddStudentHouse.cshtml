@using System.Security.Claims
@model SchoolERP.Shared.Models.StudentHouseAddViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Add Student Category";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditStudentHouse == null ? "Add Student Category" : "Edit Student Category")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveRecord()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/StudentInformation/StudentHouse" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-header">
            </div>
            <div class="card-body">
                <form id="entryForm" class="needs-validation" novalidate>
                    <input type="hidden" id="txtItemId" value="@(Model.EditStudentHouse?.StudentHouseID ?? 0)">
                    <input type="hidden" id="hdnUserID" value="@(Model.EditStudentHouse?.CreateBy ?? 0)">
                    <input type="hidden" id="hdnStudentHouseID" value="@(Model.EditStudentHouse?.StudentHouseID ?? 0)">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Category Name <span class="text-danger">*</span></label>
                            <input type="text"
                                   class="form-control"
                                   id="txtName"
                                   required value="@Model.EditStudentHouse?.StudentHouseName"
                                   placeholder="Enter category name">
                            <div class="invalid-feedback">Please enter a category name.</div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea class="form-control" id="txtDescription" rows="3" placeholder="Enter description (optional)"></textarea>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>
    <script src="~/assets/js/StudentHouse.js"></script>
}
