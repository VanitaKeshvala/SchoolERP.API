@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    ViewData["Title"] = "Bulk Delete Students";

    // Permission loading for the view
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0) PermHelper.LoadPermissions(currentUserId);

    var canDelete = PermHelper.HasPermissionByUrl("/StudentInformation/BulkDelete", "Delete");
    var canPrint = PermHelper.HasPermissionByUrl("/StudentInformation/BulkDelete", "Print");
    var canExport = PermHelper.HasPermissionByUrl("/StudentInformation/BulkDelete", "Export");
}

@section Styles {
    <style>
        .dt-buttons { display: none !important; }
    </style>
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Bulk Delete Students</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (canDelete)
        {
            <button id="btnBulkDelete" class="btn btn-danger d-inline-flex align-items-center" onclick="processBulkDelete()" disabled>
                <i class="ti ti-trash me-1"></i>Delete Selected
            </button>
        }
        @if (canPrint)
        {
            <button class="btn btn-secondary d-inline-flex align-items-center" onclick="triggerExport(4)">
                <i class="ti ti-printer me-1"></i>Print
            </button>
        }
        @if (canExport)
        {
            <div class="dropdown d-inline-flex">
                <button class="btn btn-warning dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(0)"><i class="ti ti-copy me-1"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(1)"><i class="ti ti-file-text me-1"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(2)"><i class="ti ti-file-spreadsheet me-1"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(3)"><i class="ti ti-file-description me-1"></i>PDF</a></li>
                </ul>
            </div>
        }
    </div>
</div>
<!-- End Page Header -->

<!-- start row -->
<div class="row">

    <div class="col-md-12">
        <div class="card shadow-tbl-outer mb-2">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3 bg-white">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text" class="form-control border-0 ps-2" id="txtSearchInput" style="min-width: 220px;" placeholder="Search by name, roll, admission..." />
                    </div>
                    <!--<input type="text" id="txtSearch" class="form-control w-25 me-3" placeholder="Search by name, roll, admission..." />-->
                    <div class="d-flex align-items-center flex-wrap gap-2 flex-shrink-0">
                        <div class="dropdown">
                            <a href="#" class="btn btn-white border btn-lg" data-bs-toggle="dropdown">
                                <i class="ti ti-filter text-gray-5 me-1"></i>Filters
                            </a>
                            <div class="dropdown-menu dropdown-lg dropdown-menu-end filter-dropdown p-0" id="filter-dropdown">
                                <div class="d-flex align-items-center justify-content-between border-bottom filter-header py-2 px-3">
                                    <h6 class="mb-0 fw-bold">Select Criteria</h6>
                                    <div class="d-flex align-items-center justify-content-end">
                                        <button type="button" class="btn text-primary fs-6" onclick="fetchStudents()">Apply Filter</button>
                                    </div>
                                </div>
                                <div class="filter-body pb-0 p-3">
                                    <div class="mb-3">
                                        <label class="form-label mb-1">Class</label>
                                        <select id="ddlClass" class="form-select form-control select2">
                                            <option value="">Select Class</option>
                                            @foreach (var c in ViewBag.Classes)
                                            {
                                                <option value="@c.ClassID">@c.ClassName</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label mb-1">Section</label>
                                        <select id="ddlSection" class="form-select form-control select2">
                                            <option value="">Select Section</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                        @* <button class="btn btn-primary" onclick="fetchStudents()">
                            <i class="ti ti-search me-1"></i>Search
                        </button> *@
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-12" id="activeFilterBadges" style="display: none;">
        <div class="card shadow-tbl border-0 py-2 mb-2">
            <div class="card-body p-2 d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold ms-2 me-2"><i class="ti ti-filter-check me-1"></i>Active Filters:</span>
                <div id="badgeContainer" class="d-flex flex-wrap gap-2"></div>
                <button class="btn btn-sm btn-link text-danger p-0 ms-auto me-2 fw-bold text-decoration-none" id="btnResetAllFilters" onclick="resetAllFilters()">
                    <i class="ti ti-trash me-1"></i>Clear All
                </button>
            </div>
        </div>
    </div>

    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-nowrap mb-0" id="tblStudents">
                        <thead>
                            <tr>
                                <th style="width: 50px;">
                                    <input type="checkbox" id="selectAll" class="form-check-input" onchange="toggleSelectAll(this)">
                                </th>
                                <th>Admission No</th>
                                <th>Student Name</th>
                                <th>Roll No.</th>
                                <th>Class</th>
                                <th>Father Name</th>
                                <th>DOB</th>
                                <th>Mobile Number</th>
                            </tr>
                        </thead>
                        <tbody id="studentListBody">
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">Please select filters to load students.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/assets/plugins/sweetalert/sweetalert2.all.min.js"></script>
    <script>
        function triggerExport(index) {
            if ($.fn.DataTable.isDataTable('#tblStudents')) {
                const table = $('#tblStudents').DataTable();
                table.button(index).trigger();
            } else {
                Swal.fire('Info', 'No data available to export', 'info');
            }
        }

        $(document).ready(function () {
            $('#ddlClass').change(function () {
                var classId = $(this).val();
                $('#ddlSection').empty().append('<option value="">Select Section</option>');
                if (classId) {
                    $.get('/StudentInformation/GetSections', { classId: classId }, function (data) {
                        $.each(data, function (i, item) {
                            $('#ddlSection').append('<option value="' + item.id + '">' + item.name + '</option>');
                        });
                    });
                }
            });

            // Real-time Search and Enter key trigger
            $('#txtSearchInput').on('keyup', function (e) {
                var q = $(this).val().toLowerCase();
                $('#studentListBody tr').each(function() {
                    var text = $(this).text().toLowerCase();
                    $(this).toggle(text.indexOf(q) > -1);
                });

                if (e.which === 13) fetchStudents();
                renderFilterBadges();
            });
        });

        function fetchStudents() {
            const classId = $('#ddlClass').val();
            const sectionId = $('#ddlSection').val();
            const search = $('#txtSearchInput').val();

            if (!classId && !search) {
                showToast('Please select a class or enter a search term', 'warning');
                return;
            }

            if ($.fn.DataTable.isDataTable('#tblStudents')) {
                $('#tblStudents').DataTable().destroy();
            }

            $('#studentListBody').html('<tr><td colspan="8" class="text-center py-4"><div class="spinner-border text-primary"></div></td></tr>');
            $('#selectAll').prop('checked', false);
            $('#btnBulkDelete').prop('disabled', true);

            $.get('/StudentInformation/GetStudentList', { 
                classId: classId, 
                sectionId: sectionId, 
                searchTerm: search 
            }, function (data) {
                let html = '';
                if (data && data.length > 0) {
                    data.forEach(s => {
                        html += `
                            <tr class="student-item-row">
                                <td class="ps-3">
                                    <input type="checkbox" class="form-check-input student-checkbox" value="${s.studentID}" onchange="updateDeleteButton()">
                                </td>
                                <td>${s.admissionNo || '-'}</td>
                                <td class="fw-semibold">${s.fullName}</td>
                                <td>${s.rollNo || '-'}</td>
                                <td>${$('#ddlClass option:selected').text()} (${$('#ddlSection option:selected').text() || 'All'})</td>
                                <td>-</td>
                                <td>-</td>
                                <td>-</td>
                            </tr>
                        `;
                    });
                } else {
                    html = '<tr><td colspan="8" class="text-center py-4 text-muted">No active students found.</td></tr>';
                }
                $('#studentListBody').html(html);

                if (data && data.length > 0) {
                    $('#tblStudents').DataTable({
                        dom: 'Bfrtip',
                        buttons: [
                            { extend: 'copy', exportOptions: { columns: [1, 2, 3, 4, 5, 6, 7] } },
                            { extend: 'csv', exportOptions: { columns: [1, 2, 3, 4, 5, 6, 7] } },
                            { extend: 'excel', exportOptions: { columns: [1, 2, 3, 4, 5, 6, 7] } },
                            { extend: 'pdf', exportOptions: { columns: [1, 2, 3, 4, 5, 6, 7] } },
                            { extend: 'print', exportOptions: { columns: [1, 2, 3, 4, 5, 6, 7] } }
                        ],
                        searching: false,
                        paging: false,
                        info: false
                    });
                }

                renderFilterBadges();
            });
        }

        // --- Filter Badges Logic ---
        function renderFilterBadges() {
            const container = document.getElementById('badgeContainer');
            const mainContainer = document.getElementById('activeFilterBadges');
            if (!container) return;
            container.innerHTML = '';

            const filters = [
                { id: 'txtSearchInput', label: 'Search', type: 'text' },
                { id: 'ddlClass', label: 'Class', type: 'select' },
                { id: 'ddlSection', label: 'Section', type: 'select' }
            ];

            let activeCount = 0;

            filters.forEach(f => {
                const el = document.getElementById(f.id);
                if (!el) return;

                let value = el.value;
                let text = '';

                if (f.type === 'text') {
                    if (value.trim()) {
                        text = value;
                        activeCount++;
                    }
                } else if (f.type === 'select') {
                    if (value && value !== 'all' && value !== '') {
                        const selectedOption = el.options[el.selectedIndex];
                        text = selectedOption ? selectedOption.text : value;
                        activeCount++;
                    }
                }

                if (text) {
                    const badge = document.createElement('span');
                    badge.className = 'badge bg-primary-subtle text-primary border border-primary-subtle d-flex align-items-center gap-1 fw-medium px-2 py-1';
                    badge.innerHTML = `${f.label}: ${text} <i class="ti ti-x ms-1 cursor-pointer" onclick="removeFilter('${f.id}')" style="font-size: 10px;"></i>`;
                    container.appendChild(badge);
                }
            });

            if (activeCount > 0) {
                mainContainer.style.display = 'block';
            } else {
                mainContainer.style.display = 'none';
            }
        }

        function removeFilter(filterId) {
            const el = document.getElementById(filterId);
            if (!el) return;

            if (el.tagName === 'INPUT') {
                el.value = '';
                $('#txtSearchInput').trigger('keyup');
            } else {
                el.value = '';
            }

            fetchStudents();
        }

        function resetAllFilters() {
            document.getElementById('txtSearchInput').value = '';
            document.getElementById('ddlClass').value = '';
            document.getElementById('ddlSection').value = '';
            
            fetchStudents();
        }

        function toggleSelectAll(source) {
            $('.student-checkbox').prop('checked', source.checked);
            updateDeleteButton();
        }

        function updateDeleteButton() {
            const selectedCount = $('.student-checkbox:checked').length;
            $('#btnBulkDelete').prop('disabled', selectedCount === 0);
        }

        function processBulkDelete() {
            const selectedIds = [];
            $('.student-checkbox:checked').each(function () {
                selectedIds.push(parseInt($(this).val()));
            });

            if (selectedIds.length === 0) return;

            Swal.fire({
                title: 'Are you sure?',
                text: `You are about to delete ${selectedIds.length} student(s). This action will remove them from all active lists!`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete them!',
                buttonsStyling: false,
                customClass: {
                    confirmButton: 'btn btn-danger me-2',
                    cancelButton: 'btn btn-secondary'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/StudentInformation/BulkDeleteStudents',
                        type: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify(selectedIds),
                        success: function (res) {
                            if (res.success) {
                                showToast(res.message, 'success');
                                fetchStudents(); // Reload list
                            } else {
                                Swal.fire('Error!', res.message, 'error');
                            }
                        },
                        error: function () {
                            Swal.fire('Error!', 'An unexpected error occurred.', 'error');
                        }
                    });
                }
            });
        }
    </script>
}
