@using System.Security.Claims
@model SchoolERP.Shared.Models.StudentCategoryAddViewModel
@{
    ViewData["Title"] = "Add Student Category";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditStudentCategory == null ? "Add Student Category" : "Edit Student Category")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if(p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveRecord()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }        
        <a href="/StudentInformation/StudentCategory" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-header">
                
            </div>   
            <div class="card-body">
                <form id="entryForm" class="needs-validation" novalidate>
                    <input type="hidden" id="txtItemId" value="@(Model.EditStudentCategory?.StudentCategoryID ?? 0)">
                    <input type="hidden" id="hdnUserID" value="@(Model.EditStudentCategory?.CreatedBY ?? 0)">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Category Name <span class="text-danger">*</span></label>
                            <input type="text"
                                   class="form-control"
                                   id="txtName"
                                   required value="@Model.EditStudentCategory?.StudentCategoryName"
                                   placeholder="Enter category name">
                            <div class="invalid-feedback">Please enter a category name.</div>
                        </div>                        
                    </div>
                </form>
            </div>
        </div>               
    </div>                
</div>


@section Scripts {
    <script>
        async function saveRecord() {
            const form = document.getElementById('entryForm');
            form.classList.add('was-validated');
            if (!form.checkValidity()) return;

            const data = {
                studentCategoryID:   parseInt(document.getElementById('txtItemId').value),
                studentCategoryName: document.getElementById('txtName').value.trim()
            };

            fetch('/StudentInformation/UpsertStudentCategory', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify(data)
            })
            .then(r => r.json())
            .then(res => {
                if (res.success) {
                    Swal.fire({
                        icon:              'success',
                        title:             'Saved!',
                        text:              'Student category has been added successfully.',
                        confirmButtonText: 'OK',
                        customClass: { confirmButton: 'btn btn-success' },
                        buttonsStyling: false
                    }).then(() => {
                        window.location.href = '/StudentInformation/StudentCategory';
                    });
                } else {
                    Swal.fire({
                        icon:              'error',
                        title:             'Error',
                        text:              res.message || 'Failed to save student category.',
                        confirmButtonText: 'OK',
                        customClass: { confirmButton: 'btn btn-danger' },
                        buttonsStyling: false
                    });
                }
            })
            .catch(err => {
                console.error(err);
                Swal.fire({
                    icon:              'error',
                    title:             'Error',
                    text:              'An error occurred while saving.',
                    confirmButtonText: 'OK',
                    customClass: { confirmButton: 'btn btn-danger' },
                    buttonsStyling: false
                });
            });
        }
    </script>
}
