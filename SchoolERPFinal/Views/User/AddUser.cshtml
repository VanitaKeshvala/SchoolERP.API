@model SchoolERP.Shared.Models.UsersPageViewModel
@using System.Security.Claims
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/treeview.css" />
<style>
    /* ============ Wizard UI ============ */
    .wizard-steps-indicator {
        user-select: none;
    }

    .wizard-step {
        display: flex;
        align-items: center;
        gap: 8px;
        color: grey;
        transition: all 0.3s ease;
    }

        .wizard-step.active {
            color: #5e72e4;
        }

        .wizard-step.completed {
            color: #22b14c;
        }

    .step-num {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: #e9ecef;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        font-weight: 700;
        transition: all 0.3s ease;
    }

    .wizard-step.active .step-num {
        background: #5e72e4;
        color: #fff;
        box-shadow: 0 0 0 4px rgba(94, 114, 228, 0.2);
    }

    .wizard-step.completed .step-num {
        background: #2dce89;
        color: #fff;
    }

    .wizard-step-line {
        flex: 1;
        height: 2px;
        background: #e9ecef;
        min-width: 30px;
    }

    .wizard-pane {
        display: none;
        animation: fadeIn 0.3s ease;
    }

        .wizard-pane.active {
            display: block;
        }

    .tree-grid-container {
        border: 1px solid #e0e0e0 !important;
    }
    .top-6 {
        top: 6px;
    }

    .dt-buttons {
        display: none !important;
    }
    /* Depth-0 highlight for parent nodes */
    .tree-row.depth-0 {
        background-color: #f8f9fc;
    }

        .tree-row.depth-0 .tree-label {
            font-weight: 500;
            color: #32325d;
        }

    .form-check.form-switch {
        margin-left: 10px;
    }

    .form-check-input:disabled {
        background-color: #33333360;
    }
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }


</style>
<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditUser == null ? "Add User" : "Edit User")</h6>
    </div>
    <div class="d-flex align-items-center gap-2">
        <div class="ms-auto d-flex gap-2">

            <button type="button" class="btn btn-sm btn-primary shadow-sm top-btn" id="btnWizardNext" onclick="moveWizard(1)">
                Next <i class="ti ti-arrow-narrow-right ms-1"></i>
            </button>
           
            <button type="button" class="btn btn-sm btn-success shadow-sm d-none top-btn" id="btnWizardFinish" onclick="finishWizard()">
                <i class="ti ti-cloud me-1"></i> Save
            </button>
            <a href="/User/Index" id="btnBack" class="btn btn-sm btn-info d-inline-flex align-items-center top-btn">
                <i class="ti ti-arrow-narrow-left me-1"></i>Back
            </a>
            <button type="button" class="btn btn-sm btn-info d-none top-btn" id="btnWizardPrev" onclick="moveWizard(-1)">
                <i class="ti ti-arrow-narrow-left me-1"></i> Back
            </button>
            @* <button class="btn btn-danger" data-bs-dismiss="modal"><i class="ti ti-x me-1"></i> Close</button> *@
        </div>

    </div>
</div>
<!-- End Page Header -->

