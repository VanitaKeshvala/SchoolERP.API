@section Scripts {
    <script>
        
        let selectedUserId = 0;
        
        
        // ========================================
        // Filter dropdown (searchable selects)
        // ========================================
        document.addEventListener('DOMContentLoaded', () => {
                const params = new URLSearchParams(window.location.search);
        const userId = parseInt(params.get("id")) || 0;

        if (userId > 0) {
            openEditModal(userId);
        }
            ensureFilterAllOptions();
            try {
                // Select2 searchable dropdowns (scoped to filter dropdown)
                if (window.jQuery && typeof jQuery.fn.select2 === 'function') {
                    
                    const $userType = jQuery('#ddlUserTypeID');
                    if ($userType.length && !$userType.hasClass('select2-hidden-accessible')) {
                        $userType.select2({
                            width: '100%',                           
                            allowClear: true,
                            placeholder: 'Select user type'
                        });
                    }
                }
            } catch (e) {
                console.warn('Select2 init skipped:', e);
            }

            // Load companies into filter dropdown (API already returns allCompanies)
            loadFilterCompanies();

            // Keep filter dropdown open while interacting inside it
            const filterMenu = document.getElementById('filter-dropdown');
            filterMenu?.addEventListener('click', (e) => e.stopPropagation());

            // Close button
            document.getElementById('close-filter')?.addEventListener('click', () => {
                const toggle = document.getElementById('btnFilterToggle');
                if (!toggle) return;
                bootstrap.Dropdown.getOrCreateInstance(toggle).hide();
            });

            // Apply button should close dropdown (and later you can apply table filtering here)
            document.getElementById('btnApplyFilters')?.addEventListener('click', () => {
                const toggle = document.getElementById('btnFilterToggle');
                if (!toggle) return;
                bootstrap.Dropdown.getOrCreateInstance(toggle).hide();
            });
        });

        async function loadFilterCompanies() {
            const ddl = document.getElementById('ddlFilterCompany');
            if (!ddl) return;

            try {
                const resp = await fetch('/User/GetWizardData?userId=0&roleIds=');
                const result = await resp.json();
                const companies = result?.data?.allCompanies || [];

                const existing = new Set(Array.from(ddl.options).map(opt => String(opt.value)));

                companies.forEach(c => {
                    const companyId = String(c.companyId ?? '');
                    if (!companyId || existing.has(companyId)) return;
                    const opt = document.createElement('option');
                    opt.value = companyId;
                    opt.textContent = c.schoolName || c.companyName || `Company ${c.companyId}`;
                    ddl.appendChild(opt);
                    existing.add(companyId);
                });

                // refresh select2 if active
                if (window.jQuery && typeof jQuery.fn.select2 === 'function') {
                    jQuery('#ddlFilterCompany').trigger('change.select2');
                }
            } catch (err) {
                console.error('Failed to load companies for filter:', err);
            }
        }

        function ensureFilterAllOptions() {
            const dropdownIds = [
                'ddlFilterUserType',
                'ddlFilterCompany',
                'ddlFilterRole',
                'ddlFilterStatus'
            ];

            dropdownIds.forEach(id => {
                const ddl = document.getElementById(id);
                if (!ddl) return;

                const firstOption = ddl.options.length > 0 ? ddl.options[0] : null;
                const hasAllOption = Array.from(ddl.options).some(opt => opt.value === 'all');
                if (!hasAllOption) {
                    const allOption = document.createElement('option');
                    allOption.value = 'all';
                    allOption.textContent = 'All';
                    ddl.insertBefore(allOption, ddl.firstChild);
                } else if (firstOption && firstOption.value === 'all' && firstOption.textContent.trim().length === 0) {
                    firstOption.textContent = 'All';
                }
            });
        }

        function selectUser(id, row, isLocked) {
            selectedUserId = id;
            // Highlight row
            document.querySelectorAll('.user-row').forEach(r => r.classList.remove('bg-light'));
            row.classList.add('bg-light');
            // Check radio
            row.querySelector('input[type="radio"]').checked = true;
            // Enable buttons
            document.getElementById('btnEdit').disabled = false;
            document.getElementById('btnDelete').disabled = false;
            const btnUnlock = document.getElementById('btnUnlock');
            if (btnUnlock) btnUnlock.disabled = !isLocked;
        }

           async function openEditModal(userId) {
            currentStep = 1;
            document.getElementById('userWizardForm').reset();
            document.getElementById('txtUserId').value = userId;
            document.getElementById('passwordGroup').classList.add('d-none');
            document.getElementById('confirmPasswordGroup').classList.add('d-none');
            resetWizardUI();
            wizardData.selectedCompanyIDs = [];
            try {
                const response = await fetch(`/User/GetUser?userId=${userId}`);
                const result = await response.json();
                if (result.success) {
                    //const u = result.data;
                    const u = result.user;
                    document.getElementById('txtUsername').value = u.username;
                    document.getElementById('txtFullName').value = u.fullName;
                    document.getElementById('txtEmail').value = u.email;
                    document.getElementById('txtPhoneNo').value = u.phoneNo;
                    document.getElementById('ddlUserTypeID').value = u.userTypeID;
                    if (window.jQuery && typeof jQuery.fn.select2 === 'function') {
                        jQuery('#ddlUserTypeID').val(u.userTypeID || '').trigger('change');
                    }

                    // Roles are loaded via wizard-data call later, but let's pre-check for validation
                    // Wait, we need them for step 1 validation immediately if user clicks Next.
