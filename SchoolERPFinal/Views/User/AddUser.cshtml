                        <li class="nav-item"><a data-step="2" onclick="goToWizardStep(2)" class="nav-link">Companies</a></li>
                        <li class="nav-item"><a data-step="3" onclick="goToWizardStep(3)" class="nav-link">Permissions</a></li>
                    </ul>

