@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.RoomTypeAddViewModel
@{
    ViewData["Title"] = "Add Room Occupancy Type";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditRoomType == null ? "Add Room Occupancy Type" : "Edit Room Occupancy Type")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveRecord()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Hostel/RoomType" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">

            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <input type="hidden" id="txtItemId" value="@(Model.EditRoomType?.RoomTypeID ?? 0)">
                    <input type="hidden" id="hdnUserID" value="@(Model.EditRoomType?.CreatedBy ?? 0)">
                    <input type="hidden" id="hdnRoomTypeID" value="0">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">
                                Room Type
                            </label>
                            <select class="form-select select2" id="ddlACNonAC" required style="width: 100%;">
                                <option value="">-- Select --</option>
                                @foreach (var rt in Model.RoomCoolingType.Where(x => x.IsActive))
                                {
                                    <option value="@rt.RoomCoolingTypeId" selected="@(Model.EditRoomType?.RoomCoolingTypeId == rt.RoomCoolingTypeId)">@rt.RoomCoolingTypeName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Room Occupancy Type <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtTitle"
                                   value="@Model.EditRoomType?.RoomTypeTitle"
                                   placeholder="e.g. Single" autocomplete="off" required>
                            <div class="invalid-feedback" id="errtxtTitle"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Display Name</label>
                            <input type="text" class="form-control" id="txtDisplayLabel"
                                   value="@Model.EditRoomType?.DisplayLabel"
                                   placeholder="e.g. Single" autocomplete="off">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">
                                Bed Capacity
                                <span class="text-danger">*</span>
                            </label>
                            <input type="number" class="form-control" id="txtBedCapacity"
                                   value="@Model.EditRoomType?.BedCapacity"
                                   placeholder="e.g. 1" autocomplete="off" required>
                            <div class="invalid-feedback" id="errBedCapacity"></div>
                        </div>
                        
                        
                        <div class="col-md-12 mb-3">                           
                            <label class="form-label fw-bold">Description</label>
                            <textarea class="form-control" id="txtDescription" rows="1">@Model.EditRoomType?.RoomTypeDescription</textarea>
                            <div class="invalid-feedback" id="errDdlSections"></div>
                        </div>
                        <div class="col-md-2 mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="chkActive"
                                @(Model.EditRoomType?.IsActive ?? true ? "checked" : "")>
                                <label class="form-check-label fw-bold" for="chkActive">Active</label>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>
    <script src="~/assets/js/RoomType.js"></script>
}