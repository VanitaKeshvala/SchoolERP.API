@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.HostelTypeAddViewModel
@{
    ViewData["Title"] = "Add Hostel Type";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditHostelType == null ? "Add Hostel Type" : "Edit Hostel Type")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveItem()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Hostel/HostelType" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <input type="hidden" id="txtItemId" value="@(Model.EditHostelType?.HostelTypeID ?? 0)">
                    <input type="hidden" id="hdnUserID" value="@(Model.EditHostelType?.CreatedBy ?? 0)">

                    <div class="row">

                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Hostel Type Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtHostelTypeName"
                                   value="@Model.EditHostelType?.HostelTypeName"
                                   placeholder="e.g. Girls Hostel" autocomplete="off">
                            <div class="invalid-feedback" id="errTxtHostelTypeName"></div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Display Name </label>
                            <input type="text" class="form-control" id="txtDisplayLabel"
                                   value="@Model.EditHostelType?.DisplayLabel"
                                   placeholder="e.g. Girls Hostel" autocomplete="off">
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">
                                Gender <span class="text-danger">*</span>
                            </label>

                            <select asp-for="EditHostelType.Gender" class="form-select ddlGender">
                                <option value="">-- Select Gender --</option>
                                <option value="Male" selected="@(Model.EditHostelType?.Gender == "Male")">Male</option>
                                <option value="Female" selected="@(Model.EditHostelType?.Gender == "Female")">Female</option>
                            </select>

                            <div class="invalid-feedback" id="errDdlGender"></div>
                        </div>
                        <div class="col-md-12 mb-">
                            <label class="form-label fw-bold">Description</label>
                            <textarea class="form-control" id="txtDescription" rows="1">@Model.EditHostelType?.Description</textarea>
                            <div class="invalid-feedback" id="errDdlSections"></div>
                        </div>


                        <div class="col-md-2 mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="isActive"
                                @(Model.EditHostelType?.IsActive ?? true ? "checked" : "")>
                                <label class="form-check-label fw-bold" for="isActive">Active</label>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<link href="~/assets/css/select2.min.css" rel="stylesheet" />

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/assets/js/HostelTypes.js"></script>
}