@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.HostelRoomAddViewModel
@{
    ViewData["Title"] = "Add Hostel Room";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditHostelRoom == null ? "Add Hostel Room" : "Edit Hostel Room")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveRecord()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Hostel/HostelRoom" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <form id="roomForm">
                    <input type="hidden" id="hdnRoomId" value="@Model.EditHostelRoom?.RoomId??0">
                    <div class="row row-gap-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Hostel <span class="text-danger">*</span></label>
                            <select class="form-select" id="ddlHostel" required style="width: 100%;">
                                <option value="">-- Select --</option>
                                @foreach (var h in Model.Hostels.Where(x => x.IsActive))
                                {
                                    <option value="@h.HostelID" selected="@(Model.EditHostelRoom?.HostelID == h.HostelID)">@h.HostelName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Room Type <span class="text-danger">*</span></label>
                            <select class="form-select" id="ddlRoomType" onchange="fachrecordforcust(this.value)" required style="width: 100%;">
                                <option value="">-- Select --</option>
                                @foreach (var rt in Model.RoomTypes.Where(x => x.IsActive))
                                {
                                    <option value="@rt.RoomTypeID" selected="@(Model.EditHostelRoom?.RoomTypeID == rt.RoomTypeID)">@rt.RoomTypeTitle</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Room Title <span class="text-danger">*</span></label>
                            <input type="text"
                                   value="@Model.EditHostelRoom?.RoomTitle"
                                class="form-control" id="txtRoomTitle" required placeholder="e.g. 101, A-1">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Floor Number </label>
                            <input type="text"
                                   value="@Model.EditHostelRoom?.FloorNumber"
                                   class="form-control" id="txtFloorNumber" placeholder="e.g. 1,2,3, A-1">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Allow Extra Bed <span class="text-danger">*</span></label>
                            <select id="ddlAllowExtraBed" asp-for="EditHostelRoom.AllowExtraBed" class="form-select">
                                <option value="">-- Select Gender --</option>
                                <option value="1">Yes</option>
                                <option value="0">No</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Max Extra Beds</label>
                            <input type="number"
                                   value="@Model.EditHostelRoom?.MaxExtraBeds"
                                   class="form-control" id="txtMaxExtraBeds" min="0" step="0.01">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">No. Of Beds <span class="text-danger">*</span></label>
                            <input type="number"
                                   value="@Model.EditHostelRoom?.NoOfBed"
                                class="form-control" id="txtBeds" disabled  min="1">
                        </div>                        
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Cost Per Bed <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" disabled id="txtCost" required min="0" step="0.01" value="0">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Description</label>
                            <textarea class="form-control" id="txtDescription" rows="1">@Model.EditHostelRoom?.RoomDescription</textarea>
                        </div>
                        <div>
                            <label class="text-primary" id="acBadge"></label>
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="chkActive" @(Model.EditHostelRoom?.IsActive ?? true ? "checked" : "")>
                                <label class="form-check-label" for="chkActive">Active</label>
                            </div>
                        </div>

                        <div id="divRate" class="d-none">
                            <div class="col-12 mt-2 mb-3"><div class="bg-light p-2 fw-bold text-primary border-start border-primary border-4">Room Type:- <span id="spnRoomType" class="bold"></span> and <span id="spnRoomCoolingType" class="bold"></span></div></div>
                            <div class="table-responsive">
                                <table class="table mb-0">
                                    <thead>
                                        <tr>
                                            <th>Cost Per Bed</th>
                                            <th>Security Amount</th>
                                            <th>Effective From</th>
                                            <th>Effective To</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tblRateBody">
                                    </tbody>
                                </table>
                            </div>
                            
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
        window.initSelect2('#ddlRoomType',{ placeholder: "Select Room Type" });
        window.initSelect2('#ddlHostel',{ placeholder: "Select Hostel" });
    </script>
    <script src="~/assets/js/HostelRoom.js"></script>
}