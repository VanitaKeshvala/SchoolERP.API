@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.HostelRoomAddViewModel
@{
    ViewData["Title"] = "Add Hostel Room";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditHostelRoom == null ? "Add Hostel Room" : "Edit Hostel Room")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveRecord()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Hostel/HostelRoom" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <form id="roomForm">
                    <input type="hidden" id="hdnRoomId" value="@Model.EditHostelRoom?.RoomId??0">
                    <div class="row row-gap-3">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Hostel <span class="text-danger">*</span></label>
                            <select class="form-select" id="ddlHostel" required style="width: 100%;">
                                <option value="">-- Select -- </option>
                                @foreach (var h in Model.Hostels.Where(x => x.IsActive))
                                {
                                    <option value="@h.HostelID" selected="@(Model.EditHostelRoom?.HostelID == h.HostelID)">@h.HostelName (@h.HostelTypeName)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Room Type @Model.EditHostelRoom?.RoomCoolingTypeId<span class="text-danger">*</span></label>
                            <select class="form-select" id="ddlRoomType" onchange="bindRoomOccupancyType(this.value)" required style="width: 100%;">
                                
                                @foreach (var rt in Model.RoomTypes.Where(x => x.IsActive))
                                {
                                    <option value="@rt.RoomCoolingTypeId" selected="@(Model.EditHostelRoom?.RoomTypeID == rt.RoomCoolingTypeId)">@rt.RoomCoolingTypeName</option>
                                }
                            </select>
                        </div>
                        <div class="d-block col-md-4">
                            <input type="hidden" id="hdnRoomTypeID" value="@Model.EditHostelRoom?.RoomCoolingTypeId"/>
                            <label class="form-label fw-bold">Room Occupancy Type <span class="text-danger">*</span></label>
                            <select class="form-select select2" id="ddlRoomOccupancyType" onchange="fachrecordforcust(this.value)" style="width: 100%;">
                                
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Room Title <span class="text-danger">*</span></label>
                            <input type="text"
                                   value="@Model.EditHostelRoom?.RoomTitle"
                                class="form-control" id="txtRoomTitle" required placeholder="e.g. 101, A-1">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Floor Number </label>
                            <input type="text"
                                   value="@Model.EditHostelRoom?.FloorNumber"
                                   class="form-control" id="txtFloorNumber" placeholder="e.g. 1,2,3, A-1">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Allow Extra Bed</label>
                            <select id="ddlAllowExtraBed" asp-for="EditHostelRoom.AllowExtraBed" class="form-select">
                                <option value="">-- Select Allow Extra Bed --</option>
                                <option value="1">Yes</option>
                                <option value="0">No</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Max Extra Beds</label>
                            <input type="number"
                                   value="@Model.EditHostelRoom?.MaxExtraBeds"
                                   class="form-control" id="txtMaxExtraBeds" min="0" step="0.01">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">No. Of Beds <span class="text-danger">*</span></label>
                            <input type="number"
                                   value="@Model.EditHostelRoom?.NoOfBed"
                                class="form-control" id="txtBeds"  min="1">
                        </div>                        
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Cost Per Bed <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="txtCost" value="@Model.EditHostelRoom?.CostPerBed" required min="0" step="0.01" value="0">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Security Deposit</label>
                            <input type="text"
                                   value="@Model.EditHostelRoom?.SecurityAmount"
                                   class="form-control" id="txtSecurityAmount">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Effective From</label>
                            <input type="date"
                                   value="@(Model.EditHostelRoom?.EffectiveFrom?.ToString("yyyy-MM-dd"))"
                                   class="form-control" id="txtEffectiveFrom">
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Description</label>
                            <textarea class="form-control" id="txtDescription" rows="3">@Model.EditHostelRoom?.RoomDescription</textarea>
                        </div>
                        <div>
                            <label class="text-primary" id="acBadge"></label>
                        </div>
                        <div class="col-md-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="chkActive" @(Model.EditHostelRoom?.IsActive ?? true ? "checked" : "")>
                                <label class="form-check-label" for="chkActive">Active</label>
                            </div>
                        </div>

                        <div id="divRate" class="d-none">
                            <div class="col-12 mt-2 mb-3"><div class="bg-light p-2 fw-bold text-primary border-start border-primary border-4">Room Type:- <span id="spnRoomType" class="bold"></span> and <span id="spnRoomCoolingType" class="bold"></span></div></div>
                            <div class="table-responsive">
                                <table class="table mb-0">
                                    <thead>
                                        <tr>
                                            <th>Cost Per Bed</th>
                                            <th>Security Amount</th>
                                            <th>Effective From</th>
                                            <th>Effective To</th>
                                        </tr>
                                    </thead>
                                    <tbody id="tblRateBody">
                                    </tbody>
                                </table>
                            </div>
                            
                        </div>
                    </div>
                </form>

                <!-- ============================================================ -->
                <!-- LIVE RATE PREVIEW — insert this right after the </div> that   -->
                <!-- closes id="divRate" (still inside the <form id="roomForm">)   -->
                <!-- ============================================================ -->
                <div class="col-md-12 mt-3" id="divInvoicePreview">
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-primary bg-opacity-10 border-0 d-flex justify-content-between align-items-center py-3">
                            <div>
                                <h6 class="fw-bold mb-0 text-primary"><i class="ti ti-receipt me-2"></i>Estimated Rate Preview</h6>
                                <small class="text-muted">Live preview — updates as you fill the fields above</small>
                            </div>
                            <span class="badge rounded-pill px-3 py-2 bg-secondary bg-opacity-25 text-secondary" id="prevEffectiveBadge">No date set</span>
                        </div>
                        <div class="card-body pt-3">

                            <div class="row g-3 pb-3 mb-3 border-bottom">
                                <!-- Hostel column -->
                                <div class="col-md-6 d-flex align-items-start">
                                    <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-2 flex-shrink-0" style="width:36px;height:36px;">
                                        <i class="ti ti-building text-primary"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="text-muted" style="font-size:12px;">Hostel</div>
                                        <div class="fw-bold mb-2" id="prevHostelName">-</div>

                                        <div class="d-flex flex-wrap gap-1" id="divHostelSummary">
                                            
                                        </div>
                                    </div>
                                </div>

                                <!-- Room type column -->
                                <div class="col-md-3 d-flex align-items-start">
                                    <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-2 flex-shrink-0" style="width:36px;height:36px;">
                                        <i class="ti ti-door text-primary"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted" style="font-size:12px;">Room type</div>
                                        <div class="fw-bold" id="prevRoomType">-</div>
                                    </div>
                                </div>

                                <!-- Occupancy type column -->
                                <div class="col-md-3 d-flex align-items-start">
                                    <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-2 flex-shrink-0" style="width:36px;height:36px;">
                                        <i class="ti ti-bed text-primary"></i>
                                    </div>
                                    <div>
                                        <div class="text-muted" style="font-size:12px;">Occupancy type</div>
                                        <div class="fw-bold" id="prevOccupancyType">-</div>
                                    </div>
                                </div>
                            </div>

                            <div id="lineItemsWrap">
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <div>
                                        <div class="fw-medium">Rent per bed</div>
                                        <div class="text-muted" style="font-size:12px;" id="prevBaseRentDetail">Rs 0.00 x 0 beds</div>
                                    </div>
                                    <div class="fw-bold" id="prevBaseRentAmount">Rs 0.00</div>
                                </div>
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom d-none" id="rowExtraBed">
                                    <div>
                                        <div class="fw-medium">Extra bed charge</div>
                                        <div class="text-muted" style="font-size:12px;" id="prevExtraBedDetail">if all extra beds used</div>
                                    </div>
                                    <div class="fw-bold" id="prevExtraBedAmount">Rs 0.00</div>
                                </div>
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <div>
                                        <div class="fw-medium">Security amount</div>
                                        <div class="text-muted" style="font-size:12px;">Charged one time</div>
                                    </div>
                                    <div class="fw-bold" id="prevSecurityAmount">Rs 0.00</div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center bg-primary bg-opacity-10 rounded-3 px-3 py-3 mt-3">
                                <div>
                                    <div class="fw-bold text-primary">Estimated total</div>
                                    <div class="text-muted" style="font-size:12px;"><i class="ti ti-calendar me-1"></i>Effective from <span id="prevEffectiveFrom">-</span></div>
                                </div>
                                <div class="fw-bold fs-4 text-primary" id="prevTotalAmount">Rs 0.00</div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
        window.initSelect2('#ddlRoomType',{ placeholder: "Select Room Type" });
        window.initSelect2('#ddlHostel',{ placeholder: "Select Hostel" });
    </script>
    <script src="~/assets/js/HostelRoom.js"></script>
}