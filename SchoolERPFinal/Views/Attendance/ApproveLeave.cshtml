@model SchoolERP.Shared.Models.StudentLeavePageViewModel
@using System.Security.Claims
@using System.Text.Json
@{
    ViewData["Title"] = "Approve Leave";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    int totalPages = Model.PageSize > 0
                  ? (int)Math.Ceiling((double)Model.TotalRecords / Model.PageSize)
                  : 0;
    var p = Model.Permissions;
}

<style>
    .dt-buttons {
    display: none !important;
    }
</style>

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Approve Leave</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1 responsive-btn-group">
        @if (p.CanAdd)
        {
            <a href="/Attendance/AddLeaveRequest" class="btn btn-primary d-inline-flex align-items-center top-btn">
                <i class="ti ti-plus me-1"></i> Add
            </a>
        }
        @if (p.CanEdit)
        {
            <button id="btnEdit" class="btn btn-info top-btn" disabled onclick="handleEditAction()">
                <i class="ti ti-pencil me-1"></i> Edit
            </button>

        }
        @if (p.CanDelete)
        {
            <button id="btnDelete" class="btn btn-danger top-btn" disabled onclick="handleDeleteAction()">
                <i class="ti ti-trash me-1"></i> Delete
            </button>

        }        

        @if (p.CanPrint)
        {
            <button class="btn btn-secondary d-inline-flex align-items-center top-btn" onclick="triggerExport(4)">
                <i class="ti ti-printer me-1"></i>Print
            </button>
        }
        @if (p.CanExport)
        {
            <div class="dropdown d-inline-flex">
                <button class="btn btn-warning dropdown-toggle top-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(0)"><i class="ti ti-copy me-1"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(1)"><i class="ti ti-file-text me-1"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(2)"><i class="ti ti-file-spreadsheet me-1"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(3)"><i class="ti ti-file-description me-1"></i>PDF</a></li>
                </ul>
            </div>
        }


    </div>
</div>

<div class="row">
    <!-- Filters -->

    <div class="col-xl-12">
        <div class="card mb-2 shadow-tbl-outer">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">

                    <!-- ── Search box (name="search" so form submits it) ── -->
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3 bg-white flex-grow-1 search-box-wrap" style="max-width:420px;">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text"
                        name="search"
                        id="txtSearchInput"
                        value="@Model.SearchTerm"
                               class="form-control border-0 ps-2 search-input-responsive"
                        placeholder="Search by Student Name, Admission No..."/>
                    </div>

                    <!-- Hidden form for filter submission — outside Bootstrap dropdown -->
                    <form method="get" asp-action="ApproveLeave" id="frmSearch" style="display:none;">
                        <input type="hidden" name="pageIndex" id="hdnPageIndex" value="1" />
                        <input type="hidden" name="search" id="hdnSearch" value="@Model.SearchTerm" />
                        <input type="hidden" name="classId" id="hdnSessionID" value=@Model.ClassId />
                        <input type="hidden" name="companyId" id="hdnCompanyId" value=@Model.CompanyId />
                        <input type="hidden" name="sectionId" id="hdnSectionID" value=@Model.SectionID />
                        <input type="hidden" name="status" id="hdnstatus" value=@Model.Status />
                        <input type="hidden" name="pageSize" id="hdnPageSize" value="@Model.PageSize" />
                    </form>

                    <div class="dropdown">
                        <a href="#" id="btnFilterToggle"
                        class="btn btn-white border rounded btn-md text-dark fs-14 align-items-center d-flex fw-normal"
                        data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            <i class="ti ti-filter text-gray-5 me-1"></i>Filters
                        </a>

                        <div class="dropdown-menu dropdown-lg dropdown-menu-end filter-dropdown p-2 shadow-tbl"
                        id="filter-dropdown">

                            <div class="d-flex align-items-center justify-content-between border-bottom filter-header">
                                <h6 class="mb-0 fw-bold">Select Criteria</h6>
                                <div class="d-flex align-items-center justify-content-end">
                                    <button type="button" class="btn btn-light btn-md me-2 fw-medium" onclick="resetAllFilters()" id="btnResetFilters">Reset</button>
                                    <button type="button" class="btn text-primary fs-6 fw-medium" id="btnApplyFilters">Apply</button>
                                </div>
                            </div>

                            <div class="filter-body pb-0">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Company</label>
                                        <select class="form-select form-control select2"
                                        id="ddlFilterCompany"
                                        data-placeholder="Select company">
                                            <option value="">All</option>
                                            @foreach (var c in Model.Companies ?? new List<MstCompanyViewModel>())
                                            {
                                                <option value="@c.CompanyId" selected="@(Model.CompanyId == c.CompanyId)">
                                                    @c.SchoolName
                                                </option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Class</label>
                                        <select id="classSelect" class="form-select form-control select2">
                                            <option value="">All Classes</option>
                                            @if (Model.Classes != null)
                                            {
                                                foreach (var c in Model.Classes)
                                                {
                                                    <option value="@c.ClassID">@c.ClassName</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Section</label>
                                        <select id="sectionSelect" class="form-select form-control select2">
                                            <option value="">All Sections</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-0">
                                        <label class="form-label mb-1">Status</label>
                                        <select id="statusSelect" class="form-select form-control select2">
                                            <option value="0">Pending</option>
                                            <option value="1">Approved</option>
                                            <option value="2">Rejected</option>
                                            <option value="-1">All</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- Active filter badges -->
    <div class="col-xl-12" id="activeFilterBadges" style="display: none;">
        <div class="card shadow-tbl border-0 py-2 mb-2">
            <div class="card-body p-2 d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold ms-2 me-2">
                    <i class="ti ti-filter-check me-1"></i>Active Filters:
                </span>
                <div id="badgeContainer" class="d-flex flex-wrap gap-2"></div>
                <button class="btn btn-sm btn-link text-danger p-0 ms-auto me-2 fw-bold text-decoration-none"
                id="btnResetAllFilters" onclick="resetAllFilters()">
                    <i class="ti ti-trash me-1"></i>Clear All
                </button>
            </div>
        </div>
    </div>


    <div class="col-md-12">
        <div class="card shadow-tbl">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-nowrap" id="tblLeave">
                        <thead>
                            <tr>
                                <th style="width: 50px;">Select</th>
                                <th>S.No</th>
                                <th>Student Name</th>
                                <th>Admission No</th>
                                <th>Class (Section)</th>
                                <th>From Date</th>
                                <th>To Date</th>
                                <th>Reason</th>
                                <th>Attachment</th>
                                <th>Apply Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="leaveTableBody">
                            @if (Model.StudentLeaveModel != null)
                            {
                                @foreach (var c in Model.StudentLeaveModel)
                                {
                                    <tr class="item-row" onclick="selectItem(@c.LeaveAppID, this)" style="cursor: pointer;">
                                        <td class="ps-4 text-center">
                                            <input type="checkbox" name="selectedClass"
                                            class="form-check-input student-checkbox" onclick="selectItem(@c.LeaveAppID, this)"
                                            value="@c.LeaveAppID">

                                        </td>
                                        <td>@c.LeaveAppID</td>
                                        <td>@c.StudentName</td>
                                        <td>@c.AdmissionNo</td>
                                        <td>@c.ClassName (@c.SectionName)</td>
                                        <td>@c.FromDate.ToString("dd MMM yyyy")</td>
                                        <td>@c.ToDate.ToString("dd MMM yyyy")</td>
                                        <td>@c.Reason</td>
                                        <td>
                                            @if(p.CanView)
                                            {
                                                @if (c.Attachment != null && c.Attachment.Length > 0)
                                                {
                                                    <a href="/Attendance/DownloadAttachment/@c.LeaveAppID" target="_blank" class="btn btn-sm btn-white border px-2 py-1" title="@c.AttachmentName">
                                                        <i class="ti ti-paperclip fs-5"></i>
                                                    </a>
                                                    <a href="@c.Attachment" target="_blank" class="btn btn-sm btn-white border px-2 py-1" title="View Attachment">
                                                        <i class="ti ti-eye fs-5"></i>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <span class="text-muted fs-7">-</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted fs-7">-</span>
                                            }
                                        
                                        </td>
                                        <td>@c.ApplyDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @if(c.Status == 0) 
                                            {
                                                <span class="badge bg-warning">Pending</span>
                                            }
                                            else if (c.Status == 1)
                                            {
                                                <span class="badge bg-success">Approved</span>
                                            } else {
                                                <span class="badge bg-danger">Rejected</span>
                                            }
                                        </td>
                                    </tr>
                                }

                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4">
                                        <span class="text-muted">No records found.</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <!-- ── Pagination ─────────────────────────────────────────────── -->
                    @if (totalPages > 1)
                    {
                        <div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2 mb-3">
                            <!-- Record info -->
                            <div class="text-muted small">
                                Showing
                                <strong>@(((Model.PageNumber - 1) * Model.PageSize) + 1)</strong>
                                –
                                <strong>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalRecords))</strong>
                                of
                                <strong>@Model.TotalRecords</strong> users
                            </div>

                            <nav aria-label="Subject pagination">
                                <ul class="pagination pagination-sm mb-0">

                                    <!-- First -->
                                    <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                                        <a class="page-link"
                                           href="?pageIndex=1&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&classId=@Model.ClassId&sectionId=@Model.SectionID&status=@Model.Status">
                                            <i class="ti ti-chevrons-left"></i>
                                        </a>
                                    </li>

                                    <!-- Prev -->
                                    <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                                        <a class="page-link"
                                           href="?pageIndex=@(Model.PageNumber - 1)&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&classId=@Model.ClassId&sectionId=@Model.SectionID&status=@Model.Status">
                                            <i class="ti ti-chevron-left"></i>
                                        </a>
                                    </li>

                                    <!-- Page numbers — show 5 around current -->
                                    @{
                                        int start = Math.Max(1, Model.PageNumber - 2);
                                        int end = Math.Min(totalPages, start + 4);
                                        start = Math.Max(1, end - 4);
                                    }
                                    @for (int pg = start; pg <= end; pg++)
                                    {
                                        <li class="page-item @(pg == Model.PageNumber ? "active" : "")">
                                            <a class="page-link"
                                               href="?pageIndex=@pg&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&classId=@Model.ClassId&sectionId=@Model.SectionID&status=@Model.Status">@pg</a>
                                        </li>
                                    }

                                    <!-- Next -->
                                    <li class="page-item @(Model.PageNumber >= totalPages ? "disabled" : "")">
                                        <a class="page-link"
                                           href="?pageIndex=@(Model.PageNumber + 1)&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&classId=@Model.ClassId&sectionId=@Model.SectionID&status=@Model.Status">
                                            <i class="ti ti-chevron-right"></i>
                                        </a>
                                    </li>

                                    <!-- Last -->
                                    <li class="page-item @(Model.PageNumber >= totalPages ? "disabled" : "")">
                                        <a class="page-link"
                                           href="?pageIndex=@totalPages&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&classId=@Model.ClassId&sectionId=@Model.SectionID&status=@Model.Status">
                                            <i class="ti ti-chevrons-right"></i>
                                        </a>
                                    </li>

                                </ul>
                            </nav>

                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <script src="~/assets/js/ApproveLeave.js"></script>
}
