@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.StudentLeaveAddViewModel
@{
    ViewData["Title"] = "Add Leave Request";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditStudentLeave == null ? "Add Leave Request" : "Add Leave Request")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" id="btnSaveLeave">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Attendance/ApproveLeave" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">

            <div class="card-body">
                <form id="leaveForm">
                    <input type="hidden" id="leaveAppId" value="@Model.EditStudentLeave?.LeaveAppID" />
                    <div class="row">
                        <div class="col-12 col-md-4 mb-3">
                            <label class="form-label">Class <span class="text-danger">*</span></label>
                            <select id="modalClassSelect" class="form-select select2-modal" required>
                                <option value="">Select Class</option>
                                @if (Model.Classes != null)
                                {
                                    foreach (var c in Model.Classes)
                                    {
                                        <option value="@c.ClassID" selected="@(Model.EditStudentLeave?.ClassID == c.ClassID)">@c.ClassName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-12 col-md-4 mb-3">
                            <label class="form-label">Section <span class="text-danger">*</span></label>
                            <input type="hidden" value="@Model.EditStudentLeave?.SectionID" id="hdnSectionId"/>
                            <select id="modalSectionSelect" class="form-select select2-modal" required>
                                <option value="">Select Section</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-4 mb-3">
                            <input type="hidden" value="@Model.EditStudentLeave?.StudentID" id="hdnStudentID" />
                            <label class="form-label">Student Name <span class="text-danger">*</span></label>
                            <select id="modalStudentSelect" class="form-select select2-modal" required>
                                <option value="">Select Student</option>
                            </select>
                        </div>

                        <div class="col-12 col-md-4 mb-3">
                            <label class="form-label">Apply Date</label>
                            <input type="date" id="applyDate" class="form-control" value="@(Model.EditStudentLeave?.ApplyDate.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))">
                        </div>

                        <div class="col-12 col-md-4 mb-3">
                            <label class="form-label">From Date</label>
                            <input type="date" id="fromDate" class="form-control" value="@(Model.EditStudentLeave?.FromDate.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))">
                        </div>

                        <div class="col-12 col-md-4 mb-3">
                            <label class="form-label">To Date <span class="text-danger">*</span></label>
                            <input type="date" id="toDate" class="form-control" value="@(Model.EditStudentLeave?.ToDate.ToString("yyyy-MM-dd") ?? DateTime.Now.ToString("yyyy-MM-dd"))">
                        </div>

                        <div class="col-md-12 mb-3">
                            <label class="form-label">Reason <span class="text-danger">*</span></label>
                            <textarea id="reason" class="form-control" rows="3" required>@Model.EditStudentLeave?.Reason</textarea>
                            <div class="invalid-feedback" id="errreason"></div>
                        </div>

                        <div class="col-12 col-md-12 mb-3">
                            <label class="form-label d-block">Leave Status <span class="text-danger">*</span></label>
                            <div class="form-check form-check-inline">
                                <input type="radio" class="form-check-input" name="leaveStatus" id="pen" value="0" checked>
                                <label for="pen" class="form-check-label">Pending</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input type="radio" class="form-check-input" name="leaveStatus" id="app" value="1">
                                <label for="app" class="form-check-label">Approve</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input type="radio" class="form-check-input" name="leaveStatus" id="disap" value="2">
                                <label for="disap" class="form-check-label">Disapprove</label>
                            </div>
                        </div>

                        @* <div class="col-12 col-md-12 mb-3">
                            <label class="form-label">Attach Document</label>
                            <input type="file" id="attachFile" class="form-control">
                        </div> *@
                        <div class="col-md-6">
                            <label class="form-label">Attachment</label>
                            <input type="file" class="form-control" id="attachFile" name="attachFile">
                            <small class="text-muted" id="fileInfo"></small>

                            @if (!string.IsNullOrEmpty(Model.EditStudentLeave?.AttachmentName))
                            {
                                <div id="existingFileInfo" class="mt-1 d-flex align-items-center gap-2">
                                    <a href="@Model.EditStudentLeave.Attachment" target="_blank" class="small">
                                        <i class="ti ti-paperclip me-1"></i>@Model.EditStudentLeave.AttachmentName
                                    </a>
                                    <button type="button" class="btn btn-sm btn-outline-danger py-0 px-1" onclick="removeExistingFile()">
                                        <i class="ti ti-x"></i>
                                    </button>
                                </div>
                            }
                            <!-- Tells the backend whether to keep, replace, or delete the existing file -->
                            <input type="hidden" id="hdnExistingFile" name="ExistingFileName" value="@Model.EditStudentLeave?.AttachmentName">
                            <input type="hidden" id="hdnRemoveFile" name="RemoveAttachment" value="false">
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    
    <script src="~/assets/js/ApproveLeave.js"></script>
}