@{
    ViewData["Title"] = "Attendance Report";
}

<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Attendance Report</h6>       
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        <button onclick="window.print()" class="btn btn-secondary d-inline-flex align-items-center">
            <i class="ti ti-printer me-1"></i>Print
        </button>
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm mb-2">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3 bg-white">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text" class="form-control border-0 ps-2" id="txtSearchInput" style="min-width: 220px;" placeholder="Search report..." />
                    </div>
                    <div class="dropdown">
                        <a href="#" id="btnFilterToggle" class="btn btn-white border rounded btn-md text-dark fs-14 align-items-center d-flex fw-normal"
                           data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            <i class="ti ti-filter text-gray-5 me-1"></i>Filters
                        </a>
                        <div class="dropdown-menu dropdown-lg dropdown-menu-end filter-dropdown p-0 shadow-tbl" id="filter-dropdown">
                            <div class="d-flex align-items-center justify-content-between border-bottom filter-header py-2">
                                <h6 class="mb-0 fw-bold ms-3">Select Criteria</h6>
                                <div class="d-flex align-items-center justify-content-end me-2">
                                    <button type="button" id="btnFilterSearch" class="btn text-primary fs-6 fw-medium">Filter</button>
                                </div>
                            </div>
                            <div class="filter-body pb-0 p-3">
                                <form id="filterForm">
                                    <div class="mb-3">
                                        <label class="form-label mb-1">Class<span class="text-danger">*</span></label>
                                        <select id="classSelect" class="form-select form-control select2" required>
                                            <option value="">Select Class</option>
                                            @if (ViewBag.ClassList != null)
                                            {
                                                foreach (var c in ViewBag.ClassList)
                                                {
                                                    <option value="@c.ClassID">@c.ClassName</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label mb-1">Section<span class="text-danger">*</span></label>
                                        <select id="sectionSelect" class="form-select form-control select2" required>
                                            <option value="">Select Section</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label mb-1">Date<span class="text-danger">*</span></label>
                                        <input type="date" id="attendanceDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-12" id="activeFilterBadges" style="display: none;">
        <div class="card shadow-tbl border-0 py-2 mb-2">
            <div class="card-body p-2 d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold ms-2 me-2"><i class="ti ti-filter-check me-1"></i>Active Filters:</span>
                <div id="badgeContainer" class="d-flex flex-wrap gap-2"></div>
                <button class="btn btn-sm btn-link text-danger p-0 ms-auto me-2 fw-bold text-decoration-none" id="btnResetAllFilters" onclick="resetAllFilters()">
                    <i class="ti ti-trash me-1"></i>Clear All
                </button>
            </div>
        </div>
    </div>

    <div class="col-md-12">
        <div class="card shadow-tbl">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Admission No</th>
                                <th>Roll No</th>
                                <th>Student Name</th>
                                <th>Attendance</th>
                                <th>Date</th>
                                <th>Note</th>
                            </tr>
                        </thead>
                        <tbody id="reportTableBody">
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="ti ti-info-circle fs-2 d-block mb-2"></i>
                                    Select filters and click Filter to load report.
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.select2').select2({ dropdownParent: $('#filter-dropdown') });

            $('#classSelect').on('change', function () {
                const classId = $(this).val();
                if (classId) {
                    $.get('/Attendance/GetSectionsByClass', { classId: classId }, function (res) {
                        if (res.success) {
                            let html = '<option value="">Select Section</option>';
                            res.data.forEach(s => {
                                html += `<option value="${s.sectionID}">${s.sectionName}</option>`;
                            });
                            $('#sectionSelect').html(html).trigger('change');
                            renderFilterBadges();
                        }
                    });
                }
            });

            renderFilterBadges();

            // Real-time Search
            $("#txtSearchInput").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#reportTableBody tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
                renderFilterBadges();
            });

            // Prevent dropdown closure when interacting with select2
            $('#filter-dropdown').on('click', function (e) {
                e.stopPropagation();
            });

            // Bind filter button click
            $('#btnFilterSearch').on('click', function (e) {
                e.preventDefault();
                loadReport();
            });

            // Bind date change
            $('#attendanceDate').on('change', function () {
                const classId = $('#classSelect').val();
                const sectionId = $('#sectionSelect').val();
                if (classId && sectionId) {
                    loadReport();
                } else {
                    renderFilterBadges();
                }
            });
        });

        // --- Filter Badges Logic ---
        function renderFilterBadges() {
            const container = document.getElementById('badgeContainer');
            const mainContainer = document.getElementById('activeFilterBadges');
            if (!container) return;
            container.innerHTML = '';

            const filters = [
                { id: 'txtSearchInput', label: 'Search', type: 'text' },
                { id: 'classSelect', label: 'Class', type: 'select' },
                { id: 'sectionSelect', label: 'Section', type: 'select' },
                { id: 'attendanceDate', label: 'Date', type: 'text' }
            ];

            let activeCount = 0;

            filters.forEach(f => {
                const el = document.getElementById(f.id);
                if (!el) return;

                let value = el.value;
                let text = '';

                if (f.type === 'text') {
                    if (value.trim()) {
                        text = value;
                        activeCount++;
                    }
                } else if (f.type === 'select') {
                    if (value && value !== 'all' && value !== '') {
                        const selectedOption = el.options[el.selectedIndex];
                        if (selectedOption && selectedOption.value !== "") {
                            text = selectedOption.text;
                            activeCount++;
                        }
                    }
                }

                if (text) {
                    const badge = document.createElement('span');
                    badge.className = 'badge bg-primary-subtle text-primary border border-primary-subtle d-flex align-items-center gap-1 fw-medium px-2 py-1';
                    badge.innerHTML = `${f.label}: ${text} <i class="ti ti-x ms-1 cursor-pointer" onclick="removeFilter('${f.id}')" style="font-size: 10px;"></i>`;
                    container.appendChild(badge);
                }
            });

            if (activeCount > 0) {
                mainContainer.style.display = 'block';
            } else {
                mainContainer.style.display = 'none';
            }
        }

        function removeFilter(filterId) {
            const el = document.getElementById(filterId);
            if (!el) return;

            if (el.tagName === 'INPUT' && filterId === 'txtSearchInput') {
                el.value = '';
                $(el).trigger('keyup');
            } else {
                el.value = '';
                if (filterId === 'classSelect') {
                    $('#sectionSelect').html('<option value="">Select Section</option>');
                }
                if (window.jQuery && jQuery(el).data('select2')) {
                    jQuery(el).trigger('change.select2');
                }
                loadReport();
            }
        }

        function resetAllFilters() {
            document.getElementById('txtSearchInput').value = '';
            document.getElementById('classSelect').value = '';
            document.getElementById('sectionSelect').value = '';
            // Reset date to today?
            document.getElementById('attendanceDate').value = '@DateTime.Now.ToString("yyyy-MM-dd")';
            
            $('.select2').trigger('change.select2');
            $('#txtSearchInput').trigger('keyup');
            renderFilterBadges();
        }

        function loadReport() {
            const classId = $('#classSelect').val();
            const sectionId = $('#sectionSelect').val();
            const date = $('#attendanceDate').val();

            if (!classId || !sectionId || !date) {
                showToast('Please select class, section and date', 'error');
                return;
            }

            $('#reportTableBody').html('<tr><td colspan="7" class="text-center py-5"><div class="spinner-border text-primary"></div></td></tr>');

            $.get('/Attendance/GetAttendanceList', { classId: classId, sectionId: sectionId, date: date }, function (res) {
                if (res.success) {
                    let html = '';
                    if (res.data.length === 0) {
                        html = '<tr><td colspan="7" class="text-center py-5 text-danger">No attendance records found for selected criteria.</td></tr>';
                    } else {
                        res.data.forEach((s, index) => {
                            console.log(s);
                            let statusBadge = '';
                            switch (s.attendanceStatus) {
                                case 1: statusBadge = '<span class="badge bg-success">Present</span>'; break;
                                case 2: statusBadge = '<span class="badge bg-warning">Late</span>'; break;
                                case 3: statusBadge = '<span class="badge bg-danger">Absent</span>'; break;
                                case 4: statusBadge = '<span class="badge bg-info">Half Day</span>'; break;
                                case 5: statusBadge = '<span class="badge bg-secondary">Holiday</span>'; break;
                                default: statusBadge = '<span class="badge bg-light text-dark">N/A</span>';
                            }

                            html += `
                                <tr>
                                    <td>${index + 1}</td>
                                    <td>${s.admissionNo}</td>
                                    <td>${s.rollNo || '-'}</td>
                                    <td class="fw-medium">${s.studentName}</td>
                                    <td>${statusBadge}</td>
                                    <td>${date}</td>
                                    <td class="text-muted">${s.note || '-'}</td>
                                </tr>`;
                        });
                    }
                    $('#reportTableBody').html(html);
                    renderFilterBadges();
                    const toggle = document.getElementById('btnFilterToggle');
                    if (toggle) {
                        bootstrap.Dropdown.getOrCreateInstance(toggle).hide();
                    }
                }
            });
        }
    </script>
}
