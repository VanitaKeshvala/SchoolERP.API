@*
    ======================================================================
    VIEW: Settings / PaymentMethods.cshtml
    PURPOSE: Single payment method configuration for Razorpay.
    ======================================================================
*@
@model SchoolERP.Net.Models.PaymentMethodsPageViewModel
@using System.Security.Claims
@using System.Text.Json
@using SchoolERP.Net.Helpers
@using SchoolERP.Net.Services
@inject PermissionHelper PermHelper
@{
    Layout = "_Layout";
    ViewData["Title"] = "Payment Methods";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    if (currentUserId > 0)
        PermHelper.LoadPermissions(currentUserId);
    
    var canAdd = PermHelper.HasPermissionByUrl("/Settings", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/Settings", "Edit");
    var hasPermission = canAdd || canEdit;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Payment Methods</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-2">
        @if (hasPermission)
        {
            <button class="btn btn-success" id="btnSave" onclick="savePaymentMethod()">
                <i class="ti ti-cloud me-1"></i>Save
            </button>
        }
    </div>
</div>
<!-- End Page Header -->

<!-- start row -->
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <input type="hidden" id="txtPaymentId" value="@(Model.PaymentMethod?.PaymentId ?? 0)">
                        
                        <div class="mb-3">
                            <label for="txtPaymentKey" class="form-label">Razorpay Key ID <span class="text-danger">*</span></label>
                            <input type="text" id="txtPaymentKey" class="form-control" value="@Model.PaymentMethod?.PaymentKey" placeholder="Enter Razorpay Key ID">
                            <div class="invalid-feedback" id="errPaymentKey"></div>
                        </div>

                        <div class="mb-3">
                            <label for="txtPaymentSecret" class="form-label">Razorpay Key Secret <span class="text-danger">*</span></label>
                            <input type="password" id="txtPaymentSecret" class="form-control" value="@Model.PaymentMethod?.PaymentSecret" placeholder="Enter Razorpay Key Secret">
                            <div class="invalid-feedback" id="errPaymentSecret"></div>
                        </div>

                        <div class="form-check form-switch mt-3">
                            <input class="form-check-input" type="checkbox" id="isActive" @(Model.PaymentMethod == null || Model.PaymentMethod.IsActive ? "checked" : "")>
                            <label class="form-check-label fw-medium" for="isActive">Active Status</label>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="card mb-0 border-0">
                            <div class="card-body text-center p-4">
                                <h6 class="fs-14 mb-3">Payment Gateway For India</h6>
                                <div class="mb-4">
                                    <img src="~/assets/images/razorpay.jpg" class="img-fluid rounded" width="180" alt="Razorpay Logo" onerror="this.src='https://razorpay.com/assets/razorpay-logo.png'">
                                </div>
                                <p class="text-muted mb-3">Secure your transactions with India's leading payment gateway.</p>
                                <a href="https://razorpay.com/" target="_blank" class="d-inline-flex align-items-center text-primary fw-semibold text-decoration-none">
                                    Visit Razorpay Official Site <i class="ti ti-external-link ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- end col -->
</div>
<!-- end row -->

@section Scripts {
    <script>
        const IV = window.InlineFormValidation;
        const fieldMap = { 
            txtPaymentKey: 'errPaymentKey', 
            txtPaymentSecret: 'errPaymentSecret' 
        };

        async function savePaymentMethod() {
            const paymentId = parseInt(document.getElementById('txtPaymentId').value);
            const paymentKey = document.getElementById('txtPaymentKey').value.trim();
            const paymentSecret = document.getElementById('txtPaymentSecret').value.trim();
            const isActive = document.getElementById('isActive').checked;

            // Simple validation
            let hasError = false;
            IV.clearMap(fieldMap);

            if (!paymentKey) { 
                IV.setFieldError('txtPaymentKey', 'errPaymentKey', 'Razorpay Key ID is required.'); 
                hasError = true; 
            }
            if (!paymentSecret) { 
                IV.setFieldError('txtPaymentSecret', 'errPaymentSecret', 'Razorpay Key Secret is required.'); 
                hasError = true; 
            }

            if (hasError) return;

            const btnSave = document.getElementById('btnSave');
            btnSave.disabled = true;
            btnSave.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';

            try {
                const data = {
                    paymentId: paymentId,
                    paymentKey: paymentKey,
                    paymentSecret: paymentSecret,
                    isActive: isActive
                };

                const resp = await fetch('/Settings/SavePaymentMethod', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const res = await resp.json();
                if (res.success) {
                    showToast(res.message || 'Payment method saved successfully.', 'success');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showToast(res.message || 'Failed to save settings.', 'danger');
                }
            } catch (err) {
                showToast('An error occurred while saving.', 'danger');
            } finally {
                btnSave.disabled = false;
                btnSave.innerHTML = '<i class="ti ti-cloud me-1"></i>Save';
            }
        }
    </script>
}
