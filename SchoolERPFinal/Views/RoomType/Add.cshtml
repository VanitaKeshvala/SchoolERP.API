@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.RoomCoolingTypeAddViewModel
@{
    ViewData["Title"] = "Add Room Type";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditRoomCoolingType == null ? "Add Room Type" : "Edit Room Type")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1 responsive-btn-group">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveItem()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/RoomType/Index" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <input type="hidden" id="txtItemId" value="@(Model.EditRoomCoolingType?.RoomCoolingTypeId ?? 0)">
                    <input type="hidden" id="hdnUserID" value="@(Model.EditRoomCoolingType?.CreatedBy ?? 0)">

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Room Type Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtRoomTypeName"
                                   value="@Model.EditRoomCoolingType?.RoomCoolingTypeName"
                                   placeholder="e.g. 1st Class" autocomplete="off">
                            <div class="invalid-feedback" id="errTxtHostelTypeName"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Display Name</label>
                            <input type="text" class="form-control" id="txtDisplayLabel"
                                   value="@Model.EditRoomCoolingType?.DisplayLabel"
                                   placeholder="e.g. 1st Class" autocomplete="off">
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-bold">Description</label>
                            <textarea class="form-control" id="txtDescription" rows="1">@Model.EditRoomCoolingType?.Description</textarea>
                            <div class="invalid-feedback" id="errDdlSections"></div>
                        </div>


                        <div class="col-md-2 mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="isActive"
                                @(Model.EditRoomCoolingType?.IsActive ?? true ? "checked" : "")>
                                <label class="form-check-label fw-bold" for="isActive">Active</label>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<link href="~/assets/css/select2.min.css" rel="stylesheet" />

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/assets/js/RoomCoolingType.js"></script>
}