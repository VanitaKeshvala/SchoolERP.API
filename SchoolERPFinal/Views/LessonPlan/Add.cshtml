@model SchoolERP.Shared.Models.LessonPlanAddViewModel
@using System.Security.Claims
@using System.Text.Json

@{
    Layout = "_Layout";
    ViewData["Title"] = "Lesson Plan";

    // Permission loading for the view
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;

    // Model.LessonPlanMap is expected to be the list of existing CHAPTERS
    // (TBL_MST_MAP_LESSON rows) that belong to the single lesson MASTER for the
    // currently selected Class / Section / SubjectGroup / Subject. When empty,
    // a single blank row is rendered. Model.EditLessonPlan carries the master
    // (LessonID, ClassID, SectionID, SubjectGroupID, SubjectID, IsActive).
    var existingLessons = Model.LessonPlanMap ?? new List<LessonPlanMap>();
    var masterLessonId = Model.EditLessonPlan?.LessonId ?? 0;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Lesson Plan</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd || p.CanEdit)
        {
            <button class="btn btn-success top-btn" onclick="saveAllLessons()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }

        <a href="/LessonPlan/Index" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<!-- End Page Header -->

<div id="pageNotice"></div>

<!-- Master LessonId (TBL_MST_LESSON.LessonId). 0 = no master yet for the
     current Class/Section/SubjectGroup/Subject combo -> SP will create one. -->
<input type="hidden" id="hdnLessonId" value="@masterLessonId" />

<div class="row">
    <div class="col-xl-12">
        <!-- Class / Section / Subject Group / Subject Card -->
        <div class="card shadow-tbl-outer mb-2">
            <div class="card-body">
                <div class="row">
                    <input type="hidden" id="txtSectionID" value="@Model.EditLessonPlan?.SectionID" />
                    <input type="hidden" id="txtSubjectGroupID" value="@Model.EditLessonPlan?.SubjectGroupID" />
                    <input type="hidden" id="txtSubjectID" value="@Model.EditLessonPlan?.SubjectID" />
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Class<span class="text-danger">*</span></label>
                        <select id="ddlClass" class="form-select form-control" onchange="loadSections(this.value);">
                            <option value="">Select Class</option>
                            @foreach (var c in Model.Classes)
                            {
                                <option value="@c.ClassID" selected="@(Model.EditLessonPlan?.ClassID == c.ClassID)">@c.ClassName</option>
                            }
                        </select>
                        <div class="invalid-feedback" id="errDdlClass"></div>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="form-label">Section<span class="text-danger">*</span></label>
                        <select id="ddlSection" class="form-select form-control" onchange="loadSubjectGroups();">
                            <option value="">Select Section</option>
                        </select>
                        <div class="invalid-feedback" id="errDdlSection"></div>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="form-label">Subject Group<span class="text-danger">*</span></label>
                        <select id="ddlSubjectGroup" class="form-select form-control" onchange="loadSubjects(this.value);">
                            <option value="">Select Group</option>
                        </select>
                        <div class="invalid-feedback" id="errDdlSubjectGroup"></div>
                    </div>

                    <div class="col-md-3 mb-3">
                        <label class="form-label">Subject<span class="text-danger">*</span></label>
                        <select id="ddlSubject" class="form-select form-control" onchange="loadExistingLessons()">
                            <option value="">Select Subject</option>
                        </select>
                        <div class="invalid-feedback" id="errDdlSubject"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Lessons Card -->
        <!-- Lessons Card -->
        <div class="card shadow-tbl-outer">
            <div class="card-header d-flex justify-content-between align-items-center flex-wrap">
                <h6 class="card-title mb-0">Lessons</h6>
                <button type="button" onclick="addNewLessonRow()" class="btn btn-primary">
                    <i class="ti ti-plus"></i> Add New
                </button>
            </div>
            <div class="card-body">

                <!-- Column headers — shown ONCE -->
                <div class="row lesson-header mb-2">
                    <div class="col-md-4">
                        <label class="form-label mb-0">Lesson Name<span class="text-danger">*</span></label>
                    </div>
                    <div class="col-md-7">
                        <label class="form-label mb-0">Description</label>
                    </div>
                    <div class="col-md-1"></div>
                </div>

                <div id="lessonRowsContainer" class="lesson-rows-container">
                    @if (existingLessons.Any())
                    {
                        foreach (var lesson in existingLessons)
                        {
                            <div class="lesson-row row align-items-center mb-2" data-lesson-map-id="@lesson.LessonMapId">
                                <input type="hidden" class="lesson-map-id" value="@lesson.LessonMapId" />
                                <input type="hidden" class="lesson-isdelete" value="0" />
                                <div class="col-md-4">
                                    <input type="text" class="form-control lesson-name" value="@lesson.LessonName">
                                    <div class="invalid-feedback"></div>
                                </div>
                                <div class="col-md-7">
                                    <textarea class="form-control lesson-description" rows="1">@lesson.Description</textarea>
                                </div>
                                <div class="col-md-1 d-flex justify-content-center">
                                    <button type="button" class="btn btn-danger btn-sm" onclick="deleteLessonRow(this)">
                                        <i class="ti ti-trash"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="lesson-row row align-items-center mb-2" data-lesson-map-id="0">
                            <input type="hidden" class="lesson-map-id" value="0" />
                            <input type="hidden" class="lesson-isdelete" value="0" />
                            <div class="col-md-4">
                                <input type="text" class="form-control lesson-name">
                                <div class="invalid-feedback"></div>
                            </div>
                            <div class="col-md-7">
                                <textarea class="form-control lesson-description" rows="1"></textarea>
                            </div>
                            <div class="col-md-1 d-flex justify-content-center">
                                <button type="button" class="btn btn-danger btn-sm" onclick="deleteLessonRow(this)">
                                    <i class="ti ti-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

       
    </div>
</div>
<!-- Template used to clone new, blank lesson rows -->
<template id="lessonRowTemplate">
    <div class="lesson-row row align-items-center mb-2" data-lesson-map-id="0">
        <input type="hidden" class="lesson-map-id" value="0" />
        <input type="hidden" class="lesson-isdelete" value="0" />
        <div class="col-md-4">
            <input type="text" class="form-control lesson-name">
            <div class="invalid-feedback"></div>
        </div>
        <div class="col-md-7">
            <textarea class="form-control lesson-description" rows="1"></textarea>
        </div>
        <div class="col-md-1 d-flex justify-content-center">
            <button type="button" class="btn btn-danger btn-sm" onclick="deleteLessonRow(this)">
                <i class="ti ti-trash"></i>
            </button>
        </div>
    </div>
</template>

<style>
    .lesson-header {
        border-bottom: 1px solid #eef0f2;
        padding-bottom: 6px;
    }

    .lesson-row .btn-danger {
        width: 38px;
        height: 38px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

@section Scripts {

    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/assets/js/LessonPlan.js"></script>

    
}
