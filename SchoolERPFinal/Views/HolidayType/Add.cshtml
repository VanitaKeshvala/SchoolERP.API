@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.HolidayTypeAddViewModel
@{
    ViewData["Title"] = "Add Holiday Type";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditHolidayTypes == null ? "Add Holiday Type" : "Edit Holiday Type")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveItem()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/HolidayType/Index" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <input type="hidden" id="txtItemId" value="@(Model.EditHolidayTypes?.HolidayTypeID ?? 0)">
                    <input type="hidden" id="hdnUserID" value="@(Model.EditHolidayTypes?.CreatedBy ?? 0)">

                    <div class="row">

                        <div class="col-md-8 mb-3">
                            <label class="form-label fw-semibold">Holiday Type Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtHolidayTypeName"
                                   value="@Model.EditHolidayTypes?.HolidayTypeName"
                                   placeholder="e.g. 1st Class" autocomplete="off">
                            <div class="invalid-feedback" id="errtxtHolidayTypeName"></div>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">Colour Code</label>
                            <div class="input-group">

                                <!-- Colour picker — clicking the swatch opens the native colour wheel -->
                                <input type="color"
                                       id="colourPicker"
                                       class="form-control form-control-color"
                                       value="@(Model.EditHolidayTypes?.ColourCode ?? "#4361ee")"
                                       oninput="syncColour(this.value)"
                                       style="max-width:48px; padding:3px 4px; cursor:pointer;" />

                                <!-- Hex text box — the actual value saved to DB -->
                                <input type="text"
                                       id="txtColourCode"
                                       class="form-control"
                                       value="@(Model.EditHolidayTypes?.ColourCode ?? "#4361ee")"
                                       maxlength="7"
                                       placeholder="#4361ee"
                                       oninput="syncPicker(this.value)"
                                       style="font-family:monospace;" />

                                <!-- Live preview dot -->
                                <span class="input-group-text" id="colourPreview"
                                      style="background:@(Model.EditHolidayTypes?.ColourCode ?? "#4361ee");
                     width:38px; border-radius:0 6px 6px 0; transition:background .2s;">
                                </span>

                            </div>
                            <div class="form-text text-muted" style="font-size:11px;">
                                Click the colour box to open the picker, or type a hex code like <code>#e63946</code>
                            </div>
                            <div class="invalid-feedback" id="errtxtColourCode"></div>
                        </div>
                        <div class="col-md-2 mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="isActive"
                                @(Model.EditHolidayTypes?.IsActive ?? true ? "checked" : "")>
                                <label class="form-check-label fw-bold" for="isActive">Active</label>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<link href="~/assets/css/select2.min.css" rel="stylesheet" />

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/assets/js/HolidayTypes.js"></script>
}