@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.LibraryDocumentStatusAddViewModel
@{
    ViewData["Title"] = "Add Document Status";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditDocumentStatus == null ? "Add Document Status" : "Edit Document Status")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveItem()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/LibraryDocumentStatus/Index" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <input type="hidden" id="txtItemId" value="@(Model.EditDocumentStatus?.DocumentStatusId ?? 0)">
                    <input type="hidden" id="hdnUserID" value="@(Model.EditDocumentStatus?.CreatedBy ?? 0)">

                    <div class="row">

                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Status Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtStatusName"
                                   value="@Model.EditDocumentStatus?.StatusName"
                                   placeholder="e.g. LBH" autocomplete="off">
                            <div class="invalid-feedback" id="errtxtStatusName"></div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Status Code <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtStatusCode"
                                   value="@Model.EditDocumentStatus?.StatusCode"
                                   placeholder="e.g. LBH" autocomplete="off">
                            <div class="invalid-feedback" id="errtxtStatusCode"></div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-semibold">Display Name</label>
                            <input type="text" class="form-control" id="txtDisplayLabel"
                                   value="@Model.EditDocumentStatus?.DisplayLabel"
                                   placeholder="e.g. LBH" autocomplete="off">
                        </div>
                        
                        <div class="col-md-2 m-2">
                            @* <label class="form-label fw-semibold">Can Be Issued</label> *@
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input" id="chkCanBeIssued" checked="@(Model.EditDocumentStatus?.CanBeIssued == true)" />
                                <label asp-for="@Model.EditDocumentStatus.CanBeIssued" class="form-check-label">
                                    Can Be Issued
                                </label>
                            </div>
                        </div>
                        <div class="col-md-6 m-2">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="isActive"
                                @(Model.EditDocumentStatus?.IsActive ?? true ? "checked" : "")>
                                <label class="form-check-label fw-bold" for="isActive">Active</label>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/assets/js/LibraryDocumentStatus.js"></script>
}