@using System.Security.Claims
@model SchoolERP.Shared.Models.PagePermissions
@{
    Layout = "_Layout";
    ViewData["Title"] = "Generate Staff ID Card";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model;
}
<style>
    .dt-buttons {
    display: none !important;
    }
</style>
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Generate Staff ID Card</h6>
    </div>
    <div>
        @if (p.CanPrint)
        {
            <button type="button" class="btn btn-secondary top-btn" onclick="generateSelectedStaffCards()">
                <i class="ti ti-printer me-1"></i> Generate & Print
            </button>
        }
        
        @if (p.CanExport)
        {
            <div class="dropdown d-inline-flex">
                <button class="btn btn-warning dropdown-toggle top-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(0)"><i class="ti ti-copy me-1"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(1)"><i class="ti ti-file-text me-1"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(2)"><i class="ti ti-file-spreadsheet me-1"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(3)"><i class="ti ti-file-description me-1"></i>PDF</a></li>
                </ul>
            </div>
        }
    </div>
</div>

<div class="card shadow-tbl-outer mb-2">
    <div class="card-body">
        <div class="row">
            <div class="col-md-3">
                <label class="form-label fw-semibold">Department</label>
                <select class="form-select select2" id="genDeptId">
                    <option value="">Select Department</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold">Designation</label>
                <select class="form-select select2" id="genDesigId">
                    <option value="">Select Designation</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold">ID Card Template</label>
                <select class="form-select select2" id="genIDCardId">
                    <option value="">Select Template</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button class="btn btn-info w-100" onclick="searchStaffForGen()">
                    <i class="ti ti-search me-1"></i> Search Staff
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-tbl">
    <div class="card-body">
        <div class="table-responsive" style="max-height: 600px;">
            <table class="table" id="genStaffTable">
                <thead>
                    <tr>
                        <th style="width: 50px;">
                            <input type="checkbox" class="form-check-input" id="selectAllStaff" onchange="toggleAllStaffForGen(this.checked)">
                        </th>
                        <th>Staff Code</th>
                        <th>Staff Name</th>
                        <th>Designation</th>
                        <th>Department</th>
                        <th>Mobile No</th>
                    </tr>
                </thead>
                <tbody id="genStaffList">
                    
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>

        function triggerExport(index) {
            if ($.fn.DataTable.isDataTable('#genStaffTable')) {
                const table = $('#genStaffTable').DataTable();
            table.button(index).trigger();
        }
    }

$(document).ready(function () {
            $('#genStaffTable').DataTable({
            dom: 'Bfrtip',
            buttons: [
                { extend: 'copy', exportOptions: { columns: [1, 2, 3, 4, 5] } },
                    { extend: 'csv', exportOptions: { columns: [1, 2, 3, 4, 5] } },
                    { extend: 'excel', exportOptions: { columns: [1, 2, 3, 4, 5] } },
                    { extend: 'pdf', exportOptions: { columns: [1, 2, 3, 4, 5] } },
                    { extend: 'print', exportOptions: { columns: [1, 2, 3, 4, 5] } }
            ],
            searching: false,
            paging: false,
            info: false,
                language: {
                    emptyTable: "Please select filters and search to see staff members."
                }
        });
})

        var selectedIDCardId = 0;
        var deptMapping = {};
        var desigMapping = {};

        window.loadFiltersForGen = function () {
            $.get('/Certificate/GetAllDepartments', function (resp) {
                if (resp.success) {
                    var html = '<option value="">Select Department</option>';
                    resp.data.forEach(function(item) {
                        deptMapping[item.departmentID] = item.departmentName;
                        html += '<option value="' + item.departmentName + '">' + item.departmentName + '</option>';
                    });
                    $('#genDeptId').html(html).trigger('change');
                }
            });
            $.get('/Certificate/GetAllDesignations', function (resp) {
                if (resp.success) {
                    var html = '<option value="">Select Designation</option>';
                    resp.data.forEach(function(item) {
                        desigMapping[item.hrDesignationID] = item.designationName;
                        html += '<option value="' + item.designationName + '">' + item.designationName + '</option>';
                    });
                    $('#genDesigId').html(html).trigger('change');
                }
            });
        };

        window.loadTemplatesForGen = function () {
            $.get('/Certificate/GetAllStaffIDCards', function (resp) {
                if (resp.success) {
                    var html = '<option value="">Select Template</option>';
                    resp.data.forEach(function(item) {
                        if (item.isActive) {
                            html += '<option value="' + item.idCardID + '">' + item.idCardTitle + '</option>';
                        }
                    });
                    $('#genIDCardId').html(html).trigger('change');
                }
            });
        };

      window.searchStaffForGen = function () {

    var deptId = $('#genDeptId').val();
    var desigId = $('#genDesigId').val();

    $.get('/Certificate/GetAllStaff', { isActive: true }, function (resp) {

        var table = $('#genStaffTable').DataTable();

        // CLEAR TABLE
        table.clear();

        if (resp.success) {

            var data = resp.data || [];

            // FILTERS
            if (deptId) {
                data = data.filter(x =>
                    (x.departmentName || x.DepartmentName) == deptId
                );
            }

            if (desigId) {
                data = data.filter(x =>
                    (x.designationName || x.DesignationName) == desigId
                );
            }

            // ADD ROWS
            data.forEach(function(item) {

                var sId = item.staffId || item.staffID || item.StaffID;
                var sCode = item.staffCode || item.StaffCode || '';
                var fName = item.firstName || item.FirstName || '';
                var lName = item.lastName || item.LastName || '';

                var dName =
                    item.designationName ||
                    item.DesignationName ||
                    desigMapping[
                        item.designationId ||
                        item.designationID ||
                        item.DesignationID
                    ] || '';

                var deptName =
                    item.departmentName ||
                    item.DepartmentName ||
                    deptMapping[
                        item.departmentId ||
                        item.departmentID ||
                        item.DepartmentID
                    ] || '';

                var mob = item.mobileNo || item.MobileNo || '';

                table.row.add([
                    '<input type="checkbox" class="form-check-input gen-staff-check" value="' + sId + '">',
                    sCode,
                    fName + ' ' + lName,
                    dName,
                    deptName,
                    mob
                ]);
            });

            // REFRESH DATATABLE
            table.draw();

        } else {

            table.draw();
            alert(resp.message || 'Error loading staff.');

        }

    }).fail(function(xhr) {

        console.error(xhr);
        alert('Failed to fetch staff data.');

    });

};

        window.toggleAllStaffForGen = function (c) { $('.gen-staff-check').prop('checked', c); };

        window.generateSelectedStaffCards = async function () {
            var templateId = $('#genIDCardId').val();
            if (!templateId) { alert('Please select a template.'); return; }
            var sIds = [];
            $('.gen-staff-check:checked').each(function() { sIds.push($(this).val()); });
            if (sIds.length === 0) { alert('Please select at least one staff member.'); return; }

            var $btn = $('button[onclick="generateSelectedStaffCards()"]');
            var originalBtnHtml = $btn.html();
            $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span>Generating...');

            try {
                var tResp = await $.get('/Certificate/GetStaffIDCardByID?id=' + templateId);
                if (!tResp.success || !tResp.data) {
                    alert('Failed to load template.');
                    return;
                }

                var template = tResp.data;
                var fullHtml = '<div class="id-card-print-container">';
                
                for (var i = 0; i < sIds.length; i++) {
                    var sResp = await $.get('/Certificate/GetStaffByID?id=' + sIds[i]);
                    if (sResp.success) {
                        fullHtml += createStaffCardHtml(sResp.data, template);
                    }
                }
                fullHtml += '</div>';

                if (fullHtml) {
                    var pw = window.open('', '_blank');
                    pw.document.write('<html><head><title>Print Staff ID Cards</title>');
                    pw.document.write('<style>');
                    pw.document.write('body { margin: 0; padding: 20px; font-family: sans-serif; background: #f0f0f0; }');
                    pw.document.write('.id-card-print-container { display: flex; flex-wrap: wrap; gap: 20px; justify-content: center; }');
                    
                    // Horizontal Base
                    pw.document.write('.id-card-horiz { width: 350px; min-height: 220px; height: auto; background: #fff; border-radius: 10px; overflow: hidden; position: relative; box-shadow: 0 4px 8px rgba(0,0,0,0.1); border: 1px solid #ddd; background-size: cover; background-position: center; page-break-inside: avoid; padding-bottom: 40px; }');
                    pw.document.write('.id-card-horiz .id-card-header { padding: 10px; display: flex; align-items: center; gap: 10px; color: #fff; }');
                    pw.document.write('.id-card-horiz .id-card-logo { width: 40px; height: 40px; border-radius: 50%; background: #fff; padding: 2px; }');
                    pw.document.write('.id-card-horiz .id-card-school { flex: 1; font-size: 14px; font-weight: bold; line-height: 1.2; }');
                    pw.document.write('.id-card-horiz .id-card-body { padding: 10px; display: flex; gap: 10px; }');
                    pw.document.write('.id-card-horiz .id-card-photo { width: 80px; height: 100px; border: 2px solid #eee; background: #f9f9f9; display: flex; align-items: center; justify-content: center; overflow: hidden; }');
                    pw.document.write('.id-card-horiz .id-card-photo img { width: 100%; height: 100%; object-fit: cover; }');
                    pw.document.write('.id-card-horiz .id-card-info { flex: 1; font-size: 11px; line-height: 1.4; }');
                    searchStaffForGen()
                    // Vertical Base
                    pw.document.write('.id-card-vert { width: 240px; min-height: 380px; height: auto; background: #fff; border-radius: 10px; overflow: hidden; position: relative; box-shadow: 0 4px 8px rgba(0,0,0,0.1); border: 1px solid #ddd; background-size: cover; background-position: center; page-break-inside: avoid; padding-bottom: 40px; }');
                    pw.document.write('.id-card-vert .id-card-header { padding: 15px 10px; text-align: center; color: #fff; }');
                    pw.document.write('.id-card-vert .id-card-logo { width: 50px; height: 50px; border-radius: 50%; background: #fff; padding: 2px; margin-bottom: 5px; }');
                    pw.document.write('.id-card-vert .id-card-school { font-size: 14px; font-weight: bold; line-height: 1.2; }');
                    pw.document.write('.id-card-vert .id-card-body { padding: 10px; text-align: center; }');
                    pw.document.write('.id-card-vert .id-card-photo { width: 90px; height: 110px; border: 2px solid #eee; background: #f9f9f9; display: flex; align-items: center; justify-content: center; overflow: hidden; margin: 0 auto 10px; }');
                    pw.document.write('.id-card-vert .id-card-photo img { width: 100%; height: 100%; object-fit: cover; }');
                    pw.document.write('.id-card-vert .id-card-info { font-size: 11px; line-height: 1.5; text-align: left; margin-top: 5px; }');

                    pw.document.write('.info-row { display: flex; margin-bottom: 2px; } .info-label { width: 80px; font-weight: bold; color: #555; } .info-val { flex: 1; color: #000; }');
                    pw.document.write('.id-card-footer { position: absolute; bottom: 0; width: 100%; padding: 5px 10px; font-size: 9px; color: #666; border-top: 1px solid #eee; background: rgba(255,255,255,0.8); display: flex; align-items: center; justify-content: space-between; }');
                    pw.document.write('.signature-img { height: 30px; max-width: 80px; object-fit: contain; }');
                    pw.document.write('@@media print { body { background: #fff; padding: 0; } .id-card-print-container { gap: 10px; } .id-card-horiz, .id-card-vert { box-shadow: none; border: 1px solid #000; -webkit-print-color-adjust: exact; print-color-adjust: exact; } }');
                    pw.document.write('<\/style><\/head><body>');
                    pw.document.write(fullHtml);
                    pw.document.write('<script>window.onload = function() { setTimeout(function() { window.print(); window.close(); }, 500); };<\/script>');
                    pw.document.write('<\/body><\/html>');
                    pw.document.close();
                }
            } catch (e) { 
                console.error(e);
                alert('Error generating ID cards.'); 
            } finally {
                $btn.prop('disabled', false).html(originalBtnHtml);
            }
        };

        function createStaffCardHtml(staff, template) {
            var bg = template.backgroundImageBase64 ? 'url(' + template.backgroundImageBase64 + ')' : 'none';
            var logo = template.logoImageBase64 ? '<img src="' + template.logoImageBase64 + '" class="id-card-logo" />' : '';
            var signature = template.signatureImageBase64 ? '<img src="' + template.signatureImageBase64 + '" class="signature-img" />' : '';
            
            var photo = '';
            if (staff.photoDoc) {
                photo = '<img src="data:' + (staff.photoDocType || 'image/png') + ';base64,' + staff.photoDoc + '" />';
            }

            var isVertical = template.designType == 2;
            var cardClass = isVertical ? 'id-card-vert' : 'id-card-horiz';
            
            var html = '<div class="' + cardClass + '" style="background-image:' + bg + '">';
            
            // Header
            html += '<div class="id-card-header" style="background-color:' + (template.headerColor || '#28a745') + '">';
            if (isVertical) {
                html += logo + '<div class="id-card-school">' + (template.schoolName || 'SCHOOL NAME') + '</div>';
                html += '<div style="font-size:10px; font-weight:normal; opacity:0.9;">Staff ID Card</div>';
            } else {
                html += logo + '<div class="id-card-school">' + (template.schoolName || 'SCHOOL NAME') + '<div style="font-size:10px; font-weight:normal; opacity:0.9;">Staff ID Card</div></div>';
            }
            html += '</div>';

            // Body
            html += '<div class="id-card-body">';
            html += '<div class="id-card-photo">' + (photo || '<i class="ti ti-user" style="font-size:40px; color:#ccc;"></i>') + '</div>';
            html += '<div class="id-card-info">';
            
            if (template.showStaffName) html += '<div class="info-row" style="font-size:13px; font-weight:bold; margin-bottom:5px;"><div class="info-val">' + (staff.firstName || '') + ' ' + (staff.lastName || '') + '</div></div>';
            
            var dName = staff.designationName || staff.DesignationName || desigMapping[staff.designationId || staff.designationID || staff.DesignationID] || '';
            var deptName = staff.departmentName || staff.DepartmentName || deptMapping[staff.departmentId || staff.departmentID || staff.DepartmentID] || '';

            if (template.showDesignation) html += '<div class="info-row"><div class="info-label">Designation:</div><div class="info-val">' + dName + '</div></div>';
            if (template.showStaffID) html += '<div class="info-row"><div class="info-label">Staff ID:</div><div class="info-val">' + (staff.staffCode || '') + '</div></div>';
            if (template.showDepartment) html += '<div class="info-row"><div class="info-label">Dept:</div><div class="info-val">' + deptName + '</div></div>';
            if (template.showDOJ) html += '<div class="info-row"><div class="info-label">DOJ:</div><div class="info-val">' + (staff.doj ? new Date(staff.doj).toLocaleDateString() : '') + '</div></div>';
            if (template.showBloodGroup) html += '<div class="info-row"><div class="info-label">Blood:</div><div class="info-val">---</div></div>'; // Assuming not in staff model yet or adding if available
            if (template.showPhone) html += '<div class="info-row"><div class="info-label">Phone:</div><div class="info-val">' + (staff.mobileNo || '') + '</div></div>';
            if (template.showStaffAddress) {
                html += '<div class="info-row"><div class="info-label">Address:</div><div class="info-val" style="font-size:9px;">' + (staff.currentAddress || '') + '</div></div>';
            }

            html += '</div></div>';

            // Footer
            html += '<div class="id-card-footer">';
            html += '<div style="flex:1; max-height: 30px; overflow: hidden;">' + (template.addressPhoneEmail || '') + '</div>';
            if (signature) {
                html += '<div class="signature-box" style="text-align:right;">' + signature + '<div style="font-size:7px; margin-top:2px;">Auth. Signature</div></div>';
            }
            html += '</div>';

            html += '</div>';
            return html;
        }

        $(function () {
            if ($.fn.select2) $('.select2').select2({ width: '100%' });
            loadFiltersForGen();
            loadTemplatesForGen();
        });
    </script>
}
