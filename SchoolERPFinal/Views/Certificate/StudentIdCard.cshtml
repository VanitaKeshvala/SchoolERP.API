@model SchoolERP.Shared.Models.StudentIDCardPageViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "Student ID Card";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;
}

<style>
    .dt-buttons { display: none !important; }
</style>

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">Student ID Card Management</h6>
    </div>

    <div class="d-flex flex-wrap align-items-center gap-1">
        @if(p.CanAdd)
        {
            <button class="btn btn-primary top-btn" onclick="openAddModal()"><i class="ti ti-plus me-1"></i>Add</button>
        }
        @if (p.CanEdit)
        {
            <button id="btnEdit" class="btn btn-info top-btn" disabled onclick="editSelected()"><i class="ti ti-pencil me-1"></i>Edit</button>
        }
        @if (p.CanDelete)
        {
            <button id="btnDelete" class="btn btn-danger top-btn" disabled onclick="deleteSelected()"><i class="ti ti-trash me-1"></i>Delete</button>
        }       
        @if (p.CanPrint)
        {
            <button class="btn btn-secondary d-inline-flex align-items-center top-btn" onclick="triggerExport(4)">
                <i class="ti ti-printer me-1"></i>Print
            </button>
        }
        @if (p.CanExport)
        {
            <div class="dropdown d-inline-flex">
                <button class="btn btn-warning dropdown-toggle top-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="ti ti-download me-1"></i>Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(0)"><i class="ti ti-copy me-1"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(1)"><i class="ti ti-file-text me-1"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(2)"><i class="ti ti-file-spreadsheet me-1"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport(3)"><i class="ti ti-file-description me-1"></i>PDF</a></li>
                </ul>
            </div>
        }

    </div>
</div>

<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table" id="idCardTable">
                        <thead>
                            <tr>
                                <th style="width: 50px;">Select</th>
                                <th>ID Card Title</th>
                                <th>Background Image</th>
                                <th>Design Type</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.IDCards != null && Model.IDCards.Any())
                            {
                                foreach (var item in Model.IDCards)
                                {
                                    <tr class="item-row" onclick="selectItem(@item.IDCardID, this)" style="cursor: pointer;">
                                        <td class="text-center">
                                            <input type="checkbox" name="selectedIDCard" class="form-check-input student-checkbox" value="@item.IDCardID">
                                        </td>
                                        <td>@item.IDCardTitle</td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.BackgroundImageBase64))
                                            {
                                                <img src="@item.BackgroundImageBase64" style="width:50px;height:50px;" class="rounded border" alt="Background" />
                                            }
                                            else
                                            {
                                                <span class="text-muted small">No Image</span>
                                            }
                                        </td>
                                        <td>@(item.DesignType == 1 ? "Horizontal" : "Vertical")</td>
                                        <td class="text-center" onclick="event.stopPropagation()">
                                            <div class="form-check form-switch d-flex justify-content-center">
                                                <input class="form-check-input" type="checkbox" @(item.IsActive ? "checked" : "") onclick="toggleStatus(@item.IDCardID, this.checked)">
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">No ID card templates found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!----Upsert Modal----->
<div class="modal fade" id="upsertModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header d-flex align-items-center">
                <h5 class="modal-title fw-bold mb-0" id="modalTitle">Add Student ID Card</h5>
                <div class="ms-auto d-flex align-items-center gap-1">
                    <button type="button" class="btn btn-success" onclick="saveIDCard()">
                        <i class="ti ti-cloud me-1"></i> Save
                    </button>
                    <button type="button" class="btn btn-danger ms-1" data-bs-dismiss="modal" aria-label="Close">
                        <i class="ti ti-x me-1"></i> Close
                    </button>
                </div>
            </div>
            <div class="modal-body p-4">
                <form id="upsertForm" class="row g-3">
                    <input type="hidden" id="IDCardID" name="IDCardID" value="0" />
                    
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">ID Card Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="IDCardTitle" name="IDCardTitle" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">School Name</label>
                        <input type="text" class="form-control" id="SchoolName" name="SchoolName">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Header Color</label>
                        <input type="color" class="form-control" id="HeaderColor" name="HeaderColor" value="#000000">
                    </div>

                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold">Design Type</label>
                        <select class="form-select" id="DesignType" name="DesignType">
                            <option value="1">Horizontal</option>
                            <option value="2">Vertical</option>
                        </select>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label fw-semibold">Address / Phone / Email <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="AddressPhoneEmail" name="AddressPhoneEmail" rows="2"></textarea>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Background Image</label>
                        <input type="file" class="form-control" id="BackgroundImageFile" onchange="handleImageUpload(this, 'BackgroundImage')">
                        <input type="hidden" id="BackgroundImage" name="BackgroundImage">
                        <input type="hidden" id="BackgroundImageType" name="BackgroundImageType">
                        <input type="hidden" id="BackgroundImageName" name="BackgroundImageName">
                        <div id="preview_BackgroundImage" class="mt-2 d-none">
                            <img src="" width="80" class="rounded border" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Logo</label>
                        <input type="file" class="form-control" id="LogoImageFile" onchange="handleImageUpload(this, 'LogoImage')">
                        <input type="hidden" id="LogoImage" name="LogoImage">
                        <input type="hidden" id="LogoImageType" name="LogoImageType">
                        <input type="hidden" id="LogoImageName" name="LogoImageName">
                        <div id="preview_LogoImage" class="mt-2 d-none">
                            <img src="" width="80" class="rounded border" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Signature</label>
                        <input type="file" class="form-control" id="SignatureImageFile" onchange="handleImageUpload(this, 'SignatureImage')">
                        <input type="hidden" id="SignatureImage" name="SignatureImage">
                        <input type="hidden" id="SignatureImageType" name="SignatureImageType">
                        <input type="hidden" id="SignatureImageName" name="SignatureImageName">
                        <div id="preview_SignatureImage" class="mt-2 d-none">
                            <img src="" width="80" class="rounded border" />
                        </div>
                    </div>

                    <div class="col-md-12 mt-4">
                        <h6 class="fw-bold border-bottom pb-2">Visibility Toggles</h6>
                        <div class="row">
                            <div class="col-md-3 mb-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="ShowAdmissionNo" name="ShowAdmissionNo" checked>
                                    <label class="form-check-label" for="ShowAdmissionNo">Admission No</label>
                                </div>
                            </div>
                            <div class="col-md-3 mb-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="ShowStudentName" name="ShowStudentName" checked>
                                    <label class="form-check-label" for="ShowStudentName">Student Name</label>
                                </div>
                            </div>
                            <div class="col-md-3 mb-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="ShowClass" name="ShowClass" checked>
                                    <label class="form-check-label" for="ShowClass">Class</label>
                                </div>
                            </div>
                            <div class="col-md-3 mb-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="ShowFatherName" name="ShowFatherName" checked>
                                    <label class="form-check-label" for="ShowFatherName">Father Name</label>
                                </div>
                            </div>
                            <div class="col-md-3 mb-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="ShowMotherName" name="ShowMotherName" checked>
                                    <label class="form-check-label" for="ShowMotherName">Mother Name</label>
                                </div>
                            </div>
                            <div class="col-md-3 mb-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="ShowStudentAddress" name="ShowStudentAddress" checked>
                                    <label class="form-check-label" for="ShowStudentAddress">Student Address</label>
                                </div>
                            </div>
                            <div class="col-md-3 mb-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="ShowPhone" name="ShowPhone" checked>
                                    <label class="form-check-label" for="ShowPhone">Phone</label>
                                </div>
                            </div>
                            <div class="col-md-3 mb-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="ShowDOB" name="ShowDOB" checked>
                                    <label class="form-check-label" for="ShowDOB">Date of Birth</label>
                                </div>
                            </div>
                            <div class="col-md-3 mb-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="ShowBloodGroup" name="ShowBloodGroup" checked>
                                    <label class="form-check-label" for="ShowBloodGroup">Blood Group</label>
                                </div>
                            </div>
                            <div class="col-md-3 mb-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="ShowBarcode" name="ShowBarcode" checked>
                                    <label class="form-check-label" for="ShowBarcode">Bar Code</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>

        function triggerExport(index) {
            if ($.fn.DataTable.isDataTable('#idCardTable')) {
                const table = $('#idCardTable').DataTable();
                table.button(index).trigger();
            }
        }
        let table;

        $(document).ready(function () {
            table = $('#idCardTable').DataTable({
                dom: 'Bfrtip',
                buttons: [
                    { extend: 'copy', exportOptions: { columns: [1, 2, 3] } },
                    { extend: 'csv', exportOptions: { columns: [1, 2, 3] } },
                    { extend: 'excel', exportOptions: { columns: [1, 2, 3] } },
                    { extend: 'pdf', exportOptions: { columns: [1, 2, 3] } },
                    { extend: 'print', exportOptions: { columns: [1, 2, 3] } }
                ],
                searching: false,
                paging: false,
                info: false
            });
        })

        var selectedIDCardId = 0;

        window.selectItem = function(id, row) {
            selectedIDCardId = id;
            document.querySelectorAll('#idCardTable tbody .item-row').forEach(r => r.classList.remove('bg-light'));
            row.classList.add('bg-light');
            
            
            document.getElementById('btnEdit').disabled = false;
            document.getElementById('btnDelete').disabled = false;
                    let checkedCount = $('.student-checkbox:checked').length;
        $('#btnDelete').prop('disabled', checkedCount === 0);
        // Edit sirf 1 record select hone par
        $('#btnEdit').prop('disabled', checkedCount !== 1);
        };

        window.openAddModal = function() {
            $('#upsertForm')[0].reset();
            $('#IDCardID').val(0);
            $('#modalTitle').text('Add Student ID Card');
            
            ['BackgroundImage', 'LogoImage', 'SignatureImage'].forEach(field => {
                $('#preview_' + field).addClass('d-none').find('img').attr('src', '');
                $('#' + field).val('');
                $('#' + field + 'Type').val('');
                $('#' + field + 'Name').val('');
            });

            $('#upsertModal').modal('show');
        };

        window.editSelected = function() {
            if (selectedIDCardId === 0) return;
            editIDCard(selectedIDCardId);
        };

        window.deleteSelected = function() {
            if (selectedIDCardId === 0) return;
            deleteIDCard(selectedIDCardId);
        };

        window.handleImageUpload = function(input, prefix) {
            if (input.files && input.files[0]) {
                const file = input.files[0];
                const reader = new FileReader();
                reader.onload = function (e) {
                    const base64 = e.target.result;
                    const parts = base64.split(',');
                    $('#' + prefix).val(parts[1]);
                    $('#' + prefix + 'Type').val(parts[0].split(':')[1].split(';')[0]);
                    $('#' + prefix + 'Name').val(file.name);
                    
                    $('#preview_' + prefix).removeClass('d-none').find('img').attr('src', base64);
                };
                reader.readAsDataURL(file);
            }
        };

        window.saveIDCard = function() {
            var data = {
                IDCardID: parseInt($('#IDCardID').val()) || 0,
                IDCardTitle: $('#IDCardTitle').val(),
                SchoolName: $('#SchoolName').val(),
                HeaderColor: $('#HeaderColor').val(),
                AddressPhoneEmail: $('#AddressPhoneEmail').val(),
                
                BackgroundImage: $('#BackgroundImage').val(),
                BackgroundImageType: $('#BackgroundImageType').val(),
                BackgroundImageName: $('#BackgroundImageName').val(),
                
                LogoImage: $('#LogoImage').val(),
                LogoImageType: $('#LogoImageType').val(),
                LogoImageName: $('#LogoImageName').val(),
                
                SignatureImage: $('#SignatureImage').val(),
                SignatureImageType: $('#SignatureImageType').val(),
                SignatureImageName: $('#SignatureImageName').val(),
                
                ShowAdmissionNo: $('#ShowAdmissionNo').is(':checked'),
                ShowStudentName: $('#ShowStudentName').is(':checked'),
                ShowClass: $('#ShowClass').is(':checked'),
                ShowFatherName: $('#ShowFatherName').is(':checked'),
                ShowMotherName: $('#ShowMotherName').is(':checked'),
                ShowStudentAddress: $('#ShowStudentAddress').is(':checked'),
                ShowPhone: $('#ShowPhone').is(':checked'),
                ShowDOB: $('#ShowDOB').is(':checked'),
                ShowBloodGroup: $('#ShowBloodGroup').is(':checked'),
                DesignType: parseInt($('#DesignType').val()) || 1,
                ShowBarcode: $('#ShowBarcode').is(':checked'),
                
                IsActive: true
            };

            if (!data.IDCardTitle || !data.AddressPhoneEmail) {
                alert('Please fill all mandatory fields.');
                return;
            }

            $.ajax({
                url: '/Certificate/UpsertStudentIDCard',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(data),
                success: function (resp) {
                    if (resp.success) {
                        location.reload();
                    } else {
                        alert(resp.message);
                    }
                },
                error: function() {
                    alert('Error saving ID Card template.');
                }
            });
        };

        window.editIDCard = function(id) {
            $.get('/Certificate/GetStudentIDCardByID?id=' + id, function (resp) {
                if (resp.success) {
                    var data = resp.data;
                    $('#IDCardID').val(data.idCardID);
                    $('#IDCardTitle').val(data.idCardTitle);
                    $('#SchoolName').val(data.schoolName);
                    $('#HeaderColor').val(data.headerColor || '#000000');
                    $('#AddressPhoneEmail').val(data.addressPhoneEmail);
                    
                    $('#ShowAdmissionNo').prop('checked', data.showAdmissionNo);
                    $('#ShowStudentName').prop('checked', data.showStudentName);
                    $('#ShowClass').prop('checked', data.showClass);
                    $('#ShowFatherName').prop('checked', data.showFatherName);
                    $('#ShowMotherName').prop('checked', data.showMotherName);
                    $('#ShowStudentAddress').prop('checked', data.showStudentAddress);
                    $('#ShowPhone').prop('checked', data.showPhone);
                    $('#ShowDOB').prop('checked', data.showDOB);
                    $('#ShowBloodGroup').prop('checked', data.showBloodGroup);
                    $('#DesignType').val(data.designType);
                    $('#ShowBarcode').prop('checked', data.showBarcode);

                    if (data.backgroundImageBase64) {
                        $('#preview_BackgroundImage').removeClass('d-none').find('img').attr('src', data.backgroundImageBase64);
                    } else {
                        $('#preview_BackgroundImage').addClass('d-none');
                    }
                    if (data.logoImageBase64) {
                        $('#preview_LogoImage').removeClass('d-none').find('img').attr('src', data.logoImageBase64);
                    } else {
                        $('#preview_LogoImage').addClass('d-none');
                    }
                    if (data.signatureImageBase64) {
                        $('#preview_SignatureImage').removeClass('d-none').find('img').attr('src', data.signatureImageBase64);
                    } else {
                        $('#preview_SignatureImage').addClass('d-none');
                    }

                    $('#modalTitle').text('Edit Student ID Card');
                    $('#upsertModal').modal('show');
                }
            });
        };

        window.toggleStatus = function(id, isActive) {
            $.post('/Certificate/ToggleStudentIDCardStatus?id=' + id + '&isActive=' + isActive, function (resp) {
                if (!resp.success) alert(resp.message);
            });
        };

        window.deleteIDCard = function(id) {

                   let selectedIds = [];
        $('.student-checkbox:checked').each(function () {
                 selectedIds.push(parseInt($(this).val()));
             });
        if (selectedIds.length === 0) {
                 alert("Please select at least one student.");
                 return;
             }
         Swal.fire({
             title: 'Are you sure?',
             text: "You are about to delete this student record. This action cannot be undone!",
             icon: 'warning',
             showCancelButton: true,
             confirmButtonColor: '#d33',
             cancelButtonColor: '#3085d6',
             confirmButtonText: 'Yes, delete it!',
             customClass: {
                 confirmButton: 'btn btn-danger me-2',
                 cancelButton: 'btn btn-secondary'
             },
             buttonsStyling: false
         }).then((result) => {
             if (result.isConfirmed) {
                 $.ajax({
                      url: '/Certificate/DeleteStudentIDCard',
                     type: 'POST',
                     contentType: 'application/json',
                     data: JSON.stringify(selectedIds),
                     success: function (res) {
                         if (res.success) {
                             Swal.fire('Deleted!', 'Student record has been deleted.', 'success')
                                 .then(() => location.reload());
                         } else {
                             Swal.fire('Error!', res.message || 'Failed to delete student.', 'error');
                         }
                     },
                     error: function () {
                         Swal.fire('Error!', 'An unexpected error occurred.', 'error');
                     }
                 });
             }
         });

               };

    </script>
}
