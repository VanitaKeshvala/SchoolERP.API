@model SchoolERP.Shared.Models.MstSectionViewModel
@using System.Security.Claims
@using System.Text.Json
@using SchoolERP.Net.Helpers
@inject PermissionHelper PermHelper
@{
    Layout = "_Layout";
    ViewData["Title"] = Model.EditSections == null ? "Add Section Management" : "Edit Section Management";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }

    if (currentUserId > 0)
        PermHelper.LoadPermissions(currentUserId);
    var canAdd = PermHelper.HasPermissionByUrl("/Section", "Add");
    var canEdit = PermHelper.HasPermissionByUrl("/Section", "Edit");
    var canDelete = PermHelper.HasPermissionByUrl("/Section", "Delete");
    var canPrint = PermHelper.HasPermissionByUrl("/Section", "Print");
    var canExport = PermHelper.HasPermissionByUrl("/Section", "Export");
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditSections == null ? "Add Section" : "Edit Section")</h6>
    </div>
    <div class="d-flex align-items-center gap-2">

        <button type="button" class="btn btn-success top-btn" id="btnSave" onclick="saveItem()">
            <i class="ti ti-cloud me-1"></i>Save
        </button>
        <a href="/Section/Index" class="btn btn-sm btn-info d-inline-flex align-items-center top-btn">
            <i class="ti ti-arrow-narrow-left me-1"></i>Back
        </a>
    </div>
</div>
<!-- End Page Header -->

<form id="itemForm">
    <div class="row">
        <div class="col-xl-12">
            <div class="card shadow-tbl-outer">
                <div class="card-body">
                    <div class="row">
                        <input type="hidden" id="txtItemId" value="@(Model.EditSections?.SectionID ?? 0)">
                        <input type="hidden" id="hdnUserID" value="@(Model.EditSections?.CreatedBy ?? 0)">

                        <div class="col-md-8">
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Section Name <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="txtSectionName" placeholder="e.g. Section A" value="@Model.EditSections?.SectionName" autocomplete="off">
                                <div class="invalid-feedback" id="errTxtSectionName"></div>
                            </div>
                        </div>
                        <div class="col-md-4 mt-4">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="isActive" @(Model.EditSections?.IsActive == true ? "checked" : "")>
                                <label class="form-check-label fw-bold" for="isActive">Active</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>   
</form>
<!-- start row -->
@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(canAdd);
        window.canEdit = @JsonSerializer.Serialize(canEdit);
        window.canDelete = @JsonSerializer.Serialize(canDelete);
    </script>
    <script src="~/assets/js/Section.js"></script>
}