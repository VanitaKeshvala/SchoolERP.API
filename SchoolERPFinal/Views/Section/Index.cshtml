@*
    ======================================================================
    VIEW: Section / Index.cshtml
    PURPOSE: User interface rendering for the Section Management module.
    ======================================================================
*@
@model SchoolERP.Shared.Models.MstSectionPageViewModel
@using System.Security.Claims
@using System.Text.Json
@{
    Layout = "_Layout";
    ViewData["Title"] = "Section Management";
    int currentUserId = 0;
    if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        var idClaim = User.FindFirst(ClaimTypes.NameIdentifier) ?? User.FindFirst("UserId");
        if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
    }
    var p = Model.Permissions;
    int totalPages = Model.PageSize > 0
                  ? (int)Math.Ceiling((double)Model.TotalRecords / Model.PageSize)
                  : 0;
}

<style>
    .dt-buttons { display: none !important; }
</style>

<div class="d-flex align-items-center justify-content-between flex-wrap gap-1 mb-2 p-2 page-sticky-header">
    <div>
        <h6 class="fw-bold mb-0">Sections</h6>
    </div>
    <div class="d-flex flex-wrap align-items-center gap-1 responsive-btn-group">
        @if (p.CanAdd)
        {
            <a asp-action="Add" class="btn btn-primary top-btn">
                <i class="ti ti-plus me-1"></i>Add
            </a>
        }
        @if (p.CanEdit)
        {
            <button id="btnEdit" class="btn btn-info top-btn" disabled onclick="editSelected()">
                <i class="ti ti-pencil me-1"></i>Edit
            </button>
        }
        @if (p.CanDelete)
        {
            <button id="btnDelete" class="btn btn-danger top-btn" disabled onclick="deleteSelected()">
                <i class="ti ti-trash me-1"></i>Delete
            </button>
        }
        @if (p.CanEdit)
        {
            <button id="btnActive" class="btn btn-success top-btn" disabled onclick="toggleStatus(0,true)">
                <i class="ti ti-circle-check"></i> Active
            </button>
            <button id="btnInactive" class="btn btn-danger top-btn" disabled onclick="toggleStatus(0,false)">
                <i class="ti ti-circle-x"></i> Inactive
            </button>
        }
        @if (p.CanPrint)
        {
            <button class="btn btn-secondary d-inline-flex align-items-center shadow-sm top-btn" onclick="triggerExport('print')">
                <i class="ti ti-printer me-1"></i> Print
            </button>
        }
        @if (p.CanAdd)
        {
            <button id="btnCopy" class="btn btn-primary top-btn" disabled
            onclick="openCopyModal()">
                <i class="ti ti-copy me-1"></i>Copy
            </button>
        }
        @if (p.CanExport)
        {
            <div class="dropdown d-inline-block">
                <button class="btn btn-warning dropdown-toggle d-inline-flex align-items-center shadow-sm top-btn" type="button" data-bs-toggle="dropdown">
                    <i class="ti ti-download me-1"></i> Export
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport('copy')"><i class="ti ti-copy me-2"></i>Copy</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport('csv')"><i class="ti ti-file-text me-2"></i>CSV</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport('excel')"><i class="ti ti-file-spreadsheet me-2"></i>Excel</a></li>
                    <li><a class="dropdown-item" href="javascript:void(0)" onclick="triggerExport('pdf')"><i class="ti ti-file-description me-2"></i>PDF</a></li>
                </ul>
            </div>
        }
    </div>
</div>

<div class="row">

    <div class="col-xl-12">
        <div class="card mb-2 shadow-tbl-outer">
            <div class="card-body p-3">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">

                    <!-- ── Search box (name="search" so form submits it) ── -->
                    <div class="position-relative border d-flex align-items-center rounded-2 px-3 bg-white flex-grow-1 search-box-wrap" style="max-width:420px;">
                        <i class="fas fa-search search-icon-input"></i>
                        <input type="text"
                               name="search"
                               id="txtSearchInput"
                               value="@Model.SearchTerm"
                               class="form-control border-0 ps-2 search-input-responsive"
                               placeholder="Search by Section, description..." />
                    </div>

                    <!-- Hidden form for filter submission — outside Bootstrap dropdown -->
                    <form method="get" asp-action="Index" id="frmSearch" style="display:none;">
                        <input type="hidden" name="pageIndex" id="hdnPageIndex" value="1" />
                        <input type="hidden" name="search" id="hdnSearch" value="@Model.SearchTerm" />
                        <input type="hidden" name="sessionID" id="hdnSessionID" value="" />
                        <input type="hidden" name="companyId" id="hdnCompanyId" value="" />
                        <input type="hidden" name="pageSize" id="hdnPageSize" value="@Model.PageSize" />
                    </form>

                    <div class="dropdown">
                        <a href="#" id="btnFilterToggle"
                           class="btn btn-white border rounded btn-md text-dark fs-14 align-items-center d-flex fw-normal"
                           data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            <i class="ti ti-filter text-gray-5 me-1"></i>Filters
                        </a>

                        <div class="dropdown-menu dropdown-lg dropdown-menu-end filter-dropdown p-0 shadow-tbl" id="filter-dropdown" style="max-width: calc(100vw - 2rem);">

                            <div class="d-flex align-items-center justify-content-between border-bottom filter-header">
                                <h6 class="mb-0 fw-bold">Select Criteria</h6>
                                <div class="d-flex align-items-center justify-content-end">
                                    <button type="submit" class="btn btn-light btn-md me-2 fw-medium" onclick="resetAllFilters()" id="btnResetFilters">Reset</button>
                                    <button type="submit" class="btn text-primary fs-6 fw-medium" id="btnApplyFilters">
                                        <i class="ti ti-filter me-1"></i>Apply
                                    </button>
                                    <button type="button" class="btn btn-icon btn-sm ms-1 d-md-none" id="btnCloseFilter" aria-label="Close">
                                        <i class="ti ti-x"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="filter-body pb-0">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Company</label>
                                        <select class="form-select form-control select2"
                                                id="ddlFilterCompany"
                                                data-placeholder="Select company">
                                            <option value="">All</option>
                                            @foreach (var c in Model.Companies ?? new List<MstCompanyViewModel>())
                                            {
                                                <option value="@c.CompanyId" selected="@(Model.CompanyId == c.CompanyId)">
                                                    @c.SchoolName
                                                </option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label mb-1">Session</label>
                                        <select class="form-select form-control select2"
                                                id="ddlFilterSessions"
                                                data-placeholder="Select session">
                                            <option value="">All</option>
                                            @foreach (var ut in Model.Sessions)
                                            {
                                                <option value="@ut.SessionId" selected="@(Model.SessionId == ut.SessionId)">
                                                    @ut.SessionTitle
                                                </option>
                                            }
                                        </select>
                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- Active filter badges -->
    <div class="col-xl-12" id="activeFilterBadges" style="display: none;">
        <div class="card shadow-tbl border-0 py-2 mb-2">
            <div class="card-body p-2 d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold ms-2 me-2">
                    <i class="ti ti-filter-check me-1"></i>Active Filters:
                </span>
                <div id="badgeContainer" class="d-flex flex-wrap gap-2"></div>
                <button class="btn btn-sm btn-link text-danger p-0 ms-auto me-2 fw-bold text-decoration-none"
                        id="btnResetAllFilters" onclick="resetAllFilters()">
                    <i class="ti ti-trash me-1"></i>Clear All
                </button>
            </div>
        </div>
    </div>


    <div class="col-xl-12">
        <div class="card shadow-tbl">
            <div class="card-body">
                <div class="table-responsive">
                    <div class="sticky-table-scroll">
                    <table class="table" id="sectionsTable">
                        <thead>
                            <tr class="bg-light">
                                <th class="ps-4" style="width: 50px;">Select</th>
                                <th>Section Name</th>                                
                                <th>Created On</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Sections !=null)
                            {
                                @foreach (var s in Model.Sections)
                                {
                                    <tr class="item-row" onclick="selectItem(@s.SectionID, this)" style="cursor: pointer;">
                                        <td class="ps-4 text-center">
                                            <input type="checkbox" name="selectedSection"
                                            class="form-check-input student-checkbox"
                                            value="@s.SectionID">

                                        </td>
                                        <td>
                                            @s.SectionName
                                        </td>
                                        <td>@s.CreatedOn.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @if (p.CanEdit)
                                            {
                                                <div class="form-check form-switch" onclick="event.stopPropagation()">
                                                    <input class="form-check-input section-status-switch" type="checkbox" @(s.IsActive ? "checked" : "") onchange="toggleStatus(@s.SectionID, this.checked)">
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="badge @(s.IsActive ? "bg-success" : "bg-secondary")">@(s.IsActive ? "Active" : "Inactive")</span>
                                            }
                                        </td>

                                    </tr>
                                }
                                @if (!Model.Sections.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-4">
                                            <span class="text-muted">No records found.</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4">
                                        <span class="text-muted">No records found.</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    </div>
                    <!-- ── Pagination ─────────────────────────────────────────────── -->
                    @if (totalPages > 1)
                    {
                        <div class="d-flex align-items-center justify-content-between mt-3 flex-wrap gap-2 mb-3">
                            <!-- Record info -->
                            <div class="text-muted small">
                                Showing
                                <strong>@(((Model.PageNumber - 1) * Model.PageSize) + 1)</strong>
                                –
                                <strong>@(Math.Min(Model.PageNumber * Model.PageSize, Model.TotalRecords))</strong>
                                of
                                <strong>@Model.TotalRecords</strong> users
                            </div>

                            <nav aria-label="Subject pagination">
                                <ul class="pagination pagination-sm mb-0">

                                    <!-- First -->
                                    <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                                        <a class="page-link"
                                           href="?pageIndex=1&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&sessionID=@Model.SessionId">
                                            <i class="ti ti-chevrons-left"></i>
                                        </a>
                                    </li>

                                    <!-- Prev -->
                                    <li class="page-item @(Model.PageNumber <= 1 ? "disabled" : "")">
                                        <a class="page-link"
                                           href="?pageIndex=@(Model.PageNumber - 1)&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&sessionID=@Model.SessionId">
                                            <i class="ti ti-chevron-left"></i>
                                        </a>
                                    </li>

                                    <!-- Page numbers — show 5 around current -->
                                    @{
                                        int start = Math.Max(1, Model.PageNumber - 2);
                                        int end = Math.Min(totalPages, start + 4);
                                        start = Math.Max(1, end - 4);
                                    }
                                    @for (int pg = start; pg <= end; pg++)
                                    {
                                        <li class="page-item @(pg == Model.PageNumber ? "active" : "")">
                                            <a class="page-link"
                                               href="?pageIndex=@pg&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&sessionID=@Model.SessionId">@pg</a>
                                        </li>
                                    }

                                    <!-- Next -->
                                    <li class="page-item @(Model.PageNumber >= totalPages ? "disabled" : "")">
                                        <a class="page-link"
                                           href="?pageIndex=@(Model.PageNumber + 1)&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&sessionID=@Model.SessionId">
                                            <i class="ti ti-chevron-right"></i>
                                        </a>
                                    </li>

                                    <!-- Last -->
                                    <li class="page-item @(Model.PageNumber >= totalPages ? "disabled" : "")">
                                        <a class="page-link"
                                           href="?pageIndex=@totalPages&pageSize=@Model.PageSize&search=@Model.SearchTerm&companyId=@Model.CompanyId&sessionID=@Model.SessionId">
                                            <i class="ti ti-chevrons-right"></i>
                                        </a>
                                    </li>

                                </ul>
                            </nav>

                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Copy to Session Modal ──────────────────────────────────────── -->
<div class="modal fade" id="modalCopySession" tabindex="-1"
     aria-labelledby="modalCopySessionLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="modalCopySessionLabel">
                    <i class="ti ti-copy me-2 text-primary"></i>Copy Sections to Session
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <!-- Selected sections preview -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Selected Sections</label>
                    <div id="copySelectedBadges" class="d-flex flex-wrap gap-1"></div>
                </div>

                <!-- Target session dropdown -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Copy To Session <span class="text-danger">*</span>
                    </label>
                    <select id="ddlTargetSession" class="form-select select2">
                        <option value="">-- Select Session --</option>
                        <!-- populated by JS from layout window.allSessions -->
                    </select>
                    <div class="invalid-feedback" id="errTargetSession">
                        Please select a target session.
                    </div>
                </div>

                <!-- Info note -->
                <div class="alert alert-info py-2 mb-0 small">
                    <i class="ti ti-info-circle me-1"></i>
                    Sections that already exist in the selected session will be skipped automatically.
                </div>

            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="button" class="btn btn-primary"
                        id="btnConfirmCopy" onclick="confirmCopy()">
                    <i class="ti ti-copy me-1"></i>Copy
                </button>
            </div>

        </div>
    </div>
</div>
<!-- ── End Copy Modal ─────────────────────────────────────────────── -->

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/assets/js/Section.js"></script>
}
