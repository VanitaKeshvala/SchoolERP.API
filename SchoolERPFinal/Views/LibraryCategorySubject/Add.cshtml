@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.LibraryCategorySubjectAddViewModel
@{
    ViewData["Title"] = "Add Category Subject";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditCategorySubject == null ? "Add Category Subject" : "Edit Category Subject")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveItem()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/LibraryCategorySubject/Index" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <input type="hidden" id="txtItemId" value="@(Model.EditCategorySubject?.Id ?? 0)">
                    <input type="hidden" id="hdnUserID" value="@(Model.EditCategorySubject?.CreatedBy ?? 0)">

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Category <span class="text-danger">*</span></label>
                            <select class="form-select form-control select2"
                                    id="ddlCategory"
                                    data-placeholder="Select Category">
                                <option value="">All</option>
                                @foreach (var c in Model.Category ?? new List<LibraryCategoryModel>())
                                {
                                    <option value="@c.CategoryId" selected="@(Model.EditCategorySubject?.CategoryId == c.CategoryId)">
                                        @c.CategoryName
                                    </option>
                                }
                            </select>
                            <div class="invalid-feedback" id="errddlCategory"></div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Subject</label>
                            <select class="form-select form-control select2"
                                    id="ddlSubject"
                                    data-placeholder="Select Subject">
                                <option value="">All</option>
                                @foreach (var c in Model.Subject ?? new List<LibrarySubjectModel>())
                                {
                                    <option value="@c.SubjectId" selected="@(Model.EditCategorySubject?.SubjectId == c.SubjectId)">
                                        @c.Subjectname
                                    </option>
                                }
                            </select>
                            <div class="invalid-feedback" id="errddlSubject"></div>
                        </div>
                        <div class="col-md-12 mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="isActive"
                                @(Model.EditCategorySubject?.IsActive ?? true ? "checked" : "")>
                                <label class="form-check-label fw-bold" for="isActive">Active</label>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/assets/js/LibraryCategorySubject.js"></script>
}