@using System.Security.Claims
@using System.Text.Json
@model SchoolERP.Shared.Models.HolidayAddViewModel
@{
    ViewData["Title"] = "Add Holiday";
    var p = Model.Permissions;
}

<!-- Page Header -->
<div class="d-flex align-items-sm-center justify-content-between flex-wrap gap-2 mb-2">
    <div>
        <h6 class="fw-bold mb-0">@(Model.EditHoliday == null ? "Add Holiday" : "Edit Holiday")</h6>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-1">
        @if (p.CanAdd)
        {
            <button class="btn btn-success top-btn" onclick="saveItem()">
                <i class="ti ti-device-floppy me-1"></i> Save
            </button>
        }
        <a href="/Holiday/Index" class="btn btn-secondary top-btn">
            <i class="ti ti-arrow-left me-1"></i> Back
        </a>
    </div>
</div>
<div class="row">
    <div class="col-xl-12">
        <div class="card shadow-tbl-outer">
            <div class="card-body">
                <form id="itemForm" class="needs-validation" novalidate>
                    <input type="hidden" id="txtItemId" value="@(Model.EditHoliday?.HolidayID ?? 0)">
                    <input type="hidden" id="hdnUserID" value="@(Model.EditHoliday?.CreatedBy ?? 0)">

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Holiday Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="txtHolidayName"
                                   value="@Model.EditHoliday?.HolidayName"
                                   placeholder="e.g. 1st Class" autocomplete="off">
                            <div class="invalid-feedback" id="errtxtHolidayName"></div>
                        </div>

                        <div class="col-md-6 mb-">
                            <label class="form-label fw-bold">Holiday Type <span class="text-danger">*</span></label>
                            <select class="form-select select2" id="ddlHolidayType" required style="width: 100%;">
                                <option value="">-- Select --</option>
                                @foreach (var rt in Model.HolidayTypeModel.Where(x => x.IsActive))
                                {
                                    <option value="@rt.HolidayTypeID" selected="@(Model.EditHoliday?.HolidayTypeID == rt.HolidayTypeID)">@rt.HolidayTypeName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Holiday From Date <span class="text-danger">*</span></label>
                            <input type="date"
                                   value="@(Model.EditHoliday?.FromDate?.ToString("yyyy-MM-dd"))"
                                   class="form-control" id="txtFromDate" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Holiday To Date <span class="text-danger">*</span></label>
                            <input type="date"
                                   value="@(Model.EditHoliday?.ToDate?.ToString("yyyy-MM-dd"))"
                                   class="form-control" id="txtToDate" required>
                        </div>
                        <div class="col-md-2 mb-3">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="isActive"
                                @(Model.EditHoliday?.IsActive ?? true ? "checked" : "")>
                                <label class="form-check-label fw-bold" for="isActive">Active</label>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<link href="~/assets/css/select2.min.css" rel="stylesheet" />

@section Scripts {
    <script>
        window.canAdd = @JsonSerializer.Serialize(p.CanAdd);
        window.canEdit = @JsonSerializer.Serialize(p.CanEdit);
        window.canDelete = @JsonSerializer.Serialize(p.CanDelete);
    </script>

    <script src="~/js/Holiday.js"></script>
}